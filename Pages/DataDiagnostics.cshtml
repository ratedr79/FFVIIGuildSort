@page
@model FFVIIEverCrisisAnalyzer.Pages.DataDiagnosticsModel
@{
    ViewData["Title"] = "Data Diagnostics";
}

<div class="container mt-4">
    <h1 class="mb-3"><i class="fas fa-list-check"></i> Data Diagnostics</h1>
    <p class="text-muted mb-3">Review data ingestion and enrichment checks for weapons and costumes.</p>

    <div class="card mb-3">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <div><strong>Last data load (UTC):</strong> @Model.LastLoadedUtc.ToString("u")</div>
                <div><strong>Reload count:</strong> @Model.ReloadCount</div>
            </div>
            <form method="post" asp-page-handler="ReloadData" class="mb-0">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="fas fa-rotate"></i> Reload UnknownX7 Data
                </button>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ReloadMessage))
    {
        <div class="alert @(Model.ReloadSucceeded ? "alert-success" : "alert-danger")" role="alert">
            @Model.ReloadMessage
        </div>
    }

    <div class="accordion" id="diagnosticsAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#weaponsNotEnrichedCollapse" aria-expanded="true" aria-controls="weaponsNotEnrichedCollapse">
                    Weapons NOT enriched from GearSearch (@Model.WeaponsNotEnriched.Count)
                </button>
            </h2>
            <div id="weaponsNotEnrichedCollapse" class="accordion-collapse collapse show" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    @if (Model.WeaponsNotEnriched.Count == 0)
                    {
                        <div class="text-success">All weapons enriched from GearSearch data.</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var item in Model.WeaponsNotEnriched)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#weaponsEnrichedCollapse" aria-expanded="false" aria-controls="weaponsEnrichedCollapse">
                    Weapons enriched from GearSearch (@Model.WeaponsEnriched.Count)
                </button>
            </h2>
            <div id="weaponsEnrichedCollapse" class="accordion-collapse collapse" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    @if (Model.WeaponsEnriched.Count == 0)
                    {
                        <div class="text-muted">No weapons enriched.</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var item in Model.WeaponsEnriched)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#costumesNotEnrichedCollapse" aria-expanded="false" aria-controls="costumesNotEnrichedCollapse">
                    Costumes NOT enriched from GearSearch (@Model.CostumesNotEnriched.Count)
                </button>
            </h2>
            <div id="costumesNotEnrichedCollapse" class="accordion-collapse collapse" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    @if (Model.CostumesNotEnriched.Count == 0)
                    {
                        <div class="text-success">All costumes enriched from GearSearch data.</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var item in Model.CostumesNotEnriched)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#costumesEnrichedCollapse" aria-expanded="false" aria-controls="costumesEnrichedCollapse">
                    Costumes enriched from GearSearch (@Model.CostumesEnriched.Count)
                </button>
            </h2>
            <div id="costumesEnrichedCollapse" class="accordion-collapse collapse" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    @if (Model.CostumesEnriched.Count == 0)
                    {
                        <div class="text-muted">No costumes enriched.</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var item in Model.CostumesEnriched)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#passiveSkillTypeDiagnosticsCollapse" aria-expanded="false" aria-controls="passiveSkillTypeDiagnosticsCollapse">
                    Passive Skill Type diagnostics (@Model.PassiveSkillTypeDiagnostics.Count)
                </button>
            </h2>
            <div id="passiveSkillTypeDiagnosticsCollapse" class="accordion-collapse collapse" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    <div class="small text-muted mb-2">Shows distinct `PassiveSkillType` values with current coefficient divisor mapping and one representative sample.</div>
                    @if (Model.PassiveSkillTypeDiagnostics.Count == 0)
                    {
                        <div class="text-muted">No passive skill type diagnostics available.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Value Divisor</th>
                                        <th>Coefficient Divisor</th>
                                        <th>Sample Passive</th>
                                        <th>Points → Level</th>
                                        <th>Example</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in Model.PassiveSkillTypeDiagnostics)
                                    {
                                        <tr>
                                            <td>@row.PassiveSkillType</td>
                                            <td>@row.ValueDivisor.ToString("0.##")</td>
                                            <td>@row.CoefficientDivisor.ToString("0.##")</td>
                                            <td>
                                                @if (row.SamplePassiveId.HasValue)
                                                {
                                                    <text>@row.SamplePassiveId @row.SamplePassiveName</text>
                                                }
                                                else
                                                {
                                                    <text>@row.SamplePassiveName</text>
                                                }
                                            </td>
                                            <td>@row.SamplePointLevel</td>
                                            <td>
                                                @row.ExampleText
                                                @if (row.PassiveSkillType == 17)
                                                {
                                                    <div class="small text-muted">Note: appears retired; `DescriptionLanguageId` is `0`, so there is no localization value.</div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#characterIdGapDiagnosticsCollapse" aria-expanded="false" aria-controls="characterIdGapDiagnosticsCollapse">
                    Character weapon/costume ID sequence diagnostics (@Model.CharacterIdGapDiagnostics.Count)
                </button>
            </h2>
            <div id="characterIdGapDiagnosticsCollapse" class="accordion-collapse collapse" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    <div class="small text-muted mb-2">Shows each character's weapon/costume numeric ID timeline and inserts explicit <code>MISSING</code> rows where IDs are skipped.</div>
                    @if (Model.CharacterIdGapDiagnostics.Count == 0)
                    {
                        <div class="text-muted">No character ID sequence diagnostics available.</div>
                    }
                    else
                    {
                        <div class="accordion" id="characterIdGapAccordion">
                            @for (var index = 0; index < Model.CharacterIdGapDiagnostics.Count; index++)
                            {
                                var group = Model.CharacterIdGapDiagnostics[index];
                                var headingId = $"characterIdGapHeading{index}";
                                var collapseId = $"characterIdGapCollapse{index}";
                                <div class="accordion-item mb-2">
                                    <h3 class="accordion-header" id="@headingId">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="true" aria-controls="@collapseId">
                                            @group.CharacterName
                                            <span class="ms-2 small text-muted">(Costume missing: @group.MissingCostumeCount, Weapon missing: @group.MissingWeaponCount)</span>
                                        </button>
                                    </h3>
                                    <div id="@collapseId" class="accordion-collapse collapse show" aria-labelledby="@headingId">
                                        <div class="accordion-body">
                                            <div class="form-check form-switch mb-2">
                                                <input class="form-check-input" type="checkbox" id="showMissingOnly-@index" onchange="toggleMissingRows(@index, this.checked)">
                                                <label class="form-check-label small" for="showMissingOnly-@index">Show only missing</label>
                                            </div>
                                            <div class="row g-3">
                                                <div class="col-lg-6">
                                                    <h4 class="h6 mb-2">Costumes</h4>
                                                    @if (group.CostumeRows.Count == 0)
                                                    {
                                                        <div class="text-muted small">No costume IDs found.</div>
                                                    }
                                                    else
                                                    {
                                                        <ul class="list-unstyled mb-0 small">
                                                            @foreach (var row in group.CostumeRows)
                                                            {
                                                                <li class="id-gap-row @(row.IsMissing ? "missing-row" : "present-row")" data-character-index="@index">
                                                                    <span class="font-monospace">@row.Id:</span>
                                                                    @if (row.IsMissing)
                                                                    {
                                                                        <span class="text-danger fw-semibold">MISSING</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span>@row.Name</span>
                                                                    }
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                                <div class="col-lg-6">
                                                    <h4 class="h6 mb-2">Weapons</h4>
                                                    @if (group.WeaponRows.Count == 0)
                                                    {
                                                        <div class="text-muted small">No weapon IDs found.</div>
                                                    }
                                                    else
                                                    {
                                                        <ul class="list-unstyled mb-0 small">
                                                            @foreach (var row in group.WeaponRows)
                                                            {
                                                                <li class="id-gap-row @(row.IsMissing ? "missing-row" : "present-row")" data-character-index="@index">
                                                                    <span class="font-monospace">@row.Id:</span>
                                                                    @if (row.IsMissing)
                                                                    {
                                                                        <span class="text-danger fw-semibold">MISSING</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span>@row.Name</span>
                                                                    }
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleMissingRows(characterIndex, showOnlyMissing) {
        const selector = `.id-gap-row.present-row[data-character-index="${characterIndex}"]`;
        const rows = document.querySelectorAll(selector);
        rows.forEach(row => {
            if (showOnlyMissing) {
                row.classList.add('d-none');
                return;
            }

            row.classList.remove('d-none');
        });
    }
</script>
