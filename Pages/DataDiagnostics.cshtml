@page
@model FFVIIEverCrisisAnalyzer.Pages.DataDiagnosticsModel
@{
    ViewData["Title"] = "Data Diagnostics";
}

<div class="container mt-4">
    <h1 class="mb-4">Data Diagnostics</h1>

    <div class="accordion" id="diagnosticsAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#weaponsNotEnrichedCollapse" aria-expanded="true" aria-controls="weaponsNotEnrichedCollapse">
                    Weapons NOT enriched from GearSearch (@Model.WeaponsNotEnriched.Count)
                </button>
            </h2>
            <div id="weaponsNotEnrichedCollapse" class="accordion-collapse collapse show" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    @if (Model.WeaponsNotEnriched.Count == 0)
                    {
                        <div class="text-success">All weapons enriched from GearSearch data.</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var item in Model.WeaponsNotEnriched)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#weaponsEnrichedCollapse" aria-expanded="false" aria-controls="weaponsEnrichedCollapse">
                    Weapons enriched from GearSearch (@Model.WeaponsEnriched.Count)
                </button>
            </h2>
            <div id="weaponsEnrichedCollapse" class="accordion-collapse collapse" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    @if (Model.WeaponsEnriched.Count == 0)
                    {
                        <div class="text-muted">No weapons enriched.</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var item in Model.WeaponsEnriched)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#costumesNotEnrichedCollapse" aria-expanded="false" aria-controls="costumesNotEnrichedCollapse">
                    Costumes NOT enriched from GearSearch (@Model.CostumesNotEnriched.Count)
                </button>
            </h2>
            <div id="costumesNotEnrichedCollapse" class="accordion-collapse collapse" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    @if (Model.CostumesNotEnriched.Count == 0)
                    {
                        <div class="text-success">All costumes enriched from GearSearch data.</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var item in Model.CostumesNotEnriched)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#costumesEnrichedCollapse" aria-expanded="false" aria-controls="costumesEnrichedCollapse">
                    Costumes enriched from GearSearch (@Model.CostumesEnriched.Count)
                </button>
            </h2>
            <div id="costumesEnrichedCollapse" class="accordion-collapse collapse" data-bs-parent="#diagnosticsAccordion">
                <div class="accordion-body">
                    @if (Model.CostumesEnriched.Count == 0)
                    {
                        <div class="text-muted">No costumes enriched.</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var item in Model.CostumesEnriched)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
