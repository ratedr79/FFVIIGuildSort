    @@media (max-width: 991.98px) {
        .gear-results-card .card-body {
            padding: 0.6rem;
        }

        .gear-table-wrap {
            margin: 0 -0.25rem;
            padding: 0 0.25rem 0.2rem;
        }

        .gear-table-wrap::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 16px;
            height: 100%;
            pointer-events: none;
            background: linear-gradient(to right, rgba(255, 255, 255, 0), rgba(248, 249, 252, 0.95));
            opacity: 0;
            transition: opacity 0.16s ease;
        }

        .gear-table-wrap.show-scroll-fade::after {
            opacity: 1;
        }

        .gear-table-mobile-hint {
            display: block;
        }

        #gearTable {
            min-width: 820px;
        }

        #gearTable th,
        #gearTable td {
            padding: 0.4rem 0.45rem;
            font-size: 0.86rem;
        }

