@page
@model FFVIIEverCrisisAnalyzer.Pages.GearSearchModel
@{
    ViewData["Title"] = "Gear Search";

    string? GetElementIconPath(string? element)
    {
        return (element ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "earth" => "/images/ui_icon_parameter_buff_damage_up_attribute_earth.png",
            "fire" => "/images/ui_icon_parameter_buff_damage_up_attribute_fire.png",
            "heal" => "/images/ui_icon_parameter_buff_heal.png",
            "ice" => "/images/ui_icon_parameter_buff_damage_up_attribute_ice.png",
            "lightning" or "thunder" => "/images/ui_icon_parameter_buff_damage_up_attribute_thunder.png",
            "non-elemental" or "nonelemental" => "/images/ui_icon_parameter_buff_damage_up_attribute_nonelemental.png",
            "water" => "/images/ui_icon_parameter_buff_damage_up_attribute_water.png",
            "wind" => "/images/ui_icon_parameter_buff_damage_up_attribute_wind.png",
            _ => null
        };
    }

    string? GetSigilIconPath(string? sigilType)
    {
        return (sigilType ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "circle" or "o" => "/images/ui_icon_sigil_o.png",
            "triangle" => "/images/ui_icon_sigil_triangle.png",
            "cross" or "x" => "/images/ui_icon_sigil_x.png",
            "diamond" => "/images/ui_icon_sigil_diamond.png",
            "square" => "/images/ui_icon_sigil_square.png",
            _ => null
        };
    }

    string GetSigilLevelLabel(int level)
    {
        return level switch
        {
            1 => "I",
            2 => "II",
            _ => level.ToString()
        };
    }

    IReadOnlyList<string> GetTierNames(int count)
    {
        var tierNames = new[]
        {
            "Low",
            "Mid",
            "High",
            "Extra High",
            "Extreme High",
            "Extreme High+",
            "Extreme High++"
        };

        return tierNames.Take(Math.Max(count, 0)).ToList();
    }

    string GetTierImagePath(bool isBuffTier, string tierName)
    {
        var suffix = tierName switch
        {
            "Low" => "low",
            "Mid" => "mid",
            "High" => "high",
            "Extra High" => "extra_high",
            "Extreme High" => "very_high",
            "Extreme High+" => "extra_extra_high",
            "Extreme High++" => "maximum",
            _ => "low"
        };

        var direction = isBuffTier ? "up" : "down";
        return $"/images/img_ui_battle_eff_buff_{direction}_{suffix}.png";
    }

    IReadOnlyList<(string Name, string Value)> BuildTierEntries(string values)
    {
        var parts = (values ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => part.Trim())
            .Where(part => part.Length > 0)
            .ToList();

        var names = GetTierNames(parts.Count);
        return parts
            .Select((value, index) => (names[index], value))
            .ToList();
    }

    var elementOptions = Model.Weapons
        .Select(w => w.Element)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var rangeOptions = Model.Weapons
        .Select(w => w.Range)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var abilityTypeOptions = Model.Weapons
        .Select(w => w.AbilityType)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var equipmentTypeOptions = Model.Weapons
        .Select(w => w.EquipmentType)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    const string custRAbilityPrefix = "Adds R Ability: ";
    var rAbilityOptions = Model.Weapons
        .SelectMany(w =>
            w.MaxPassiveSkills.Select(p => p.SkillName)
            .Concat(w.Customizations
                .Where(c => c.Kind == "R Ability")
                .Select(c => !string.IsNullOrWhiteSpace(c.PassiveSkillName)
                    ? c.PassiveSkillName!
                    : (c.Description.StartsWith(custRAbilityPrefix)
                        ? c.Description.Substring(custRAbilityPrefix.Length)
                        : c.Description))))
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var effectOptions = Model.Weapons
        .SelectMany(w => w.EffectTags)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var subRAbilityOptions = Model.Weapons
        .SelectMany(w => w.SubRAbilityTags)
        .GroupBy(t => t.Key, StringComparer.OrdinalIgnoreCase)
        .Select(g => g.First())
        .OrderBy(t => t.Label)
        .ToList();

    var sigilOptions = new List<(string Type, string Symbol)>
    {
        ("Circle", "◯"),
        ("Triangle", "△"),
        ("Cross", "✕"),
        ("Diamond", "◊"),
    };

    var quickSigilFilters = new List<(string Value, string Label)>
    {
        ("Circle", "Circle Sigil"),
        ("Triangle", "Triangle Sigil"),
        ("Cross", "X Sigil"),
        ("Diamond", "Diamond Sigil")
    };

    var elementalQuickFilters = new List<(string Element, string AbilityType, string Label)>
    {
        ("Earth", "Phys.", "Earth Phys."),
        ("Earth", "Mag.", "Earth Mag."),
        ("Fire", "Phys.", "Fire Phys."),
        ("Fire", "Mag.", "Fire Mag."),
        ("Ice", "Phys.", "Ice Phys."),
        ("Ice", "Mag.", "Ice Mag."),
        ("Lightning", "Phys.", "Lightning Phys."),
        ("Lightning", "Mag.", "Lightning Mag."),
        ("Water", "Phys.", "Water Phys."),
        ("Water", "Mag.", "Water Mag."),
        ("Wind", "Phys.", "Wind Phys."),
        ("Wind", "Mag.", "Wind Mag.")
    };

    var buffDebuffReferenceSections = new[]
    {
        new
        {
            Title = "Allies / Us",
            Description = "These buff/debuff families are affected by buff/debuff extension and use ally-side scaling.",
            Rows = new[]
            {
                new { Family = "Attack", BuffTiers = "10%, 20%, 30%, 40%, 50%, 60%, 70%", DebuffTiers = "-10%, -20%, -30%, -40%, -50%, -60%, -70%" },
                new { Family = "Defense", BuffTiers = "20%, 50%, 80%, 110%, 150%, 200%, 250%", DebuffTiers = "-15%, -30%, -45%, -60%, -75%, -85%, -95%" },
                new { Family = "Elemental Damage", BuffTiers = "10%, 25%, 40%, 60%, 80%, 100%, 120%", DebuffTiers = "-10%, -25%, -40%, -55%, -70%, -85%, -95%" },
                new { Family = "Elemental Resistance", BuffTiers = "25%, 37.5%, 50%, 62.5%, 75%, 85%, 90%", DebuffTiers = "-15%, -30%, -50%, -75%, -100%, -125%, -150%" }
            }
        },
        new
        {
            Title = "Enemies",
            Description = "Enemy-side scaling differs from ally-side scaling even when the named tier is the same.",
            Rows = new[]
            {
                new { Family = "Attack", BuffTiers = "15%, 30%, 50%, 75%, 100%, 125%, 150%", DebuffTiers = "-10%, -20%, -30%, -40%, -50%, -60%" },
                new { Family = "Defense", BuffTiers = "15%, 30%, 50%, 75%, 100%, 125%, 150%", DebuffTiers = "-15%, -25%, -35%, -45%, -55%, -65%" },
                new { Family = "Elemental Damage", BuffTiers = "15%, 30%, 50%, 75%, 100%, 125%, 150%", DebuffTiers = "-10%, -25%, -40%, -55%, -70%, -80%" },
                new { Family = "Elemental Resistance", BuffTiers = "20%, 40%, 60%, 80%, 100%, 100%, 100%", DebuffTiers = "-15%, -30%, -50%, -75%, -100%, -125%" },
                new { Family = "Sigil Resistance", BuffTiers = "1, 2, 3, 4, 5, 6, 7", DebuffTiers = "-1, -2, -3, -4, -5, -6" }
            }
        }
    };

    var buffDebuffStatusNotes = new[]
    {
        new { Effect = "Poison / Venom", Notes = "4% max HP / 1.9s on allies; 2% max HP / 4.9s on enemies." },
        new { Effect = "Sadness", Notes = "-50% LB / summon gain." },
        new { Effect = "Pain / Fog (wait-time effect)", Notes = "Adds 3s of waiting time on enemies." },
        new { Effect = "Confusion", Notes = "50% chance, 10% self-damage, damage type still uncertain; each self-hit appears to add +25% chance to end confusion." },
        new { Effect = "Sleep", Notes = "x2 damage received." },
        new { Effect = "Slow", Notes = "-50% ATB gain." },
        new { Effect = "Block Rec.", Notes = "15s max duration on enemies." },
        new { Effect = "Pain (HP damage-over-time effect)", Notes = "7.5% max HP on allies; 1.5% max HP on enemies." },
        new { Effect = "Agony", Notes = "Pain, but doubled." },
        new { Effect = "Dread", Notes = "-50%, -60%, or -70% tactics gauge gain rate based on affected character count; -50% in multiplayer." },
        new { Effect = "Enfeeble", Notes = "+2 debuff effect tiers on allies; +1 debuff effect tier on enemies." },
        new { Effect = "Stop", Notes = "-25% duration per application (minimum -3s); may still always apply for at least 1s." },
        new { Effect = "Regeneration (non-heal)", Notes = "5% max HP / 2.9s." },
        new { Effect = "Regen", Notes = "15% heal / 2.9s." },
        new { Effect = "Haste", Notes = "+50% ATB gain." },
        new { Effect = "Exploit Weakness", Notes = "Damage buff on attacks that display the 'Weakness' text." },
        new { Effect = "Enliven", Notes = "+2 buff effect tiers." },
        new { Effect = "Reflect", Notes = "Unreleased." }
    };
}

<style>
    #gearTable {
        table-layout: fixed;
        width: 100%;
    }

    #gearTable th,
    #gearTable td {
        white-space: normal;
        vertical-align: middle;
    }

    .weapon-banner-row td {
        background: transparent;
        border: 0;
        padding: 0.38rem 0 0.12rem;
    }

    .weapon-banner-row.weapon-banner-row-alt td {
        background: transparent;
    }

    .weapon-banner-row:hover td {
        box-shadow: none;
    }

    .weapon-banner {
        --character-accent: #7a35d8;
        --character-accent-secondary: #43d6ff;
        --character-accent-soft: rgba(122, 53, 216, 0.14);
        --character-accent-faint: rgba(67, 214, 255, 0.08);
        --element-accent: var(--character-accent);
        --element-accent-soft: rgba(122, 53, 216, 0.18);
        --element-accent-faint: rgba(122, 53, 216, 0.07);
        --element-accent-border: rgba(122, 53, 216, 0.28);
        --element-accent-glow: rgba(122, 53, 216, 0.16);
        position: relative;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.85rem;
        align-items: center;
        font-size: 0.95rem;
        text-transform: none;
        padding: 0.78rem 0.95rem 0.78rem 1.08rem;
        border-radius: 1.05rem;
        border: 1px solid rgba(134, 116, 166, 0.24);
        background: linear-gradient(135deg, var(--character-accent-soft) 0%, rgba(255, 255, 255, 0.96) 24%, rgba(255, 255, 255, 0.98) 68%, var(--character-accent-faint) 100%);
        box-shadow: 0 12px 28px rgba(44, 29, 76, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.68);
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .weapon-banner::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 0.28rem;
        background: linear-gradient(180deg, var(--character-accent), var(--character-accent-secondary));
    }

    .weapon-banner::after {
        content: "";
        position: absolute;
        right: -2.2rem;
        top: -2.4rem;
        width: 8.4rem;
        height: 8.4rem;
        background: radial-gradient(circle, var(--element-accent-soft), rgba(255, 255, 255, 0) 72%);
        pointer-events: none;
    }

    .weapon-banner-meta {
        display: flex;
        align-items: center;
        gap: 0.88rem;
        margin-right: 0.4rem;
        min-width: 0;
        flex: 1 1 320px;
    }

    .weapon-banner-visuals {
        display: inline-flex;
        align-items: center;
        gap: 0.48rem;
        flex: 0 0 auto;
    }

    .weapon-banner-portrait-shell,
    .weapon-banner-item-art-shell {
        position: relative;
        width: 60px;
        height: 60px;
        padding: 2px;
        border-radius: 1rem;
        flex: 0 0 auto;
        box-shadow: 0 10px 22px rgba(44, 29, 76, 0.16);
    }

    .weapon-banner-portrait-shell {
        background: linear-gradient(145deg, var(--character-accent), var(--character-accent-secondary));
    }

    .weapon-banner-item-art-shell {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(238, 231, 248, 0.96));
    }

    .weapon-banner-portrait-shell::after,
    .weapon-banner-item-art-shell::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.32);
        pointer-events: none;
    }

    .weapon-banner-portrait,
    .weapon-banner-item-art {
        display: block;
        width: 100%;
        height: 100%;
        border-radius: calc(1rem - 2px);
        object-fit: cover;
        object-position: center top;
        background: #ebe7f3;
    }

    .gear-item-preview-trigger {
        display: block;
        border: 0;
        padding: 0;
        background: none;
        appearance: none;
        cursor: zoom-in;
    }

    .gear-item-preview-trigger:focus-visible {
        outline: 2px solid #b28bff;
        outline-offset: 2px;
    }

    .weapon-banner-titleblock {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.32rem;
        min-width: 0;
    }

    .weapon-banner-pills {
        display: inline-flex;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: 0.3rem;
    }

    .weapon-banner-actions {
        display: inline-flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
        gap: 0.4rem;
        margin-left: auto;
    }

    .weapon-banner-character {
        display: inline-flex;
        align-items: center;
        gap: 0;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        color: #705b8f;
        text-transform: uppercase;
        line-height: 1;
    }

    .weapon-banner-character-label {
        font-size: 0.48rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #8c78aa;
        line-height: 1;
    }

    .weapon-banner-character-value {
        font-size: 0.92rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        line-height: 1;
        color: #312049;
        text-transform: uppercase;
    }

    .weapon-banner-name-row,
    .gear-mobile-card-name-row,
    #compareTable .compare-header-name-row {
        display: inline-flex;
        align-items: flex-start;
        gap: 0.46rem;
        min-width: 0;
        max-width: 100%;
    }

    #compareTable .compare-header-name-row {
        justify-content: center;
    }

    .gear-type-inline-icon {
        width: 1.6rem;
        height: 1.6rem;
        flex: 0 0 auto;
        object-fit: contain;
        margin-top: 0.08rem;
        filter: drop-shadow(0 2px 4px rgba(92, 29, 155, 0.16));
    }

    .weapon-banner-name {
        display: inline-block;
        max-width: 100%;
        position: relative;
        padding: 0.03rem 0.2rem 0.28rem 0;
        font-size: 1.32rem;
        font-weight: 800;
        font-family: "Barlow Semi Condensed", "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        letter-spacing: 0.015em;
        line-height: 1.02;
        color: #241a36;
        text-shadow: 0 1px 0 rgba(255, 255, 255, 0.72), 0 10px 24px rgba(92, 29, 155, 0.12);
        text-wrap: balance;
        z-index: 0;
    }

    .weapon-banner-name::before {
        content: "";
        position: absolute;
        inset: -0.12rem -0.24rem 0.08rem -0.3rem;
        border-radius: 0.9rem;
        background: radial-gradient(circle at left center, var(--element-accent-soft), rgba(255, 255, 255, 0) 66%);
        z-index: -1;
        pointer-events: none;
    }

    .weapon-banner-name::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 0;
        width: min(100%, 12.5rem);
        height: 0.24rem;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--element-accent), rgba(255, 255, 255, 0.84) 68%, var(--element-accent));
        box-shadow: 0 4px 12px var(--element-accent-glow);
    }

    .weapon-banner-pill,
    .weapon-banner-equipment {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.32rem;
        border-radius: 999px;
        min-height: 1.52rem;
        padding: 0.24rem 0.62rem;
        border: 1px solid rgba(215, 204, 237, 0.96);
        background: rgba(255, 255, 255, 0.82);
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: #6d5b86;
        line-height: 1;
        white-space: nowrap;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .weapon-banner-equipment {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(240, 232, 252, 0.96));
        border-color: rgba(187, 169, 221, 0.98);
        color: #55406f;
        box-shadow: 0 4px 10px rgba(92, 29, 155, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.85);
    }

    .weapon-banner-pill-icon {
        width: 0.92rem;
        height: 0.92rem;
        object-fit: contain;
        flex: 0 0 auto;
        border-radius: 0.22rem;
        filter: drop-shadow(0 1px 1px rgba(92, 29, 155, 0.14));
    }

    .weapon-banner-pill-element {
        border-color: var(--element-accent-border);
        color: var(--element-accent);
        background: linear-gradient(135deg, var(--element-accent-faint), rgba(255, 255, 255, 0.97) 72%, rgba(255, 255, 255, 0.9));
        box-shadow: 0 4px 12px var(--element-accent-glow), inset 0 1px 0 rgba(255, 255, 255, 0.86);
    }

    .advanced-toggle-btn {
        background-color: #ffffff;
        color: #5c1d9b;
        border-color: rgba(92, 29, 155, 0.3);
        font-weight: 600;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
    }

    .advanced-toggle-btn:hover,
    .advanced-toggle-btn:focus {
        background-color: #f5ecff;
        color: #4a147a;
        border-color: rgba(92, 29, 155, 0.5);
    }

    .advanced-toggle-btn .filter-count-badge {
        margin-left: 0.35rem;
        background-color: #4a147a !important;
        color: #ffffff !important;
        border: 1px solid rgba(255, 255, 255, 0.55);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
        font-weight: 700;
    }

    .filters-header-toggle {
        white-space: nowrap;
    }

    .sticky-gear-controls {
        position: sticky;
        top: 0.75rem;
        z-index: 1010;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
        border-color: #ddd3ed;
    }

    .gear-search-toolbar-body {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .gear-search-topline {
        display: flex;
        flex-wrap: wrap;
        align-items: start;
        gap: 0.75rem;
    }

    .gear-search-input-group {
        flex: 1 1 320px;
        min-width: min(100%, 320px);
    }

    .gear-search-toolbar-actions {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        flex: 0 0 auto;
        padding-top: 1.5rem;
    }

    .gear-search-toolbar-actions .advanced-toggle-btn {
        min-height: 2.6rem;
        padding-inline: 1rem;
        border-radius: 0.85rem;
    }

    .gear-filters-header-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .gear-search-toolbar-section {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .gear-search-toolbar-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6d6780;
    }

    .gear-search-toolbar-hint {
        font-size: 0.78rem;
        color: #7b758e;
        line-height: 1.35;
    }

    .character-chip-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        scroll-snap-type: x proximity;
    }

    .character-chip-option {
        position: relative;
        scroll-snap-align: start;
    }

    .character-chip-input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .character-chip-label {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2rem;
        padding: 0.3rem 0.75rem;
        border-radius: 999px;
        border: 1px solid #d9cdec;
        background: #fcfbff;
        color: #4f4465;
        font-size: 0.82rem;
        font-weight: 600;
        line-height: 1.2;
        cursor: pointer;
        user-select: none;
        transition: background-color 0.16s ease, border-color 0.16s ease, color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .character-chip-label:hover,
    .character-chip-input:focus + .character-chip-label {
        border-color: rgba(92, 29, 155, 0.38);
        background: #f7f1ff;
        color: #4a147a;
        box-shadow: 0 2px 8px rgba(92, 29, 155, 0.12);
    }

    .character-chip-input:checked + .character-chip-label {
        border-color: #5c1d9b;
        background: #efe4ff;
        color: #4a147a;
        box-shadow: 0 4px 10px rgba(92, 29, 155, 0.14);
    }

    .gear-toolbar-active-filters {
        padding-top: 0.55rem;
        padding-bottom: 0.1rem;
        border-top: 1px solid #efe7fb;
    }

    .gear-filters-panel {
        border-color: #ddd3ed;
        box-shadow: 0 4px 14px rgba(33, 22, 56, 0.05);
    }

    .gear-filters-panel .card-header {
        background: linear-gradient(180deg, rgba(249, 246, 255, 0.96), rgba(255, 255, 255, 0.98));
        border-bottom-color: #ece3f8;
        padding-top: 0.9rem;
        padding-bottom: 0.9rem;
    }

    .gear-filters-panel .card-body {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        padding-top: 0.95rem;
    }

    .sticky-compare-panel {
        position: sticky;
        top: var(--gear-compare-top, 6.5rem);
        z-index: 1005;
    }

