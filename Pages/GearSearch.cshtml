@page
@model FFVIIEverCrisisAnalyzer.Pages.GearSearchModel
@{
    ViewData["Title"] = "Gear Search";

    var elementOptions = Model.Weapons
        .Select(w => w.Element)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var rangeOptions = Model.Weapons
        .Select(w => w.Range)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var abilityTypeOptions = Model.Weapons
        .Select(w => w.AbilityType)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var equipmentTypeOptions = Model.Weapons
        .Select(w => w.EquipmentType)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    const string custRAbilityPrefix = "Adds R Ability: ";
    var rAbilityOptions = Model.Weapons
        .SelectMany(w =>
            w.MaxPassiveSkills.Select(p => p.SkillName)
            .Concat(w.Customizations
                .Where(c => c.Kind == "R Ability" && c.Description.StartsWith(custRAbilityPrefix))
                .Select(c => c.Description.Substring(custRAbilityPrefix.Length))))
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var effectOptions = Model.Weapons
        .SelectMany(w => w.EffectTags)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var sigilOptions = new List<(string Type, string Symbol)>
    {
        ("Circle", "◯"),
        ("Triangle", "△"),
        ("Cross", "✕"),
        ("Diamond", "◊"),
    };
}

<style>
    #gearTable {
        table-layout: fixed;
        width: 100%;
    }

    #gearTable th,
    #gearTable td {
        white-space: normal;
        vertical-align: middle;
    }

    .weapon-banner-row td {
        background: linear-gradient(90deg, rgba(92, 29, 155, 0.08), rgba(92, 29, 155, 0.02));
        border: 0;
        padding: 0.65rem 1rem 0.35rem;
    }

    .weapon-banner {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: baseline;
        font-size: 0.95rem;
        text-transform: none;
    }

    .weapon-banner-character {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: #6c5a8d;
        text-transform: uppercase;
    }

    .weapon-banner-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: #3a2758;
    }

    .weapon-banner-equipment {
        font-size: 0.85rem;
        color: #8d79b7;
    }

    .advanced-toggle-btn {
        background-color: #ffffff;
        color: #5c1d9b;
        border-color: rgba(92, 29, 155, 0.3);
        font-weight: 600;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
    }

    .advanced-toggle-btn:hover,
    .advanced-toggle-btn:focus {
        background-color: #f5ecff;
        color: #4a147a;
        border-color: rgba(92, 29, 155, 0.5);
    }

    .stat-stack {
        line-height: 1.2;
    }

    .sigil-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
    }

    .sigil-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.15rem;
        padding: 0.15rem 0.4rem;
        border-radius: 0.35rem;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid;
    }

    .sigil-circle  { background: #e8f5e9; color: #2e7d32; border-color: #a5d6a7; }
    .sigil-triangle { background: #fff3e0; color: #e65100; border-color: #ffcc80; }
    .sigil-cross   { background: #fce4ec; color: #880e4f; border-color: #f48fb1; }
    .sigil-diamond { background: #e3f2fd; color: #0d47a1; border-color: #90caf9; }

    .sigil-mat { border-style: dashed; opacity: 0.85; }

    .sigil-legend {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 1rem;
        margin-top: 0.75rem;
        padding: 0.5rem 0.75rem;
        background: #f9f5ff;
        border-radius: 0.4rem;
        font-size: 0.85rem;
        color: #5a5a5a;
    }

    .cust-rability-list {
        margin-top: 0.3rem;
        padding-top: 0.3rem;
        border-top: 1px dashed #c9b8e8;
    }

    .cust-rability-list li {
        display: flex;
        align-items: baseline;
        gap: 0.3rem;
        color: #6a3fa0;
        font-style: italic;
    }

    .cust-rability-badge {
        font-size: 0.7rem;
        font-weight: 700;
        font-style: normal;
        background: #ede0ff;
        color: #5c1d9b;
        border: 1px solid #c9a8f5;
        border-radius: 0.25rem;
        padding: 0 0.3rem;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .sigil-legend-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .weapon-name-cell .weapon-meta {
        font-size: 0.85rem;
        color: #7a7194;
    }

    .weapon-name-cell .weapon-character {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: #8b7bb5;
        text-transform: uppercase;
    }

    .ability-detail-row {
        background-color: #f9f5ff;
        border-left: 3px solid #b28bff;
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        line-height: 1.4;
    }

    .ability-detail-row .ability-meta {
        font-size: 0.85rem;
        color: #6c5a8d;
        margin-top: 0.25rem;
    }

    .customization-detail-row {
        background-color: #fff9f2;
        border-left: 3px solid #f4b183;
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 0.65rem 1rem;
        font-size: 0.92rem;
        line-height: 1.4;
    }

    .customization-entry {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 0.75rem;
        align-items: baseline;
        margin-bottom: 0.35rem;
    }

    .customization-entry:last-child {
        margin-bottom: 0;
    }

    .customization-slot {
        font-size: 0.75rem;
        font-weight: 700;
        color: #ad6e2f;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .customization-kind {
        font-weight: 600;
        color: #6f4c1f;
    }

    .customization-description {
        flex: 1 1 100%;
        color: #4a3c2c;
    }

    .btn-view-levels,
    .btn-toggle-details {
        font-size: 0.72rem;
        padding: 0.15rem 0.55rem;
        border-radius: 0.35rem;
        font-weight: 600;
        white-space: nowrap;
    }

    #viewLevelsModal .modal-header {
        background: linear-gradient(90deg, rgba(92, 29, 155, 0.08), rgba(92, 29, 155, 0.02));
        border-bottom: 2px solid #b28bff;
    }

    #viewLevelsModal .snapshot-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        align-items: baseline;
    }

    #viewLevelsModal .snapshot-section {
        margin-bottom: 1rem;
    }

    #viewLevelsModal .snapshot-section-title {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6c5a8d;
        margin-bottom: 0.35rem;
    }

    #viewLevelsModal .snapshot-ability {
        background-color: #f9f5ff;
        border-left: 3px solid #b28bff;
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 0.65rem 0.85rem;
        font-size: 0.92rem;
        line-height: 1.45;
    }

    #viewLevelsModal .snapshot-stats {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    #viewLevelsModal .snapshot-stat {
        text-align: center;
        min-width: 80px;
    }

    #viewLevelsModal .snapshot-stat-value {
        font-size: 1.25rem;
        font-weight: 700;
        color: #3a2758;
    }

    #viewLevelsModal .snapshot-stat-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #8d79b7;
    }

    #viewLevelsModal .snapshot-rability-list,
    #viewLevelsModal .snapshot-customization-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    #viewLevelsModal .snapshot-rability-list li {
        padding: 0.2rem 0;
        font-size: 0.9rem;
    }

    #viewLevelsModal .snapshot-customization-entry {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem 0.65rem;
        align-items: baseline;
        margin-bottom: 0.3rem;
        font-size: 0.9rem;
    }

    #viewLevelsModal .snapshot-spinner {
        display: none;
    }

    #viewLevelsModal .snapshot-spinner.active {
        display: inline-block;
    }

    #viewLevelsModal .snapshot-error {
        display: none;
        color: #dc3545;
        font-size: 0.85rem;
    }

    #viewLevelsModal .snapshot-error.active {
        display: block;
    }
</style>

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Gear Search</h1>
            <p class="text-muted mb-0">Browse all weapons with passive skills and filters.</p>
        </div>
        <a class="btn btn-outline-primary" href="https://cyphersignal.github.io/ff7ec/" target="_blank" rel="noopener">
            <i class="fas fa-arrow-up-right-from-square me-2"></i>Open original FF7EC Equipment Database
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label mb-1">Characters</label>
                    <div class="text-muted small mb-2">Check one or more characters to filter. Leave all unchecked to show everything.</div>
                    <div id="characterCheckboxGroup" class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2">
                        @foreach (var character in GearSearchModel.AvailableCharacters)
                        {
                            var checkboxId = $"character-{character.Replace(" ", "-").ToLowerInvariant()}";
                            <div class="col">
                                <div class="form-check">
                                    <input class="form-check-input character-checkbox" type="checkbox" value="@character" id="@checkboxId" />
                                    <label class="form-check-label" for="@checkboxId">@character</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <label for="searchBox" class="form-label">Search</label>
                    <input id="searchBox" type="text" class="form-control" placeholder="Search by weapon, ability, effects..." />
                </div>
                <div class="col-md-6 col-lg-4">
                    <label for="pageSize" class="form-label">Rows per page</label>
                    <select id="pageSize" class="form-select">
                        @foreach (var size in GearSearchModel.AvailablePageSizes)
                        {
                            if (Model.PageSize == size)
                            {
                                <option value="@size" selected>@size</option>
                            }
                            else
                            {
                                <option value="@size">@size</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Advanced Search</span>
            <button class="btn btn-sm advanced-toggle-btn" type="button" data-bs-toggle="collapse" data-bs-target="#advancedSearchCollapse" aria-expanded="false" aria-controls="advancedSearchCollapse">
                Toggle Filters
            </button>
        </div>
        <div class="collapse" id="advancedSearchCollapse">
            <div class="card-body">
                <div class="accordion" id="advancedFiltersAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingElement">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseElement" aria-expanded="false" aria-controls="collapseElement">
                                Element Type
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".element-filter">Reset</button>
                        </h2>
                        <div id="collapseElement" class="accordion-collapse collapse" aria-labelledby="headingElement" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var element in elementOptions)
                                    {
                                        var checkboxId = $"element-{element.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter element-filter" type="checkbox" value="@element" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@element</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingAbility">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAbility" aria-expanded="false" aria-controls="collapseAbility">
                                Ability Type
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".ability-filter">Reset</button>
                        </h2>
                        <div id="collapseAbility" class="accordion-collapse collapse" aria-labelledby="headingAbility" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var ability in abilityTypeOptions)
                                    {
                                        var checkboxId = $"ability-{ability.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter ability-filter" type="checkbox" value="@ability" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@ability</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingRange">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRange" aria-expanded="false" aria-controls="collapseRange">
                                Range Type
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".range-filter">Reset</button>
                        </h2>
                        <div id="collapseRange" class="accordion-collapse collapse" aria-labelledby="headingRange" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var range in rangeOptions)
                                    {
                                        var checkboxId = $"range-{range.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter range-filter" type="checkbox" value="@range" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@range</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingEquipment">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEquipment" aria-expanded="false" aria-controls="collapseEquipment">
                                Equipment Type
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".equipment-filter">Reset</button>
                        </h2>
                        <div id="collapseEquipment" class="accordion-collapse collapse" aria-labelledby="headingEquipment" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var type in equipmentTypeOptions)
                                    {
                                        var checkboxId = $"equipment-{type.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter equipment-filter" type="checkbox" value="@type" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@type</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingRAbilities">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRAbilities" aria-expanded="false" aria-controls="collapseRAbilities">
                                R Abilities
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".rability-filter">Reset</button>
                        </h2>
                        <div id="collapseRAbilities" class="accordion-collapse collapse" aria-labelledby="headingRAbilities" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body" style="max-height: 320px; overflow-y: auto;">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var passive in rAbilityOptions)
                                    {
                                        var checkboxId = $"rability-{passive.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter rability-filter" type="checkbox" value="@passive" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@passive</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingEffects">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEffects" aria-expanded="false" aria-controls="collapseEffects">
                                Effects
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".effect-filter">Reset</button>
                        </h2>
                        <div id="collapseEffects" class="accordion-collapse collapse" aria-labelledby="headingEffects" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body" style="max-height: 320px; overflow-y: auto;">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var effect in effectOptions)
                                    {
                                        var checkboxId = $"effect-{effect.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter effect-filter" type="checkbox" value="@effect" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@effect</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingSigils">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSigils" aria-expanded="false" aria-controls="collapseSigils">
                                Sigils
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".sigil-filter">Reset</button>
                        </h2>
                        <div id="collapseSigils" class="accordion-collapse collapse" aria-labelledby="headingSigils" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-4 g-2">
                                    @foreach (var sigil in sigilOptions)
                                    {
                                        var checkboxId = $"sigil-{sigil.Type.ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter sigil-filter" type="checkbox" value="@sigil.Type" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@sigil.Symbol @sigil.Type</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-3 col-lg-2">
                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" id="hasCustomizationsFilter" />
                            <label class="form-check-label" for="hasCustomizationsFilter">
                                Has Customizations
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <table id="gearTable" class="table table-striped table-bordered w-100">
                <thead>
                    <tr>
                        <th>Element</th>
                        <th><nobr>Pot. %</nobr></th>
                        <th>Stats</th>
                        <th>Range</th>
                        <th>Type</th>
                        <th>Effects</th>
                        <th>R. Abilities</th>
                        <th>Sigils</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var weapon in Model.Weapons)
                    {
                        <tr data-weapon-id="@weapon.Id" data-character="@weapon.Character" data-equipment="@weapon.EquipmentType" data-weapon="@weapon.Name" data-has-customizations="@weapon.Customizations.Any().ToString().ToLowerInvariant()" data-has-details="@((!string.IsNullOrWhiteSpace(weapon.AbilityText) || weapon.Customizations.Any()).ToString().ToLowerInvariant())" data-sigils="@string.Join(" ", weapon.Sigils.Select(s => s.SigilType).Distinct())">
                            @{
                                var costumeNoAbility = weapon.EquipmentType.Equals("Costume", System.StringComparison.OrdinalIgnoreCase) && string.IsNullOrWhiteSpace(weapon.AbilityText);
                                var abilityMarkup = !string.IsNullOrWhiteSpace(weapon.AbilityText)
                                    ? weapon.AbilityText.Replace("\r\n", "<br />").Replace("\n", "<br />")
                                    : "<span class=\"text-muted\">No ability data</span>";
                                var rechargeMarkup = !string.IsNullOrWhiteSpace(weapon.RechargeTime)
                                    ? $"<div class=\"ability-meta\">Recharge: {weapon.RechargeTime}</div>"
                                    : string.Empty;
                                var useCountMarkup = !string.IsNullOrWhiteSpace(weapon.UseCount)
                                    ? $"<div class=\"ability-meta\">Uses: {weapon.UseCount}</div>"
                                    : string.Empty;
                            }
                            <td>
                                @(costumeNoAbility ? "N/A" : weapon.Element)
                                <span class="visually-hidden weapon-name-search">@weapon.Name</span>
                            </td>
                            <td>
                                @if (costumeNoAbility)
                                {
                                    @:N/A
                                }
                                else
                                {
                                    @string.Format("{0:N1}%", weapon.DamagePercent)
                                }
                            </td>
                            <td>
                                @if (costumeNoAbility)
                                {
                                    @:N/A
                                }
                                else
                                {
                                    <div class="stat-stack">
                                        <div><nobr>@string.Format("P: {0:N0}", weapon.PatkOb10Lv130)</nobr></div>
                                        <div><nobr>@string.Format("M: {0:N0}", weapon.MatkOb10Lv130)</nobr></div>
                                        <div><nobr>@string.Format("H: {0:N0}", weapon.HealOb10Lv130)</nobr></div>
                                    </div>
                                }
                            </td>
                            <td>@(costumeNoAbility ? "N/A" : weapon.Range)</td>
                            <td>@(costumeNoAbility ? "N/A" : weapon.AbilityType)</td>
                            <td>
                                @if (weapon.EffectTags.Any())
                                {
                                    <span>@string.Join(", ", weapon.EffectTags)</span>
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </td>
                            <td>
                                @if (weapon.MaxPassiveSkills.Any())
                                {
                                    <ul class="list-unstyled small mb-0">
                                        @foreach (var passive in weapon.MaxPassiveSkills)
                                        {
                                            <li>
                                                <strong>+@passive.TotalPoints</strong> @passive.SkillName
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <span class="text-muted">No OB data</span>
                                }
                                @{
                                    var custRAbilityNames = weapon.Customizations
                                        .Where(c => c.Kind == "R Ability" && c.Description.StartsWith(custRAbilityPrefix))
                                        .Select(c => c.Description.Substring(custRAbilityPrefix.Length))
                                        .ToList();
                                }
                                @if (custRAbilityNames.Any())
                                {
                                    <ul class="list-unstyled small mb-0 cust-rability-list">
                                        @foreach (var name in custRAbilityNames)
                                        {
                                            <li><span class="cust-rability-badge">Cust.</span> @name</li>
                                        }
                                    </ul>
                                }
                                <div class="ability-template d-none">
                                    @Html.Raw(abilityMarkup)
                                    @Html.Raw(rechargeMarkup)
                                    @Html.Raw(useCountMarkup)
                                </div>
                                @if (weapon.Customizations.Any())
                                {
                                    <div class="customization-template d-none">
                                        @foreach (var customization in weapon.Customizations)
                                        {
                                            <div class="customization-entry">
                                                <span class="customization-slot">@customization.Slot</span>
                                                <span class="customization-kind">@customization.Kind</span>
                                                <span class="customization-description">@customization.Description</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </td>
                            <td>
                                @if (weapon.Sigils.Any())
                                {
                                    <div class="sigil-badges">
                                        @foreach (var sigil in weapon.Sigils)
                                        {
                                            var sigilClass = sigil.SigilType.ToLowerInvariant();
                                            var sourceClass = sigil.Source == "Command" ? "sigil-cmd" : "sigil-mat";
                                            @if (sigil.Source == "Command")
                                            {
                                                <span class="sigil-badge sigil-@sigilClass @sourceClass" title="@sigil.SigilType Sigil (Command)">@sigil.SigilSymbol</span>
                                            }
                                            else
                                            {
                                                <span class="sigil-badge sigil-@sigilClass @sourceClass" title="@sigil.SigilType Sigil Boost @sigil.Level (Materia)">@sigil.SigilSymbol <small>×@sigil.Level</small></span>
                                            }
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">&mdash;</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="sigil-legend">
        <span class="fw-semibold text-muted me-1">Sigil Legend:</span>
        <span class="sigil-legend-item">
            <span class="sigil-badge sigil-circle sigil-cmd">◯</span>
            <span>Command Ability (solid border)</span>
        </span>
        <span class="sigil-legend-item">
            <span class="sigil-badge sigil-circle sigil-mat">◯ <small>×1</small></span>
            <span>Materia Support (dashed border)</span>
        </span>
    </div>
</div>

<!-- View Levels Modal -->
<div class="modal fade" id="viewLevelsModal" tabindex="-1" aria-labelledby="viewLevelsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="viewLevelsModalLabel">View Levels</h5>
                    <div class="snapshot-meta mt-1">
                        <span class="weapon-banner-character" id="snapshotCharacter"></span>
                        <span class="weapon-banner-name" id="snapshotWeaponName"></span>
                        <span class="weapon-banner-equipment" id="snapshotEquipment"></span>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label for="snapshotOverboost" class="form-label fw-semibold">Overboost</label>
                        <select id="snapshotOverboost" class="form-select">
                            <option value="0">5 Star</option>
                            <option value="1">OB1</option>
                            <option value="2">OB2</option>
                            <option value="3">OB3</option>
                            <option value="4">OB4</option>
                            <option value="5">OB5</option>
                            <option value="6">OB6</option>
                            <option value="7">OB7</option>
                            <option value="8">OB8</option>
                            <option value="9">OB9</option>
                            <option value="10" selected>OB10</option>
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label for="snapshotLevel" class="form-label fw-semibold">Level</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="range" class="form-range flex-grow-1" id="snapshotLevelRange" min="1" max="130" value="130" />
                            <input type="number" class="form-control" id="snapshotLevel" min="1" max="130" value="130" style="width: 5rem;" />
                        </div>
                    </div>
                </div>

                <div class="snapshot-section" id="snapshotAbilitySection">
                    <div class="snapshot-section-title">Ability</div>
                    <div class="snapshot-ability" id="snapshotAbility">
                        <span class="text-muted">Loading...</span>
                    </div>
                </div>

                <div class="snapshot-section" id="snapshotStatsSection">
                    <div class="snapshot-section-title">Stats</div>
                    <div class="snapshot-stats">
                        <div class="snapshot-stat">
                            <div class="snapshot-stat-value" id="snapshotPatk">0</div>
                            <div class="snapshot-stat-label">PATK</div>
                        </div>
                        <div class="snapshot-stat">
                            <div class="snapshot-stat-value" id="snapshotMatk">0</div>
                            <div class="snapshot-stat-label">MATK</div>
                        </div>
                        <div class="snapshot-stat">
                            <div class="snapshot-stat-value" id="snapshotHeal">0</div>
                            <div class="snapshot-stat-label">Heal</div>
                        </div>
                    </div>
                </div>

                <div class="snapshot-section" id="snapshotRAbilitiesSection">
                    <div class="snapshot-section-title">R Abilities</div>
                    <ul class="snapshot-rability-list" id="snapshotRAbilities">
                        <li class="text-muted">Loading...</li>
                    </ul>
                </div>

                <div class="snapshot-section" id="snapshotCustomizationsSection">
                    <div class="snapshot-section-title">Customizations</div>
                    <div id="snapshotCustomizations">
                        <span class="text-muted">Loading...</span>
                    </div>
                </div>

                <div class="snapshot-error" id="snapshotError">Failed to load weapon data. Please try again.</div>
            </div>
            <div class="modal-footer">
                <span class="spinner-border spinner-border-sm snapshot-spinner me-2" id="snapshotSpinner" role="status">
                    <span class="visually-hidden">Loading...</span>
                </span>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tableElement = document.getElementById('gearTable');
            const selectedCharacters = new Set();
            const selectedEquipmentTypes = new Set();

            const table = new DataTable(tableElement, {
                pageLength: @Model.PageSize,
                lengthChange: false,
                order: [[0, 'asc']],
                dom: 'lrtip'
            });

            const selectedSigils = new Set();

            DataTable.ext.search.push(function (settings, data, dataIndex) {
                if (settings.nTable !== tableElement) {
                    return true;
                }

                const rowNode = table.row(dataIndex).node();
                const rowCharacter = rowNode.getAttribute('data-character') ?? '';
                const rowEquipment = rowNode.getAttribute('data-equipment') ?? '';
                const rowSigils = (rowNode.getAttribute('data-sigils') ?? '').split(' ').filter(Boolean);

                const characterMatch = selectedCharacters.size === 0 || selectedCharacters.has(rowCharacter);
                const equipmentMatch = selectedEquipmentTypes.size === 0 || selectedEquipmentTypes.has(rowEquipment);
                const sigilMatch = selectedSigils.size === 0 || [...selectedSigils].some(s => rowSigils.includes(s));

                return characterMatch && equipmentMatch && sigilMatch;
            });

            const searchBox = document.getElementById('searchBox');
            searchBox.addEventListener('keyup', (e) => table.search(e.target.value).draw());

            const pageSizeSelect = document.getElementById('pageSize');
            pageSizeSelect.addEventListener('change', (e) => table.page.len(parseInt(e.target.value, 10)).draw());

            const escapeRegex = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            const updateCharacterFilter = () => {
                selectedCharacters.clear();
                document.querySelectorAll('.character-checkbox:checked').forEach(cb => selectedCharacters.add(cb.value));
                table.draw();
            };

            document.getElementById('characterCheckboxGroup')
                .addEventListener('change', (event) => {
                    if (event.target && event.target.classList.contains('character-checkbox')) {
                        updateCharacterFilter();
                    }
                });

            const advancedFilters = [
                { selector: '.element-filter', columnIndex: 0 },
                { selector: '.range-filter', columnIndex: 3 },
                { selector: '.ability-filter', columnIndex: 4 },
                { selector: '.effect-filter', columnIndex: 5 },
                { selector: '.rability-filter', columnIndex: 6 }
            ];

            const applyAdvancedFilter = (selector, columnIndex) => {
                const selected = Array.from(document.querySelectorAll(`${selector}:checked`)).map(cb => cb.value);
                if (selected.length === 0) {
                    table.column(columnIndex).search('', true, false).draw();
                    return;
                }

                const pattern = selected
                    .map(value => escapeRegex(value))
                    .join('|');

                table.column(columnIndex).search(pattern, true, false).draw();
            };

            advancedFilters.forEach(group => {
                document.querySelectorAll(group.selector).forEach(cb => {
                    cb.addEventListener('change', () => applyAdvancedFilter(group.selector, group.columnIndex));
                });
            });

            const updateEquipmentFilter = () => {
                selectedEquipmentTypes.clear();
                document.querySelectorAll('.equipment-filter:checked').forEach(cb => selectedEquipmentTypes.add(cb.value));
                table.draw();
            };

            document.querySelectorAll('.equipment-filter').forEach(cb => {
                cb.addEventListener('change', updateEquipmentFilter);
            });

            const updateSigilFilter = () => {
                selectedSigils.clear();
                document.querySelectorAll('.sigil-filter:checked').forEach(cb => selectedSigils.add(cb.value));
                table.draw();
            };

            document.querySelectorAll('.sigil-filter').forEach(cb => {
                cb.addEventListener('change', updateSigilFilter);
            });

            document.querySelectorAll('.reset-filter').forEach(button => {
                button.addEventListener('click', () => {
                    const targetSelector = button.getAttribute('data-filter-target');
                    if (!targetSelector) {
                        return;
                    }

                    document.querySelectorAll(`${targetSelector}:checked`).forEach(cb => cb.checked = false);
                    const filterGroup = advancedFilters.find(group => group.selector === targetSelector);
                    if (filterGroup) {
                        applyAdvancedFilter(filterGroup.selector, filterGroup.columnIndex);
                    }

                    if (targetSelector === '.character-checkbox') {
                        updateCharacterFilter();
                    }

                    if (targetSelector === '.equipment-filter') {
                        updateEquipmentFilter();
                    }

                    if (targetSelector === '.sigil-filter') {
                        updateSigilFilter();
                    }
                });
            });

            const expandedWeaponIds = new Set();

            const renderDetailRows = () => {
                table.rows({ page: 'current' }).every(function () {
                    const rowNode = this.node();
                    const weaponId = rowNode.getAttribute('data-weapon-id') ?? '';
                    const template = rowNode.querySelector('.ability-template');
                    const customizationTemplate = rowNode.querySelector('.customization-template');

                    const abilityHtml = template ? template.innerHTML.trim() : '';
                    const customizationHtml = customizationTemplate ? customizationTemplate.innerHTML.trim() : '';

                    if (!abilityHtml && !customizationHtml) {
                        if (this.child && this.child.isShown()) {
                            this.child.hide();
                        }
                        return;
                    }

                    const sections = [];
                    if (abilityHtml) {
                        sections.push(`<div class="ability-detail-row">
                            <div class="text-uppercase text-muted small mb-2">Ability</div>
                            ${abilityHtml}
                        </div>`);
                    }

                    if (customizationHtml) {
                        sections.push(`<div class="customization-detail-row">
                            <div class="text-uppercase text-muted small mb-2">Customizations</div>
                            ${customizationHtml}
                        </div>`);
                    }

                    const content = `<div class="detail-wrapper">${sections.join('')}</div>`;
                    this.child(content);
                    if (expandedWeaponIds.has(weaponId)) {
                        this.child.show();
                    } else {
                        this.child.hide();
                    }
                });
            };

            const renderBannerRows = () => {
                document.querySelectorAll('#gearTable tbody tr.weapon-banner-row').forEach(row => row.remove());
                const columnCount = table.columns().count();

                table.rows({ page: 'current' }).every(function () {
                    const rowNode = this.node();
                    const weaponId = rowNode.getAttribute('data-weapon-id') ?? '';
                    const character = rowNode.getAttribute('data-character') ?? '';
                    const weapon = rowNode.getAttribute('data-weapon') ?? '';
                    const equipment = rowNode.getAttribute('data-equipment') ?? '';
                    const isCostume = equipment.toLowerCase() === 'costume';

                    const bannerRow = document.createElement('tr');
                    bannerRow.classList.add('weapon-banner-row');

                    const bannerCell = document.createElement('td');
                    bannerCell.colSpan = columnCount;

                    const viewLevelsBtn = isCostume ? '' :
                        `<button type="button" class="btn btn-outline-primary btn-view-levels"
                            data-weapon-id="${weaponId}"
                            data-character="${character}"
                            data-weapon="${weapon}"
                            data-equipment="${equipment}">View Levels</button>`;

                    const hasDetailsAttr = rowNode.getAttribute('data-has-details') === 'true';
                    const isExpanded = expandedWeaponIds.has(weaponId);
                    const detailsBtn = hasDetailsAttr
                        ? `<button type="button" class="btn btn-outline-secondary btn-toggle-details" data-weapon-id="${weaponId}">${isExpanded ? 'Hide Ability Details' : 'Show Ability Details'}</button>`
                        : '';

                    bannerCell.innerHTML = `
                        <div class="weapon-banner">
                            <span class="weapon-banner-character">${character}</span>
                            <span class="weapon-banner-name">${weapon}</span>
                            <span class="weapon-banner-equipment">${equipment}</span>
                            ${viewLevelsBtn}
                            ${detailsBtn}
                        </div>`;
                    bannerRow.appendChild(bannerCell);

                    rowNode.parentNode?.insertBefore(bannerRow, rowNode);
                });
            };

            const renderDecorations = () => {
                renderBannerRows();
                renderDetailRows();
            };

            const customizationFilterCheckbox = document.getElementById('hasCustomizationsFilter');

            $.fn.dataTable.ext.search.push(function (settings, rowData, dataIndex) {
                if (settings.nTable !== table.table().node()) {
                    return true;
                }

                if (!customizationFilterCheckbox.checked) {
                    return true;
                }

                const rowNode = table.row(dataIndex).node();
                const hasCustomizations = rowNode?.getAttribute('data-has-customizations') === 'true';
                return hasCustomizations;
            });

            customizationFilterCheckbox.addEventListener('change', () => {
                table.draw();
            });

            // --- View Levels Modal Logic ---
            const viewLevelsModal = document.getElementById('viewLevelsModal');
            const bsModal = new bootstrap.Modal(viewLevelsModal);
            const snapshotOverboost = document.getElementById('snapshotOverboost');
            const snapshotLevel = document.getElementById('snapshotLevel');
            const snapshotLevelRange = document.getElementById('snapshotLevelRange');
            const snapshotSpinner = document.getElementById('snapshotSpinner');
            const snapshotError = document.getElementById('snapshotError');

            let currentWeaponId = null;
            let snapshotDebounceTimer = null;
            let snapshotAbortController = null;

            const formatNumber = (n) => Number(n).toLocaleString();

            const setSnapshotLoading = (loading) => {
                snapshotSpinner.classList.toggle('active', loading);
                snapshotOverboost.disabled = loading;
                snapshotLevel.disabled = loading;
                snapshotLevelRange.disabled = loading;
            };

            const showSnapshotError = (show) => {
                snapshotError.classList.toggle('active', show);
            };

            const updateSnapshotContent = (data) => {
                showSnapshotError(false);

                // Ability
                const abilityEl = document.getElementById('snapshotAbility');
                if (data.abilityText) {
                    abilityEl.innerHTML = data.abilityText.replace(/\r?\n/g, '<br />');
                } else {
                    abilityEl.innerHTML = '<span class="text-muted">No ability data</span>';
                }

                // Stats
                document.getElementById('snapshotPatk').textContent = formatNumber(data.patk);
                document.getElementById('snapshotMatk').textContent = formatNumber(data.matk);
                document.getElementById('snapshotHeal').textContent = formatNumber(data.heal);

                // R Abilities
                const rAbilitiesEl = document.getElementById('snapshotRAbilities');
                if (data.rAbilities && data.rAbilities.length > 0) {
                    rAbilitiesEl.innerHTML = data.rAbilities.map(r => {
                        if (r.isLocked) {
                            const hint = r.lockedUntilLevel != null
                                ? ` <span class="text-muted">(unlocks at Lv. ${r.lockedUntilLevel})</span>`
                                : '';
                            return `<li class="text-muted"><i class="fas fa-lock fa-xs me-1"></i>${r.skillName}${hint}</li>`;
                        }
                        const breakdown = (r.basePoints > 0 && r.upgradePoints > 0)
                            ? ` <small class="text-muted">(Lv. ${r.basePoints} + OB ${r.upgradePoints})</small>`
                            : '';
                        return `<li><strong>+${r.totalPoints}</strong> ${r.skillName}${breakdown}</li>`;
                    }).join('');
                } else {
                    rAbilitiesEl.innerHTML = '<li class="text-muted">No R Ability data at this level</li>';
                }

                // Customizations
                const customEl = document.getElementById('snapshotCustomizations');
                if (data.customizations && data.customizations.length > 0) {
                    customEl.innerHTML = data.customizations.map(c =>
                        `<div class="snapshot-customization-entry">
                            <span class="customization-slot">${c.slot}</span>
                            <span class="customization-kind">${c.kind}</span>
                            <span class="customization-description">${c.description}</span>
                        </div>`
                    ).join('');
                    document.getElementById('snapshotCustomizationsSection').style.display = '';
                } else {
                    customEl.innerHTML = '<span class="text-muted">No customizations available</span>';
                    document.getElementById('snapshotCustomizationsSection').style.display = 'none';
                }
            };

            const fetchSnapshot = () => {
                if (!currentWeaponId) return;

                if (snapshotAbortController) {
                    snapshotAbortController.abort();
                }
                snapshotAbortController = new AbortController();

                const overboost = snapshotOverboost.value;
                const level = snapshotLevel.value;
                const url = `/GearSearch?handler=WeaponSnapshot&weaponId=${encodeURIComponent(currentWeaponId)}&overboost=${overboost}&level=${level}`;

                setSnapshotLoading(true);
                showSnapshotError(false);

                fetch(url, { signal: snapshotAbortController.signal })
                    .then(response => {
                        if (!response.ok) throw new Error('Request failed');
                        return response.json();
                    })
                    .then(data => {
                        updateSnapshotContent(data);
                        setSnapshotLoading(false);
                    })
                    .catch(err => {
                        if (err.name === 'AbortError') return;
                        showSnapshotError(true);
                        setSnapshotLoading(false);
                    });
            };

            const debouncedFetchSnapshot = () => {
                clearTimeout(snapshotDebounceTimer);
                snapshotDebounceTimer = setTimeout(fetchSnapshot, 250);
            };

            snapshotOverboost.addEventListener('change', debouncedFetchSnapshot);
            snapshotLevel.addEventListener('change', debouncedFetchSnapshot);
            snapshotLevel.addEventListener('input', () => {
                snapshotLevelRange.value = snapshotLevel.value;
            });
            snapshotLevelRange.addEventListener('input', () => {
                snapshotLevel.value = snapshotLevelRange.value;
                debouncedFetchSnapshot();
            });

            document.getElementById('gearTable').addEventListener('click', (e) => {
                const toggleBtn = e.target.closest('.btn-toggle-details');
                if (toggleBtn) {
                    const wid = toggleBtn.getAttribute('data-weapon-id');
                    if (expandedWeaponIds.has(wid)) {
                        expandedWeaponIds.delete(wid);
                    } else {
                        expandedWeaponIds.add(wid);
                    }
                    renderDecorations();
                    return;
                }

                const btn = e.target.closest('.btn-view-levels');
                if (!btn) return;

                currentWeaponId = btn.getAttribute('data-weapon-id');
                const character = btn.getAttribute('data-character');
                const weapon = btn.getAttribute('data-weapon');
                const equipment = btn.getAttribute('data-equipment');

                document.getElementById('snapshotCharacter').textContent = character;
                document.getElementById('snapshotWeaponName').textContent = weapon;
                document.getElementById('snapshotEquipment').textContent = equipment;

                // Reset controls to defaults
                snapshotOverboost.value = '10';
                snapshotLevel.value = '130';
                snapshotLevelRange.value = '130';

                // Clear previous content
                document.getElementById('snapshotAbility').innerHTML = '<span class="text-muted">Loading...</span>';
                document.getElementById('snapshotPatk').textContent = '...';
                document.getElementById('snapshotMatk').textContent = '...';
                document.getElementById('snapshotHeal').textContent = '...';
                document.getElementById('snapshotRAbilities').innerHTML = '<li class="text-muted">Loading...</li>';
                document.getElementById('snapshotCustomizations').innerHTML = '<span class="text-muted">Loading...</span>';
                document.getElementById('snapshotCustomizationsSection').style.display = '';
                showSnapshotError(false);

                bsModal.show();
                fetchSnapshot();
            });

            updateCharacterFilter();
            updateEquipmentFilter();
            renderDecorations();
            table.on('draw', renderDecorations);
        });
    </script>
}
