                'Angeal': { portrait: 'Angeal.jpg', accent: '#6f8bb5', secondary: '#d6deee', soft: 'rgba(111, 139, 181, 0.16)', faint: 'rgba(214, 222, 238, 0.18)' },
                'Barret': { portrait: 'Barret.jpg', accent: '#7c5a44', secondary: '#d9b087', soft: 'rgba(124, 90, 68, 0.18)', faint: 'rgba(217, 176, 135, 0.16)' },
