    .gear-mobile-card-name::before {
        content: "";
        position: absolute;
        inset: -0.08rem -0.2rem 0.06rem -0.24rem;
        border-radius: 0.8rem;
        background: radial-gradient(circle at left center, var(--element-accent-soft), rgba(255, 255, 255, 0) 68%);
        z-index: -1;
        pointer-events: none;
