<!-- Compare Modal -->
<div class="modal fade" id="compareModal" tabindex="-1" aria-labelledby="compareModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="compareModalLabel">Compare Weapons</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-bordered mb-0" id="compareTable">
                        <thead id="compareTableHead"></thead>
                        <tbody id="compareTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tableElement = document.getElementById('gearTable');
            const gearTableWrap = document.querySelector('.gear-table-wrap');
            const selectedCharacters = new Set();
            const selectedEquipmentTypes = new Set();
            const selectedSubRAbilities = new Set();

            const syncGearTableFade = () => {
                if (!gearTableWrap || window.innerWidth >= 992) {
                    return;
                }

                const maxScrollLeft = gearTableWrap.scrollWidth - gearTableWrap.clientWidth;
                const shouldShowFade = maxScrollLeft > 2 && gearTableWrap.scrollLeft <= 2;
                gearTableWrap.classList.toggle('show-scroll-fade', shouldShowFade);
            };

            if (gearTableWrap) {
                gearTableWrap.addEventListener('scroll', syncGearTableFade, { passive: true });
                window.addEventListener('resize', syncGearTableFade);
                requestAnimationFrame(syncGearTableFade);
            }

            const table = new DataTable(tableElement, {
                pageLength: @Model.PageSize,
                lengthChange: false,
                order: [[0, 'asc']],
                columnDefs: [
                    { orderable: false, targets: '_all' },
                    { visible: false, targets: 0 }
                ],
                dom: 'lrtip'
            });

            const gearMobileResults = document.getElementById('gearMobileResults');
            const gearMobileResultsList = document.getElementById('gearMobileResultsList');
            const gearMobileResultsEmpty = document.getElementById('gearMobileResultsEmpty');
            const gearMobilePagination = document.getElementById('gearMobilePagination');
            const gearMobilePrevPage = document.getElementById('gearMobilePrevPage');
            const gearMobileNextPage = document.getElementById('gearMobileNextPage');
            const gearMobilePageInfo = document.getElementById('gearMobilePageInfo');
            const isCardMode = () => true;

            const selectedSigils = new Set();

            const stickyControlsCard = document.querySelector('.sticky-gear-controls');
            const mainSearchCard = document.getElementById('mainSearchCard');
            const mainSearchCollapse = document.getElementById('mainSearchCollapse');
            const mainSearchToggleBtn = document.getElementById('mainSearchToggleBtn');
            const advancedSearchCard = document.getElementById('advancedSearchCard');
            const advancedSearchCollapse = document.getElementById('advancedSearchCollapse');
            const advancedSearchToggleBtn = document.getElementById('advancedSearchToggleBtn');
            const syncStickyOffsets = () => {
                if (!stickyControlsCard || window.innerWidth < 992) {
                    document.documentElement.style.removeProperty('--gear-compare-top');
                    return;
                }

                const baseTop = 12;
                const controlsHeight = stickyControlsCard.getBoundingClientRect().height;
                const compareTop = Math.ceil(baseTop + controlsHeight + 8);
                document.documentElement.style.setProperty('--gear-compare-top', `${compareTop}px`);
            };

            syncStickyOffsets();
            window.addEventListener('resize', syncStickyOffsets);
            if (mainSearchCollapse) {
                ['shown.bs.collapse', 'hidden.bs.collapse'].forEach(eventName => {
                    mainSearchCollapse.addEventListener(eventName, () => {
                        syncStickyOffsets();
                        setTimeout(syncStickyOffsets, 220);
                    });
                });
            }

            DataTable.ext.search.push(function (settings, data, dataIndex) {
                if (settings.nTable !== tableElement) {
                    return true;
                }

                const rowNode = table.row(dataIndex).node();
                const rowCharacter = rowNode.getAttribute('data-character') ?? '';
                const rowEquipment = rowNode.getAttribute('data-equipment') ?? '';
                const rowSigils = (rowNode.getAttribute('data-sigils') ?? '').split(' ').filter(Boolean);
                const rowSubR = (rowNode.getAttribute('data-subr') ?? '').split(' ').filter(Boolean);

                const characterMatch = selectedCharacters.size === 0 || selectedCharacters.has(rowCharacter);
                const equipmentMatch = selectedEquipmentTypes.size === 0 || selectedEquipmentTypes.has(rowEquipment);
                const sigilMatch = selectedSigils.size === 0 || [...selectedSigils].some(s => rowSigils.includes(s));
                const subRMatch = selectedSubRAbilities.size === 0 || [...selectedSubRAbilities].some(s => rowSubR.includes(s));

                return characterMatch && equipmentMatch && sigilMatch && subRMatch;
            });

            const searchBox = document.getElementById('searchBox');
            searchBox.addEventListener('keyup', (e) => table.search(e.target.value).draw());

            const resultsSummaryEl = document.getElementById('resultsSummary');
            const activeFiltersWrap = document.getElementById('activeFiltersWrap');
            const activeFilterChips = document.getElementById('activeFilterChips');
            const clearAllFiltersBtn = document.getElementById('clearAllFiltersBtn');
            const quickEquipmentButtons = Array.from(document.querySelectorAll('[data-quick-equipment]'));
            const quickCustomizationButton = document.querySelector('[data-quick-customizations="true"]');
            const quickFiltersClearBtn = document.getElementById('quickFiltersClearBtn');
            const mobileMainClearBtn = document.getElementById('mobileMainClearBtn');
            const mobileMainApplyBtn = document.getElementById('mobileMainApplyBtn');
            const mobileClearFiltersBtn = document.getElementById('mobileClearFiltersBtn');
            const mobileApplyFiltersBtn = document.getElementById('mobileApplyFiltersBtn');

            const pageSizeSelect = document.getElementById('pageSize');
            pageSizeSelect.addEventListener('change', (e) => table.page.len(parseInt(e.target.value, 10)).draw());

            const escapeRegex = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            const escapeHtml = (value) => String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');

            const appendRAbilityEffectBlocks = (listElement, effectClassName) => {
                if (!listElement) {
                    return;
                }

                listElement.querySelectorAll('.rability-hoverable').forEach((el) => {
                    const raw = el.getAttribute('data-rability-effects') ?? '';
                    const lines = raw
                        .split('|')
                        .map(v => v.trim())
                        .filter(Boolean);

                    if (lines.length === 0) {
                        return;
                    }

                    const effectBlock = document.createElement('div');
                    effectBlock.className = `${effectClassName} text-muted`;
                    effectBlock.innerHTML = lines.map(line => `<div>${escapeHtml(line)}</div>`).join('');

                    const parentItem = el.closest('li');
                    if (parentItem) {
                        parentItem.appendChild(effectBlock);
                    }
                });
            };
            const updateCharacterFilter = () => {
                selectedCharacters.clear();
                document.querySelectorAll('.character-checkbox:checked').forEach(cb => selectedCharacters.add(cb.value));
                table.draw();
            };

            document.getElementById('characterCheckboxGroup')
                .addEventListener('change', (event) => {
                    if (event.target && event.target.classList.contains('character-checkbox')) {
                        updateCharacterFilter();
                    }
                });

            const advancedFilters = [
                { selector: '.element-filter', columnIndex: 1 },
                { selector: '.range-filter', columnIndex: 4 },
                { selector: '.ability-filter', columnIndex: 5 },
                { selector: '.effect-filter', columnIndex: 6 },
                { selector: '.rability-filter', columnIndex: 7 }
            ];

            const filterCountBadges = [
                { selector: '.element-filter', badgeId: 'badgeElementCount' },
                { selector: '.ability-filter', badgeId: 'badgeAbilityCount' },
                { selector: '.range-filter', badgeId: 'badgeRangeCount' },
                { selector: '.equipment-filter', badgeId: 'badgeEquipmentCount' },
                { selector: '.rability-filter', badgeId: 'badgeRAbilitiesCount' },
                { selector: '.effect-filter', badgeId: 'badgeEffectsCount' },
                { selector: '.subr-filter', badgeId: 'badgeSubRAbilitiesCount' },
                { selector: '.sigil-filter', badgeId: 'badgeSigilsCount' }
            ];

            const accordionSelectionMap = [
                { selector: '.element-filter', collapseId: 'collapseElement' },
                { selector: '.ability-filter', collapseId: 'collapseAbility' },
                { selector: '.range-filter', collapseId: 'collapseRange' },
                { selector: '.equipment-filter', collapseId: 'collapseEquipment' },
                { selector: '.rability-filter', collapseId: 'collapseRAbilities' },
                { selector: '.effect-filter', collapseId: 'collapseEffects' },
                { selector: '.subr-filter', collapseId: 'collapseSubRAbilities' },
                { selector: '.sigil-filter', collapseId: 'collapseSigils' }
            ];

            const updateFilterCountBadges = () => {
                filterCountBadges.forEach(({ selector, badgeId }) => {
                    const count = document.querySelectorAll(`${selector}:checked`).length;
                    const badge = document.getElementById(badgeId);
                    if (!badge) {
                        return;
                    }

                    badge.textContent = count.toString();
                    badge.classList.toggle('d-none', count === 0);
                });
            };

            const syncMainSearchToggleLabel = () => {
                if (!mainSearchToggleBtn) {
                    return;
                }

                const isOpen = mainSearchCollapse?.classList.contains('show') ?? false;
                mainSearchToggleBtn.textContent = isOpen ? 'Close Search' : 'Open Search';
            };

            const syncMainSearchPresentation = () => {
                const isMobile = window.innerWidth < 992;
                const isOpen = mainSearchCollapse?.classList.contains('show') ?? false;

                document.body.classList.toggle('gear-main-open', isMobile && isOpen);
                mainSearchCard?.classList.toggle('gear-main-mobile-active', isMobile && isOpen);
                syncMainSearchToggleLabel();
            };

            const updateResultsSummary = () => {
                const visibleCount = table.rows({ filter: 'applied' }).count();
                const totalCount = table.rows().count();
                resultsSummaryEl.textContent = `Showing ${visibleCount} of ${totalCount} items`;
            };

            const syncQuickFilterButtons = () => {
                quickEquipmentButtons.forEach((button) => {
                    const value = button.getAttribute('data-quick-equipment') ?? '';
                    const isChecked = !!document.querySelector(`.equipment-filter[value="${CSS.escape(value)}"]:checked`);
                    button.classList.toggle('active', isChecked);
                });

                if (quickCustomizationButton) {
                    quickCustomizationButton.classList.toggle('active', customizationFilterCheckbox.checked);
                }
            };

            const syncAdvancedAccordionSelectionState = () => {
                accordionSelectionMap.forEach(({ selector, collapseId }) => {
                    const collapseEl = document.getElementById(collapseId);
                    if (!collapseEl) {
                        return;
                    }

                    const hasSelected = document.querySelectorAll(`${selector}:checked`).length > 0;
                    const collapse = bootstrap.Collapse.getOrCreateInstance(collapseEl, { toggle: false });
                    if (hasSelected) {
                        collapse.show();
                    } else {
                        collapse.hide();
                    }
                });
            };

            const syncAdvancedSearchToggleLabel = () => {
                if (!advancedSearchToggleBtn) {
                    return;
                }

                const activeCount = buildActiveFilterEntries().length;
                const isOpen = advancedSearchCollapse?.classList.contains('show') ?? false;
                const label = isOpen ? 'Close Filters' : 'Open Filters';

                if (activeCount > 0) {
                    advancedSearchToggleBtn.innerHTML = `${label}<span class="badge rounded-pill text-bg-primary filter-count-badge">${activeCount}</span>`;
                } else {
                    advancedSearchToggleBtn.textContent = label;
                }
            };

            const syncAdvancedSearchPresentation = () => {
                const isMobile = window.innerWidth < 992;
                const isOpen = advancedSearchCollapse?.classList.contains('show') ?? false;

                document.body.classList.toggle('gear-advanced-open', isMobile && isOpen);
                advancedSearchCard?.classList.toggle('gear-advanced-mobile-active', isMobile && isOpen);
                syncAdvancedSearchToggleLabel();
            };

            const buildActiveFilterEntries = () => {
                const entries = [];

                const searchValue = searchBox.value.trim();
                if (searchValue.length > 0) {
                    entries.push({ kind: 'search', label: `Search: ${searchValue}` });
                }

                document.querySelectorAll('.character-checkbox:checked').forEach(cb => {
                    entries.push({ selector: '.character-checkbox', value: cb.value, label: `Character: ${cb.value}` });
                });

                document.querySelectorAll('.element-filter:checked').forEach(cb => {
                    entries.push({ selector: '.element-filter', value: cb.value, label: `Element: ${cb.value}` });
                });

                document.querySelectorAll('.ability-filter:checked').forEach(cb => {
                    entries.push({ selector: '.ability-filter', value: cb.value, label: `Ability: ${cb.value}` });
                });

                document.querySelectorAll('.range-filter:checked').forEach(cb => {
                    entries.push({ selector: '.range-filter', value: cb.value, label: `Range: ${cb.value}` });
                });

                document.querySelectorAll('.equipment-filter:checked').forEach(cb => {
                    entries.push({ selector: '.equipment-filter', value: cb.value, label: `Equipment: ${cb.value}` });
                });

                document.querySelectorAll('.rability-filter:checked').forEach(cb => {
                    entries.push({ selector: '.rability-filter', value: cb.value, label: `R Ability: ${cb.value}` });
                });

                document.querySelectorAll('.effect-filter:checked').forEach(cb => {
                    entries.push({ selector: '.effect-filter', value: cb.value, label: `Effect: ${cb.value}` });
                });

                document.querySelectorAll('.subr-filter:checked').forEach(cb => {
                    entries.push({ selector: '.subr-filter', value: cb.value, label: `Sub-R: ${cb.dataset.label ?? cb.value}` });
                });

                document.querySelectorAll('.sigil-filter:checked').forEach(cb => {
                    entries.push({ selector: '.sigil-filter', value: cb.value, label: `Sigil: ${cb.value}` });
                });

                if (customizationFilterCheckbox.checked) {
                    entries.push({ kind: 'hasCustomizations', label: 'Has Customizations' });
                }

                return entries;
            };

            const renderActiveFilterChips = () => {
                const entries = buildActiveFilterEntries();
                activeFilterChips.innerHTML = '';

                entries.forEach(entry => {
                    const chip = document.createElement('button');
                    chip.type = 'button';
                    chip.className = 'btn btn-outline-secondary active-filter-chip';
                    chip.textContent = `✕ ${entry.label}`;

                    if (entry.kind) {
                        chip.dataset.kind = entry.kind;
                    }
                    if (entry.selector) {
                        chip.dataset.selector = entry.selector;
                    }
                    if (entry.value) {
                        chip.dataset.value = entry.value;
                    }

                    activeFilterChips.appendChild(chip);
                });

                activeFiltersWrap.classList.toggle('d-none', entries.length === 0);
            };

            const applyAdvancedFilter = (selector, columnIndex) => {
                const selected = Array.from(document.querySelectorAll(`${selector}:checked`)).map(cb => cb.value);
                if (selected.length === 0) {
                    table.column(columnIndex).search('', true, false).draw();
                    return;
                }

                const pattern = selected
                    .map(value => escapeRegex(value))
                    .join('|');

                table.column(columnIndex).search(pattern, true, false).draw();
            };

            const syncFilterUi = () => {
                updateFilterCountBadges();
                renderActiveFilterChips();
                updateResultsSummary();
                syncQuickFilterButtons();
                syncAdvancedSearchToggleLabel();
            };

            quickEquipmentButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const targetValue = button.getAttribute('data-quick-equipment');
                    if (!targetValue) {
                        return;
                    }

                    const checkbox = document.querySelector(`.equipment-filter[value="${CSS.escape(targetValue)}"]`);
                    if (!checkbox) {
                        return;
                    }

                    checkbox.checked = !checkbox.checked;
                    updateEquipmentFilter();
                });
            });

            if (quickCustomizationButton) {
                quickCustomizationButton.addEventListener('click', () => {
                    customizationFilterCheckbox.checked = !customizationFilterCheckbox.checked;
                    table.draw();
                });
            }

            if (quickFiltersClearBtn) {
                quickFiltersClearBtn.addEventListener('click', () => {
                    document.querySelectorAll('.equipment-filter:checked').forEach(cb => {
                        cb.checked = false;
                    });
                    customizationFilterCheckbox.checked = false;
                    updateEquipmentFilter();
                });
            }

            advancedFilters.forEach(group => {
                document.querySelectorAll(group.selector).forEach(cb => {
                    cb.addEventListener('change', () => applyAdvancedFilter(group.selector, group.columnIndex));
                });
            });

            const updateEquipmentFilter = () => {
                selectedEquipmentTypes.clear();
                document.querySelectorAll('.equipment-filter:checked').forEach(cb => selectedEquipmentTypes.add(cb.value));
                table.draw();
            };

            document.querySelectorAll('.equipment-filter').forEach(cb => {
                cb.addEventListener('change', updateEquipmentFilter);
            });

            const updateSigilFilter = () => {
                selectedSigils.clear();
                document.querySelectorAll('.sigil-filter:checked').forEach(cb => selectedSigils.add(cb.value));
                table.draw();
            };

            document.querySelectorAll('.sigil-filter').forEach(cb => {
                cb.addEventListener('change', updateSigilFilter);
            });

            const updateSubRFilter = () => {
                selectedSubRAbilities.clear();
                document.querySelectorAll('.subr-filter:checked').forEach(cb => selectedSubRAbilities.add(cb.value));
                table.draw();
            };

            document.querySelectorAll('.subr-filter').forEach(cb => {
                cb.addEventListener('change', updateSubRFilter);
            });

            document.querySelectorAll('.reset-filter').forEach(button => {
                button.addEventListener('click', () => {
                    const targetSelector = button.getAttribute('data-filter-target');
                    if (!targetSelector) {
                        return;
                    }

                    document.querySelectorAll(`${targetSelector}:checked`).forEach(cb => cb.checked = false);
                    const filterGroup = advancedFilters.find(group => group.selector === targetSelector);
                    if (filterGroup) {
                        applyAdvancedFilter(filterGroup.selector, filterGroup.columnIndex);
                    }

                    if (targetSelector === '.character-checkbox') {
                        updateCharacterFilter();
                    }

                    if (targetSelector === '.equipment-filter') {
                        updateEquipmentFilter();
                    }

                    if (targetSelector === '.sigil-filter') {
                        updateSigilFilter();
                    }

                    if (targetSelector === '.subr-filter') {
                        updateSubRFilter();
                    }
                });
            });

            const initAdvancedOptionSearch = ({ inputId, clearButtonId, checkboxSelector, noMatchesId }) => {
                const input = document.getElementById(inputId);
                const clearButton = document.getElementById(clearButtonId);
                const noMatchesEl = noMatchesId ? document.getElementById(noMatchesId) : null;

                if (!input || !clearButton) {
                    return;
                }

                const applySearch = () => {
                    const query = input.value.trim().toLowerCase();
                    let visibleCount = 0;

                    document.querySelectorAll(checkboxSelector).forEach((checkbox) => {
                        const optionCol = checkbox.closest('.col');
                        if (!optionCol) {
                            return;
                        }

                        const label = optionCol.querySelector('label');
                        const text = (label?.textContent ?? checkbox.value ?? '').toLowerCase();
                        const matches = query.length === 0 || text.includes(query);
                        optionCol.classList.toggle('d-none', !matches);
                        if (matches) {
                            visibleCount += 1;
                        }
                    });

                    clearButton.disabled = query.length === 0;
                    if (noMatchesEl) {
                        noMatchesEl.classList.toggle('d-none', visibleCount > 0);
                    }
                };

                input.addEventListener('input', applySearch);
                clearButton.addEventListener('click', () => {
                    if (input.value.length === 0) {
                        return;
                    }

                    input.value = '';
                    applySearch();
                    input.focus();
                });

                applySearch();
            };

            initAdvancedOptionSearch({
                inputId: 'rabilityFilterSearch',
                clearButtonId: 'clearRabilityFilterSearch',
                checkboxSelector: '.rability-filter',
                noMatchesId: 'rabilityFilterNoMatches'
            });

            initAdvancedOptionSearch({
                inputId: 'effectFilterSearch',
                clearButtonId: 'clearEffectFilterSearch',
                checkboxSelector: '.effect-filter',
                noMatchesId: 'effectFilterNoMatches'
            });

            initAdvancedOptionSearch({
                inputId: 'subRFilterSearch',
                clearButtonId: 'clearSubRFilterSearch',
                checkboxSelector: '.subr-filter',
                noMatchesId: 'subRFilterNoMatches'
            });

            // --- Compare Feature ---
            const compareItems = new Map(); // weaponId → scraped data object
            const compareCountEl = document.getElementById('compareCount');
            const compareNamesEl = document.getElementById('compareNames');
            const compareClearBtn = document.getElementById('compareClearBtn');
            const compareOpenBtn = document.getElementById('compareOpenBtn');
            const compareModal = new bootstrap.Modal(document.getElementById('compareModal'));

            const buildCompareRAbilitiesHtml = (rAbilityCell) => {
                if (!rAbilityCell) {
                    return '<span class="text-muted">None</span>';
                }

                let combinedHtml = '';

                const baseList = rAbilityCell.querySelector('ul.list-unstyled:not(.cust-rability-list)');
                if (baseList) {
                    const baseClone = baseList.cloneNode(true);
                    appendRAbilityEffectBlocks(baseClone, 'compare-rability-effects');

                    combinedHtml += baseClone.outerHTML;
                }

                const custList = rAbilityCell.querySelector('.cust-rability-list');
                if (custList) {
                    const custClone = custList.cloneNode(true);
                    appendRAbilityEffectBlocks(custClone, 'compare-rability-effects');
                    combinedHtml += custClone.outerHTML;
                }

                return combinedHtml || '<span class="text-muted">None</span>';
            };

            const scrapeWeaponData = (weaponId) => {
                const row = document.querySelector(`#gearTable tbody tr[data-weapon-id="${weaponId}"]`);
                if (!row) return null;
                const cells = row.querySelectorAll('td');
                // DataTables visible:false removes hidden col from DOM
                // cells[0]=Element, 1=Pot%, 2=Stats, 3=Range, 4=Type, 5=Effects, 6=R Abilities, 7=Sigils
                const character = row.getAttribute('data-character') ?? '';
                const name = row.getAttribute('data-weapon') ?? '';
                const equipment = row.getAttribute('data-equipment') ?? '';

                const elementCell = cells[0];
                const element = elementCell ? elementCell.childNodes[0]?.textContent?.trim() ?? '' : '';

                const potPercent = cells[1]?.textContent?.trim() ?? '';

                const statsHtml = cells[2]?.querySelector('.stat-stack')?.innerHTML ?? cells[2]?.textContent?.trim() ?? 'N/A';

                const range = cells[3]?.textContent?.trim() ?? '';
                const abilityType = cells[4]?.textContent?.trim() ?? '';

                const effectsEl = cells[5]?.querySelector('span');
                const effects = effectsEl ? effectsEl.textContent.trim() : 'None';

                const rAbilitiesHtml = buildCompareRAbilitiesHtml(cells[6]);

                // Sigils
                const sigilBadges = cells[7]?.querySelector('.sigil-badges');
                const sigilsHtml = sigilBadges ? sigilBadges.outerHTML : '<span class="text-muted">&mdash;</span>';

                // Ability text from template
                const abilityTemplate = cells[6]?.querySelector('.ability-template');
                const abilityText = abilityTemplate ? abilityTemplate.innerHTML.trim() : '<span class="text-muted">No ability data</span>';

                // Customizations from template
                const custTemplate = cells[6]?.querySelector('.customization-template');
                const customizationsHtml = custTemplate ? custTemplate.innerHTML.trim() : '<span class="text-muted">None</span>';

                return { name, character, equipment, element, potPercent, statsHtml, range, abilityType, effects, rAbilitiesHtml, sigilsHtml, abilityText, customizationsHtml };
            };

            const updateComparePanel = () => {
                const count = compareItems.size;
                compareCountEl.textContent = `${count} item${count !== 1 ? 's' : ''} selected`;
                compareNamesEl.innerHTML = [...compareItems.values()]
                    .map(d => `<span class="compare-name-tag">${d.name}</span>`).join('');
                compareClearBtn.disabled = count === 0;
                compareOpenBtn.disabled = count < 2;
                renderDecorations();
            };

            const populateCompareModal = () => {
                const items = [...compareItems.values()];
                const head = document.getElementById('compareTableHead');
                const body = document.getElementById('compareTableBody');

                head.innerHTML = `<tr><th></th>${items.map(d => `<th>${d.character}<br><small>${d.name}</small></th>`).join('')}</tr>`;

                const rows = [
                    ['Character', d => d.character],
                    ['Equipment', d => d.equipment],
                    ['Element', d => d.element],
                    ['Pot. %', d => d.potPercent],
                    ['Stats', d => d.statsHtml],
                    ['Range', d => d.range],
                    ['Type', d => d.abilityType],
                    ['Effects', d => d.effects],
                    ['R. Abilities', d => d.rAbilitiesHtml],
                    ['Sigils', d => d.sigilsHtml],
                    ['Ability', d => d.abilityText],
                    ['Customizations', d => d.customizationsHtml]
                ];

                body.innerHTML = rows.map(([label, fn]) =>
                    `<tr><td>${label}</td>${items.map(d => `<td>${fn(d)}</td>`).join('')}</tr>`
                ).join('');
            };

            compareClearBtn.addEventListener('click', () => {
                compareItems.clear();
                updateComparePanel();
            });

            compareOpenBtn.addEventListener('click', () => {
                populateCompareModal();
                initRAbilityPopovers();
                compareModal.show();
            });

            const expandedWeaponIds = new Set();

            const renderDetailRows = () => {
                table.rows({ page: 'current' }).every(function () {
                    const rowNode = this.node();
                    const weaponId = rowNode.getAttribute('data-weapon-id') ?? '';
                    const template = rowNode.querySelector('.ability-template');
                    const customizationTemplate = rowNode.querySelector('.customization-template');

                    const abilityHtml = template ? template.innerHTML.trim() : '';
                    const customizationHtml = customizationTemplate ? customizationTemplate.innerHTML.trim() : '';

                    if (!abilityHtml && !customizationHtml) {
                        if (this.child && this.child.isShown()) {
                            this.child.hide();
                        }
                        return;
                    }

                    const sections = [];
                    if (abilityHtml) {
                        sections.push(`<div class="ability-detail-row">
                            <div class="text-uppercase text-muted small mb-2">Ability</div>
                            ${abilityHtml}
                        </div>`);
                    }

                    if (customizationHtml) {
                        sections.push(`<div class="customization-detail-row">
                            <div class="text-uppercase text-muted small mb-2">Customizations</div>
                            ${customizationHtml}
                        </div>`);
                    }

                    const content = `<div class="detail-wrapper">${sections.join('')}</div>`;
                    this.child(content);
                    if (expandedWeaponIds.has(weaponId)) {
                        this.child.show();
                    } else {
                        this.child.hide();
                    }
                });
            };

            const renderBannerRows = () => {
                document.querySelectorAll('#gearTable tbody tr.weapon-banner-row, #gearTable tbody tr.weapon-spacer-row').forEach(row => row.remove());
                const columnCount = table.columns(':visible').count();
                let isFirstBanner = true;
                let bannerIndex = 0;

                table.rows({ page: 'current' }).every(function () {
                    const rowNode = this.node();
                    const weaponId = rowNode.getAttribute('data-weapon-id') ?? '';
                    const character = rowNode.getAttribute('data-character') ?? '';
                    const weapon = rowNode.getAttribute('data-weapon') ?? '';
                    const equipment = rowNode.getAttribute('data-equipment') ?? '';
                    const isCostume = equipment.toLowerCase() === 'costume';

                    const bannerRow = document.createElement('tr');
                    bannerRow.classList.add('weapon-banner-row');
                    if (bannerIndex % 2 === 1) {
                        bannerRow.classList.add('weapon-banner-row-alt');
                    }

                    const bannerCell = document.createElement('td');
                    bannerCell.colSpan = columnCount;

                    const viewLevelsBtn = isCostume ? '' :
                        `<button type="button" class="btn btn-sm btn-outline-primary btn-view-levels"
                            data-weapon-id="${weaponId}"
                            data-character="${character}"
                            data-weapon="${weapon}"
                            data-equipment="${equipment}">View Levels</button>`;

                    const hasDetailsAttr = rowNode.getAttribute('data-has-details') === 'true';
                    const isExpanded = expandedWeaponIds.has(weaponId);
                    const detailsBtn = hasDetailsAttr
                        ? `<button type="button" class="btn btn-sm btn-outline-secondary btn-toggle-details" data-weapon-id="${weaponId}">${isExpanded ? 'Hide Ability Details' : 'Show Ability Details'}</button>`
                        : '';

                    const inCompare = compareItems.has(weaponId);
                    const compareFull = !inCompare && compareItems.size >= 3;
                    const compareBtn = `<button type="button" class="btn btn-sm ${inCompare ? 'btn-warning' : 'btn-outline-info'} btn-compare-toggle" data-weapon-id="${weaponId}" ${compareFull ? 'disabled' : ''}>${inCompare ? 'Remove from Compare' : 'Add to Compare'}</button>`;

                    bannerCell.innerHTML = `
                        <div class="weapon-banner">
                            <div class="weapon-banner-meta">
                                <span class="weapon-banner-name">${weapon}</span>
                                <div class="weapon-banner-pills">
                                    <span class="weapon-banner-character">${character}</span>
                                    <span class="weapon-banner-equipment">${equipment}</span>
                                </div>
                            </div>
                            <div class="weapon-banner-actions">
                                ${viewLevelsBtn}
                                ${detailsBtn}
                                ${compareBtn}
                            </div>
                        </div>`;
                    bannerRow.appendChild(bannerCell);

                    if (!isFirstBanner) {
                        const spacerRow = document.createElement('tr');
                        spacerRow.classList.add('weapon-spacer-row');
                        const spacerCell = document.createElement('td');
                        spacerCell.colSpan = columnCount;
                        spacerRow.appendChild(spacerCell);
                        rowNode.parentNode?.insertBefore(spacerRow, rowNode);
                    }
                    isFirstBanner = false;
                    bannerIndex += 1;

                    rowNode.parentNode?.insertBefore(bannerRow, rowNode);
                });
            };

            const renderMobileResults = () => {
                if (!gearMobileResults || !gearMobileResultsList || !gearMobileResultsEmpty || !gearMobilePagination || !gearMobilePageInfo || !gearMobilePrevPage || !gearMobileNextPage) {
                    return;
                }

                if (!isCardMode()) {
                    gearMobileResultsList.innerHTML = '';
                    gearMobileResults.classList.add('d-none');
                    return;
                }

                gearMobileResults.classList.remove('d-none');

                const pageRows = table.rows({ page: 'current', filter: 'applied' }).nodes().toArray();
                const pageInfo = table.page.info();

                if (pageRows.length === 0) {
                    gearMobileResultsList.innerHTML = '';
                    gearMobileResultsEmpty.style.display = 'block';
                    gearMobilePagination.classList.add('d-none');
                    return;
                }

                gearMobileResultsEmpty.style.display = 'none';

                gearMobileResultsList.innerHTML = pageRows.map((rowNode) => {
                    const cells = rowNode.querySelectorAll('td');
                    const weaponId = rowNode.getAttribute('data-weapon-id') ?? '';
                    const character = escapeHtml(rowNode.getAttribute('data-character') ?? '');
                    const weapon = escapeHtml(rowNode.getAttribute('data-weapon') ?? '');
                    const equipment = rowNode.getAttribute('data-equipment') ?? '';
                    const equipmentSafe = escapeHtml(equipment);
                    const isCostume = equipment.toLowerCase() === 'costume';
                    const hasDetails = rowNode.getAttribute('data-has-details') === 'true';
                    const isExpanded = expandedWeaponIds.has(weaponId);

                    const elementCell = cells[0];
                    const elementText = escapeHtml(elementCell ? (elementCell.childNodes[0]?.textContent?.trim() ?? '') : '');
                    const potText = escapeHtml(cells[1]?.textContent?.trim() ?? '');
                    const statsHtml = cells[2]?.querySelector('.stat-stack')?.innerHTML ?? `<span class="text-muted">${escapeHtml(cells[2]?.textContent?.trim() ?? 'N/A')}</span>`;
                    const effectsHtml = cells[5]?.innerHTML ?? '<span class="text-muted">None</span>';

                    const showInlineRAbilityEffects = window.innerWidth >= 768;
                    const rAbilitiesLabel = showInlineRAbilityEffects ? 'R. Abilities' : 'R. Abilities (tap)';

                    const rAbilityMainList = cells[6]?.querySelector('ul.list-unstyled:not(.cust-rability-list)');
                    let rAbilityMain = '<span class="text-muted">None</span>';
                    if (rAbilityMainList) {
                        const listClone = rAbilityMainList.cloneNode(true);

                        if (showInlineRAbilityEffects) {
                            appendRAbilityEffectBlocks(listClone, 'gear-mobile-rability-effects-inline');
                        }

                        rAbilityMain = listClone.outerHTML;
                    }

                    const rAbilityCustList = cells[6]?.querySelector('.cust-rability-list');
                    let rAbilityCust = '';
                    if (rAbilityCustList) {
                        const custClone = rAbilityCustList.cloneNode(true);
                        if (showInlineRAbilityEffects) {
                            appendRAbilityEffectBlocks(custClone, 'gear-mobile-rability-effects-inline');
                        }
                        rAbilityCust = custClone.outerHTML;
                    }
                    const rAbilitiesHtml = `${rAbilityMain}${rAbilityCust}`;

                    const sigilsHtml = cells[7]?.querySelector('.sigil-badges')?.outerHTML ?? '<span class="text-muted">&mdash;</span>';
                    const abilityHtml = cells[6]?.querySelector('.ability-template')?.innerHTML?.trim() ?? '';
                    const customizationHtml = cells[6]?.querySelector('.customization-template')?.innerHTML?.trim() ?? '';
                    const hasExtra = Boolean(abilityHtml || customizationHtml);

                    const inCompare = compareItems.has(weaponId);
                    const compareFull = !inCompare && compareItems.size >= 3;
                    const compareBtnClass = inCompare ? 'btn-warning' : 'btn-outline-info';
                    const compareLabel = inCompare ? 'Remove from Compare' : 'Add to Compare';

                    const viewLevelsBtn = isCostume
                        ? ''
                        : `<button type="button" class="btn btn-sm btn-outline-primary btn-view-levels"
                                data-weapon-id="${escapeHtml(weaponId)}"
                                data-character="${character}"
                                data-weapon="${weapon}"
                                data-equipment="${equipmentSafe}">View Levels</button>`;

                    const detailsBtn = hasDetails
                        ? `<button type="button" class="btn btn-sm btn-outline-secondary btn-toggle-details" data-weapon-id="${escapeHtml(weaponId)}">${isExpanded ? 'Hide Ability Details' : 'Show Ability Details'}</button>`
                        : '';

                    const compareBtn = `<button type="button" class="btn btn-sm ${compareBtnClass} btn-compare-toggle" data-weapon-id="${escapeHtml(weaponId)}" ${compareFull ? 'disabled' : ''}>${compareLabel}</button>`;

                    const extraSection = hasExtra
                        ? `<div class="gear-mobile-extra ${isExpanded ? '' : 'd-none'}" data-weapon-extra="${escapeHtml(weaponId)}">
                                ${abilityHtml ? `<div class="ability-detail-row"><div class="text-uppercase text-muted small mb-2">Ability</div>${abilityHtml}</div>` : ''}
                                ${customizationHtml ? `<div class="customization-detail-row mt-2"><div class="text-uppercase text-muted small mb-2">Customizations</div>${customizationHtml}</div>` : ''}
                           </div>`
                        : '';

                    return `<article class="gear-mobile-card" data-weapon-id="${escapeHtml(weaponId)}">
                        <div class="gear-mobile-card-header">
                            <div>
                                <div class="gear-mobile-card-name">${weapon}</div>
                                <div class="gear-mobile-card-pills">
                                    <span class="gear-mobile-pill">${character}</span>
                                    <span class="gear-mobile-pill">${equipmentSafe}</span>
                                </div>
                            </div>
                        </div>
                        <div class="gear-mobile-card-body">
                            <div class="gear-mobile-row"><div class="gear-mobile-label">Element</div><div class="gear-mobile-value">${elementText || '<span class="text-muted">N/A</span>'}</div></div>
                            <div class="gear-mobile-row"><div class="gear-mobile-label">Pot. %</div><div class="gear-mobile-value">${potText || '<span class="text-muted">N/A</span>'}</div></div>
                            <div class="gear-mobile-row"><div class="gear-mobile-label">Stats</div><div class="gear-mobile-value">${statsHtml}</div></div>
                            <div class="gear-mobile-row"><div class="gear-mobile-label">Effects</div><div class="gear-mobile-value">${effectsHtml}</div></div>
                            <div class="gear-mobile-row"><div class="gear-mobile-label">${rAbilitiesLabel}</div><div class="gear-mobile-value">${rAbilitiesHtml}</div></div>
                            <div class="gear-mobile-row"><div class="gear-mobile-label">Sigils</div><div class="gear-mobile-value">${sigilsHtml}</div></div>
                        </div>
                        <div class="gear-mobile-actions">
                            ${viewLevelsBtn}
                            ${detailsBtn}
                            ${compareBtn}
                        </div>
                        ${extraSection}
                    </article>`;
                }).join('');

                const totalPages = pageInfo.pages || 1;
                const currentPage = (pageInfo.page ?? 0) + 1;
                gearMobilePageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
                gearMobilePrevPage.disabled = currentPage <= 1;
                gearMobileNextPage.disabled = currentPage >= totalPages;
                gearMobilePagination.classList.toggle('d-none', totalPages <= 1);
            };

            const renderDecorations = () => {
                renderBannerRows();
                renderDetailRows();
                renderMobileResults();
                initRAbilityPopovers();
                syncGearTableFade();
            };

            let rAbilityPopovers = [];
            const isTouchDevice = window.matchMedia('(hover: none), (pointer: coarse)').matches;

            const disposeRAbilityPopovers = () => {
                rAbilityPopovers.forEach(popover => popover.dispose());
                rAbilityPopovers = [];
            };

            const initRAbilityPopovers = () => {
                disposeRAbilityPopovers();

                document.querySelectorAll('.rability-hoverable').forEach((el) => {
                    const raw = el.getAttribute('data-rability-effects') ?? '';
                    const lines = raw
                        .split('|')
                        .map(v => v.trim())
                        .filter(Boolean);

                    const content = lines.length > 0
                        ? `<ul class="mb-0 ps-3">${lines.map(line => `<li>${escapeHtml(line)}</li>`).join('')}</ul>`
                        : '<span>No effect details</span>';

                    const popover = new bootstrap.Popover(el, {
                        container: 'body',
                        html: true,
                        sanitize: true,
                        placement: 'auto',
                        trigger: isTouchDevice ? 'click focus' : 'hover focus',
                        content
                    });

                    rAbilityPopovers.push(popover);
                });
            };

            document.addEventListener('click', (event) => {
                if (event.target.closest('.rability-hoverable') || event.target.closest('.popover')) {
                    return;
                }

                rAbilityPopovers.forEach(popover => popover.hide());
            });

            const customizationFilterCheckbox = document.getElementById('hasCustomizationsFilter');

            if (gearMobilePrevPage) {
                gearMobilePrevPage.addEventListener('click', () => table.page('previous').draw('page'));
            }

            if (gearMobileNextPage) {
                gearMobileNextPage.addEventListener('click', () => table.page('next').draw('page'));
            }

            $.fn.dataTable.ext.search.push(function (settings, rowData, dataIndex) {
                if (settings.nTable !== table.table().node()) {
                    return true;
                }

                if (!customizationFilterCheckbox.checked) {
                    return true;
                }

                const rowNode = table.row(dataIndex).node();
                const hasCustomizations = rowNode?.getAttribute('data-has-customizations') === 'true';
                return hasCustomizations;
            });

            customizationFilterCheckbox.addEventListener('change', () => {
                table.draw();
            });

            if (mobileClearFiltersBtn) {
                mobileClearFiltersBtn.addEventListener('click', () => {
                    clearAllFiltersBtn.click();
                });
            }

            if (mobileMainClearBtn) {
                mobileMainClearBtn.addEventListener('click', () => {
                    searchBox.value = '';
                    table.search('').draw();
                });
            }

            if (mobileMainApplyBtn && mainSearchCollapse) {
                mobileMainApplyBtn.addEventListener('click', () => {
                    bootstrap.Collapse.getOrCreateInstance(mainSearchCollapse).hide();
                });
            }

            if (mobileApplyFiltersBtn && advancedSearchCollapse) {
                mobileApplyFiltersBtn.addEventListener('click', () => {
                    bootstrap.Collapse.getOrCreateInstance(advancedSearchCollapse).hide();
                });
            }

            if (advancedSearchCollapse) {
                ['shown.bs.collapse', 'hidden.bs.collapse'].forEach(eventName => {
                    advancedSearchCollapse.addEventListener(eventName, (event) => {
                        if (event.target !== advancedSearchCollapse) {
                            return;
                        }

                        if (eventName === 'shown.bs.collapse') {
                            if (window.innerWidth < 992 && mainSearchCollapse?.classList.contains('show')) {
                                bootstrap.Collapse.getOrCreateInstance(mainSearchCollapse, { toggle: false }).hide();
                            }
                            syncAdvancedAccordionSelectionState();
                        }
                        syncAdvancedSearchPresentation();
                    });
                });
            }

            if (mainSearchCollapse) {
                ['shown.bs.collapse', 'hidden.bs.collapse'].forEach(eventName => {
                    mainSearchCollapse.addEventListener(eventName, (event) => {
                        if (event.target !== mainSearchCollapse) {
                            return;
                        }

                        syncMainSearchPresentation();
                    });
                });

                if (window.innerWidth < 992 && mainSearchCollapse.classList.contains('show')) {
                    bootstrap.Collapse.getOrCreateInstance(mainSearchCollapse, { toggle: false }).hide();
                }
            }

            window.addEventListener('resize', syncAdvancedSearchPresentation);
            window.addEventListener('resize', syncMainSearchPresentation);

            activeFilterChips.addEventListener('click', (event) => {
                const chip = event.target.closest('.active-filter-chip');
                if (!chip) {
                    return;
                }

                const kind = chip.dataset.kind;
                const selector = chip.dataset.selector;
                const value = chip.dataset.value;

                if (kind === 'search') {
                    searchBox.value = '';
                    table.search('').draw();
                    return;
                }

                if (kind === 'hasCustomizations') {
                    customizationFilterCheckbox.checked = false;
                    table.draw();
                    return;
                }

                if (!selector || !value) {
                    return;
                }

                document.querySelectorAll(selector).forEach(cb => {
                    if (cb.value === value) {
                        cb.checked = false;
                    }
                });

                if (selector === '.character-checkbox') {
                    updateCharacterFilter();
                    return;
                }

                if (selector === '.equipment-filter') {
                    updateEquipmentFilter();
                    return;
                }

                if (selector === '.sigil-filter') {
                    updateSigilFilter();
                    return;
                }

                if (selector === '.subr-filter') {
                    updateSubRFilter();
                    return;
                }

                const filterGroup = advancedFilters.find(group => group.selector === selector);
                if (filterGroup) {
                    applyAdvancedFilter(filterGroup.selector, filterGroup.columnIndex);
                }
            });

            clearAllFiltersBtn.addEventListener('click', () => {
                searchBox.value = '';
                table.search('');

                document.querySelectorAll('.character-checkbox:checked, .advanced-filter:checked').forEach(cb => {
                    cb.checked = false;
                });

                customizationFilterCheckbox.checked = false;

                selectedCharacters.clear();
                selectedEquipmentTypes.clear();
                selectedSigils.clear();
                selectedSubRAbilities.clear();

                advancedFilters.forEach(group => {
                    table.column(group.columnIndex).search('', true, false);
                });

                table.draw();
            });

            // --- View Levels Modal Logic ---
            const viewLevelsModal = document.getElementById('viewLevelsModal');
            const bsModal = new bootstrap.Modal(viewLevelsModal);
            const snapshotOverboost = document.getElementById('snapshotOverboost');
            const snapshotLevel = document.getElementById('snapshotLevel');
            const snapshotLevelRange = document.getElementById('snapshotLevelRange');
            const snapshotSpinner = document.getElementById('snapshotSpinner');
            const snapshotError = document.getElementById('snapshotError');
            const snapshotCustomizationUnlockHint = document.getElementById('snapshotCustomizationUnlockHint');

            let currentWeaponId = null;
            let snapshotDebounceTimer = null;
            let snapshotAbortController = null;

            const formatNumber = (n) => Number(n).toLocaleString();

            const setSnapshotLoading = (loading) => {
                snapshotSpinner.classList.toggle('active', loading);
                snapshotOverboost.disabled = loading;
                snapshotLevel.disabled = loading;
                snapshotLevelRange.disabled = loading;
            };

            const showSnapshotError = (show) => {
                snapshotError.classList.toggle('active', show);
            };

            const updateSnapshotCustomizationUnlockHint = () => {
                const showHint = !snapshotOverboost.classList.contains('d-none') && snapshotOverboost.value === '0';
                snapshotCustomizationUnlockHint.classList.toggle('d-none', !showHint);
            };

            const updateSnapshotContent = (data) => {
                showSnapshotError(false);

                // Ability
                const abilityEl = document.getElementById('snapshotAbility');
                if (data.abilityText) {
                    abilityEl.innerHTML = data.abilityText.replace(/\r?\n/g, '<br />');
                } else {
                    abilityEl.innerHTML = '<span class="text-muted">No ability data</span>';
                }

                // Stats
                document.getElementById('snapshotPatk').textContent = formatNumber(data.patk);
                document.getElementById('snapshotMatk').textContent = formatNumber(data.matk);
                document.getElementById('snapshotHeal').textContent = formatNumber(data.heal);

                // R Abilities
                const rAbilitiesEl = document.getElementById('snapshotRAbilities');
                if (data.rAbilities && data.rAbilities.length > 0) {
                    rAbilitiesEl.innerHTML = data.rAbilities.map(r => {
                        if (r.isLocked) {
                            const hint = r.lockedUntilLevel != null
                                ? ` <span class="text-muted">(unlocks at Lv. ${r.lockedUntilLevel})</span>`
                                : '';
                            return `<li class="text-muted"><i class="fas fa-lock fa-xs me-1"></i>${r.skillName}${hint}</li>`;
                        }
                        const breakdown = (r.basePoints > 0 && r.upgradePoints > 0)
                            ? ` <small class="text-muted">(Lv. ${r.basePoints} + OB ${r.upgradePoints})</small>`
                            : '';
                        const effectsHtml = Array.isArray(r.effects) && r.effects.length > 0
                            ? `<ul class="snapshot-rability-effects">${r.effects
                                .filter(e => e && e.description)
                                .map(e => `<li>${escapeHtml(e.description)}</li>`)
                                .join('')}</ul>`
                            : '';
                        return `<li class="snapshot-rability-item"><div class="snapshot-rability-main"><strong>+${r.totalPoints}</strong> ${escapeHtml(r.skillName)}${breakdown}</div>${effectsHtml}</li>`;
                    }).join('');
                } else {
                    rAbilitiesEl.innerHTML = '<li class="text-muted">No R Ability data at this level</li>';
                }

                // Customizations
                const customEl = document.getElementById('snapshotCustomizations');
                if (data.customizations && data.customizations.length > 0) {
                    customEl.innerHTML = data.customizations.map(c =>
                        `<div class="snapshot-customization-entry">
                            <span class="customization-slot">${c.slot}</span>
                            <span class="customization-kind">${c.kind}</span>
                            <span class="customization-description">${c.description}</span>
                        </div>`
                    ).join('');
                    document.getElementById('snapshotCustomizationsSection').style.display = '';
                } else {
                    customEl.innerHTML = '<span class="text-muted">No customizations available</span>';
                    document.getElementById('snapshotCustomizationsSection').style.display = 'none';
                }
            };

            const fetchSnapshot = () => {
                if (!currentWeaponId) return;

                if (snapshotAbortController) {
                    snapshotAbortController.abort();
                }
                snapshotAbortController = new AbortController();

                const overboost = snapshotOverboost.value;
                const level = snapshotLevel.value;
                const url = `/GearSearch?handler=WeaponSnapshot&weaponId=${encodeURIComponent(currentWeaponId)}&overboost=${overboost}&level=${level}`;

                setSnapshotLoading(true);
                showSnapshotError(false);

                fetch(url, { signal: snapshotAbortController.signal })
                    .then(response => {
                        if (!response.ok) throw new Error('Request failed');
                        return response.json();
                    })
                    .then(data => {
                        updateSnapshotContent(data);
                        setSnapshotLoading(false);
                    })
                    .catch(err => {
                        if (err.name === 'AbortError') return;
                        showSnapshotError(true);
                        setSnapshotLoading(false);
                    });
            };

            const debouncedFetchSnapshot = () => {
                clearTimeout(snapshotDebounceTimer);
                snapshotDebounceTimer = setTimeout(fetchSnapshot, 250);
            };

            snapshotOverboost.addEventListener('change', () => {
                updateSnapshotCustomizationUnlockHint();
                debouncedFetchSnapshot();
            });
            snapshotLevel.addEventListener('change', debouncedFetchSnapshot);
            snapshotLevel.addEventListener('input', () => {
                snapshotLevelRange.value = snapshotLevel.value;
            });
            snapshotLevelRange.addEventListener('input', () => {
                snapshotLevel.value = snapshotLevelRange.value;
                debouncedFetchSnapshot();
            });

            document.addEventListener('click', (e) => {
                const compareBtn = e.target.closest('.btn-compare-toggle');
                if (compareBtn) {
                    const wid = compareBtn.getAttribute('data-weapon-id');
                    if (compareItems.has(wid)) {
                        compareItems.delete(wid);
                    } else if (compareItems.size < 3) {
                        const data = scrapeWeaponData(wid);
                        if (data) compareItems.set(wid, data);
                    }
                    updateComparePanel();
                    return;
                }

                const toggleBtn = e.target.closest('.btn-toggle-details');
                if (toggleBtn) {
                    const wid = toggleBtn.getAttribute('data-weapon-id');
                    if (expandedWeaponIds.has(wid)) {
                        expandedWeaponIds.delete(wid);
                    } else {
                        expandedWeaponIds.add(wid);
                    }
                    renderDecorations();
                    return;
                }

                const btn = e.target.closest('.btn-view-levels');
                if (!btn) return;

                currentWeaponId = btn.getAttribute('data-weapon-id');
                const character = btn.getAttribute('data-character');
                const weapon = btn.getAttribute('data-weapon');
                const equipment = btn.getAttribute('data-equipment');

                document.getElementById('snapshotCharacter').textContent = character;
                document.getElementById('snapshotWeaponName').textContent = weapon;
                document.getElementById('snapshotEquipment').textContent = equipment;

                // Toggle overboost visibility for Ultimate Weapons
                const isUltimate = equipment.toLowerCase() === 'ultimate';
                snapshotOverboost.classList.toggle('d-none', isUltimate);
                document.getElementById('snapshotOverboostNa').classList.toggle('d-none', !isUltimate);

                // Reset controls to defaults
                snapshotOverboost.value = '10';
                snapshotLevel.value = '130';
                snapshotLevelRange.value = '130';
                updateSnapshotCustomizationUnlockHint();

                // Clear previous content
                document.getElementById('snapshotAbility').innerHTML = '<span class="text-muted">Loading...</span>';
                document.getElementById('snapshotPatk').textContent = '...';
                document.getElementById('snapshotMatk').textContent = '...';
                document.getElementById('snapshotHeal').textContent = '...';
                document.getElementById('snapshotRAbilities').innerHTML = '<li class="text-muted">Loading...</li>';
                document.getElementById('snapshotCustomizations').innerHTML = '<span class="text-muted">Loading...</span>';
                document.getElementById('snapshotCustomizationsSection').style.display = '';
                showSnapshotError(false);

                bsModal.show();
                fetchSnapshot();
            });

            updateCharacterFilter();
            updateEquipmentFilter();
            renderDecorations();
            syncFilterUi();
            syncMainSearchPresentation();
            syncAdvancedSearchPresentation();
            table.on('draw', () => {
                renderDecorations();
                syncFilterUi();
            });

            window.addEventListener('resize', () => {
                renderDecorations();
            });
        });
    </script>
}
