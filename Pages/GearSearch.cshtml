<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="mb-3"><i class="fas fa-search"></i> Gear Search</h1>
            <p class="text-muted mb-0">Browse all weapons with passive skills and advanced filters.</p>
        </div>
        <a class="btn btn-outline-primary" href="https://cyphersignal.github.io/ff7ec/" target="_blank" rel="noopener">
            <i class="fas fa-arrow-up-right-from-square me-2"></i>Open original FF7EC Equipment Database
        </a>
    </div>

    <div class="card mb-4 sticky-gear-controls" id="mainSearchCard">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Main Search</span>
            <button class="btn btn-sm advanced-toggle-btn" id="mainSearchToggleBtn" type="button" data-bs-toggle="collapse" data-bs-target="#mainSearchCollapse" aria-expanded="true" aria-controls="mainSearchCollapse">
                Toggle
            </button>
        </div>
        <div class="collapse show" id="mainSearchCollapse">
            <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label mb-1">Characters</label>
                    <div class="text-muted small mb-2">Check one or more characters to filter. Leave all unchecked to show everything.</div>
                    <div id="characterCheckboxGroup" class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2">
                        @foreach (var character in GearSearchModel.AvailableCharacters)
                        {
                            var checkboxId = $"character-{character.Replace(" ", "-").ToLowerInvariant()}";
                            <div class="col">
                                <div class="form-check">
                                    <input class="form-check-input character-checkbox" type="checkbox" value="@character" id="@checkboxId" />
                                    <label class="form-check-label" for="@checkboxId">@character</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <label for="searchBox" class="form-label">Search</label>
                    <input id="searchBox" type="text" class="form-control" placeholder="Search by weapon, ability, effects..." />
                </div>
                <div class="col-md-6 col-lg-4">
                    <label for="pageSize" class="form-label">Rows per page</label>
                    <select id="pageSize" class="form-select">
                        @foreach (var size in GearSearchModel.AvailablePageSizes)
                        {
                            if (Model.PageSize == size)
                            {
                                <option value="@size" selected>@size</option>
                            }
                            else
                            {
                                <option value="@size">@size</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label mb-1">Quick Filters</label>
                    <div class="quick-filter-bar">
                        @foreach (var quickEquipment in equipmentTypeOptions.Take(3))
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary quick-filter-btn" data-quick-equipment="@quickEquipment">@quickEquipment</button>
                        }
                        <button type="button" class="btn btn-sm btn-outline-secondary quick-filter-btn" data-quick-customizations="true">Has Customizations</button>
                        <button type="button" class="btn btn-sm btn-link text-decoration-none quick-filter-clear" id="quickFiltersClearBtn">Clear Quick</button>
                    </div>
                </div>
            </div>

            <div class="main-mobile-actions d-lg-none">
                <button type="button" class="btn btn-outline-secondary" id="mobileMainClearBtn">Clear Search</button>
                <button type="button" class="btn btn-primary" id="mobileMainApplyBtn">Apply & Close</button>
            </div>
        </div>
        </div>
    </div>

