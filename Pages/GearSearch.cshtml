    .gear-mobile-card {
        --character-accent: #7a35d8;
        --character-accent-secondary: #43d6ff;
        --character-accent-soft: rgba(122, 53, 216, 0.14);
        --character-accent-faint: rgba(67, 214, 255, 0.08);
        --element-accent: var(--character-accent);
        --element-accent-soft: rgba(122, 53, 216, 0.18);
        --element-accent-faint: rgba(122, 53, 216, 0.07);
        --element-accent-border: rgba(122, 53, 216, 0.28);
        --element-accent-glow: rgba(122, 53, 216, 0.14);
        position: relative;
        border: 1px solid #ddd3ed;
        border-radius: 0.82rem;
        background: linear-gradient(135deg, var(--character-accent-soft), rgba(255, 255, 255, 0.98) 24%, rgba(255, 255, 255, 0.98) 70%, var(--character-accent-faint));
        box-shadow: 0 8px 18px rgba(39, 26, 65, 0.08);
        padding: 0.56rem 0.6rem;
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .gear-mobile-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 0.24rem;
        background: linear-gradient(180deg, var(--character-accent), var(--character-accent-secondary));
    }

    .gear-mobile-card::after {
        content: "";
        position: absolute;
        right: -2rem;
        top: -2rem;
        width: 6.8rem;
        height: 6.8rem;
        background: radial-gradient(circle, var(--element-accent-soft), rgba(255, 255, 255, 0) 74%);
        pointer-events: none;
    }

    .gear-mobile-card-header {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        margin-bottom: 0;
    }

    .gear-mobile-card-visuals {
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        flex: 0 0 auto;
    }

    .gear-mobile-card-portrait-shell,
    .gear-mobile-card-item-art-shell {
        position: relative;
        width: 52px;
        height: 52px;
        padding: 2px;
        border-radius: 0.9rem;
        flex: 0 0 auto;
        box-shadow: 0 10px 22px rgba(44, 29, 76, 0.14);
    }

    .gear-mobile-card-portrait-shell {
        background: linear-gradient(145deg, var(--character-accent), var(--character-accent-secondary));
    }

    .gear-mobile-card-item-art-shell {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(238, 231, 248, 0.96));
    }

    .gear-mobile-card-portrait-shell::after,
    .gear-mobile-card-item-art-shell::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.32);
        pointer-events: none;
    }

    .gear-mobile-card-portrait,
    .gear-mobile-card-item-art {
        display: block;
        width: 100%;
        height: 100%;
        border-radius: calc(0.9rem - 2px);
        object-fit: cover;
        object-position: center top;
        background: #ebe7f3;
