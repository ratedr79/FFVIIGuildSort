<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="mb-3"><i class="fas fa-search"></i> Gear Search</h1>
            <p class="text-muted mb-0">Browse all weapons with passive skills and advanced filters.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#buffDebuffNotesModal">
                <i class="fas fa-book-open me-2"></i>Buff/Debuff Notes
            </button>
            <a class="btn btn-outline-primary" href="https://cyphersignal.github.io/ff7ec/" target="_blank" rel="noopener">
                <i class="fas fa-arrow-up-right-from-square me-2"></i>Open original FF7EC Equipment Database
            </a>
        </div>
    </div>

    <div class="card mb-4 sticky-gear-controls" id="gearSearchToolbarCard">
        <div class="card-body gear-search-toolbar-body">
            <div class="gear-search-topline">
                <div class="gear-search-input-group">
                    <label for="searchBox" class="form-label gear-search-toolbar-label mb-1">Search</label>
                    <input id="searchBox" type="text" class="form-control" placeholder="Search by weapon, ability, effects..." />
                    <div class="gear-search-toolbar-hint mt-1">Search gear first, then refine with characters, quick presets, or filters.</div>
                </div>
                <div class="gear-search-toolbar-actions d-lg-none">
                    <button class="btn advanced-toggle-btn" id="mobileFiltersToggleBtn" type="button" data-bs-toggle="collapse" data-bs-target="#filtersPanelCollapse" aria-expanded="false" aria-controls="filtersPanelCollapse">
                        Filters
                    </button>
                </div>
            </div>

            <div class="gear-search-toolbar-section">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <span class="gear-search-toolbar-label">Characters</span>
                    <span class="gear-search-toolbar-hint">Select one or more, or leave all unchecked to browse everything.</span>
                </div>
                <div id="characterCheckboxGroup" class="character-chip-grid">
                    @foreach (var character in GearSearchModel.AvailableCharacters)
                    {
                        var checkboxId = $"character-{character.Replace(" ", "-").ToLowerInvariant()}";
                        <div class="character-chip-option">
                            <input class="character-chip-input character-checkbox" type="checkbox" value="@character" id="@checkboxId" />
                            <label class="character-chip-label" for="@checkboxId">@character</label>
                        </div>
                    }
                </div>
            </div>

            <div class="gear-search-toolbar-section">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <span class="gear-search-toolbar-label">Quick Filters</span>
                    <button type="button" class="btn btn-sm btn-link text-decoration-none quick-filter-clear" id="quickFiltersClearBtn">Clear Quick</button>
                </div>
                <div class="quick-filter-bar">
                    @foreach (var quickEquipment in equipmentTypeOptions.Take(3))
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary quick-filter-btn" data-quick-equipment="@quickEquipment">@quickEquipment</button>
                    }
                    @foreach (var quickFilter in elementalQuickFilters)
                    {
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary quick-filter-btn"
                                data-quick-element="@quickFilter.Element"
                                data-quick-ability="@quickFilter.AbilityType">@quickFilter.Label</button>
                    }
                    @foreach (var quickSigil in quickSigilFilters)
                    {
                        var quickSigilIconPath = GetSigilIconPath(quickSigil.Value);
                        <button type="button" class="btn btn-sm btn-outline-secondary quick-filter-btn" data-quick-sigil="@quickSigil.Value">
                            @if (!string.IsNullOrWhiteSpace(quickSigilIconPath))
                            {
                                <img class="quick-filter-icon" src="@quickSigilIconPath" alt="" aria-hidden="true" />
                            }
                            <span>@quickSigil.Label</span>
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-outline-secondary quick-filter-btn" data-quick-owned="true">Only Owned</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary quick-filter-btn" data-quick-customizations="true">Has Customizations</button>
                </div>
            </div>

            <div id="activeFiltersWrap" class="active-filters-wrap d-none gear-toolbar-active-filters">
                <span class="active-filters-label">Active Filters</span>
                <div id="activeFilterChips" class="active-filter-chips"></div>
                <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none" id="clearAllFiltersBtn">Clear all</button>
            </div>
        </div>
    </div>

    <div class="card mb-4 gear-filters-panel" id="filtersPanelCard">
        <div class="card-header d-flex justify-content-between align-items-center gap-2">
            <div>
                <div class="fw-semibold">Filters</div>
                <div class="small text-muted">Refine results without leaving the current list. If advanced filters are hidden, use the Filters button here to show them.</div>
            </div>
            <div class="gear-filters-header-actions">
                <button type="button" class="btn btn-sm advanced-toggle-btn filters-header-toggle d-none d-lg-inline-flex" id="desktopFiltersToggleBtn" data-bs-toggle="collapse" data-bs-target="#filtersPanelCollapse" aria-expanded="false" aria-controls="filtersPanelCollapse">
                    Filters
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary d-lg-none" id="mobileCloseFiltersBtn" data-bs-toggle="collapse" data-bs-target="#filtersPanelCollapse" aria-expanded="false" aria-controls="filtersPanelCollapse">
                    Close
                </button>
            </div>
        </div>
        <div class="collapse" id="filtersPanelCollapse">
            <div class="card-body">
                <div class="accordion" id="advancedFiltersAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingElement">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseElement" aria-expanded="false" aria-controls="collapseElement">
                                Element Type
                                <span id="badgeElementCount" class="badge rounded-pill text-bg-secondary ms-2 filter-count-badge d-none">0</span>
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".element-filter">Reset</button>
                        </h2>
                        <div id="collapseElement" class="accordion-collapse collapse" aria-labelledby="headingElement" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var element in elementOptions)
                                    {
                                        var checkboxId = $"element-{element.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter element-filter" type="checkbox" value="@element" id="@checkboxId" />
