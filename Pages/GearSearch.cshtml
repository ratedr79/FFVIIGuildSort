                                        var checkboxId = $"rability-{passive.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter rability-filter" type="checkbox" value="@passive" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@passive</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div id="rabilityFilterNoMatches" class="small text-muted mt-2 d-none">No matches found.</div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingEffects">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEffects" aria-expanded="false" aria-controls="collapseEffects">
                                Effects
                                <span id="badgeEffectsCount" class="badge rounded-pill text-bg-secondary ms-2 filter-count-badge d-none">0</span>
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".effect-filter">Reset</button>
                        </h2>
                        <div id="collapseEffects" class="accordion-collapse collapse" aria-labelledby="headingEffects" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body" style="max-height: 320px; overflow-y: auto;">
                                <div class="row g-2 mb-2">
                                    <div class="col-12 col-md-9">
                                        <input
                                            type="text"
                                            class="form-control form-control-sm"
                                            id="effectFilterSearch"
                                            placeholder="Search Effects..."
                                            autocomplete="off" />
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <button type="button" class="btn btn-sm btn-outline-secondary w-100" id="clearEffectFilterSearch">Clear</button>
                                    </div>
                                </div>
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var effect in effectOptions)
                                    {
                                        var checkboxId = $"effect-{effect.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter effect-filter" type="checkbox" value="@effect" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@effect</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div id="effectFilterNoMatches" class="small text-muted mt-2 d-none">No matches found.</div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingSubRAbilities">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSubRAbilities" aria-expanded="false" aria-controls="collapseSubRAbilities">
                                Sub-R Abilities
                                <span id="badgeSubRAbilitiesCount" class="badge rounded-pill text-bg-secondary ms-2 filter-count-badge d-none">0</span>
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".subr-filter">Reset</button>
                        </h2>
                        <div id="collapseSubRAbilities" class="accordion-collapse collapse" aria-labelledby="headingSubRAbilities" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body" style="max-height: 320px; overflow-y: auto;">
                                <div class="row g-2 mb-2">
                                    <div class="col-12 col-md-9">
                                        <input
                                            type="text"
                                            class="form-control form-control-sm"
                                            id="subRFilterSearch"
                                            placeholder="Search Sub-R Abilities..."
                                            autocomplete="off" />
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <button type="button" class="btn btn-sm btn-outline-secondary w-100" id="clearSubRFilterSearch">Clear</button>
                                    </div>
                                </div>
                                <div class="row row-cols-1 row-cols-md-2 g-2">
                                    @foreach (var subR in subRAbilityOptions)
                                    {
                                        var checkboxId = $"subr-{subR.Key.Replace(":", "-").Replace("/", "-").Replace(" ", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter subr-filter" type="checkbox" value="@subR.Key" data-label="@subR.Label" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@subR.Label</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div id="subRFilterNoMatches" class="small text-muted mt-2 d-none">No matches found.</div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingSigils">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSigils" aria-expanded="false" aria-controls="collapseSigils">
                                Sigils
                                <span id="badgeSigilsCount" class="badge rounded-pill text-bg-secondary ms-2 filter-count-badge d-none">0</span>
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".sigil-filter">Reset</button>
                        </h2>
                        <div id="collapseSigils" class="accordion-collapse collapse" aria-labelledby="headingSigils" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-4 g-2">
                                    @foreach (var sigil in sigilOptions)
                                    {
                                        var checkboxId = $"sigil-{sigil.Type.ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter sigil-filter" type="checkbox" value="@sigil.Type" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@sigil.Symbol @sigil.Type</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="border-top pt-2 d-flex flex-wrap align-items-center gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="ownedItemsOnlyFilter" />
                        <label class="form-check-label" for="ownedItemsOnlyFilter">
                            Only Show Owned Items
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="hasCustomizationsFilter" />
                        <label class="form-check-label" for="hasCustomizationsFilter">
                            Has Customizations
                        </label>
                    </div>
                </div>

                <div class="gear-filters-sheet-footer d-lg-none">
                    <button type="button" class="btn btn-outline-secondary" id="mobileClearFiltersBtn">Clear all</button>
                    <button type="button" class="btn btn-primary" id="mobileApplyFiltersBtn">Apply filters</button>
                </div>
            </div>
        </div>
    </div>

    <div class="gear-results-meta flex-md-row align-items-md-center justify-content-between mb-2">
        <div id="resultsSummary" class="results-summary">Showing 0 of 0 items</div>
        <div class="gear-results-page-size">
            <label for="pageSize" class="form-label mb-0 small text-muted">Rows per page</label>
            <select id="pageSize" class="form-select form-select-sm">
                @foreach (var size in GearSearchModel.AvailablePageSizes)
                {
                    if (Model.PageSize == size)
                    {
                        <option value="@size" selected>@size</option>
                    }
                    else
                    {
                        <option value="@size">@size</option>
                    }
                }
            </select>
        </div>
    </div>

    <div id="ownedInventoryGuidance" class="alert alert-warning border d-none mb-3">
        <strong><code>Only Show Owned Items</code> is on, but no local inventory data was found.</strong>
        Visit <a href="/PlayerInventoryManagement" class="alert-link">Player Inventory Management</a> to mark owned gear or import an inventory backup, then return here to filter by owned items.
    </div>

    <div class="card mb-2 sticky-compare-panel" id="comparePanel">
        <div class="card-body d-flex flex-wrap align-items-center gap-2">
            <span class="fw-semibold text-muted">Compare:</span>
            <span id="compareCount" class="small text-muted">0 items selected</span>
            <span id="compareNames" class="d-flex flex-wrap gap-1"></span>
            <div class="ms-auto d-flex gap-2">
                <button class="btn btn-sm btn-outline-danger" id="compareClearBtn" disabled>Clear</button>
                <button class="btn btn-sm btn-primary" id="compareOpenBtn" disabled>Compare Items</button>
            </div>
        </div>
    </div>

    <div id="gearMobileResults" class="gear-mobile-results mb-3" aria-live="polite">
        <div id="gearMobileResultsList" class="d-flex flex-column gap-2"></div>
        <div id="gearMobileResultsEmpty" class="gear-mobile-empty alert alert-light border text-muted mb-0">
            No matching gear found.
        </div>
        <div id="gearMobilePagination" class="gear-mobile-pagination d-none">
            <button type="button" class="btn btn-sm btn-outline-secondary" id="gearMobilePrevPage">Previous</button>
            <span id="gearMobilePageInfo" class="gear-mobile-page-info">Page 1 of 1</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="gearMobileNextPage">Next</button>
        </div>
    </div>

    <div class="card gear-results-card">
        <div class="card-body">
            <div class="gear-table-wrap">
                <table id="gearTable" class="table table-striped table-bordered w-100">
                    <thead>
                        <tr>
                            <th class="d-none">Name</th>
                            <th>Element</th>
                            <th><nobr>Pot. %</nobr></th>
                            <th>Stats</th>
                            <th>Range</th>
                            <th>Type</th>
                            <th>Effects</th>
                            <th>R. Abilities</th>
                            <th>Sigils</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var weapon in Model.Weapons)
                    {
                        var costumeNoAbility = string.Equals(weapon.EquipmentType, "Costume", StringComparison.OrdinalIgnoreCase)
                            && string.IsNullOrWhiteSpace(weapon.AbilityText)
                            && !weapon.EffectTags.Any();
                        var abilityMarkup = !string.IsNullOrWhiteSpace(weapon.AbilityText)
                            ? $"<div>{System.Net.WebUtility.HtmlEncode(weapon.AbilityText).Replace("\r\n", "<br />").Replace("\n", "<br />")}</div>"
                            : "<span class=\"text-muted\">No ability data</span>";
                        var atbMarkup = $"<div class=\"ability-meta\">ATB Cost: {weapon.CommandAtb}</div>";
                        var rechargeMarkup = !string.IsNullOrWhiteSpace(weapon.RechargeTime)
                            ? $"<div class=\"ability-meta\">Recharge: {System.Net.WebUtility.HtmlEncode(weapon.RechargeTime)}</div>"
                            : string.Empty;
                        var useCountMarkup = !string.IsNullOrWhiteSpace(weapon.UseCount)
                            ? $"<div class=\"ability-meta\">Uses: {weapon.UseCount}</div>"
                            : string.Empty;
                        var displayElement = costumeNoAbility ? "N/A" : weapon.Element;
                        var displayElementIconPath = GetElementIconPath(displayElement);
                        var displayAbilityType = costumeNoAbility ? "N/A" : weapon.AbilityType;
                        <tr data-weapon-id="@weapon.Id" data-character="@weapon.Character" data-equipment="@weapon.EquipmentType" data-weapon="@weapon.Name" data-element="@displayElement" data-ability-type="@displayAbilityType" data-item-image-url="@weapon.ImageUrl" data-item-preview-image-url="@weapon.PreviewImageUrl" data-has-customizations="@weapon.Customizations.Any().ToString().ToLowerInvariant()" data-has-details="@((!string.IsNullOrWhiteSpace(weapon.AbilityText) || weapon.Customizations.Any()).ToString().ToLowerInvariant())" data-sigils="@string.Join(" ", weapon.Sigils.Select(s => s.SigilType).Distinct())" data-subr="@string.Join(" ", weapon.SubRAbilityTags.Select(t => t.Key).Distinct(StringComparer.OrdinalIgnoreCase))">
                            <td class="d-none">@weapon.Name</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(displayElementIconPath))
                                {
                                    <span class="element-stack">
                                        <span class="element-stack-item">
                                            <img class="element-stack-icon" src="@displayElementIconPath" alt="" aria-hidden="true" />
                                            <span class="element-stack-value">@displayElement</span>
                                        </span>
                                    </span>
                                }
                                else
                                {
                                    @displayElement
                                }
                                <span class="visually-hidden weapon-name-search">@weapon.Name</span>
                            </td>
                            <td>
                                @if (costumeNoAbility)
                                {
                                    @:N/A
                                }
                                else
                                {
                                    <span class="potency-cell">@string.Format("{0:N1}%", weapon.DamagePercent)</span>
                                }
                            </td>
                            <td class="stats-cell">
                                @if (costumeNoAbility)
                                {
                                    <span class="text-muted">N/A</span>
                                }
                                else
                                {
                                    <div class="stat-stack" title="Lv. @weapon.MaxLevel / OB10">
                                        <span class="stat-stack-item">
                                            <img class="stat-stack-icon" src="/images/ui_icon_parameter_buff_physical_attack.png" alt="Physical attack" />
                                            <span class="stat-stack-value">@weapon.PatkAtMaxLevel.ToString("N0")</span>
                                        </span>
                                        <span class="stat-stack-item">
                                            <img class="stat-stack-icon" src="/images/ui_icon_parameter_buff_magical_attack.png" alt="Magical attack" />
                                            <span class="stat-stack-value">@weapon.MatkAtMaxLevel.ToString("N0")</span>
                                        </span>
                                        <span class="stat-stack-item">
                                            <img class="stat-stack-icon" src="/images/ui_icon_parameter_buff_heal.png" alt="Heal" />
                                            <span class="stat-stack-value">@weapon.HealAtMaxLevel.ToString("N0")</span>
                                        </span>
                                    </div>
                                }
                            </td>
                            <td>@(costumeNoAbility ? "N/A" : weapon.Range)</td>
                            <td>@displayAbilityType</td>
                            <td class="effects-cell">
                                @if (weapon.EffectTags.Any())
                                {
                                    <span>@string.Join(", ", weapon.EffectTags)</span>
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </td>
                            <td class="rabilities-cell">
                                @if (weapon.MaxPassiveSkills.Any())
                                {
                                    <ul class="list-unstyled small mb-0">
                                        @foreach (var passive in weapon.MaxPassiveSkills)
                                        {
                                            var passiveEffectLines = passive.Effects
                                                .Select(e => e.Description)
                                                .Where(s => !string.IsNullOrWhiteSpace(s))
                                                .ToList();
                                            var passiveHoverText = passiveEffectLines.Count > 0
                                                ? string.Join(" | ", passiveEffectLines)
                                                : "No effect details";
                                            <li>
                                                <span class="rability-hoverable" tabindex="0" role="button" aria-label="Show passive effect details" data-rability-effects="@passiveHoverText"><strong>+@passive.TotalPoints</strong> @passive.SkillName</span>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <span class="text-muted">No OB data</span>
                                }
                                @{
                                    var custRAbilities = weapon.Customizations
                                        .Where(c => c.Kind == "R Ability")
                                        .Select(c =>
                                        {
                                            var passiveName = !string.IsNullOrWhiteSpace(c.PassiveSkillName)
                                                ? c.PassiveSkillName!
                                                : (c.Description.StartsWith(custRAbilityPrefix)
                                                    ? c.Description.Substring(custRAbilityPrefix.Length)
                                                    : c.Description);
                                            var passiveEffectLines = c.PassiveEffects
                                                .Select(e => e.Description)
                                                .Where(s => !string.IsNullOrWhiteSpace(s))
                                                .ToList();
                                            var passiveHoverText = passiveEffectLines.Count > 0
                                                ? string.Join(" | ", passiveEffectLines)
                                                : "No effect details";
                                            return new
                                            {
                                                Name = passiveName,
                                                Points = c.PassiveSkillPoints,
                                                HoverText = passiveHoverText
                                            };
                                        })
                                        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                        .ToList();
                                }
                                @if (custRAbilities.Any())
                                {
                                    <ul class="list-unstyled small mb-0 cust-rability-list">
                                        @foreach (var passive in custRAbilities)
                                        {
                                            <li>
                                                <span class="cust-rability-badge">Cust.</span>
                                                <span class="rability-hoverable" tabindex="0" role="button" aria-label="Show passive effect details" data-rability-effects="@passive.HoverText">
                                                    @if (passive.Points > 0)
                                                    {
                                                        <strong>+@passive.Points</strong>
                                                    }
                                                    @passive.Name
                                                </span>
                                            </li>
                                        }
                                    </ul>
                                }
                                <div class="ability-template d-none">
                                    @Html.Raw(abilityMarkup)
                                    @Html.Raw(atbMarkup)
                                    @Html.Raw(rechargeMarkup)
                                    @Html.Raw(useCountMarkup)
                                </div>
                                @if (weapon.Customizations.Any())
                                {
                                    <div class="customization-template d-none">
                                        @foreach (var customization in weapon.Customizations)
                                        {
                                            <div class="customization-entry">
                                                <span class="customization-slot">@customization.Slot</span>
                                                <span class="customization-kind">@customization.Kind</span>
                                                <span class="customization-description">@customization.Description</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </td>
                            <td>
                                @if (weapon.Sigils.Any())
                                {
                                    <div class="sigil-badges">
                                        @foreach (var sigil in weapon.Sigils)
                                        {
                                            var sigilClass = sigil.SigilType.ToLowerInvariant();
                                            var sourceClass = sigil.Source == "Command" ? "sigil-cmd" : "sigil-mat";
                                            var sigilIconPath = GetSigilIconPath(sigil.SigilType);
                                            var levelLabel = GetSigilLevelLabel(sigil.Level);
                                            @if (sigil.Source == "Command")
                                            {
                                                <span class="sigil-badge sigil-@sigilClass @sourceClass" title="@sigil.SigilType Sigil (Command)">
                                                    @if (!string.IsNullOrWhiteSpace(sigilIconPath))
                                                    {
                                                        <img class="sigil-badge-icon" src="@sigilIconPath" alt="" aria-hidden="true" />
                                                    }
                                                    else
                                                    {
                                                        <span>@sigil.SigilSymbol</span>
                                                    }
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="sigil-badge sigil-@sigilClass @sourceClass" title="@sigil.SigilType Sigil Boost @levelLabel (Materia)">
                                                    @if (!string.IsNullOrWhiteSpace(sigilIconPath))
                                                    {
                                                        <img class="sigil-badge-icon" src="@sigilIconPath" alt="" aria-hidden="true" />
                                                    }
                                                    else
                                                    {
                                                        <span>@sigil.SigilSymbol</span>
                                                    }
                                                    <span class="sigil-badge-level">@levelLabel</span>
                                                </span>
                                            }
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">&mdash;</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="gear-table-mobile-hint">Swipe horizontally to see all columns</div>
        </div>
    </div>
    <div class="sigil-legend">
        <span class="fw-semibold text-muted me-1">Sigil Legend:</span>
        <span class="sigil-legend-item">
            <span class="sigil-badge sigil-circle sigil-cmd">
                <img class="sigil-badge-icon" src="@GetSigilIconPath("Circle")" alt="" aria-hidden="true" />
            </span>
            <span>Command Ability (solid border)</span>
        </span>
        <span class="sigil-legend-item">
            <span class="sigil-badge sigil-circle sigil-mat">
                <img class="sigil-badge-icon" src="@GetSigilIconPath("Circle")" alt="" aria-hidden="true" />
                <span class="sigil-badge-level">I</span>
            </span>
            <span>Materia Support (dashed border)</span>
        </span>
    </div>
</div>

