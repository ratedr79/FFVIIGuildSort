@page
@model FFVIIEverCrisisAnalyzer.Pages.GearSearchModel
@{
    ViewData["Title"] = "Gear Search";

    var elementOptions = Model.Weapons
        .Select(w => w.Element)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var rangeOptions = Model.Weapons
        .Select(w => w.Range)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var abilityTypeOptions = Model.Weapons
        .Select(w => w.AbilityType)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var equipmentTypeOptions = Model.Weapons
        .Select(w => w.EquipmentType)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var rAbilityOptions = Model.Weapons
        .SelectMany(w => w.MaxPassiveSkills.Select(p => p.SkillName))
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    var effectOptions = Model.Weapons
        .SelectMany(w => w.EffectTags)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();
}

<style>
    #gearTable {
        table-layout: fixed;
        width: 100%;
    }

    #gearTable th,
    #gearTable td {
        white-space: normal;
        vertical-align: middle;
    }

    .weapon-banner-row td {
        background: linear-gradient(90deg, rgba(92, 29, 155, 0.08), rgba(92, 29, 155, 0.02));
        border: 0;
        padding: 0.65rem 1rem 0.35rem;
    }

    .weapon-banner {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: baseline;
        font-size: 0.95rem;
        text-transform: none;
    }

    .weapon-banner-character {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: #6c5a8d;
        text-transform: uppercase;
    }

    .weapon-banner-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: #3a2758;
    }

    .weapon-banner-equipment {
        font-size: 0.85rem;
        color: #8d79b7;
    }

    .advanced-toggle-btn {
        background-color: #ffffff;
        color: #5c1d9b;
        border-color: rgba(92, 29, 155, 0.3);
        font-weight: 600;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
    }

    .advanced-toggle-btn:hover,
    .advanced-toggle-btn:focus {
        background-color: #f5ecff;
        color: #4a147a;
        border-color: rgba(92, 29, 155, 0.5);
    }

    .stat-stack {
        line-height: 1.2;
    }

    .weapon-name-cell .weapon-meta {
        font-size: 0.85rem;
        color: #7a7194;
    }

    .weapon-name-cell .weapon-character {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: #8b7bb5;
        text-transform: uppercase;
    }

    .ability-detail-row {
        background-color: #f9f5ff;
        border-left: 3px solid #b28bff;
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        line-height: 1.4;
    }

    .ability-detail-row .ability-meta {
        font-size: 0.85rem;
        color: #6c5a8d;
        margin-top: 0.25rem;
    }

    .customization-detail-row {
        background-color: #fff9f2;
        border-left: 3px solid #f4b183;
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 0.65rem 1rem;
        font-size: 0.92rem;
        line-height: 1.4;
    }

    .customization-entry {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 0.75rem;
        align-items: baseline;
        margin-bottom: 0.35rem;
    }

    .customization-entry:last-child {
        margin-bottom: 0;
    }

    .customization-slot {
        font-size: 0.75rem;
        font-weight: 700;
        color: #ad6e2f;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .customization-kind {
        font-weight: 600;
        color: #6f4c1f;
    }

    .customization-description {
        flex: 1 1 100%;
        color: #4a3c2c;
    }
</style>

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Gear Search</h1>
            <p class="text-muted mb-0">Browse all weapons with passive skills and filters.</p>
        </div>
        <a class="btn btn-outline-primary" href="https://cyphersignal.github.io/ff7ec/" target="_blank" rel="noopener">
            <i class="fas fa-arrow-up-right-from-square me-2"></i>Open original FF7EC Equipment Database
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label mb-1">Characters</label>
                    <div class="text-muted small mb-2">Check one or more characters to filter. Leave all unchecked to show everything.</div>
                    <div id="characterCheckboxGroup" class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2">
                        @foreach (var character in GearSearchModel.AvailableCharacters)
                        {
                            var checkboxId = $"character-{character.Replace(" ", "-").ToLowerInvariant()}";
                            <div class="col">
                                <div class="form-check">
                                    <input class="form-check-input character-checkbox" type="checkbox" value="@character" id="@checkboxId" />
                                    <label class="form-check-label" for="@checkboxId">@character</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <label for="searchBox" class="form-label">Search</label>
                    <input id="searchBox" type="text" class="form-control" placeholder="Search by weapon, ability, effects..." />
                </div>
                <div class="col-md-6 col-lg-4">
                    <label for="pageSize" class="form-label">Rows per page</label>
                    <select id="pageSize" class="form-select">
                        @foreach (var size in GearSearchModel.AvailablePageSizes)
                        {
                            if (Model.PageSize == size)
                            {
                                <option value="@size" selected>@size</option>
                            }
                            else
                            {
                                <option value="@size">@size</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Advanced Search</span>
            <button class="btn btn-sm advanced-toggle-btn" type="button" data-bs-toggle="collapse" data-bs-target="#advancedSearchCollapse" aria-expanded="false" aria-controls="advancedSearchCollapse">
                Toggle Filters
            </button>
        </div>
        <div class="collapse" id="advancedSearchCollapse">
            <div class="card-body">
                <div class="accordion" id="advancedFiltersAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingElement">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseElement" aria-expanded="false" aria-controls="collapseElement">
                                Element Type
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".element-filter">Reset</button>
                        </h2>
                        <div id="collapseElement" class="accordion-collapse collapse" aria-labelledby="headingElement" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var element in elementOptions)
                                    {
                                        var checkboxId = $"element-{element.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter element-filter" type="checkbox" value="@element" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@element</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingAbility">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAbility" aria-expanded="false" aria-controls="collapseAbility">
                                Ability Type
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".ability-filter">Reset</button>
                        </h2>
                        <div id="collapseAbility" class="accordion-collapse collapse" aria-labelledby="headingAbility" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var ability in abilityTypeOptions)
                                    {
                                        var checkboxId = $"ability-{ability.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter ability-filter" type="checkbox" value="@ability" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@ability</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingRange">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRange" aria-expanded="false" aria-controls="collapseRange">
                                Range Type
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".range-filter">Reset</button>
                        </h2>
                        <div id="collapseRange" class="accordion-collapse collapse" aria-labelledby="headingRange" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var range in rangeOptions)
                                    {
                                        var checkboxId = $"range-{range.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter range-filter" type="checkbox" value="@range" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@range</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingEquipment">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEquipment" aria-expanded="false" aria-controls="collapseEquipment">
                                Equipment Type
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".equipment-filter">Reset</button>
                        </h2>
                        <div id="collapseEquipment" class="accordion-collapse collapse" aria-labelledby="headingEquipment" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var type in equipmentTypeOptions)
                                    {
                                        var checkboxId = $"equipment-{type.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter equipment-filter" type="checkbox" value="@type" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@type</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingRAbilities">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRAbilities" aria-expanded="false" aria-controls="collapseRAbilities">
                                R Abilities
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".rability-filter">Reset</button>
                        </h2>
                        <div id="collapseRAbilities" class="accordion-collapse collapse" aria-labelledby="headingRAbilities" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body" style="max-height: 320px; overflow-y: auto;">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var passive in rAbilityOptions)
                                    {
                                        var checkboxId = $"rability-{passive.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter rability-filter" type="checkbox" value="@passive" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@passive</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header d-flex align-items-center justify-content-between" id="headingEffects">
                            <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEffects" aria-expanded="false" aria-controls="collapseEffects">
                                Effects
                            </button>
                            <button type="button" class="btn btn-sm btn-link text-decoration-none reset-filter" data-filter-target=".effect-filter">Reset</button>
                        </h2>
                        <div id="collapseEffects" class="accordion-collapse collapse" aria-labelledby="headingEffects" data-bs-parent="#advancedFiltersAccordion">
                            <div class="accordion-body" style="max-height: 320px; overflow-y: auto;">
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @foreach (var effect in effectOptions)
                                    {
                                        var checkboxId = $"effect-{effect.Replace(" ", "-").Replace("/", "-").ToLowerInvariant()}";
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input advanced-filter effect-filter" type="checkbox" value="@effect" id="@checkboxId" />
                                                <label class="form-check-label" for="@checkboxId">@effect</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <table id="gearTable" class="table table-striped table-bordered w-100">
                <thead>
                    <tr>
                        <th>Element</th>
                        <th>Damage %</th>
                        <th>PATK, MATK, Heal</th>
                        <th>Range</th>
                        <th>Type</th>
                        <th>Effects</th>
                        <th>R. Abilities (Lv. 130/OB 10)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var weapon in Model.Weapons)
                    {
                        <tr data-character="@weapon.Character" data-equipment="@weapon.EquipmentType" data-weapon="@weapon.Name">
                            @{
                                var costumeNoAbility = weapon.EquipmentType.Equals("Costume", System.StringComparison.OrdinalIgnoreCase) && string.IsNullOrWhiteSpace(weapon.AbilityText);
                                var abilityMarkup = !string.IsNullOrWhiteSpace(weapon.AbilityText)
                                    ? weapon.AbilityText.Replace("\r\n", "<br />").Replace("\n", "<br />")
                                    : "<span class=\"text-muted\">No ability data</span>";
                                var rechargeMarkup = !string.IsNullOrWhiteSpace(weapon.RechargeTime)
                                    ? $"<div class=\"ability-meta\">Recharge: {weapon.RechargeTime}</div>"
                                    : string.Empty;
                                var useCountMarkup = !string.IsNullOrWhiteSpace(weapon.UseCount)
                                    ? $"<div class=\"ability-meta\">Uses: {weapon.UseCount}</div>"
                                    : string.Empty;
                            }
                            <td>
                                @(costumeNoAbility ? "N/A" : weapon.Element)
                                <span class="visually-hidden weapon-name-search">@weapon.Name</span>
                            </td>
                            <td>
                                @if (costumeNoAbility)
                                {
                                    @:N/A
                                }
                                else
                                {
                                    @string.Format("{0:N1}%", weapon.DamagePercent)
                                }
                            </td>
                            <td>
                                @if (costumeNoAbility)
                                {
                                    @:N/A
                                }
                                else
                                {
                                    <div class="stat-stack">
                                        <div>@string.Format("PATK {0:N0}", weapon.PatkOb10Lv130)</div>
                                        <div>@string.Format("MATK {0:N0}", weapon.MatkOb10Lv130)</div>
                                        <div>@string.Format("Heal {0:N0}", weapon.HealOb10Lv130)</div>
                                    </div>
                                }
                            </td>
                            <td>@(costumeNoAbility ? "N/A" : weapon.Range)</td>
                            <td>@(costumeNoAbility ? "N/A" : weapon.AbilityType)</td>
                            <td>
                                @if (weapon.EffectTags.Any())
                                {
                                    <span>@string.Join(", ", weapon.EffectTags)</span>
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </td>
                            <td>
                                @if (weapon.MaxPassiveSkills.Any())
                                {
                                    <ul class="list-unstyled small mb-0">
                                        @foreach (var passive in weapon.MaxPassiveSkills)
                                        {
                                            <li>
                                                <strong>+@passive.TotalPoints</strong> @passive.SkillName
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <span class="text-muted">No OB data</span>
                                }
                                <div class="ability-template d-none">
                                    @Html.Raw(abilityMarkup)
                                    @Html.Raw(rechargeMarkup)
                                    @Html.Raw(useCountMarkup)
                                </div>
                                @if (weapon.Customizations.Any())
                                {
                                    <div class="customization-template d-none">
                                        @foreach (var customization in weapon.Customizations)
                                        {
                                            <div class="customization-entry">
                                                <span class="customization-slot">@customization.Slot</span>
                                                <span class="customization-kind">@customization.Kind</span>
                                                <span class="customization-description">@customization.Description</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tableElement = document.getElementById('gearTable');
            const selectedCharacters = new Set();
            const selectedEquipmentTypes = new Set();

            const table = new DataTable(tableElement, {
                pageLength: @Model.PageSize,
                lengthChange: false,
                order: [[0, 'asc']],
                dom: 'lrtip'
            });

            DataTable.ext.search.push(function (settings, data, dataIndex) {
                if (settings.nTable !== tableElement) {
                    return true;
                }

                const rowNode = table.row(dataIndex).node();
                const rowCharacter = rowNode.getAttribute('data-character') ?? '';
                const rowEquipment = rowNode.getAttribute('data-equipment') ?? '';

                const characterMatch = selectedCharacters.size === 0 || selectedCharacters.has(rowCharacter);
                const equipmentMatch = selectedEquipmentTypes.size === 0 || selectedEquipmentTypes.has(rowEquipment);

                return characterMatch && equipmentMatch;
            });

            const searchBox = document.getElementById('searchBox');
            searchBox.addEventListener('keyup', (e) => table.search(e.target.value).draw());

            const pageSizeSelect = document.getElementById('pageSize');
            pageSizeSelect.addEventListener('change', (e) => table.page.len(parseInt(e.target.value, 10)).draw());

            const escapeRegex = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            const updateCharacterFilter = () => {
                selectedCharacters.clear();
                document.querySelectorAll('.character-checkbox:checked').forEach(cb => selectedCharacters.add(cb.value));
                table.draw();
            };

            document.getElementById('characterCheckboxGroup')
                .addEventListener('change', (event) => {
                    if (event.target && event.target.classList.contains('character-checkbox')) {
                        updateCharacterFilter();
                    }
                });

            const advancedFilters = [
                { selector: '.element-filter', columnIndex: 0 },
                { selector: '.range-filter', columnIndex: 3 },
                { selector: '.ability-filter', columnIndex: 4 },
                { selector: '.effect-filter', columnIndex: 5 },
                { selector: '.rability-filter', columnIndex: 6 }
            ];

            const applyAdvancedFilter = (selector, columnIndex) => {
                const selected = Array.from(document.querySelectorAll(`${selector}:checked`)).map(cb => cb.value);
                if (selected.length === 0) {
                    table.column(columnIndex).search('', true, false).draw();
                    return;
                }

                const pattern = selected
                    .map(value => escapeRegex(value))
                    .join('|');

                table.column(columnIndex).search(pattern, true, false).draw();
            };

            advancedFilters.forEach(group => {
                document.querySelectorAll(group.selector).forEach(cb => {
                    cb.addEventListener('change', () => applyAdvancedFilter(group.selector, group.columnIndex));
                });
            });

            const updateEquipmentFilter = () => {
                selectedEquipmentTypes.clear();
                document.querySelectorAll('.equipment-filter:checked').forEach(cb => selectedEquipmentTypes.add(cb.value));
                table.draw();
            };

            document.querySelectorAll('.equipment-filter').forEach(cb => {
                cb.addEventListener('change', updateEquipmentFilter);
            });

            document.querySelectorAll('.reset-filter').forEach(button => {
                button.addEventListener('click', () => {
                    const targetSelector = button.getAttribute('data-filter-target');
                    if (!targetSelector) {
                        return;
                    }

                    document.querySelectorAll(`${targetSelector}:checked`).forEach(cb => cb.checked = false);
                    const filterGroup = advancedFilters.find(group => group.selector === targetSelector);
                    if (filterGroup) {
                        applyAdvancedFilter(filterGroup.selector, filterGroup.columnIndex);
                    }

                    if (targetSelector === '.character-checkbox') {
                        updateCharacterFilter();
                    }

                    if (targetSelector === '.equipment-filter') {
                        updateEquipmentFilter();
                    }
                });
            });

            const renderDetailRows = () => {
                table.rows({ page: 'current' }).every(function () {
                    const rowNode = this.node();
                    const template = rowNode.querySelector('.ability-template');
                    const customizationTemplate = rowNode.querySelector('.customization-template');

                    const abilityHtml = template ? template.innerHTML.trim() : '';
                    const customizationHtml = customizationTemplate ? customizationTemplate.innerHTML.trim() : '';

                    if (!abilityHtml && !customizationHtml) {
                        if (this.child && this.child.isShown()) {
                            this.child.hide();
                        }
                        return;
                    }

                    const sections = [];
                    if (abilityHtml) {
                        sections.push(`<div class="ability-detail-row">
                            <div class="text-uppercase text-muted small mb-2">Ability</div>
                            ${abilityHtml}
                        </div>`);
                    }

                    if (customizationHtml) {
                        sections.push(`<div class="customization-detail-row">
                            <div class="text-uppercase text-muted small mb-2">Customizations</div>
                            ${customizationHtml}
                        </div>`);
                    }

                    const content = `<div class="detail-wrapper">${sections.join('')}</div>`;
                    this.child(content).show();
                });
            };

            const renderBannerRows = () => {
                document.querySelectorAll('#gearTable tbody tr.weapon-banner-row').forEach(row => row.remove());
                const columnCount = table.columns().count();

                table.rows({ page: 'current' }).every(function () {
                    const rowNode = this.node();
                    const character = rowNode.getAttribute('data-character') ?? '';
                    const weapon = rowNode.getAttribute('data-weapon') ?? '';
                    const equipment = rowNode.getAttribute('data-equipment') ?? '';

                    const bannerRow = document.createElement('tr');
                    bannerRow.classList.add('weapon-banner-row');

                    const bannerCell = document.createElement('td');
                    bannerCell.colSpan = columnCount;
                    bannerCell.innerHTML = `
                        <div class="weapon-banner">
                            <span class="weapon-banner-character">${character}</span>
                            <span class="weapon-banner-name">${weapon}</span>
                            <span class="weapon-banner-equipment">${equipment}</span>
                        </div>`;
                    bannerRow.appendChild(bannerCell);

                    rowNode.parentNode?.insertBefore(bannerRow, rowNode);
                });
            };

            const renderDecorations = () => {
                renderBannerRows();
                renderDetailRows();
            };

            updateCharacterFilter();
            updateEquipmentFilter();
            renderDecorations();
            table.on('draw', renderDecorations);
        });
    </script>
}
