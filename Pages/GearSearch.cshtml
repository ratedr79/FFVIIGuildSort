<div class="modal fade" id="buffDebuffNotesModal" tabindex="-1" aria-labelledby="buffDebuffNotesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="buffDebuffNotesModalLabel">Buff / Debuff Notes</h5>
