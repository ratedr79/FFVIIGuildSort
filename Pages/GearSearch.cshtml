                    </div>

                    <div class="col-12 col-md-3 col-lg-2">
                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" id="hasCustomizationsFilter" />
                            <label class="form-check-label" for="hasCustomizationsFilter">
                                Has Customizations
                            </label>
                        </div>
                    </div>
                </div>

                <div class="advanced-mobile-actions d-lg-none">
                    <button type="button" class="btn btn-outline-secondary" id="mobileClearFiltersBtn">Clear Filters</button>
                    <button type="button" class="btn btn-primary" id="mobileApplyFiltersBtn">Apply & Close</button>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-2">
        <div id="resultsSummary" class="results-summary">Showing 0 of 0 items</div>
        <div id="activeFiltersWrap" class="active-filters-wrap d-none">
            <span class="active-filters-label">Active Filters</span>
            <div id="activeFilterChips" class="active-filter-chips"></div>
            <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none" id="clearAllFiltersBtn">Clear all</button>
        </div>
    </div>

    <div class="card mb-2 sticky-compare-panel" id="comparePanel">
        <div class="card-body d-flex flex-wrap align-items-center gap-2">
            <span class="fw-semibold text-muted">Compare:</span>
            <span id="compareCount" class="small text-muted">0 items selected</span>
            <span id="compareNames" class="d-flex flex-wrap gap-1"></span>
            <div class="ms-auto d-flex gap-2">
                <button class="btn btn-sm btn-outline-danger" id="compareClearBtn" disabled>Clear</button>
                <button class="btn btn-sm btn-primary" id="compareOpenBtn" disabled>Compare Items</button>
            </div>
        </div>
    </div>

    <div id="gearMobileResults" class="gear-mobile-results mb-3" aria-live="polite">
        <div id="gearMobileResultsList" class="d-flex flex-column gap-2"></div>
        <div id="gearMobileResultsEmpty" class="gear-mobile-empty alert alert-light border text-muted mb-0">
            No matching gear found.
        </div>
        <div id="gearMobilePagination" class="gear-mobile-pagination d-none">
            <button type="button" class="btn btn-sm btn-outline-secondary" id="gearMobilePrevPage">Previous</button>
            <span id="gearMobilePageInfo" class="gear-mobile-page-info">Page 1 of 1</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="gearMobileNextPage">Next</button>
        </div>
    </div>

    <div class="card gear-results-card">
        <div class="card-body">
            <div class="gear-table-wrap">
                <table id="gearTable" class="table table-striped table-bordered w-100">
                    <thead>
                        <tr>
                            <th class="d-none">Name</th>
                            <th>Element</th>
                            <th><nobr>Pot. %</nobr></th>
                            <th>Stats</th>
                            <th>Range</th>
                            <th>Type</th>
                            <th>Effects</th>
                            <th>R. Abilities</th>
                            <th>Sigils</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var weapon in Model.Weapons)
                    {
                        <tr data-weapon-id="@weapon.Id" data-character="@weapon.Character" data-equipment="@weapon.EquipmentType" data-weapon="@weapon.Name" data-has-customizations="@weapon.Customizations.Any().ToString().ToLowerInvariant()" data-has-details="@((!string.IsNullOrWhiteSpace(weapon.AbilityText) || weapon.Customizations.Any()).ToString().ToLowerInvariant())" data-sigils="@string.Join(" ", weapon.Sigils.Select(s => s.SigilType).Distinct())" data-subr="@string.Join(" ", weapon.SubRAbilityTags.Select(t => t.Key).Distinct(StringComparer.OrdinalIgnoreCase))">
                            @{
                                var costumeNoAbility = weapon.EquipmentType.Equals("Costume", System.StringComparison.OrdinalIgnoreCase) && string.IsNullOrWhiteSpace(weapon.AbilityText);
                                var abilityMarkup = !string.IsNullOrWhiteSpace(weapon.AbilityText)
                                    ? weapon.AbilityText.Replace("\r\n", "<br />").Replace("\n", "<br />")
                                    : "<span class=\"text-muted\">No ability data</span>";
                                var rechargeMarkup = !string.IsNullOrWhiteSpace(weapon.RechargeTime)
                                    ? $"<div class=\"ability-meta\">Recharge: {weapon.RechargeTime}</div>"
                                    : string.Empty;
                                var useCountMarkup = !string.IsNullOrWhiteSpace(weapon.UseCount)
                                    ? $"<div class=\"ability-meta\">Uses: {weapon.UseCount}</div>"
                                    : string.Empty;
                            }
                            <td class="d-none">@weapon.Name</td>
                            <td>
                                @(costumeNoAbility ? "N/A" : weapon.Element)
                                <span class="visually-hidden weapon-name-search">@weapon.Name</span>
                            </td>
                            <td>
                                @if (costumeNoAbility)
                                {
                                    @:N/A
                                }
                                else
                                {
                                    @string.Format("{0:N1}%", weapon.DamagePercent)
                                }
                            </td>
                            <td>
                                @if (costumeNoAbility)
                                {
                                    @:N/A
                                }
                                else
                                {
                                    <div class="stat-stack">
                                        <div><nobr>@string.Format("P: {0:N0}", weapon.PatkOb10Lv130)</nobr></div>
                                        <div><nobr>@string.Format("M: {0:N0}", weapon.MatkOb10Lv130)</nobr></div>
                                        <div><nobr>@string.Format("H: {0:N0}", weapon.HealOb10Lv130)</nobr></div>
                                    </div>
                                }
                            </td>
                            <td>@(costumeNoAbility ? "N/A" : weapon.Range)</td>
                            <td>@(costumeNoAbility ? "N/A" : weapon.AbilityType)</td>
                            <td class="effects-cell">
                                @if (weapon.EffectTags.Any())
                                {
                                    <span>@string.Join(", ", weapon.EffectTags)</span>
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </td>
                            <td class="rabilities-cell">
                                @if (weapon.MaxPassiveSkills.Any())
                                {
                                    <ul class="list-unstyled small mb-0">
                                        @foreach (var passive in weapon.MaxPassiveSkills)
                                        {
                                            var passiveEffectLines = passive.Effects
                                                .Select(e => e.Description)
                                                .Where(s => !string.IsNullOrWhiteSpace(s))
                                                .ToList();
                                            var passiveHoverText = passiveEffectLines.Count > 0
                                                ? string.Join(" | ", passiveEffectLines)
                                                : "No effect details";
                                            <li>
                                                <span class="rability-hoverable" tabindex="0" role="button" aria-label="Show passive effect details" data-rability-effects="@passiveHoverText"><strong>+@passive.TotalPoints</strong> @passive.SkillName</span>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <span class="text-muted">No OB data</span>
                                }
                                @{
                                    var custRAbilities = weapon.Customizations
                                        .Where(c => c.Kind == "R Ability")
                                        .Select(c =>
                                        {
                                            var passiveName = !string.IsNullOrWhiteSpace(c.PassiveSkillName)
                                                ? c.PassiveSkillName!
                                                : (c.Description.StartsWith(custRAbilityPrefix)
                                                    ? c.Description.Substring(custRAbilityPrefix.Length)
                                                    : c.Description);
                                            var passiveEffectLines = c.PassiveEffects
                                                .Select(e => e.Description)
                                                .Where(s => !string.IsNullOrWhiteSpace(s))
                                                .ToList();
                                            var passiveHoverText = passiveEffectLines.Count > 0
                                                ? string.Join(" | ", passiveEffectLines)
                                                : "No effect details";
                                            return new
                                            {
                                                Name = passiveName,
                                                Points = c.PassiveSkillPoints,
                                                HoverText = passiveHoverText
                                            };
                                        })
                                        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                        .ToList();
                                }
                                @if (custRAbilities.Any())
                                {
                                    <ul class="list-unstyled small mb-0 cust-rability-list">
                                        @foreach (var passive in custRAbilities)
                                        {
                                            <li>
                                                <span class="cust-rability-badge">Cust.</span>
                                                <span class="rability-hoverable" tabindex="0" role="button" aria-label="Show passive effect details" data-rability-effects="@passive.HoverText">
                                                    @if (passive.Points > 0)
                                                    {
                                                        <strong>+@passive.Points</strong>
                                                    }
                                                    @passive.Name
                                                </span>
                                            </li>
                                        }
                                    </ul>
                                }
                                <div class="ability-template d-none">
                                    @Html.Raw(abilityMarkup)
                                    @Html.Raw(rechargeMarkup)
                                    @Html.Raw(useCountMarkup)
                                </div>
                                @if (weapon.Customizations.Any())
                                {
                                    <div class="customization-template d-none">
                                        @foreach (var customization in weapon.Customizations)
                                        {
                                            <div class="customization-entry">
                                                <span class="customization-slot">@customization.Slot</span>
                                                <span class="customization-kind">@customization.Kind</span>
                                                <span class="customization-description">@customization.Description</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </td>
                            <td>
                                @if (weapon.Sigils.Any())
                                {
                                    <div class="sigil-badges">
                                        @foreach (var sigil in weapon.Sigils)
                                        {
                                            var sigilClass = sigil.SigilType.ToLowerInvariant();
                                            var sourceClass = sigil.Source == "Command" ? "sigil-cmd" : "sigil-mat";
                                            @if (sigil.Source == "Command")
                                            {
                                                <span class="sigil-badge sigil-@sigilClass @sourceClass" title="@sigil.SigilType Sigil (Command)">@sigil.SigilSymbol</span>
                                            }
                                            else
                                            {
                                                <span class="sigil-badge sigil-@sigilClass @sourceClass" title="@sigil.SigilType Sigil Boost @sigil.Level (Materia)">@sigil.SigilSymbol <small>×@sigil.Level</small></span>
                                            }
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">&mdash;</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="gear-table-mobile-hint">Swipe horizontally to see all columns</div>
        </div>
    </div>
    <div class="sigil-legend">
        <span class="fw-semibold text-muted me-1">Sigil Legend:</span>
        <span class="sigil-legend-item">
            <span class="sigil-badge sigil-circle sigil-cmd">◯</span>
            <span>Command Ability (solid border)</span>
        </span>
        <span class="sigil-legend-item">
            <span class="sigil-badge sigil-circle sigil-mat">◯ <small>×1</small></span>
            <span>Materia Support (dashed border)</span>
        </span>
    </div>
</div>

<!-- View Levels Modal -->
<div class="modal fade" id="viewLevelsModal" tabindex="-1" aria-labelledby="viewLevelsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="viewLevelsModalLabel">View Levels</h5>
                    <div class="snapshot-meta mt-1">
                        <span class="weapon-banner-character" id="snapshotCharacter"></span>
                        <span class="weapon-banner-name" id="snapshotWeaponName"></span>
                        <span class="weapon-banner-equipment" id="snapshotEquipment"></span>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <div class="col-sm-6" id="snapshotOverboostCol">
                        <label for="snapshotOverboost" class="form-label fw-semibold">Overboost</label>
                        <select id="snapshotOverboost" class="form-select">
