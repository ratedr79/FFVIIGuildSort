            <div class="modal-body">
                <div class="alert alert-light border mb-3 buff-notes-note">
                    Tier tables below cover buff/debuff families affected by buff/debuff extension. Named tiers can scale differently on allies versus enemies, so both target sides are listed separately.
                </div>

                @foreach (var referenceSection in buffDebuffReferenceSections)
                {
                    <section class="buff-notes-section">
                        <h6 class="fw-semibold mb-1">@referenceSection.Title</h6>
                        <div class="text-muted small mb-2">@referenceSection.Description</div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered buff-notes-table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Family</th>
                                        <th>Buff tiers</th>
                                        <th>Debuff tiers</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in referenceSection.Rows)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@row.Family</td>
                                            <td>
                                                <div class="buff-tier-list">
                                                    @foreach (var tier in BuildTierEntries(row.BuffTiers))
                                                    {
                                                        <div class="buff-tier-entry">
                                                            <span class="buff-tier-label-wrap">
                                                                <img class="buff-tier-icon" src="@GetTierImagePath(true, tier.Name)" alt="" aria-hidden="true" />
                                                                <span class="buff-tier-label">@tier.Name</span>
                                                            </span>
                                                            <span class="buff-tier-value">@tier.Value</span>
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                <div class="buff-tier-list">
                                                    @foreach (var tier in BuildTierEntries(row.DebuffTiers))
                                                    {
                                                        <div class="buff-tier-entry">
                                                            <span class="buff-tier-label-wrap">
                                                                <img class="buff-tier-icon" src="@GetTierImagePath(false, tier.Name)" alt="" aria-hidden="true" />
                                                                <span class="buff-tier-label">@tier.Name</span>
                                                            </span>
                                                            <span class="buff-tier-value">@tier.Value</span>
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }

                <section class="buff-notes-section mt-4">
                    <h6 class="fw-semibold mb-1">Status and Special-Case Notes</h6>
                    <div class="text-muted small mb-2">Unreleased or uncertain observations are preserved as notes rather than normalized away.</div>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered buff-notes-table mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Effect</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var note in buffDebuffStatusNotes)
                                {
                                    <tr>
                                        <td class="fw-semibold">@note.Effect</td>
                                        <td>@note.Notes</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>

