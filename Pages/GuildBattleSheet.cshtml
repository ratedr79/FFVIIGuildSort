@page
@model FFVIIEverCrisisAnalyzer.Pages.GuildBattleSheetModel
@{
    ViewData["Title"] = "Guild Battle Sheet";
    var sheet = Model.Sheet;
}

<div class="container mt-3 guild-battle-sheet-page">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-3 guild-sheet-page-header">
        <div>
            <h1 class="mb-1 guild-sheet-page-title"><i class="fas fa-scroll text-success"></i> Monthly Guild Battle Sheet</h1>
            <p class="text-muted mb-0 guild-sheet-page-subtitle">Featured-only weapon recommendations for the current guild battle element and damage type.</p>
        </div>
        @if (sheet != null)
        {
            <form method="get" class="row g-2 align-items-end guild-sheet-toolbar">
                <div class="col-auto">
                    <label class="form-label mb-1" for="battleId">Month</label>
                    <select class="form-select" id="battleId" name="id" onchange="this.form.submit()">
                        @foreach (var battle in sheet.AvailableBattles)
                        {
                            if (battle.Id == sheet.SelectedBattleSummary.Id)
                            {
                                <option value="@battle.Id" selected>@battle.DisplayLabel</option>
                            }
                            else
                            {
                                <option value="@battle.Id">@battle.DisplayLabel</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1" for="recommendationMode">Mode</label>
                    <select class="form-select" id="recommendationMode" name="mode" onchange="this.form.submit()">
                        @if (sheet.RecommendationMode == FFVIIEverCrisisAnalyzer.Models.GuildBattleSheetRecommendationMode.Traditional)
                        {
                            <option value="Traditional" selected>Traditional</option>
                        }
                        else
                        {
                            <option value="Traditional">Traditional</option>
                        }

                        @if (sheet.RecommendationMode == FFVIIEverCrisisAnalyzer.Models.GuildBattleSheetRecommendationMode.Character)
                        {
                            <option value="Character" selected>Character</option>
                        }
                        else
                        {
                            <option value="Character">Character</option>
                        }
                    </select>
                </div>
                <div class="col-auto form-check mt-4 pt-2">
                    <input class="form-check-input" type="checkbox" value="true" id="debugMode" name="debug" @(Model.Debug ? "checked" : null) onchange="this.form.submit()" />
                    <label class="form-check-label" for="debugMode">Debug mode</label>
                </div>
            </form>
        }
    </div>

    @if (!ViewContext.ModelState.IsValid)
    {
        <div class="alert alert-danger" role="alert">
            @foreach (var error in ViewContext.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    @if (sheet != null)
    {
        <div class="card shadow-sm border-0 battle-sheet-hero mb-3">
            <div class="card-body p-3 p-lg-4">
                <div class="d-flex flex-column flex-xl-row justify-content-between gap-3 align-items-xl-center">
                    <div>
                        <div class="text-uppercase small fw-semibold text-success-emphasis mb-2">Featured Pool Only</div>
                        <h2 class="mb-2">@sheet.SelectedBattle.Month @sheet.SelectedBattle.Year — @sheet.SelectedBattle.AbilityType @sheet.SelectedBattle.Element</h2>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="sheet-pill sheet-pill-strong">@sheet.SelectedBattle.AbilityType</span>
                            <span class="sheet-pill sheet-pill-neutral">@sheet.SelectedBattle.Element</span>
                            @if (!string.IsNullOrWhiteSpace(sheet.SelectedBattle.Rank))
                            {
                                <span class="sheet-pill sheet-pill-dark">@sheet.SelectedBattle.Rank</span>
                            }
                            <span class="sheet-pill sheet-pill-light">Generated @sheet.GeneratedAtUtc.ToLocalTime().ToString("g")</span>
                        </div>
                    </div>
                    <div class="hero-note-panel">
                        <div class="hero-note-title">Battle Focus</div>
                        <div class="hero-note-body">This sheet only surfaces <strong>Featured</strong> weapons from the shared Gear Search dataset, then ranks them for @sheet.SelectedBattle.AbilityType.ToLowerInvariant() @sheet.SelectedBattle.Element.ToLowerInvariant() guild battle value.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-xl-8">
                <div class="card shadow-sm border-0 h-100 guild-sheet-surface-card">
                    <div class="card-header bg-white border-0 px-3 px-lg-4 pt-3 pb-0 guild-sheet-card-header">
                        <div class="guild-sheet-card-kicker">Primary Loadout Picks</div>
                        <h3 class="mb-1 guild-sheet-card-title">Main Featured Recommendations</h3>
                        <p class="text-muted mb-0 guild-sheet-card-subtitle">@(sheet.RecommendationMode == FFVIIEverCrisisAnalyzer.Models.GuildBattleSheetRecommendationMode.Character
                            ? "Character mode anchors one featured recommendation per character, promoting true element/type DPS packages first and then support-style party or boss utility."
                            : "Traditional mode prioritizes pinned entries, matching element/type DPS, and utility tags like resist down, damage up, damage bonus, buffs, and Exploit Weakness.")</p>
                    </div>
                    <div class="card-body p-3 p-lg-4">
                        @if (sheet.MainRecommendations.Count == 0)
                        {
                            <p class="text-muted mb-0">No featured recommendations were generated for this month.</p>
                        }
                        else
                        {
                            <div class="row g-3">
                                @foreach (var entry in sheet.MainRecommendations)
                                {
                                    var packageLabel = sheet.RecommendationMode == FFVIIEverCrisisAnalyzer.Models.GuildBattleSheetRecommendationMode.Character
                                        ? entry.Highlights.FirstOrDefault(highlight => highlight.Equals("DPS Package", StringComparison.OrdinalIgnoreCase)
                                            || highlight.Equals("Support Package", StringComparison.OrdinalIgnoreCase)
                                            || highlight.Equals("Support Pivot", StringComparison.OrdinalIgnoreCase))
                                        : null;
                                    var packageSubtitle = packageLabel?.Equals("DPS Package", StringComparison.OrdinalIgnoreCase) == true
                                        ? "Battle-fit DPS anchor"
                                        : packageLabel?.Equals("Support Pivot", StringComparison.OrdinalIgnoreCase) == true
                                            ? "Support fallback for off-fit DPS"
                                            : packageLabel?.Equals("Support Package", StringComparison.OrdinalIgnoreCase) == true
                                                ? "Party support utility"
                                                : null;
                                    <div class="col-12 col-lg-6">
                                        <div class="recommendation-card h-100 @(entry.IsTopPick ? "recommendation-card-top-pick" : null)">
                                            <div class="d-flex gap-3 align-items-start">
                                                <button type="button" class="gear-thumb-button" data-bs-toggle="modal" data-bs-target="#previewModal" data-image-url="@entry.PreviewImageUrl" data-image-title="@entry.Name">
                                                    <img src="@entry.ImageUrl" alt="@entry.Name" class="gear-thumb" />
                                                </button>
                                                <div class="flex-grow-1">
                                                    <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                                                        <h4 class="h5 mb-0">@entry.Name</h4>
                                                        @if (entry.IsTopPick)
                                                        {
                                                            <span class="badge text-bg-warning">Top Pick</span>
                                                        }
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-secondary guild-sheet-view-levels-button btn-view-levels"
                                                                data-weapon-id="@entry.WeaponId"
                                                                data-character="@entry.Character"
                                                                data-weapon="@entry.Name"
                                                                data-equipment="@entry.EquipmentType"
                                                                data-element="@entry.Element"
                                                                data-ability-type="@entry.AbilityType"
                                                                data-image-url="@entry.ImageUrl"
                                                                data-preview-image-url="@entry.PreviewImageUrl"
                                                                data-has-customizations="@(entry.HasCustomizations ? "true" : "false")">
                                                            View Levels
                                                        </button>
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(packageLabel))
                                                    {
                                                        <div class="mb-2">
                                                            <span class="guild-sheet-package-badge @(packageLabel.Equals("DPS Package", StringComparison.OrdinalIgnoreCase) ? "guild-sheet-package-badge-dps" : packageLabel.Equals("Support Pivot", StringComparison.OrdinalIgnoreCase) ? "guild-sheet-package-badge-pivot" : "guild-sheet-package-badge-support")">@packageLabel</span>
                                                        </div>
                                                        @if (!string.IsNullOrWhiteSpace(packageSubtitle))
                                                        {
                                                            <div class="guild-sheet-package-subtitle">@packageSubtitle</div>
                                                        }
                                                    }
                                                    <div class="text-muted small mb-2">@entry.Character</div>
                                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                                        <span class="sheet-pill sheet-pill-light">@entry.Element</span>
                                                        <span class="sheet-pill sheet-pill-light">@entry.AbilityType</span>
                                                        <span class="sheet-pill sheet-pill-neutral">Score @entry.Score.ToString("0.#")</span>
                                                        @if (entry.DamagePercent > 0)
                                                        {
                                                            <span class="sheet-pill sheet-pill-light">@entry.DamagePercent.ToString("0.#")%</span>
                                                        }
                                                    </div>
                                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                                        @foreach (var highlight in entry.Highlights)
                                                        {
                                                            <span class="sheet-pill sheet-pill-highlight">@highlight</span>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(entry.InclusionSummary))
                                                    {
                                                        <div class="guild-sheet-inclusion-summary mb-2">@entry.InclusionSummary</div>
                                                    }
                                                    <div class="small text-body-secondary ability-snippet mb-2">@entry.AbilityText</div>
                                                    @if (entry.RelevantCustomizationDetails.Count > 0)
                                                    {
                                                        <div class="guild-sheet-customization-block mb-2">
                                                            <div class="guild-sheet-customization-title">Relevant customization</div>
                                                            <ul class="mb-0 ps-3 guild-sheet-customization-list">
                                                                @foreach (var customization in entry.RelevantCustomizationDetails)
                                                                {
                                                                    <li>@customization</li>
                                                                }
                                                            </ul>
                                                        </div>
                                                    }
                                                    @if (sheet.DebugMode && entry.MatchReasons.Count > 0)
                                                    {
                                                        <div class="debug-block small">
                                                            <div class="fw-semibold mb-1">Why this matched</div>
                                                            <ul class="mb-0 ps-3">
                                                                @foreach (var reason in entry.MatchReasons)
                                                                {
                                                                    <li>@reason</li>
                                                                }
                                                            </ul>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="card shadow-sm border-0 h-100 guild-sheet-surface-card">
                    <div class="card-header bg-white border-0 px-3 px-lg-4 pt-3 pb-0 guild-sheet-card-header">
                        <div class="guild-sheet-card-kicker">Quick Summary</div>
                        <h3 class="mb-1 guild-sheet-card-title">Write-Up</h3>
                        <p class="text-muted mb-0 guild-sheet-card-subtitle">@(sheet.UsesManualWriteup ? "Manual monthly notes" : "Auto-generated callouts from current featured matches")</p>
                    </div>
                    <div class="card-body p-3 p-lg-4">
                        @if (sheet.WriteupLines.Count == 0)
                        {
                            <p class="text-muted mb-0">No notes are available for this battle.</p>
                        }
                        else
                        {
                            <ul class="writeup-list mb-0">
                                @foreach (var line in sheet.WriteupLines)
                                {
                                    <li>@line</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-lg-6">
                @await Html.PartialAsync("_GuildBattleSheetSection", sheet.PotencySection)
            </div>
            <div class="col-lg-6">
                @await Html.PartialAsync("_GuildBattleSheetSection", sheet.SubWeaponSection)
            </div>
        </div>

        <div class="row g-3">
            <div class="col-lg-4">
                @await Html.PartialAsync("_GuildBattleSheetSection", sheet.ResistanceDownSection)
            </div>
            <div class="col-lg-4">
                @await Html.PartialAsync("_GuildBattleSheetSection", sheet.DamageUpSection)
            </div>
            <div class="col-lg-4">
                @await Html.PartialAsync("_GuildBattleSheetSection", sheet.DamageBonusSection)
            </div>
        </div>

        <div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="previewModalTitle">Preview</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center">
                        <img id="previewModalImage" src="" alt="Preview" class="img-fluid rounded shadow-sm" />
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="viewLevelsModal" tabindex="-1" aria-labelledby="viewLevelsModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content guild-sheet-snapshot-modal-content">
                    <div class="modal-header guild-sheet-snapshot-modal-header">
                        <div class="w-100">
                            <h5 class="modal-title" id="viewLevelsModalLabel">View Levels</h5>
                            <div class="guild-sheet-snapshot-header" id="snapshotHeader">
                                <div class="guild-sheet-snapshot-art-shell">
                                    <img id="snapshotItemArt" class="guild-sheet-snapshot-art" alt="" />
                                </div>
                                <div class="guild-sheet-snapshot-meta">
                                    <div class="guild-sheet-snapshot-character" id="snapshotCharacter"></div>
                                    <div class="guild-sheet-snapshot-name" id="snapshotWeaponName"></div>
                                    <div class="guild-sheet-snapshot-pills">
                                        <span class="sheet-pill sheet-pill-neutral" id="snapshotEquipment"></span>
                                        <span class="sheet-pill sheet-pill-light" id="snapshotElement"></span>
                                        <span class="sheet-pill sheet-pill-light" id="snapshotAbilityType"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6" id="snapshotOverboostCol">
                                <label for="snapshotOverboost" class="form-label fw-semibold">Overboost</label>
                                <select id="snapshotOverboost" class="form-select">
                                    <option value="0">5 Star</option>
                                    <option value="1">OB1</option>
                                    <option value="2">OB2</option>
                                    <option value="3">OB3</option>
                                    <option value="4">OB4</option>
                                    <option value="5">OB5</option>
                                    <option value="6">OB6</option>
                                    <option value="7">OB7</option>
                                    <option value="8">OB8</option>
                                    <option value="9">OB9</option>
                                    <option value="10" selected>OB10</option>
                                </select>
                                <div id="snapshotOverboostNa" class="form-control-plaintext text-muted d-none">N/A</div>
                                <div id="snapshotCustomizationUnlockHint" class="form-text text-muted d-none">Customizations unlock at Lv. 80.</div>
                            </div>
                            <div class="col-sm-6">
                                <label for="snapshotLevel" class="form-label fw-semibold">Level</label>
                                <div class="d-flex align-items-center gap-2">
                                    <input type="range" class="form-range flex-grow-1" id="snapshotLevelRange" min="1" max="@Model.UiMaxWeaponLevel" value="@Model.DefaultWeaponLevel" />
                                    <input type="number" class="form-control" id="snapshotLevel" min="1" max="@Model.UiMaxWeaponLevel" value="@Model.DefaultWeaponLevel" style="width: 5rem;" />
                                </div>
                            </div>
                        </div>

                        <div class="guild-sheet-snapshot-section" id="snapshotAbilitySection">
                            <div class="guild-sheet-snapshot-section-title">Ability</div>
                            <div class="guild-sheet-snapshot-ability" id="snapshotAbility">
                                <span class="text-muted">Loading...</span>
                            </div>
                        </div>

                        <div class="guild-sheet-snapshot-section" id="snapshotStatsSection">
                            <div class="guild-sheet-snapshot-section-title">Stats</div>
                            <div class="guild-sheet-snapshot-stats">
                                <div class="guild-sheet-snapshot-stat">
                                    <div class="guild-sheet-snapshot-stat-value" id="snapshotPatk">0</div>
                                    <div class="guild-sheet-snapshot-stat-label">PATK</div>
                                </div>
                                <div class="guild-sheet-snapshot-stat">
                                    <div class="guild-sheet-snapshot-stat-value" id="snapshotMatk">0</div>
                                    <div class="guild-sheet-snapshot-stat-label">MATK</div>
                                </div>
                                <div class="guild-sheet-snapshot-stat">
                                    <div class="guild-sheet-snapshot-stat-value" id="snapshotHeal">0</div>
                                    <div class="guild-sheet-snapshot-stat-label">Heal</div>
                                </div>
                            </div>
                        </div>

                        <div class="guild-sheet-snapshot-section" id="snapshotRAbilitiesSection">
                            <div class="guild-sheet-snapshot-section-title">R Abilities</div>
                            <ul class="guild-sheet-snapshot-rability-list" id="snapshotRAbilities">
                                <li class="text-muted">Loading...</li>
                            </ul>
                        </div>

                        <div class="guild-sheet-snapshot-section" id="snapshotCustomizationsSection">
                            <div class="guild-sheet-snapshot-section-title">Customizations</div>
                            <div id="snapshotCustomizations">
                                <span class="text-muted">Loading...</span>
                            </div>
                        </div>

                        <div class="guild-sheet-snapshot-error" id="snapshotError">Failed to load weapon data. Please try again.</div>
                    </div>
                    <div class="modal-footer">
                        <span class="spinner-border spinner-border-sm guild-sheet-snapshot-spinner me-2" id="snapshotSpinner" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </span>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@await Html.PartialAsync("_GuildBattleSheetStyles")

@section Scripts {
    <script>
        (() => {
            const previewModal = document.getElementById('previewModal');
            if (previewModal) {
                previewModal.addEventListener('show.bs.modal', event => {
                    const button = event.relatedTarget;
                    if (!button) {
                        return;
                    }

                    const imageUrl = button.getAttribute('data-image-url') || '';
                    const imageTitle = button.getAttribute('data-image-title') || 'Preview';
                    const titleEl = document.getElementById('previewModalTitle');
                    const imageEl = document.getElementById('previewModalImage');
                    if (titleEl) {
                        titleEl.textContent = imageTitle;
                    }
                    if (imageEl) {
                        imageEl.src = imageUrl;
                        imageEl.alt = imageTitle;
                    }
                });
            }

            const viewLevelsModal = document.getElementById('viewLevelsModal');
            if (!viewLevelsModal || typeof bootstrap === 'undefined') {
                return;
            }

            const bsViewLevelsModal = new bootstrap.Modal(viewLevelsModal);
            const snapshotOverboost = document.getElementById('snapshotOverboost');
            const snapshotLevel = document.getElementById('snapshotLevel');
            const snapshotLevelRange = document.getElementById('snapshotLevelRange');
            const snapshotHeader = document.getElementById('snapshotHeader');
            const snapshotItemArt = document.getElementById('snapshotItemArt');
            const snapshotCharacter = document.getElementById('snapshotCharacter');
            const snapshotWeaponName = document.getElementById('snapshotWeaponName');
            const snapshotEquipment = document.getElementById('snapshotEquipment');
            const snapshotElement = document.getElementById('snapshotElement');
            const snapshotAbilityType = document.getElementById('snapshotAbilityType');
            const snapshotSpinner = document.getElementById('snapshotSpinner');
            const snapshotError = document.getElementById('snapshotError');
            const snapshotCustomizationUnlockHint = document.getElementById('snapshotCustomizationUnlockHint');
            const snapshotOverboostNa = document.getElementById('snapshotOverboostNa');
            const snapshotCustomizationsSection = document.getElementById('snapshotCustomizationsSection');
            const defaultSnapshotLevel = @Model.DefaultWeaponLevel;
            const customizationUnlockLevel = 80;

            let currentWeaponId = null;
            let currentWeaponSupportsCustomizations = false;
            let snapshotDebounceTimer = null;
            let snapshotAbortController = null;

            const formatNumber = value => Number(value ?? 0).toLocaleString();
            const escapeHtml = value => String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
            const getItemImageFallbackUrl = equipment => String(equipment ?? '').trim().toLowerCase() === 'costume'
                ? '/images/ui_icon_outfit.png'
                : '/images/ui_icon_weapon.png';
            const getResolvedItemImageUrl = (imageUrl, equipment) => {
                const value = String(imageUrl ?? '').trim();
                return value.length > 0 ? value : getItemImageFallbackUrl(equipment);
            };
            const getResolvedPreviewImageUrl = (previewImageUrl, imageUrl, equipment) => {
                const previewValue = String(previewImageUrl ?? '').trim();
                return previewValue.length > 0 ? previewValue : getResolvedItemImageUrl(imageUrl, equipment);
            };
            const buildSnapshotHeaderStyle = element => {
                const normalized = String(element ?? '').trim().toLowerCase();
                switch (normalized) {
                    case 'fire':
                        return 'background:linear-gradient(135deg, rgba(255,245,245,0.98), rgba(255,228,230,0.98)); border-color: rgba(239,68,68,0.22);';
                    case 'ice':
                        return 'background:linear-gradient(135deg, rgba(240,249,255,0.98), rgba(224,242,254,0.98)); border-color: rgba(14,165,233,0.22);';
                    case 'lightning':
                    case 'thunder':
                        return 'background:linear-gradient(135deg, rgba(255,251,235,0.98), rgba(254,243,199,0.98)); border-color: rgba(245,158,11,0.24);';
                    case 'water':
                        return 'background:linear-gradient(135deg, rgba(239,246,255,0.98), rgba(219,234,254,0.98)); border-color: rgba(59,130,246,0.22);';
                    case 'wind':
                        return 'background:linear-gradient(135deg, rgba(240,253,250,0.98), rgba(204,251,241,0.98)); border-color: rgba(20,184,166,0.22);';
                    case 'earth':
                        return 'background:linear-gradient(135deg, rgba(250,245,255,0.98), rgba(243,232,255,0.98)); border-color: rgba(139,92,246,0.22);';
                    default:
                        return 'background:linear-gradient(135deg, rgba(248,250,252,0.98), rgba(241,245,249,0.98)); border-color: rgba(148,163,184,0.24);';
                }
            };

            const setSnapshotLoading = loading => {
                snapshotSpinner?.classList.toggle('active', loading);
                if (snapshotOverboost) snapshotOverboost.disabled = loading;
                if (snapshotLevel) snapshotLevel.disabled = loading;
                if (snapshotLevelRange) snapshotLevelRange.disabled = loading;
            };

            const showSnapshotError = show => {
                snapshotError?.classList.toggle('active', show);
            };

            const updateSnapshotCustomizationUnlockHint = () => {
                if (!snapshotCustomizationUnlockHint || !snapshotLevel) {
                    return;
                }

                const currentLevel = Number(snapshotLevel.value || '0');
                const showHint = currentWeaponSupportsCustomizations && currentLevel > 0 && currentLevel < customizationUnlockLevel;
                snapshotCustomizationUnlockHint.classList.toggle('d-none', !showHint);
            };

            const updateSnapshotContent = data => {
                showSnapshotError(false);

                const abilityEl = document.getElementById('snapshotAbility');
                if (abilityEl) {
                    abilityEl.innerHTML = data.abilityText
                        ? String(data.abilityText).replace(/\r?\n/g, '<br />')
                        : '<span class="text-muted">No ability data</span>';
                }

                const patkEl = document.getElementById('snapshotPatk');
                const matkEl = document.getElementById('snapshotMatk');
                const healEl = document.getElementById('snapshotHeal');
                if (patkEl) patkEl.textContent = formatNumber(data.patk);
                if (matkEl) matkEl.textContent = formatNumber(data.matk);
                if (healEl) healEl.textContent = formatNumber(data.heal);

                if (typeof data.level === 'number') {
                    if (snapshotLevel) snapshotLevel.value = data.level.toString();
                    if (snapshotLevelRange) snapshotLevelRange.value = data.level.toString();
                }

                updateSnapshotCustomizationUnlockHint();

                const rAbilitiesEl = document.getElementById('snapshotRAbilities');
                const baseRAbilities = Array.isArray(data.rAbilities) ? data.rAbilities : [];
                const customizationRAbilities = Array.isArray(data.customizations)
                    ? data.customizations.filter(c => c && c.kind === 'R Ability')
                    : [];
                const combinedRAbilities = [
                    ...baseRAbilities.map(r => ({
                        isCustomization: false,
                        isLocked: !!r.isLocked,
                        lockedUntilLevel: r.lockedUntilLevel,
                        basePoints: r.basePoints,
                        upgradePoints: r.upgradePoints,
                        totalPoints: r.totalPoints,
                        skillName: r.skillName,
                        effects: Array.isArray(r.effects) ? r.effects : []
                    })),
                    ...customizationRAbilities.map(c => ({
                        isCustomization: true,
                        isLocked: false,
                        lockedUntilLevel: null,
                        basePoints: 0,
                        upgradePoints: 0,
                        totalPoints: Number(c.passiveSkillPoints ?? 0),
                        skillName: c.passiveSkillName || c.description || 'Customization R Ability',
                        effects: Array.isArray(c.passiveEffects) ? c.passiveEffects : []
                    }))
                ];

                if (rAbilitiesEl) {
                    if (combinedRAbilities.length > 0) {
                        rAbilitiesEl.innerHTML = combinedRAbilities.map(r => {
                            if (r.isLocked) {
                                const hint = r.lockedUntilLevel != null
                                    ? ` <span class="text-muted">(unlocks at Lv. ${r.lockedUntilLevel})</span>`
                                    : '';
                                return `<li class="text-muted"><i class="fas fa-lock fa-xs me-1"></i>${escapeHtml(r.skillName)}${hint}</li>`;
                            }

                            const breakdown = (r.basePoints > 0 && r.upgradePoints > 0)
                                ? ` <small class="text-muted">(Lv. ${r.basePoints} + OB ${r.upgradePoints})</small>`
                                : '';
                            const customizationBadge = r.isCustomization
                                ? '<span class="sheet-pill sheet-pill-highlight guild-sheet-snapshot-inline-pill me-1">Cust.</span>'
                                : '';
                            const effectsHtml = Array.isArray(r.effects) && r.effects.length > 0
                                ? `<ul class="guild-sheet-snapshot-rability-effects">${r.effects
                                    .filter(e => e && e.description)
                                    .map(e => `<li>${escapeHtml(e.description)}</li>`)
                                    .join('')}</ul>`
                                : '';

                            return `<li class="guild-sheet-snapshot-rability-item"><div class="guild-sheet-snapshot-rability-main">${customizationBadge}<strong>+${r.totalPoints}</strong> ${escapeHtml(r.skillName)}${breakdown}</div>${effectsHtml}</li>`;
                        }).join('');
                    } else {
                        rAbilitiesEl.innerHTML = '<li class="text-muted">No R Ability data at this level</li>';
                    }
                }

                const customEl = document.getElementById('snapshotCustomizations');
                const nonRAbilityCustomizations = Array.isArray(data.customizations)
                    ? data.customizations.filter(c => c && c.kind !== 'R Ability')
                    : [];
                if (customEl && snapshotCustomizationsSection) {
                    if (nonRAbilityCustomizations.length > 0) {
                        customEl.innerHTML = nonRAbilityCustomizations.map(c => `
                            <div class="guild-sheet-snapshot-customization-entry">
                                <span class="guild-sheet-snapshot-customization-slot">${escapeHtml(c.slot)}</span>
                                <span class="guild-sheet-snapshot-customization-kind">${escapeHtml(c.kind)}</span>
                                <span class="guild-sheet-snapshot-customization-description">${escapeHtml(c.description)}</span>
                            </div>`).join('');
                        snapshotCustomizationsSection.style.display = '';
                    } else {
                        customEl.innerHTML = '<span class="text-muted">No customizations available</span>';
                        snapshotCustomizationsSection.style.display = 'none';
                    }
                }
            };

            const fetchSnapshot = () => {
                if (!currentWeaponId || !snapshotOverboost || !snapshotLevel) {
                    return;
                }

                if (snapshotAbortController) {
                    snapshotAbortController.abort();
                }
                snapshotAbortController = new AbortController();

                const overboost = snapshotOverboost.value;
                const level = snapshotLevel.value;
                const url = `/GuildBattleSheet?handler=WeaponSnapshot&weaponId=${encodeURIComponent(currentWeaponId)}&overboost=${overboost}&level=${level}`;

                setSnapshotLoading(true);
                showSnapshotError(false);

                fetch(url, { signal: snapshotAbortController.signal })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Request failed');
                        }
                        return response.json();
                    })
                    .then(data => {
                        updateSnapshotContent(data);
                        setSnapshotLoading(false);
                    })
                    .catch(err => {
                        if (err.name === 'AbortError') {
                            return;
                        }
                        showSnapshotError(true);
                        setSnapshotLoading(false);
                    });
            };

            const debouncedFetchSnapshot = () => {
                clearTimeout(snapshotDebounceTimer);
                snapshotDebounceTimer = setTimeout(fetchSnapshot, 250);
            };

            snapshotOverboost?.addEventListener('change', debouncedFetchSnapshot);
            snapshotLevel?.addEventListener('change', () => {
                updateSnapshotCustomizationUnlockHint();
                debouncedFetchSnapshot();
            });
            snapshotLevel?.addEventListener('input', () => {
                if (snapshotLevelRange && snapshotLevel) {
                    snapshotLevelRange.value = snapshotLevel.value;
                }
                updateSnapshotCustomizationUnlockHint();
            });
            snapshotLevelRange?.addEventListener('input', () => {
                if (snapshotLevel && snapshotLevelRange) {
                    snapshotLevel.value = snapshotLevelRange.value;
                }
                updateSnapshotCustomizationUnlockHint();
                debouncedFetchSnapshot();
            });

            document.addEventListener('click', event => {
                const trigger = event.target.closest('.btn-view-levels');
                if (!trigger) {
                    return;
                }

                currentWeaponId = trigger.getAttribute('data-weapon-id');
                const character = trigger.getAttribute('data-character') || '';
                const weapon = trigger.getAttribute('data-weapon') || '';
                const equipment = trigger.getAttribute('data-equipment') || '';
                const element = trigger.getAttribute('data-element') || '';
                const abilityType = trigger.getAttribute('data-ability-type') || '';
                const imageUrl = trigger.getAttribute('data-image-url') || '';
                const previewImageUrl = trigger.getAttribute('data-preview-image-url') || '';
                currentWeaponSupportsCustomizations = trigger.getAttribute('data-has-customizations') === 'true';

                if (snapshotHeader) {
                    snapshotHeader.setAttribute('style', buildSnapshotHeaderStyle(element));
                }
                if (snapshotItemArt) {
                    const fallbackUrl = getItemImageFallbackUrl(equipment);
                    snapshotItemArt.onerror = () => {
                        snapshotItemArt.onerror = null;
                        snapshotItemArt.src = fallbackUrl;
                    };
                    snapshotItemArt.src = getResolvedPreviewImageUrl(previewImageUrl, imageUrl, equipment);
                    snapshotItemArt.alt = `${weapon} art`;
                }
                if (snapshotCharacter) {
                    snapshotCharacter.textContent = character;
                }
                if (snapshotWeaponName) {
                    snapshotWeaponName.textContent = weapon;
                }
                if (snapshotEquipment) {
                    snapshotEquipment.textContent = equipment;
                    snapshotEquipment.style.display = equipment ? '' : 'none';
                }
                if (snapshotElement) {
                    snapshotElement.textContent = element;
                    snapshotElement.style.display = element ? '' : 'none';
                }
                if (snapshotAbilityType) {
                    snapshotAbilityType.textContent = abilityType;
                    snapshotAbilityType.style.display = abilityType ? '' : 'none';
                }

                const isUltimate = equipment.toLowerCase() === 'ultimate';
                snapshotOverboost?.classList.toggle('d-none', isUltimate);
                snapshotOverboostNa?.classList.toggle('d-none', !isUltimate);

                if (snapshotOverboost) {
                    snapshotOverboost.value = '10';
                }
                if (snapshotLevel) {
                    snapshotLevel.value = defaultSnapshotLevel.toString();
                }
                if (snapshotLevelRange) {
                    snapshotLevelRange.value = defaultSnapshotLevel.toString();
                }
                updateSnapshotCustomizationUnlockHint();

                const abilityEl = document.getElementById('snapshotAbility');
                const patkEl = document.getElementById('snapshotPatk');
                const matkEl = document.getElementById('snapshotMatk');
                const healEl = document.getElementById('snapshotHeal');
                const rAbilitiesEl = document.getElementById('snapshotRAbilities');
                const customizationsEl = document.getElementById('snapshotCustomizations');
                if (abilityEl) abilityEl.innerHTML = '<span class="text-muted">Loading...</span>';
                if (patkEl) patkEl.textContent = '...';
                if (matkEl) matkEl.textContent = '...';
                if (healEl) healEl.textContent = '...';
                if (rAbilitiesEl) rAbilitiesEl.innerHTML = '<li class="text-muted">Loading...</li>';
                if (customizationsEl) customizationsEl.innerHTML = '<span class="text-muted">Loading...</span>';
                if (snapshotCustomizationsSection) snapshotCustomizationsSection.style.display = '';
                showSnapshotError(false);

                bsViewLevelsModal.show();
                fetchSnapshot();
            });
        })();
    </script>
}
