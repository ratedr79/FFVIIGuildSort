@page
@model FFVIIEverCrisisAnalyzer.Pages.GuildSurveyPlannerModel
@{
    ViewData["Title"] = "Guild Survey Planner";
    var planner = Model.Planner;
}

<div class="container mt-3 guild-survey-planner-page">
    @if (planner != null)
    {
        <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-3">
            <div>
                <h1 class="mb-1"><i class="fas fa-clipboard-list" style="color: var(--brand-primary);"></i> Guild Survey Planner</h1>
                <p class="text-muted mb-0">Leadership-only prep page for quickly spotting per-character outfits, battle-fit DPS weapons, and support or enhancement weapons for the next guild survey.</p>
            </div>
            <form method="get" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label mb-1 fw-semibold" for="plannerElement">Element</label>
                    <select class="form-select" id="plannerElement" name="element" onchange="this.form.submit()">
                        @foreach (var element in planner.AvailableElements)
                        {
                            var isSelected = element == planner.SelectedElement;
                            <option value="@element" selected="@isSelected">@element</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1 fw-semibold" for="plannerAbilityType">Ability Type</label>
                    <select class="form-select" id="plannerAbilityType" name="abilityType" onchange="this.form.submit()">
                        @foreach (var abilityType in planner.AvailableAbilityTypes)
                        {
                            var isSelected = abilityType == planner.SelectedAbilityType;
                            <option value="@abilityType" selected="@isSelected">@abilityType</option>
                        }
                    </select>
                </div>
            </form>
        </div>

        <div class="card shadow-sm border-0 mb-3 planner-hero-card">
            <div class="card-body p-3 p-lg-4">
                <div class="text-uppercase small fw-semibold planner-hero-eyebrow mb-2">Monthly Survey Prep</div>
                <div class="d-flex flex-column flex-xl-row justify-content-between gap-3 align-items-xl-center">
                    <div>
                        <h2 class="h4 mb-2">@planner.SelectedElement @planner.SelectedAbilityType</h2>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="planner-pill planner-pill-hero">@planner.SelectedElement</span>
                            <span class="planner-pill planner-pill-hero">@planner.SelectedAbilityType</span>
                            <span class="planner-pill planner-pill-neutral">Generated @planner.GeneratedAtUtc.ToLocalTime().ToString("g")</span>
                        </div>
                    </div>
                    <div class="text-muted small planner-hero-note">Use this page to spot likely survey asks quickly: elemental outfits, matching DPS weapons, and support or self-enhancement weapons that still matter for the current fight profile.</div>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
            <div class="dc-section-hint mb-0">
                @(planner.CharacterPlans.Count(p => p.HasAnySuggestions)) of @planner.CharacterPlans.Count characters have matches for <span class="fw-semibold">@planner.SelectedElement @planner.SelectedAbilityType</span>. Expand a character to see their outfits and weapons.
            </div>
            <div class="btn-group" role="group" aria-label="Expand or collapse all characters">
                <button type="button" class="btn btn-sm btn-outline-primary" id="plannerExpandAll">Expand all</button>
                <button type="button" class="btn btn-sm btn-outline-primary" id="plannerCollapseAll">Collapse all</button>
            </div>
        </div>

        <div class="accordion dc-accordion planner-accordion" id="plannerCharacterAccordion">
            @{ var charIndex = 0; }
            @foreach (var characterPlan in planner.CharacterPlans)
            {
                charIndex++;
                var collapseId = $"plannerCharacterCollapse{charIndex}";
                var headingId = $"plannerCharacterHeading{charIndex}";
                var roleSlug = characterPlan.Role.ToString().ToLowerInvariant();
                var roleCssClass = $"planner-pill planner-pill-role planner-pill-role-{roleSlug}";
                var suggestionCount = characterPlan.OutfitSuggestions.Count + characterPlan.DpsWeaponSuggestions.Count + characterPlan.UtilityWeaponSuggestions.Count;
                <div class="accordion-item">
                    <h3 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed planner-character-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                            <span class="d-flex flex-wrap align-items-center gap-2 w-100 pe-2">
                                <span class="planner-character-name">@characterPlan.Character</span>
                                <span class="@roleCssClass">@characterPlan.Role</span>
                                @if (characterPlan.HasAnySuggestions)
                                {
                                    <span class="planner-pill planner-pill-count ms-auto">@suggestionCount @(suggestionCount == 1 ? "suggestion" : "suggestions")</span>
                                }
                                else
                                {
                                    <span class="planner-pill planner-pill-empty ms-auto">No matches</span>
                                }
                            </span>
                        </button>
                    </h3>
                    @* No data-bs-parent: characters expand independently so multiple can stay open (and Expand all works). *@
                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId">
                        <div class="accordion-body">
                            @if (!characterPlan.HasAnySuggestions)
                            {
                                <div class="planner-empty-state text-muted small">No especially relevant outfits or weapons were found for <span class="fw-semibold">@characterPlan.Character</span> under the current filters. Try a different element or ability type.</div>
                            }
                            else
                            {
                                <section class="planner-group mb-3">
                                    <div class="planner-group-label small text-uppercase fw-semibold mb-2"><i class="fas fa-tshirt me-1"></i> Outfits</div>
                                    @if (characterPlan.OutfitSuggestions.Count == 0)
                                    {
                                        <div class="text-muted small">No standout outfit matches.</div>
                                    }
                                    else
                                    {
                                        <ul class="list-group list-group-flush planner-list">
                                            @foreach (var suggestion in characterPlan.OutfitSuggestions)
                                            {
                                                var previewImageUrl = string.IsNullOrWhiteSpace(suggestion.PreviewImageUrl) ? suggestion.ImageUrl : suggestion.PreviewImageUrl;
                                                <li class="list-group-item px-0 planner-list-item">
                                                    <div class="d-flex gap-3 align-items-start planner-gear-row">
                                                        <button type="button" class="planner-thumb-button" data-bs-toggle="modal" data-bs-target="#plannerPreviewModal" data-image-url="@previewImageUrl" data-image-title="@suggestion.Name">
                                                            <img src="@suggestion.ImageUrl" alt="@suggestion.Name" class="planner-thumb-image" />
                                                        </button>
                                                        <div class="flex-grow-1">
                                                            <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                                                                <span class="fw-semibold planner-item-title">@suggestion.Name</span>
                                                                <span class="planner-pill planner-pill-neutral">@suggestion.EquipmentType</span>
                                                            </div>
                                                            @if (suggestion.Highlights.Count > 0)
                                                            {
                                                                <div class="d-flex flex-wrap gap-2 mb-1">
                                                                    @foreach (var highlight in suggestion.Highlights)
                                                                    {
                                                                        <span class="planner-pill planner-pill-highlight">@highlight</span>
                                                                    }
                                                                </div>
                                                            }
                                                            <div class="small planner-summary">@suggestion.Summary</div>
                                                            @if (!string.IsNullOrWhiteSpace(suggestion.DetailText))
                                                            {
                                                                <div class="small text-muted mt-1 planner-detail-text">@suggestion.DetailText</div>
                                                            }
                                                        </div>
                                                    </div>
                                                </li>
                                            }
                                        </ul>
                                    }
                                </section>

                                <section class="planner-group mb-3">
                                    <div class="planner-group-label small text-uppercase fw-semibold mb-2"><i class="fas fa-bolt me-1"></i> Matching DPS Weapons</div>
                                    @if (characterPlan.DpsWeaponSuggestions.Count == 0)
                                    {
                                        <div class="text-muted small">No matching element and damage-type DPS weapons found.</div>
                                    }
                                    else
                                    {
                                        <ul class="list-group list-group-flush planner-list">
                                            @foreach (var suggestion in characterPlan.DpsWeaponSuggestions)
                                            {
                                                var previewImageUrl = string.IsNullOrWhiteSpace(suggestion.PreviewImageUrl) ? suggestion.ImageUrl : suggestion.PreviewImageUrl;
                                                <li class="list-group-item px-0 planner-list-item">
                                                    <div class="d-flex gap-3 align-items-start planner-gear-row">
                                                        <button type="button" class="planner-thumb-button" data-bs-toggle="modal" data-bs-target="#plannerPreviewModal" data-image-url="@previewImageUrl" data-image-title="@suggestion.Name">
                                                            <img src="@suggestion.ImageUrl" alt="@suggestion.Name" class="planner-thumb-image" />
                                                        </button>
                                                        <div class="flex-grow-1">
                                                            <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                                                                <span class="fw-semibold planner-item-title">@suggestion.Name</span>
                                                                <span class="planner-pill planner-pill-element">@suggestion.Element</span>
                                                                <span class="planner-pill planner-pill-type">@suggestion.AbilityType</span>
                                                                <span class="planner-pill planner-pill-neutral">@suggestion.EquipmentType</span>
                                                                @if (suggestion.DamagePercent > 0)
                                                                {
                                                                    <span class="planner-pill planner-pill-damage">@suggestion.DamagePercent.ToString("0.#")%</span>
                                                                }
                                                            </div>
                                                            <div class="small planner-summary">@suggestion.Summary</div>
                                                            @if (!string.IsNullOrWhiteSpace(suggestion.DetailText))
                                                            {
                                                                <div class="small text-muted mt-1 planner-detail-text">@suggestion.DetailText</div>
                                                            }
                                                        </div>
                                                    </div>
                                                </li>
                                            }
                                        </ul>
                                    }
                                </section>

                                <section class="planner-group">
                                    <div class="planner-group-label small text-uppercase fw-semibold mb-2"><i class="fas fa-hands-helping me-1"></i> Support / Enhancement Weapons</div>
                                    @if (characterPlan.UtilityWeaponSuggestions.Count == 0)
                                    {
                                        <div class="text-muted small">No standout support or enhancement weapons found.</div>
                                    }
                                    else
                                    {
                                        <ul class="list-group list-group-flush planner-list">
                                            @foreach (var suggestion in characterPlan.UtilityWeaponSuggestions)
                                            {
                                                var previewImageUrl = string.IsNullOrWhiteSpace(suggestion.PreviewImageUrl) ? suggestion.ImageUrl : suggestion.PreviewImageUrl;
                                                <li class="list-group-item px-0 planner-list-item">
                                                    <div class="d-flex gap-3 align-items-start planner-gear-row">
                                                        <button type="button" class="planner-thumb-button" data-bs-toggle="modal" data-bs-target="#plannerPreviewModal" data-image-url="@previewImageUrl" data-image-title="@suggestion.Name">
                                                            <img src="@suggestion.ImageUrl" alt="@suggestion.Name" class="planner-thumb-image" />
                                                        </button>
                                                        <div class="flex-grow-1">
                                                            <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                                                                <span class="fw-semibold planner-item-title">@suggestion.Name</span>
                                                                <span class="planner-pill planner-pill-neutral">@suggestion.EquipmentType</span>
                                                                @if (!string.IsNullOrWhiteSpace(suggestion.Element))
                                                                {
                                                                    <span class="planner-pill planner-pill-element">@suggestion.Element</span>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(suggestion.AbilityType))
                                                                {
                                                                    <span class="planner-pill planner-pill-type">@suggestion.AbilityType</span>
                                                                }
                                                                @if (suggestion.IsSelfOnlyEnhancement)
                                                                {
                                                                    <span class="planner-pill planner-pill-self">Self Only</span>
                                                                }
                                                            </div>
                                                            @if (suggestion.Highlights.Count > 0)
                                                            {
                                                                <div class="d-flex flex-wrap gap-2 mb-1">
                                                                    @foreach (var highlight in suggestion.Highlights)
                                                                    {
                                                                        <span class="planner-pill planner-pill-info">@highlight</span>
                                                                    }
                                                                </div>
                                                            }
                                                            <div class="small planner-summary">@suggestion.Summary</div>
                                                            @if (!string.IsNullOrWhiteSpace(suggestion.DetailText))
                                                            {
                                                                <div class="small text-muted mt-1 planner-detail-text">@suggestion.DetailText</div>
                                                            }
                                                        </div>
                                                    </div>
                                                </li>
                                            }
                                        </ul>
                                    }
                                </section>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="modal fade" id="plannerPreviewModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="plannerPreviewModalTitle">Preview</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center">
                        <img id="plannerPreviewModalImage" src="" alt="Preview" class="img-fluid rounded shadow-sm" />
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .planner-hero-card {
        background: linear-gradient(180deg, var(--brand-primary-soft), rgba(238, 240, 255, 0.25));
        border: 1px solid rgba(102, 126, 234, 0.18);
    }

    .planner-hero-eyebrow {
        color: var(--brand-primary-strong);
        letter-spacing: 0.04em;
    }

    .planner-hero-note {
        max-width: 30rem;
    }

    /* Character accordion — reuses .dc-accordion; these tune the header layout/rhythm. */
    .planner-accordion .accordion-button {
        padding-top: 0.85rem;
        padding-bottom: 0.85rem;
    }

    .planner-accordion .accordion-button:focus {
        box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem rgba(102, 126, 234, 0.5);
    }

    .planner-character-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: #0f172a;
    }

    .planner-accordion .accordion-button:not(.collapsed) .planner-character-name {
        color: var(--brand-primary-strong);
    }

    .planner-group-label {
        color: var(--brand-primary-strong);
        letter-spacing: 0.03em;
        border-bottom: 1px solid rgba(102, 126, 234, 0.18);
        padding-bottom: 0.35rem;
    }

    .planner-empty-state {
        padding: 0.85rem 1rem;
        border-radius: 0.75rem;
        background: #f8fafc;
        border: 1px dashed rgba(148, 163, 184, 0.45);
    }

    .planner-list {
        gap: 0.75rem;
    }

    .planner-list-item {
        border: 0;
        background: transparent;
        padding-top: 0;
        padding-bottom: 0;
    }

    .planner-gear-row {
        padding: 0.9rem;
        border-radius: 0.9rem;
        background: rgba(248, 250, 252, 0.92);
        border: 1px solid rgba(148, 163, 184, 0.22);
    }

    .planner-thumb-button {
        border: 0;
        background: transparent;
        padding: 0;
        border-radius: 0.9rem;
        flex-shrink: 0;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .planner-thumb-button:hover,
    .planner-thumb-button:focus-visible {
        transform: translateY(-1px);
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        outline: none;
    }

    .planner-thumb-image {
        width: 64px;
        height: 64px;
        object-fit: contain;
        border-radius: 0.9rem;
        background: #fff;
        border: 1px solid rgba(148, 163, 184, 0.35);
        box-shadow: 0 0.35rem 1rem rgba(15, 23, 42, 0.08);
    }

    .planner-item-title {
        color: #0f172a;
    }

    .planner-summary {
        color: #1f2937;
        line-height: 1.45;
    }

    .planner-detail-text {
        white-space: pre-line;
    }

    .planner-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        line-height: 1;
        border: 1px solid transparent;
        color: #0f172a;
    }

    .planner-pill-neutral {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #334155;
    }

    .planner-pill-hero {
        background: var(--brand-primary-soft);
        border-color: rgba(102, 126, 234, 0.45);
        color: var(--brand-primary-strong);
    }

    .planner-pill-count {
        background: var(--brand-primary-soft);
        border-color: rgba(102, 126, 234, 0.45);
        color: var(--brand-primary-strong);
        font-weight: 600;
    }

    .planner-pill-empty {
        background: #f1f5f9;
        border-color: #cbd5e1;
        color: #64748b;
        font-weight: 600;
    }

    .planner-pill-role {
        background: #e2e8f0;
        border-color: #cbd5e1;
        color: #1e293b;
    }

    .planner-pill-role-dps {
        background: #dbeafe;
        border-color: #93c5fd;
        color: #1d4ed8;
    }

    .planner-pill-role-support {
        background: #cffafe;
        border-color: #67e8f9;
        color: #155e75;
    }

    .planner-pill-role-healer {
        background: #dcfce7;
        border-color: #86efac;
        color: #166534;
    }

    .planner-pill-role-tank {
        background: #ede9fe;
        border-color: #c4b5fd;
        color: #6d28d9;
    }

    .planner-pill-element {
        background: #dbeafe;
        border-color: #93c5fd;
        color: #1d4ed8;
    }

    .planner-pill-type {
        background: #ede9fe;
        border-color: #c4b5fd;
        color: #6d28d9;
    }

    .planner-pill-damage {
        background: #fee2e2;
        border-color: #fca5a5;
        color: #b91c1c;
    }

    .planner-pill-highlight {
        background: #fef3c7;
        border-color: #fcd34d;
        color: #92400e;
    }

    .planner-pill-info {
        background: #cffafe;
        border-color: #67e8f9;
        color: #155e75;
    }

    .planner-pill-self {
        background: #e2e8f0;
        border-color: #94a3b8;
        color: #334155;
    }

    @@media (max-width: 575.98px) {
        .planner-character-name {
            font-size: 1rem;
        }

        .planner-gear-row {
            padding: 0.7rem;
        }
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modal = document.getElementById('plannerPreviewModal');
            if (modal) {
                modal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    if (!button) {
                        return;
                    }

                    const imageUrl = button.getAttribute('data-image-url') || '';
                    const imageTitle = button.getAttribute('data-image-title') || 'Preview';
                    const titleEl = document.getElementById('plannerPreviewModalTitle');
                    const imageEl = document.getElementById('plannerPreviewModalImage');

                    if (titleEl) {
                        titleEl.textContent = imageTitle;
                    }

                    if (imageEl) {
                        imageEl.src = imageUrl;
                        imageEl.alt = imageTitle;
                    }
                });
            }

            // Expand all / Collapse all for the character accordion.
            const accordion = document.getElementById('plannerCharacterAccordion');
            if (accordion && window.bootstrap) {
                const collapses = accordion.querySelectorAll('.accordion-collapse');

                function setAll(show) {
                    collapses.forEach(function (el) {
                        const instance = bootstrap.Collapse.getOrCreateInstance(el, { toggle: false });
                        if (show) {
                            instance.show();
                        } else {
                            instance.hide();
                        }
                    });
                }

                const expandBtn = document.getElementById('plannerExpandAll');
                const collapseBtn = document.getElementById('plannerCollapseAll');
                if (expandBtn) {
                    expandBtn.addEventListener('click', function () { setAll(true); });
                }
                if (collapseBtn) {
                    collapseBtn.addEventListener('click', function () { setAll(false); });
                }
            }
        });
    </script>
}
