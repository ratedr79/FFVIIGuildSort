@page
@model IndexModel
@{
    ViewData["Title"] = "SOLDIER Tools";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12 text-center mb-4">
            <h1><i class="fas fa-tools"></i> SOLDIER Tools</h1>
            <p class="text-muted">Select a tool to get started</p>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-6 col-lg-3">
            <a href="/PowerLevelAnalyzer" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-primary">
                    <div class="card-body text-center">
                        <div class="mb-3"><i class="fas fa-futbol fa-3x text-primary"></i></div>
                        <h5 class="card-title">Power Level Analyzer</h5>
                        <p class="card-text text-muted small">
                            Upload guild survey CSV data to calculate player power levels, find optimal team compositions, and assign players to guilds.
                        </p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="/GuildBattle" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-success">
                    <div class="card-body text-center">
                        <div class="mb-3"><i class="fas fa-chess fa-3x text-success"></i></div>
                        <h5 class="card-title">Guild Battle</h5>
                        <p class="card-text text-muted small">
                            Run a single guild battle simulation using player damage data from a Google Sheet or CSV. Generates stage assignments and an attack plan.
                        </p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="/GuildBattleTest" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-warning">
                    <div class="card-body text-center">
                        <div class="mb-3"><i class="fas fa-flask fa-3x text-warning"></i></div>
                        <h5 class="card-title">Guild Battle Test</h5>
                        <p class="card-text text-muted small">
                            Run multiple guild battle simulations to analyze variance, assignment stability, and expected outcomes across many randomized runs.
                        </p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="/ZelarithAssignment" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-info">
                    <div class="card-body text-center">
                        <div class="mb-3"><i class="fas fa-terminal fa-3x text-info"></i></div>
                        <h5 class="card-title">Zelarith's Assignments</h5>
                        <p class="card-text text-muted small">
                            Run the Dispatcher application to generate stage assignments, then simulate the battle plan with multiple runs to verify expected results.
                        </p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="/GearSearch" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-secondary">
                    <div class="card-body text-center">
                        <div class="mb-3"><i class="fas fa-search fa-3x text-secondary"></i></div>
                        <h5 class="card-title">Gear Search</h5>
                        <p class="card-text text-muted small">
                            Paginated Gear Search with filters and passive skill data drawn from the FF7EC database.
                        </p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="/EnemyStats" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-danger">
                    <div class="card-body text-center">
                        <div class="mb-3"><i class="fas fa-dragon fa-3x text-danger"></i></div>
                        <h5 class="card-title">Enemy Stats</h5>
                        <p class="card-text text-muted small">
                            Search UnknownX7 boss data, then inspect HP, attack, resistances, immunities, and descriptions.
                        </p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="https://cyphersignal.github.io/ff7ec/" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-secondary">
                    <div class="card-body text-center">
                        <div class="mb-3"><i class="fas fa-database fa-3x text-secondary"></i></div>
                        <h5 class="card-title">FF7EC Equipment Database <i class="fas fa-external-link-alt small"></i></h5>
                        <p class="card-text text-muted small">
                            Searchable list of Ever Crisis weapons and outfits. Includes ability to find weapons by effect, element and more!
                        </p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
