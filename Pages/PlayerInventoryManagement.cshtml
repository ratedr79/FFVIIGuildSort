                    return;
                }
                const itemId = viewButton.getAttribute('data-item-id');
                if (!itemId) {
                    return;
                }
                openSnapshot(itemId);
            });

            snapshotOverboost.addEventListener('change', () => {
                debouncedFetchSnapshot();
            });

            snapshotLevel.addEventListener('input', () => {
                snapshotLevelRange.value = snapshotLevel.value;
            });

            snapshotLevel.addEventListener('change', () => {
                snapshotLevelRange.value = snapshotLevel.value;
                debouncedFetchSnapshot();
            });

            snapshotLevelRange.addEventListener('input', () => {
                snapshotLevel.value = snapshotLevelRange.value;
                debouncedFetchSnapshot();
            });

            pasteImportModalElement?.addEventListener('hidden.bs.modal', () => {
                clearPasteImportSession(false);
            });

            surveyQuickViewModalElement?.addEventListener('hidden.bs.modal', () => {
                clearSurveyQuickViewError();
                setSurveyQuickViewLoading(false);
            });

            populateCharacterOptions();
            syncFiltersToUi();
            renderPasteImportPreview();
            setSurveyQuickViewLoading(false);
            renderInventory();

            // ===== Character Stats (Phase 1: enter + save base/stream stats + account-wide Highwind) =====
            // Stored separately in localStorage; Phase 2 wires it into the Interactive Team Builder so total
            // PATK/MATK = (intrinsic + weapon stats + branding) x (1 + Highwind%) can feed the damage calc.
            const characterStatsStorageKey = 'player-character-stats-v1';
            const characterStatKeys = [
                { key: 'hp', label: 'HP' },
                { key: 'patk', label: 'PATK' },
                { key: 'matk', label: 'MATK' },
                { key: 'pdef', label: 'PDEF' },
                { key: 'mdef', label: 'MDEF' },
                { key: 'heal', label: 'HEAL' }
            ];
            const characterStatBlocks = ['base', 'characterStream', 'roleStream'];
            // Highwind-only ability-potency lines (no base/stream — pure account-wide % bonuses). Stored in the same
            // highwind object alongside the 6 stat keys. "Boost Wpn. C. Ability Pot." feeds the damage calc as the
            // weapon command-ability potency bonus; the other two are recorded for completeness (materia / limit
            // abilities are outside the team-builder damage estimate).
            const highwindExtraKeys = [
                { key: 'wpnCAbilityPot', label: 'Boost Wpn. C. Ability Pot.' },
                { key: 'matCAbilityPot', label: 'Boost Mat. C. Ability Pot.' },
                { key: 'limitAbilityPot', label: 'Boost Limit Ability Pot.' }
            ];

            const characterStatsModalElement = document.getElementById('characterStatsModal');
            const characterStatsModal = characterStatsModalElement ? new bootstrap.Modal(characterStatsModalElement) : null;
            const openCharacterStatsButton = document.getElementById('openCharacterStatsButton');
            const characterStatsHint = document.getElementById('characterStatsHint');
            const characterStatsHighwindInputs = document.getElementById('characterStatsHighwindInputs');
            const characterStatsSelect = document.getElementById('characterStatsSelect');
            const characterStatsLevel = document.getElementById('characterStatsLevel');
            const characterStatsGridBody = document.getElementById('characterStatsGridBody');
            const characterStatsFillStreamsButton = document.getElementById('characterStatsFillStreamsButton');
            const characterStatsSaveButton = document.getElementById('characterStatsSaveButton');
            const characterStatsClearButton = document.getElementById('characterStatsClearButton');
            const characterStatsSavedMessage = document.getElementById('characterStatsSavedMessage');

            let characterStatsWorking = null; // in-memory working copy kept while the modal is open

            function statNumberOrZero(value) {
                const n = Number.parseFloat(value);
                return Number.isFinite(n) ? n : 0;
            }

            function emptyStatRow() {
                return characterStatKeys.reduce((acc, s) => { acc[s.key] = 0; return acc; }, {});
            }

            function emptyCharacterStats() {
                return { level: null, base: emptyStatRow(), characterStream: emptyStatRow(), roleStream: emptyStatRow() };
            }

            // The Highwind row carries the 6 stat keys PLUS the highwind-only ability-potency lines.
            function emptyHighwindRow() {
                const row = emptyStatRow();
                highwindExtraKeys.forEach(s => { row[s.key] = 0; });
                return row;
            }

            function defaultCharacterStatsState() {
                return { version: 1, highwind: emptyHighwindRow(), characters: {} };
            }

            function normalizeStatRow(raw) {
                const row = emptyStatRow();
                if (raw && typeof raw === 'object') {
                    characterStatKeys.forEach(s => { row[s.key] = statNumberOrZero(raw[s.key]); });
                }
                return row;
            }

            function normalizeHighwindRow(raw) {
                const row = normalizeStatRow(raw);
                if (raw && typeof raw === 'object') {
                    highwindExtraKeys.forEach(s => { row[s.key] = statNumberOrZero(raw[s.key]); });
                } else {
                    highwindExtraKeys.forEach(s => { row[s.key] = 0; });
                }
                return row;
            }

            function normalizeCharacterStatsState(raw) {
                const state = defaultCharacterStatsState();
                if (!raw || typeof raw !== 'object') { return state; }
                state.highwind = normalizeHighwindRow(raw.highwind);
                if (raw.characters && typeof raw.characters === 'object') {
                    Object.entries(raw.characters).forEach(([name, value]) => {
                        if (!name || !value || typeof value !== 'object') { return; }
                        const lvl = Number.parseInt(value.level, 10);
                        state.characters[name] = {
                            level: Number.isFinite(lvl) ? lvl : null,
                            base: normalizeStatRow(value.base),
                            characterStream: normalizeStatRow(value.characterStream),
                            roleStream: normalizeStatRow(value.roleStream)
                        };
                    });
                }
                return state;
            }

            function loadCharacterStatsState() {
                try {
                    const raw = window.localStorage.getItem(characterStatsStorageKey);
                    return normalizeCharacterStatsState(raw ? JSON.parse(raw) : null);
                } catch (e) {
                    return defaultCharacterStatsState();
                }
            }

            function characterStatsEntered(entry) {
                if (!entry) { return false; }
                return characterStatBlocks.some(block => characterStatKeys.some(s => statNumberOrZero(entry[block] ? entry[block][s.key] : 0) !== 0))
                    || (Number.isFinite(entry.level) && entry.level > 0);
            }

            function updateCharacterStatsHint() {
                const state = loadCharacterStatsState();
                const count = Object.values(state.characters).filter(characterStatsEntered).length;
                const highwindSet = characterStatKeys.concat(highwindExtraKeys).some(s => statNumberOrZero(state.highwind[s.key]) !== 0);
                if (characterStatsHint) {
                    characterStatsHint.textContent = (count > 0 || highwindSet)
                        ? `${count} character${count === 1 ? '' : 's'} entered · Highwind ${highwindSet ? 'set' : 'not set'}.`
                        : 'Record base / stream stats and the Highwind bonus to enable damage estimates.';
                }
            }

            function computeCharacterStatTotal(state, charName, statKey) {
                const c = state.characters[charName] || emptyCharacterStats();
                const intrinsic = statNumberOrZero(c.base[statKey]) + statNumberOrZero(c.characterStream[statKey]) + statNumberOrZero(c.roleStream[statKey]);
                const boost = statNumberOrZero(state.highwind[statKey]) / 100;
                // The game floors stat math, so we floor too — this reproduces the in-game total exactly.
                return Math.floor(intrinsic * (1 + boost));
            }

            function currentCharacterStatsKey() {
                return characterStatsSelect ? characterStatsSelect.value : '';
            }

            function ensureWorkingCharacter(name) {
                if (!characterStatsWorking.characters[name]) {
                    characterStatsWorking.characters[name] = emptyCharacterStats();
                }
                return characterStatsWorking.characters[name];
            }

            function renderHighwindInputs() {
                if (!characterStatsHighwindInputs) { return; }
                const statCols = characterStatKeys.map(s => `
                    <div class="col-6 col-md-4 col-lg-2">
                        <label class="form-label small mb-1" for="highwind_${s.key}">${s.label} %</label>
                        <input type="number" step="0.1" inputmode="decimal" class="form-control form-control-sm" id="highwind_${s.key}" data-highwind="${s.key}" value="${characterStatsWorking.highwind[s.key] || 0}" />
                    </div>`).join('');
                const extraCols = highwindExtraKeys.map(s => `
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1" for="highwind_${s.key}">${s.label} %</label>
                        <input type="number" step="0.1" inputmode="decimal" class="form-control form-control-sm" id="highwind_${s.key}" data-highwind="${s.key}" value="${characterStatsWorking.highwind[s.key] || 0}" />
                    </div>`).join('');
                characterStatsHighwindInputs.innerHTML = statCols + extraCols;
                characterStatsHighwindInputs.querySelectorAll('input[data-highwind]').forEach(input => {
                    input.addEventListener('input', () => {
                        characterStatsWorking.highwind[input.getAttribute('data-highwind')] = statNumberOrZero(input.value);
                        refreshCharacterStatsTotals();
                    });
                });
            }

            function renderCharacterStatsGrid() {
                const name = currentCharacterStatsKey();
                if (!name || !characterStatsGridBody) { return; }
                const c = ensureWorkingCharacter(name);
                if (!Number.isFinite(c.level) || c.level <= 0) { c.level = 100; }
                if (characterStatsLevel) { characterStatsLevel.value = c.level; }
                characterStatsGridBody.innerHTML = characterStatKeys.map(s => `
                    <tr>
                        <td class="fw-semibold">${s.label}</td>
                        ${characterStatBlocks.map(block => {
                            const readOnly = block === 'base'; // Base auto-fills from the level dropdown; streams are editable.
                            return `<td><input type="number" step="1" inputmode="numeric" class="form-control form-control-sm${readOnly ? ' bg-light text-muted' : ''}" data-block="${block}" data-stat="${s.key}" value="${c[block][s.key] || 0}"${readOnly ? ' readonly tabindex="-1"' : ''} /></td>`;
                        }).join('')}
                        <td class="fw-semibold" data-total="${s.key}">${computeCharacterStatTotal(characterStatsWorking, name, s.key)}</td>
                    </tr>`).join('');
                characterStatsGridBody.querySelectorAll('input[data-block]:not([readonly])').forEach(input => {
                    input.addEventListener('input', () => {
                        ensureWorkingCharacter(name)[input.getAttribute('data-block')][input.getAttribute('data-stat')] = statNumberOrZero(input.value);
                        refreshCharacterStatsTotals();
                    });
                });
            }

            // Per-character stream maxes (every growth-board node unlocked), cached from the server for the
            // "Fill streams from max" action and the brand-new-character default.
            const characterStreamMaxByName = {};

            function streamsAreEmpty(c) {
                return characterStatBlocks.filter(b => b !== 'base')
                    .every(block => characterStatKeys.every(s => statNumberOrZero(c[block][s.key]) === 0));
            }

            function applyStreamMax(name) {
                const max = characterStreamMaxByName[name];
                if (!max) { return; }
                const c = ensureWorkingCharacter(name);
                characterStatKeys.forEach(s => {
                    c.characterStream[s.key] = statNumberOrZero(max.characterStream[s.key]);
                    c.roleStream[s.key] = statNumberOrZero(max.roleStream[s.key]);
                });
            }

            // Auto-fill the read-only Base row from the level, cache the stream maxes, and default the streams to
            // max for a character that has none entered yet (Character/Role Stream = sum of all growth-board nodes).
            function fetchCharacterStatDefaults(name) {
                if (!name) { return; }
                const c = ensureWorkingCharacter(name);
                const level = (Number.isFinite(c.level) && c.level > 0) ? c.level : 100;
                c.level = level;
                fetch(`?handler=CharacterStatDefaults&character=${encodeURIComponent(name)}&level=${level}`, { headers: { 'Accept': 'application/json' } })
                    .then(response => (response.ok ? response.json() : null))
                    .then(data => {
                        if (!data || !data.base) { return; }
                        characterStatKeys.forEach(s => { c.base[s.key] = statNumberOrZero(data.base[s.key]); });
                        characterStreamMaxByName[name] = { characterStream: data.characterStream || {}, roleStream: data.roleStream || {} };
                        if (streamsAreEmpty(c)) { applyStreamMax(name); }
                        if (currentCharacterStatsKey() === name) { renderCharacterStatsGrid(); }
                    })
                    .catch(() => { /* offline / unknown character — keep whatever is stored */ });
            }

            function refreshCharacterStatsTotals() {
                const name = currentCharacterStatsKey();
                if (!name || !characterStatsGridBody) { return; }
                characterStatKeys.forEach(s => {
                    const cell = characterStatsGridBody.querySelector(`[data-total="${s.key}"]`);
                    if (cell) { cell.textContent = computeCharacterStatTotal(characterStatsWorking, name, s.key); }
                });
            }

            function commitCharacterStatsLevel() {
                const name = currentCharacterStatsKey();
                if (!name) { return; }
                const lvl = Number.parseInt(characterStatsLevel ? characterStatsLevel.value : '', 10);
                ensureWorkingCharacter(name).level = Number.isFinite(lvl) ? lvl : null;
            }

            function populateCharacterStatsSelect() {
                if (!characterStatsSelect) { return; }
                const previous = characterStatsSelect.value;
                const entered = new Set(Object.entries(characterStatsWorking.characters)
                    .filter(entry => characterStatsEntered(entry[1])).map(entry => entry[0]));
                characterStatsSelect.innerHTML = (availableCharacters || []).map(name =>
                    `<option value="${escapeHtml(name)}">${escapeHtml(name)}${entered.has(name) ? ' ✓' : ''}</option>`).join('');
                if (previous) { characterStatsSelect.value = previous; }
            }

            function openCharacterStats() {
                characterStatsWorking = loadCharacterStatsState();
                if (characterStatsSavedMessage) { characterStatsSavedMessage.classList.remove('active'); characterStatsSavedMessage.textContent = ''; }
                renderHighwindInputs();
                populateCharacterStatsSelect();
                renderCharacterStatsGrid();
                fetchCharacterStatDefaults(currentCharacterStatsKey());
                characterStatsModal?.show();
            }

            function saveCharacterStats() {
                commitCharacterStatsLevel();
                // Drop characters that ended up entirely empty so the store stays tidy.
                Object.keys(characterStatsWorking.characters).forEach(name => {
                    if (!characterStatsEntered(characterStatsWorking.characters[name])) {
                        delete characterStatsWorking.characters[name];
                    }
                });
                try {
                    window.localStorage.setItem(characterStatsStorageKey, JSON.stringify(characterStatsWorking));
                } catch (e) { /* storage full / blocked */ }
                populateCharacterStatsSelect();
                updateCharacterStatsHint();
                if (characterStatsSavedMessage) {
                    characterStatsSavedMessage.textContent = 'Character stats saved.';
                    characterStatsSavedMessage.classList.add('active');
                }
            }

            updateCharacterStatsHint();
            openCharacterStatsButton?.addEventListener('click', openCharacterStats);
            characterStatsSelect?.addEventListener('change', () => {
                renderCharacterStatsGrid();
                fetchCharacterStatDefaults(currentCharacterStatsKey());
            });
            characterStatsLevel?.addEventListener('input', commitCharacterStatsLevel);
            characterStatsLevel?.addEventListener('change', () => {
                commitCharacterStatsLevel();
                fetchCharacterStatDefaults(currentCharacterStatsKey());
            });
            characterStatsSaveButton?.addEventListener('click', saveCharacterStats);
            characterStatsFillStreamsButton?.addEventListener('click', () => {
                const name = currentCharacterStatsKey();
                if (!name) { return; }
                applyStreamMax(name);
                renderCharacterStatsGrid();
            });
            characterStatsClearButton?.addEventListener('click', () => {
                const name = currentCharacterStatsKey();
                if (!name) { return; }
                characterStatsWorking.characters[name] = emptyCharacterStats();
                renderCharacterStatsGrid();
                fetchCharacterStatDefaults(name);
            });
        })();
    </script>
}
