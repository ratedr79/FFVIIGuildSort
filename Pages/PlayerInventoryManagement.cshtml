@section Scripts {
    <script>
        (function () {
            const storageKey = 'player-inventory-state-v1';
            const inventoryPageSizeOptions = [24, 48, 96];
            const defaultInventoryPageSize = window.matchMedia('(max-width: 767.98px)').matches ? 24 : 48;
            const inventoryGrid = document.getElementById('inventoryGrid');
            const inventoryResultsCard = inventoryGrid?.closest('.inventory-results-card');
            const inventoryEmptyState = document.getElementById('inventoryEmptyState');
            const inventorySearchInput = document.getElementById('inventorySearchInput');
            const inventoryCharacterFilter = document.getElementById('inventoryCharacterFilter');
            const inventoryTypeFilter = document.getElementById('inventoryTypeFilter');
            const inventoryClearFiltersButton = document.getElementById('inventoryClearFiltersButton');
            const inventoryExportButton = document.getElementById('inventoryExportButton');
            const inventoryImportButton = document.getElementById('inventoryImportButton');
            const inventoryImportFileInput = document.getElementById('inventoryImportFileInput');
            const inventoryPasteImportButton = document.getElementById('inventoryPasteImportButton');
            const inventoryBulkHelpButton = document.getElementById('inventoryBulkHelpButton');
            const inventoryResetButton = document.getElementById('inventoryResetButton');
            const inventorySummaryMeta = document.getElementById('inventorySummaryMeta');
            const inventoryOwnedSummary = document.getElementById('inventoryOwnedSummary');
            const inventoryBulkScope = document.getElementById('inventoryBulkScope');
            const inventoryBulkScopeSummary = document.getElementById('inventoryBulkScopeSummary');
            const inventorySelectionCountBadge = document.getElementById('inventorySelectionCountBadge');
            const inventorySelectCurrentPageButton = document.getElementById('inventorySelectCurrentPageButton');
            const inventoryClearSelectionButton = document.getElementById('inventoryClearSelectionButton');
            const inventoryUndoBulkUpdateButton = document.getElementById('inventoryUndoBulkUpdateButton');
            const bulkWeaponOwnershipSelect = document.getElementById('bulkWeaponOwnershipSelect');
            const applyBulkWeaponOwnershipButton = document.getElementById('applyBulkWeaponOwnershipButton');
            const bulkWeaponLevelSelect = document.getElementById('bulkWeaponLevelSelect');
            const applyBulkWeaponLevelButton = document.getElementById('applyBulkWeaponLevelButton');
            const clearBulkWeaponLevelButton = document.getElementById('clearBulkWeaponLevelButton');
            const bulkCostumeOwnershipSelect = document.getElementById('bulkCostumeOwnershipSelect');
            const applyBulkCostumeOwnershipButton = document.getElementById('applyBulkCostumeOwnershipButton');
            const resetBulkScopeButton = document.getElementById('resetBulkScopeButton');
            const inventoryPaginationBar = document.getElementById('inventoryPaginationBar');
            const inventoryPageSizeSelect = document.getElementById('inventoryPageSizeSelect');
            const inventoryFirstPageButton = document.getElementById('inventoryFirstPageButton');
            const inventoryPreviousPageButton = document.getElementById('inventoryPreviousPageButton');
            const inventoryNextPageButton = document.getElementById('inventoryNextPageButton');
            const inventoryLastPageButton = document.getElementById('inventoryLastPageButton');
            const inventoryPaginationStatus = document.getElementById('inventoryPaginationStatus');
            const inventorySuccessMessage = document.getElementById('inventorySuccessMessage');
            const inventoryErrorMessage = document.getElementById('inventoryErrorMessage');
            const allItems = JSON.parse(document.getElementById('inventoryCatalogJson').textContent || '[]');
            const availableCharacters = JSON.parse(document.getElementById('inventoryCharactersJson').textContent || '[]');
            const allowedInventoryLevels = JSON.parse(document.getElementById('inventoryLevelsJson').textContent || '[]');
            const defaultSnapshotLevel = @Model.DefaultWeaponLevel;
            const viewLevelsModal = document.getElementById('viewLevelsModal');
            const bsModal = viewLevelsModal ? new bootstrap.Modal(viewLevelsModal) : null;
            const imagePreviewModalElement = document.getElementById('itemImagePreviewModal');
            const imagePreviewModal = imagePreviewModalElement ? new bootstrap.Modal(imagePreviewModalElement) : null;
            const imagePreviewTitle = document.getElementById('itemImagePreviewModalLabel');
            const imagePreviewCaption = document.getElementById('itemImagePreviewModalCaption');
            const imagePreviewImage = document.getElementById('itemImagePreviewModalImage');
            const inventoryBulkHelpModalElement = document.getElementById('inventoryBulkHelpModal');
            const inventoryBulkHelpModal = inventoryBulkHelpModalElement ? new bootstrap.Modal(inventoryBulkHelpModalElement) : null;
            const pasteImportModalElement = document.getElementById('pasteImportModal');
            const pasteImportModal = pasteImportModalElement ? new bootstrap.Modal(pasteImportModalElement) : null;
            const pasteImportInput = document.getElementById('pasteImportInput');
            const pasteImportMode = document.getElementById('pasteImportMode');
            const parsePasteImportButton = document.getElementById('parsePasteImportButton');
            const applyPasteImportButton = document.getElementById('applyPasteImportButton');
            const clearPasteImportButton = document.getElementById('clearPasteImportButton');
            const pasteImportSummary = document.getElementById('pasteImportSummary');
            const pasteImportErrors = document.getElementById('pasteImportErrors');
            const pasteImportPreviewBody = document.getElementById('pasteImportPreviewBody');
            const snapshotOverboost = document.getElementById('snapshotOverboost');
            const snapshotLevel = document.getElementById('snapshotLevel');
            const snapshotLevelRange = document.getElementById('snapshotLevelRange');
            const snapshotPortrait = document.getElementById('snapshotPortrait');
            const snapshotItemArt = document.getElementById('snapshotItemArt');
            const snapshotCharacter = document.getElementById('snapshotCharacter');
            const snapshotWeaponName = document.getElementById('snapshotWeaponName');
            const snapshotEquipment = document.getElementById('snapshotEquipment');
            const snapshotElement = document.getElementById('snapshotElement');
            const snapshotAbilityType = document.getElementById('snapshotAbilityType');
            const snapshotSpinner = document.getElementById('snapshotSpinner');
            const snapshotError = document.getElementById('snapshotError');
            const inventoryStatuses = [
                { value: 'do-not-own', label: 'Do Not Own' },
                { value: '3-star', label: '3 Star' },
                { value: '4-star', label: '4 Star' },
                { value: '5-star', label: '5 Star' },
                { value: 'ob1', label: 'OB1' },
                { value: 'ob2', label: 'OB2' },
                { value: 'ob3', label: 'OB3' },
                { value: 'ob4', label: 'OB4' },
                { value: 'ob5', label: 'OB5' },
                { value: 'ob6', label: 'OB6' },
                { value: 'ob7', label: 'OB7' },
                { value: 'ob8', label: 'OB8' },
                { value: 'ob9', label: 'OB9' },
                { value: 'ob10', label: 'OB10' }
            ];

            let state = loadState();
            let currentSnapshotItem = null;
            let inventorySearchDebounceTimer = null;
            let snapshotDebounceTimer = null;
            let snapshotAbortController = null;
            let selectedItemIds = new Set();
            let undoStateSnapshot = null;
            let lastParsedPasteImport = null;
            const itemNameLookup = buildItemNameLookup(allItems);

            function createDefaultState() {
                return {
                    version: 1,
                    filters: {
                        searchText: '',
                        character: 'all',
                        itemType: 'all',
                        page: 1,
                        pageSize: defaultInventoryPageSize
                    },
                    costumes: {},
                    weapons: {}
                };
            }

            function normalizeWeaponOwnership(value) {
                const normalized = String(value || '').trim().toLowerCase();
                return inventoryStatuses.some(entry => entry.value === normalized) ? normalized : 'do-not-own';
            }

            function normalizeWeaponLevel(value) {
                const parsed = Number.parseInt(String(value || ''), 10);
                return allowedInventoryLevels.includes(parsed) ? parsed : null;
            }

            function normalizeInventoryPageSize(value) {
                const parsed = Number.parseInt(String(value || ''), 10);
                return inventoryPageSizeOptions.includes(parsed) ? parsed : defaultInventoryPageSize;
            }

            function normalizeInventoryPage(value) {
                const parsed = Number.parseInt(String(value || ''), 10);
                return Number.isFinite(parsed) && parsed > 0 ? parsed : 1;
            }

            function normalizeState(rawState) {
                const baseState = createDefaultState();
                const nextState = rawState && typeof rawState === 'object' ? rawState : {};
                const normalized = {
                    version: 1,
                    filters: {
                        searchText: typeof nextState.filters?.searchText === 'string' ? nextState.filters.searchText : '',
                        character: typeof nextState.filters?.character === 'string' ? nextState.filters.character : 'all',
                        itemType: typeof nextState.filters?.itemType === 'string' ? nextState.filters.itemType : 'all',
                        page: normalizeInventoryPage(nextState.filters?.page),
                        pageSize: normalizeInventoryPageSize(nextState.filters?.pageSize)
                    },
                    costumes: {},
                    weapons: {}
                };

                if (!['all', ...availableCharacters].includes(normalized.filters.character)) {
                    normalized.filters.character = 'all';
                }

                if (!['all', 'Weapon', 'Costume'].includes(normalized.filters.itemType)) {
                    normalized.filters.itemType = 'all';
                }

                if (nextState.costumes && typeof nextState.costumes === 'object') {
                    Object.entries(nextState.costumes).forEach(([itemId, value]) => {
                        normalized.costumes[itemId] = {
                            owned: !!value?.owned
                        };
                    });
                }

                if (nextState.weapons && typeof nextState.weapons === 'object') {
                    Object.entries(nextState.weapons).forEach(([itemId, value]) => {
                        normalized.weapons[itemId] = {
                            ownership: normalizeWeaponOwnership(value?.ownership),
                            level: normalizeWeaponLevel(value?.level)
                        };
                    });
                }

                return { ...baseState, ...normalized };
            }

            function loadState() {
                try {
                    const raw = localStorage.getItem(storageKey);
                    if (!raw) {
                        return createDefaultState();
                    }

                    return normalizeState(JSON.parse(raw));
                } catch {
                    return createDefaultState();
                }
            }

            function saveState() {
                localStorage.setItem(storageKey, JSON.stringify(state));
            }

            function hideMessages() {
                inventorySuccessMessage.classList.remove('active');
                inventorySuccessMessage.textContent = '';
                inventoryErrorMessage.classList.remove('active');
                inventoryErrorMessage.textContent = '';
            }

            function showSuccess(message) {
                inventorySuccessMessage.textContent = message;
                inventorySuccessMessage.classList.add('active');
                inventoryErrorMessage.classList.remove('active');
                inventoryErrorMessage.textContent = '';
            }

            function showError(message) {
                inventoryErrorMessage.textContent = message;
                inventoryErrorMessage.classList.add('active');
                inventorySuccessMessage.classList.remove('active');
                inventorySuccessMessage.textContent = '';
            }

            function escapeHtml(value) {
                return String(value ?? '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function getCostumeRecord(itemId) {
                return state.costumes[itemId] || { owned: false };
            }

            function getWeaponRecord(itemId) {
                const record = state.weapons[itemId] || {};
                return {
                    ownership: normalizeWeaponOwnership(record.ownership),
                    level: normalizeWeaponLevel(record.level)
                };
            }

            function isOwned(item) {
                if (String(item.equipmentType).toLowerCase() === 'costume') {
                    return !!getCostumeRecord(item.id).owned;
                }

                return getWeaponRecord(item.id).ownership !== 'do-not-own';
            }

            function countOwnedByType() {
                let ownedWeapons = 0;
                let ownedCostumes = 0;

                allItems.forEach(item => {
                    if (!isOwned(item)) {
                        return;
                    }

                    if (String(item.equipmentType).toLowerCase() === 'costume') {
                        ownedCostumes += 1;
                    } else {
                        ownedWeapons += 1;
                    }
                });

                return { ownedWeapons, ownedCostumes };
            }

            function updateInventorySummary(filteredCount, visibleCount, pageStart) {
                const { ownedWeapons, ownedCostumes } = countOwnedByType();
                if (filteredCount <= 0 || visibleCount <= 0) {
                    inventorySummaryMeta.textContent = `Showing 0 of ${allItems.length.toLocaleString()} items`;
                } else {
                    const pageEnd = pageStart + visibleCount - 1;
                    if (filteredCount === allItems.length) {
                        inventorySummaryMeta.textContent = `Showing ${pageStart.toLocaleString()}-${pageEnd.toLocaleString()} of ${allItems.length.toLocaleString()} items`;
                    } else {
                        inventorySummaryMeta.textContent = `Showing ${pageStart.toLocaleString()}-${pageEnd.toLocaleString()} of ${filteredCount.toLocaleString()} filtered items · ${allItems.length.toLocaleString()} total`;
                    }
                }
                inventoryOwnedSummary.textContent = `Owned weapons: ${ownedWeapons.toLocaleString()} · Owned costumes: ${ownedCostumes.toLocaleString()}`;
            }

            function updatePaginationControls(filteredCount, currentPage, totalPages) {
                inventoryPaginationBar.classList.toggle('d-none', filteredCount <= 0);
                inventoryFirstPageButton.disabled = filteredCount <= 0 || currentPage <= 1;
                inventoryPreviousPageButton.disabled = filteredCount <= 0 || currentPage <= 1;
                inventoryNextPageButton.disabled = filteredCount <= 0 || currentPage >= totalPages;
                inventoryLastPageButton.disabled = filteredCount <= 0 || currentPage >= totalPages;
                inventoryPaginationStatus.textContent = filteredCount <= 0
                    ? 'Page 0 of 0'
                    : `Page ${currentPage.toLocaleString()} of ${totalPages.toLocaleString()}`;
            }

            function getPagedItems(filteredItems) {
                const pageSize = normalizeInventoryPageSize(state.filters.pageSize);
                const totalPages = filteredItems.length > 0 ? Math.ceil(filteredItems.length / pageSize) : 0;
                const safePage = totalPages > 0 ? Math.min(normalizeInventoryPage(state.filters.page), totalPages) : 1;
                const pageStartIndex = totalPages > 0 ? (safePage - 1) * pageSize : 0;
                const pageItems = filteredItems.slice(pageStartIndex, pageStartIndex + pageSize);
                return {
                    pageItems,
                    currentPage: safePage,
                    totalPages,
                    pageStart: pageItems.length > 0 ? pageStartIndex + 1 : 0
                };
            }

            function buildOwnershipLabel(item) {
                if (String(item.equipmentType).toLowerCase() === 'costume') {
                    return getCostumeRecord(item.id).owned ? 'Own' : 'Do Not Own';
                }

                const record = getWeaponRecord(item.id);
                const match = inventoryStatuses.find(entry => entry.value === record.ownership);
                return match ? match.label : 'Do Not Own';
            }

            function getSnapshotOverboostValue(ownership) {
                const normalized = normalizeWeaponOwnership(ownership);
                if (normalized.startsWith('ob')) {
                    return normalized.substring(2);
                }

                return '0';
            }

            function syncFiltersToUi() {
                inventorySearchInput.value = state.filters.searchText;
                inventoryCharacterFilter.value = state.filters.character;
                inventoryTypeFilter.value = state.filters.itemType;
                inventoryPageSizeSelect.value = String(state.filters.pageSize);
            }

            function populateCharacterOptions() {
                inventoryCharacterFilter.innerHTML = '<option value="all">All characters</option>';
                availableCharacters.forEach(character => {
                    const option = document.createElement('option');
                    option.value = character;
                    option.textContent = character;
                    inventoryCharacterFilter.appendChild(option);
                });
            }

            function compareInventoryItems(left, right) {
                const leftCharacterId = Number.parseInt(String(left?.characterId ?? 0), 10) || 0;
                const rightCharacterId = Number.parseInt(String(right?.characterId ?? 0), 10) || 0;
                if (leftCharacterId !== rightCharacterId) {
                    return leftCharacterId - rightCharacterId;
                }

                const equipmentCompare = String(left?.equipmentType ?? '').localeCompare(String(right?.equipmentType ?? ''), undefined, { sensitivity: 'base' });
                if (equipmentCompare !== 0) {
                    return equipmentCompare;
                }

                const nameCompare = String(left?.name ?? '').localeCompare(String(right?.name ?? ''), undefined, { sensitivity: 'base' });
                if (nameCompare !== 0) {
                    return nameCompare;
                }

                return String(left?.id ?? '').localeCompare(String(right?.id ?? ''), undefined, { sensitivity: 'base' });
            }

            function isCostumeItem(item) {
                return String(item?.equipmentType ?? '').toLowerCase() === 'costume';
            }

            function cloneInventoryEntries(entries) {
                return JSON.parse(JSON.stringify(entries || {}));
            }

            function normalizeImportName(value) {
                return String(value ?? '')
                    .trim()
                    .toLowerCase()
                    .replace(/[’‘]/g, "'")
                    .replace(/[“”]/g, '"')
                    .replace(/\s+/g, ' ');
            }

            function buildItemNameLookup(items) {
                const lookup = new Map();
                items.forEach(item => {
                    const key = normalizeImportName(item?.name);
                    if (!key) {
                        return;
                    }

                    if (!lookup.has(key)) {
                        lookup.set(key, []);
                    }

                    lookup.get(key).push(item);
                });
                return lookup;
            }

            function getCurrentPageItems() {
                return getPagedItems(getFilteredItems()).pageItems;
            }

            function getItemsForScope(scopeValue) {
                if (scopeValue === 'selected') {
                    return allItems.filter(item => selectedItemIds.has(String(item.id)));
                }

                if (scopeValue === 'current-page') {
                    return getCurrentPageItems();
                }

                return getFilteredItems();
            }

            function getBulkScopeBreakdown(scopeValue) {
                const items = getItemsForScope(scopeValue);
                let weaponCount = 0;
                let costumeCount = 0;
                let ownedWeaponCount = 0;
                let weaponLevelCount = 0;

                items.forEach(item => {
                    if (isCostumeItem(item)) {
                        costumeCount += 1;
                        return;
                    }

                    weaponCount += 1;
                    const record = getWeaponRecord(item.id);
                    if (record.ownership !== 'do-not-own') {
                        ownedWeaponCount += 1;
                    }
                    if (record.level != null) {
                        weaponLevelCount += 1;
                    }
                });

                return {
                    items,
                    totalCount: items.length,
                    weaponCount,
                    costumeCount,
                    ownedWeaponCount,
                    weaponLevelCount
                };
            }

            function updateBulkActionUi() {
                const scopeValue = inventoryBulkScope?.value || 'filtered';
                const breakdown = getBulkScopeBreakdown(scopeValue);
                const selectedCount = selectedItemIds.size;
                const scopeLabel = scopeValue === 'selected'
                    ? 'Selected items'
                    : scopeValue === 'current-page'
                        ? 'Current page'
                        : 'Filtered results';
                const selectionHint = scopeValue === 'selected' && selectedCount === 0
                    ? ' · Select one or more cards to use this scope.'
                    : '';

                inventorySelectionCountBadge.textContent = `${selectedCount.toLocaleString()} selected`;
                inventoryBulkScopeSummary.textContent = `${scopeLabel}: ${breakdown.totalCount.toLocaleString()} items in scope · ${breakdown.weaponCount.toLocaleString()} weapons · ${breakdown.costumeCount.toLocaleString()} costumes · ${breakdown.ownedWeaponCount.toLocaleString()} owned weapons${selectionHint}`;
                inventorySelectCurrentPageButton.disabled = getCurrentPageItems().length === 0;
                inventoryClearSelectionButton.disabled = selectedCount === 0;
                inventoryUndoBulkUpdateButton.disabled = !undoStateSnapshot;
                applyBulkWeaponOwnershipButton.disabled = breakdown.weaponCount === 0 || !bulkWeaponOwnershipSelect.value;
                applyBulkWeaponLevelButton.disabled = breakdown.ownedWeaponCount === 0 || !bulkWeaponLevelSelect.value;
                clearBulkWeaponLevelButton.disabled = breakdown.weaponLevelCount === 0;
                applyBulkCostumeOwnershipButton.disabled = breakdown.costumeCount === 0 || !bulkCostumeOwnershipSelect.value;
                resetBulkScopeButton.disabled = breakdown.totalCount === 0;
            }

            function setItemSelection(itemId, isSelected) {
                const normalizedItemId = String(itemId || '');
                if (!normalizedItemId) {
                    return;
                }

                if (isSelected) {
                    selectedItemIds.add(normalizedItemId);
                } else {
                    selectedItemIds.delete(normalizedItemId);
                }

                updateBulkActionUi();
            }

            function clearSelection() {
                if (selectedItemIds.size === 0) {
                    updateBulkActionUi();
                    return;
                }

                selectedItemIds.clear();
                renderInventory();
            }

            function selectCurrentPageItems() {
                const pageItems = getCurrentPageItems();
                if (pageItems.length === 0) {
                    updateBulkActionUi();
                    return;
                }

                pageItems.forEach(item => selectedItemIds.add(String(item.id)));
                renderInventory();
            }

            function storeUndoSnapshot(description) {
                undoStateSnapshot = {
                    description: String(description || 'bulk update'),
                    costumes: cloneInventoryEntries(state.costumes),
                    weapons: cloneInventoryEntries(state.weapons)
                };
                updateBulkActionUi();
            }

            function clearUndoSnapshot() {
                undoStateSnapshot = null;
                updateBulkActionUi();
            }

            function undoLastBulkUpdate() {
                if (!undoStateSnapshot) {
                    return;
                }

                state = {
                    ...state,
                    costumes: cloneInventoryEntries(undoStateSnapshot.costumes),
                    weapons: cloneInventoryEntries(undoStateSnapshot.weapons)
                };
                saveState();
                const description = undoStateSnapshot.description;
                undoStateSnapshot = null;
                renderInventory();
                showSuccess(`Reverted the last bulk update${description ? ` (${description})` : ''}.`);
            }

            function confirmBulkAction(itemCount, message, destructive = false) {
                if (itemCount <= 0) {
                    return false;
                }

                if (!destructive && itemCount < 36) {
                    return true;
                }

                return window.confirm(message);
            }

            function getFilteredItems() {
                const searchText = state.filters.searchText.trim().toLowerCase();
                return allItems.filter(item => {
                    if (state.filters.character !== 'all' && item.character !== state.filters.character) {
                        return false;
                    }

                    if (state.filters.itemType === 'Weapon') {
                        if (String(item.equipmentType).toLowerCase() === 'costume') {
                            return false;
                        }
                    } else if (state.filters.itemType === 'Costume') {
                        if (String(item.equipmentType).toLowerCase() !== 'costume') {
                            return false;
                        }
                    } else if (state.filters.itemType !== 'all' && item.equipmentType !== state.filters.itemType) {
                        return false;
                    }

                    if (searchText.length > 0 && !String(item.name).toLowerCase().includes(searchText)) {
                        return false;
                    }

                    return true;
                }).sort(compareInventoryItems);
            }

            function openItemImagePreview(previewImageUrl, fallbackImageUrl, name, equipmentType) {
                if (!imagePreviewModal || !imagePreviewTitle || !imagePreviewCaption || !imagePreviewImage) {
                    return;
                }

                const resolvedFallbackUrl = String(fallbackImageUrl || '').trim();
                const resolvedPreviewUrl = String(previewImageUrl || '').trim() || resolvedFallbackUrl;
                imagePreviewTitle.textContent = name || 'Gear Art Preview';
                imagePreviewCaption.textContent = equipmentType
                    ? `${equipmentType} image preview`
                    : 'Larger gear art preview.';
                imagePreviewImage.alt = name ? `${name} full art` : 'Gear art preview';
                imagePreviewImage.onerror = () => {
                    imagePreviewImage.onerror = null;
                    if (resolvedFallbackUrl) {
                        imagePreviewImage.src = resolvedFallbackUrl;
                    }
                };
                imagePreviewImage.src = resolvedPreviewUrl;
                imagePreviewModal.show();
            }

            function buildCostumeOptions(selectedValue) {
                return ['do-not-own', 'own'].map(value => {
                    const label = value === 'own' ? 'Own' : 'Do Not Own';
                    return `<option value="${value}" ${selectedValue === value ? 'selected' : ''}>${label}</option>`;
                }).join('');
            }

            function buildWeaponOptions(selectedValue) {
                return inventoryStatuses.map(entry => `<option value="${entry.value}" ${selectedValue === entry.value ? 'selected' : ''}>${entry.label}</option>`).join('');
            }

            function buildLevelOptions(selectedValue) {
                return ['<option value="">Not Set</option>']
                    .concat(allowedInventoryLevels.map(level => `<option value="${level}" ${selectedValue === level ? 'selected' : ''}>Level ${level}</option>`))
                    .join('');
            }

            function renderInventoryCard(item) {
                const isCostume = String(item.equipmentType).toLowerCase() === 'costume';
                const owned = isOwned(item);
                const isSelected = selectedItemIds.has(String(item.id));
                const statusLabel = buildOwnershipLabel(item);
                const weaponRecord = getWeaponRecord(item.id);
                const costumeRecord = getCostumeRecord(item.id);
                const levelValue = weaponRecord.level;
                const levelDisabled = weaponRecord.ownership === 'do-not-own';
                const pills = [
                    `<span class="inventory-pill inventory-pill-type">${escapeHtml(item.equipmentType)}</span>`,
                    item.element ? `<span class="inventory-pill">${escapeHtml(item.element)}</span>` : '',
                    item.abilityType ? `<span class="inventory-pill">${escapeHtml(item.abilityType)}</span>` : '',
                    `<span class="inventory-pill ${owned ? 'inventory-pill-owned' : 'inventory-pill-unowned'}">${escapeHtml(statusLabel)}</span>`
                ].filter(Boolean).join('');

                return `<article class="inventory-card ${owned ? 'inventory-card-owned' : ''} ${isSelected ? 'inventory-card-selected' : ''}" data-item-id="${escapeHtml(item.id)}" data-item-type="${escapeHtml(item.equipmentType)}">
                    <div class="inventory-card-header">
                        <div class="inventory-card-visuals">
                            <div class="inventory-card-portrait-shell">
                                <img class="inventory-card-portrait" src="${escapeHtml(item.characterPortraitUrl)}" alt="${escapeHtml(item.character)} portrait" loading="lazy" />
                            </div>
                            <button type="button" class="inventory-card-item-shell inventory-item-preview-trigger" data-preview-image-url="${escapeHtml(item.previewImageUrl || item.imageUrl)}" data-fallback-image-url="${escapeHtml(item.imageUrl)}" data-preview-name="${escapeHtml(item.name)}" data-preview-equipment="${escapeHtml(item.equipmentType)}" aria-label="Open larger image for ${escapeHtml(item.name)}">
                                <img class="inventory-card-item" src="${escapeHtml(item.imageUrl)}" alt="${escapeHtml(item.name)}" loading="lazy" />
                            </button>
                        </div>
                        <div class="inventory-card-content">
                            <div class="inventory-card-character"><i class="fas fa-user"></i>${escapeHtml(item.character)}</div>
                            <div class="inventory-card-name">${escapeHtml(item.name)}</div>
                            <div class="inventory-pill-row">${pills}</div>
                        </div>
                        <div class="inventory-card-selection form-check">
                            <input class="form-check-input inventory-selection-checkbox" type="checkbox" value="${escapeHtml(item.id)}" data-item-id="${escapeHtml(item.id)}" aria-label="Select ${escapeHtml(item.name)} for bulk actions" ${isSelected ? 'checked' : ''} />
                        </div>
                    </div>
                    <div class="inventory-card-body">
                        <div class="inventory-ability">${escapeHtml(item.abilityText || 'No ability description available.')}</div>
                        <div class="inventory-control-grid">
                            <div class="inventory-control-block ${isCostume ? 'inventory-control-block-full' : ''}">
                                <label class="inventory-control-label" for="ownership-${escapeHtml(item.id)}">${isCostume ? 'Costume Ownership' : 'Weapon Ownership'}</label>
                                <select class="form-select inventory-ownership-select" id="ownership-${escapeHtml(item.id)}" data-item-id="${escapeHtml(item.id)}" data-item-type="${escapeHtml(item.equipmentType)}">
                                    ${isCostume ? buildCostumeOptions(costumeRecord.owned ? 'own' : 'do-not-own') : buildWeaponOptions(weaponRecord.ownership)}
                                </select>
                            </div>
                            ${isCostume ? '' : `<div class="inventory-control-block">
                                <label class="inventory-control-label" for="level-${escapeHtml(item.id)}">Inventory Level</label>
                                <select class="form-select inventory-level-select ${levelDisabled ? 'inventory-select-disabled' : ''}" id="level-${escapeHtml(item.id)}" data-item-id="${escapeHtml(item.id)}" ${levelDisabled ? 'disabled' : ''}>
                                    ${buildLevelOptions(levelValue)}
                                </select>
                            </div>`}
                        </div>
                        <div class="inventory-card-actions">
                            ${item.supportsViewLevels ? `<button type="button" class="btn btn-sm btn-outline-primary inventory-view-levels-button" data-item-id="${escapeHtml(item.id)}"><i class="fas fa-chart-line"></i> View Levels</button>` : ''}
                        </div>
                    </div>
                </article>`;
            }

            function rerenderInventoryCard(itemId) {
                const item = allItems.find(entry => entry.id === itemId);
                if (!item) {
                    return;
                }

                const selector = `.inventory-card[data-item-id="${CSS.escape(String(itemId))}"]`;
                const existingCard = inventoryGrid.querySelector(selector);
                if (!existingCard) {
                    return;
                }

                existingCard.outerHTML = renderInventoryCard(item);
            }

            function renderInventory() {
                const filteredItems = getFilteredItems();
                const paging = getPagedItems(filteredItems);

                if (state.filters.page !== paging.currentPage || state.filters.pageSize !== normalizeInventoryPageSize(state.filters.pageSize)) {
                    state.filters.page = paging.currentPage;
                    state.filters.pageSize = normalizeInventoryPageSize(state.filters.pageSize);
                    saveState();
                }

                updateInventorySummary(filteredItems.length, paging.pageItems.length, paging.pageStart);
                updatePaginationControls(filteredItems.length, paging.currentPage, paging.totalPages);

                if (filteredItems.length === 0) {
                    inventoryGrid.innerHTML = '';
                    inventoryEmptyState.classList.add('active');
                    updateBulkActionUi();
                    return;
                }

                inventoryEmptyState.classList.remove('active');
                inventoryGrid.innerHTML = paging.pageItems.map(renderInventoryCard).join('');
                updateBulkActionUi();
            }

            function updateFilters(nextFilters, resetPage = true) {
                state.filters = {
                    ...state.filters,
                    ...nextFilters
                };
                if (resetPage) {
                    state.filters.page = 1;
                }
                saveState();
                syncFiltersToUi();
                renderInventory();
            }

            function scrollInventoryResultsToTop() {
                const scrollTarget = inventoryPaginationBar || inventoryResultsCard || inventoryGrid;
                if (!scrollTarget) {
                    return;
                }

                const behavior = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth';
                scrollTarget.scrollIntoView({ behavior, block: 'start' });
            }

            function commitSearchFilter(searchText) {
                if (String(searchText || '') === String(state.filters.searchText || '')) {
                    return;
                }

                updateFilters({ searchText: searchText || '' });
            }

            function refreshInventoryMeta() {
                const filteredItems = getFilteredItems();
                const paging = getPagedItems(filteredItems);
                updateInventorySummary(filteredItems.length, paging.pageItems.length, paging.pageStart);
                updatePaginationControls(filteredItems.length, paging.currentPage, paging.totalPages);
                updateBulkActionUi();
            }

            function setCostumeOwnership(itemId, ownsItem) {
                if (ownsItem) {
                    state.costumes[itemId] = { owned: true };
                } else {
                    delete state.costumes[itemId];
                }
                clearUndoSnapshot();
                saveState();
                rerenderInventoryCard(itemId);
                refreshInventoryMeta();
            }

            function setWeaponOwnership(itemId, ownership) {
                const normalizedOwnership = normalizeWeaponOwnership(ownership);
                const current = getWeaponRecord(itemId);
                if (normalizedOwnership === 'do-not-own') {
                    delete state.weapons[itemId];
                } else {
                    state.weapons[itemId] = {
                        ownership: normalizedOwnership,
                        level: current.level
                    };
                }
                clearUndoSnapshot();
                saveState();
                rerenderInventoryCard(itemId);
                refreshInventoryMeta();
            }

            function setWeaponLevel(itemId, level) {
                const normalizedLevel = normalizeWeaponLevel(level);
                const current = getWeaponRecord(itemId);
                if (current.ownership === 'do-not-own') {
                    return;
                }

                state.weapons[itemId] = {
                    ownership: current.ownership,
                    level: normalizedLevel
                };
                clearUndoSnapshot();
                saveState();
                rerenderInventoryCard(itemId);
                refreshInventoryMeta();
            }

            function exportState() {
                const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const anchor = document.createElement('a');
                const stamp = new Date().toISOString().slice(0, 10);
                anchor.href = url;
                anchor.download = `player-inventory-${stamp}.json`;
                document.body.appendChild(anchor);
                anchor.click();
                anchor.remove();
                URL.revokeObjectURL(url);
                showSuccess('Inventory exported successfully. Save the file somewhere safe.');
            }

            function importState(file) {
                const reader = new FileReader();
                reader.onload = () => {
                    try {
                        const parsed = JSON.parse(String(reader.result || '{}'));
                        state = normalizeState(parsed);
                        clearUndoSnapshot();
                        saveState();
                        syncFiltersToUi();
                        renderInventory();
                        showSuccess('Inventory imported successfully.');
                    } catch {
                        showError('The selected file is not a valid inventory export.');
                    }
                };
                reader.onerror = () => {
                    showError('Failed to read the selected import file.');
                };
                reader.readAsText(file);
            }

            function getWeaponOwnershipLabelFromValue(value) {
                const match = inventoryStatuses.find(entry => entry.value === normalizeWeaponOwnership(value));
                return match ? match.label : 'Do Not Own';
            }

            function formatBulkScopeLabel(scopeValue) {
                if (scopeValue === 'selected') {
                    return 'selected items';
                }

                if (scopeValue === 'current-page') {
                    return 'the current page';
                }

                return 'filtered results';
            }

            function applyBulkWeaponOwnershipUpdate() {
                hideMessages();
                const scopeValue = inventoryBulkScope.value || 'filtered';
                const ownership = bulkWeaponOwnershipSelect.value;
                const breakdown = getBulkScopeBreakdown(scopeValue);
                if (!ownership) {
                    showError('Choose a weapon ownership value before applying a bulk update.');
                    return;
                }

                if (breakdown.weaponCount === 0) {
                    showError(`No weapons are available in ${formatBulkScopeLabel(scopeValue)}.`);
                    return;
                }

                const destructive = ownership === 'do-not-own';
                const confirmMessage = destructive
                    ? `Reset ${breakdown.weaponCount.toLocaleString()} weapon entries in ${formatBulkScopeLabel(scopeValue)} to Do Not Own? This also clears stored weapon levels.`
                    : `Apply ${getWeaponOwnershipLabelFromValue(ownership)} to ${breakdown.weaponCount.toLocaleString()} weapons in ${formatBulkScopeLabel(scopeValue)}?`;
                if (!confirmBulkAction(breakdown.weaponCount, confirmMessage, destructive)) {
                    return;
                }

                const undoSnapshot = {
                    description: `weapon ownership (${getWeaponOwnershipLabelFromValue(ownership)})`,
                    costumes: cloneInventoryEntries(state.costumes),
                    weapons: cloneInventoryEntries(state.weapons)
                };
                let changedCount = 0;

                breakdown.items.forEach(item => {
                    if (isCostumeItem(item)) {
                        return;
                    }

                    const current = getWeaponRecord(item.id);
                    if (ownership === 'do-not-own') {
                        if (current.ownership !== 'do-not-own' || current.level != null) {
                            delete state.weapons[item.id];
                            changedCount += 1;
                        }
                        return;
                    }

                    if (current.ownership === ownership) {
                        return;
                    }

                    state.weapons[item.id] = {
                        ownership,
                        level: current.level
                    };
                    changedCount += 1;
                });

                if (changedCount === 0) {
                    showError(`Weapons in ${formatBulkScopeLabel(scopeValue)} already use ${getWeaponOwnershipLabelFromValue(ownership)}.`);
                    return;
                }

                saveState();
                undoStateSnapshot = undoSnapshot;
                renderInventory();
                showSuccess(`Updated ${changedCount.toLocaleString()} weapons to ${getWeaponOwnershipLabelFromValue(ownership)}.`);
            }

            function applyBulkWeaponLevelUpdate() {
                hideMessages();
                const scopeValue = inventoryBulkScope.value || 'filtered';
                const targetLevel = normalizeWeaponLevel(bulkWeaponLevelSelect.value);
                const breakdown = getBulkScopeBreakdown(scopeValue);
                if (targetLevel == null) {
                    showError('Choose a weapon level before applying a bulk update.');
                    return;
                }

                if (breakdown.ownedWeaponCount === 0) {
                    showError(`No owned weapons are available in ${formatBulkScopeLabel(scopeValue)}.`);
                    return;
                }

                if (!confirmBulkAction(breakdown.ownedWeaponCount, `Apply Level ${targetLevel} to ${breakdown.ownedWeaponCount.toLocaleString()} owned weapons in ${formatBulkScopeLabel(scopeValue)}?`)) {
                    return;
                }

                const undoSnapshot = {
                    description: `weapon level (${targetLevel})`,
                    costumes: cloneInventoryEntries(state.costumes),
                    weapons: cloneInventoryEntries(state.weapons)
                };
                let changedCount = 0;

                breakdown.items.forEach(item => {
                    if (isCostumeItem(item)) {
                        return;
                    }

                    const current = getWeaponRecord(item.id);
                    if (current.ownership === 'do-not-own' || current.level === targetLevel) {
                        return;
                    }

                    state.weapons[item.id] = {
                        ownership: current.ownership,
                        level: targetLevel
                    };
                    changedCount += 1;
                });

                if (changedCount === 0) {
                    showError(`Owned weapons in ${formatBulkScopeLabel(scopeValue)} already use Level ${targetLevel}.`);
                    return;
                }

                saveState();
                undoStateSnapshot = undoSnapshot;
                renderInventory();
                showSuccess(`Updated ${changedCount.toLocaleString()} owned weapons to Level ${targetLevel}.`);
            }

            function clearBulkWeaponLevels() {
                hideMessages();
                const scopeValue = inventoryBulkScope.value || 'filtered';
                const breakdown = getBulkScopeBreakdown(scopeValue);
                if (breakdown.weaponLevelCount === 0) {
                    showError(`No stored weapon levels are available in ${formatBulkScopeLabel(scopeValue)}.`);
                    return;
                }

                if (!confirmBulkAction(breakdown.weaponLevelCount, `Clear stored weapon levels for ${breakdown.weaponLevelCount.toLocaleString()} weapons in ${formatBulkScopeLabel(scopeValue)}?`, true)) {
                    return;
                }

                const undoSnapshot = {
                    description: 'clear weapon levels',
                    costumes: cloneInventoryEntries(state.costumes),
                    weapons: cloneInventoryEntries(state.weapons)
                };
                let changedCount = 0;

                breakdown.items.forEach(item => {
                    if (isCostumeItem(item)) {
                        return;
                    }

                    const current = getWeaponRecord(item.id);
                    if (current.ownership === 'do-not-own' || current.level == null) {
                        return;
                    }

                    state.weapons[item.id] = {
                        ownership: current.ownership,
                        level: null
                    };
                    changedCount += 1;
                });

                if (changedCount === 0) {
                    showError(`No stored weapon levels were changed in ${formatBulkScopeLabel(scopeValue)}.`);
                    return;
                }

                saveState();
                undoStateSnapshot = undoSnapshot;
                renderInventory();
                showSuccess(`Cleared stored levels for ${changedCount.toLocaleString()} weapons.`);
            }

            function applyBulkCostumeOwnershipUpdate() {
                hideMessages();
                const scopeValue = inventoryBulkScope.value || 'filtered';
                const targetOwnership = bulkCostumeOwnershipSelect.value;
                const breakdown = getBulkScopeBreakdown(scopeValue);
                if (!targetOwnership) {
                    showError('Choose a costume ownership value before applying a bulk update.');
                    return;
                }

                if (breakdown.costumeCount === 0) {
                    showError(`No costumes are available in ${formatBulkScopeLabel(scopeValue)}.`);
                    return;
                }

                const markOwned = targetOwnership === 'own';
                const confirmMessage = markOwned
                    ? `Mark ${breakdown.costumeCount.toLocaleString()} costumes in ${formatBulkScopeLabel(scopeValue)} as owned?`
                    : `Reset ${breakdown.costumeCount.toLocaleString()} costumes in ${formatBulkScopeLabel(scopeValue)} to Do Not Own?`;
                if (!confirmBulkAction(breakdown.costumeCount, confirmMessage, !markOwned)) {
                    return;
                }

                const undoSnapshot = {
                    description: `costume ownership (${markOwned ? 'Own' : 'Do Not Own'})`,
                    costumes: cloneInventoryEntries(state.costumes),
                    weapons: cloneInventoryEntries(state.weapons)
                };
                let changedCount = 0;

                breakdown.items.forEach(item => {
                    if (!isCostumeItem(item)) {
                        return;
                    }

                    const currentlyOwned = getCostumeRecord(item.id).owned;
                    if (currentlyOwned === markOwned) {
                        return;
                    }

                    if (markOwned) {
                        state.costumes[item.id] = { owned: true };
                    } else {
                        delete state.costumes[item.id];
                    }
                    changedCount += 1;
                });

                if (changedCount === 0) {
                    showError(`Costumes in ${formatBulkScopeLabel(scopeValue)} already use ${markOwned ? 'Own' : 'Do Not Own'}.`);
                    return;
                }

                saveState();
                undoStateSnapshot = undoSnapshot;
                renderInventory();
                showSuccess(`Updated ${changedCount.toLocaleString()} costumes to ${markOwned ? 'Own' : 'Do Not Own'}.`);
            }

            function resetBulkScope() {
                hideMessages();
                const scopeValue = inventoryBulkScope.value || 'filtered';
                const breakdown = getBulkScopeBreakdown(scopeValue);
                if (breakdown.totalCount === 0) {
                    showError(`No items are available in ${formatBulkScopeLabel(scopeValue)}.`);
                    return;
                }

                if (!confirmBulkAction(breakdown.totalCount, `Reset ${breakdown.totalCount.toLocaleString()} items in ${formatBulkScopeLabel(scopeValue)} to Do Not Own? This clears weapon levels too.`, true)) {
                    return;
                }

                const undoSnapshot = {
                    description: 'reset scope to Do Not Own',
                    costumes: cloneInventoryEntries(state.costumes),
                    weapons: cloneInventoryEntries(state.weapons)
                };
                let changedCount = 0;

                breakdown.items.forEach(item => {
                    if (isCostumeItem(item)) {
                        if (getCostumeRecord(item.id).owned) {
                            delete state.costumes[item.id];
                            changedCount += 1;
                        }
                        return;
                    }

                    const current = getWeaponRecord(item.id);
                    if (current.ownership !== 'do-not-own' || current.level != null) {
                        delete state.weapons[item.id];
                        changedCount += 1;
                    }
                });

                if (changedCount === 0) {
                    showError(`Items in ${formatBulkScopeLabel(scopeValue)} are already unowned.`);
                    return;
                }

                saveState();
                undoStateSnapshot = undoSnapshot;
                renderInventory();
                showSuccess(`Reset ${changedCount.toLocaleString()} items to Do Not Own.`);
            }

            function parseDelimitedLine(line, delimiter) {
                const result = [];
                let current = '';
                let inQuotes = false;
                for (let index = 0; index < line.length; index += 1) {
                    const character = line[index];
                    if (character === '"') {
                        if (inQuotes && line[index + 1] === '"') {
                            current += '"';
                            index += 1;
                        } else {
                            inQuotes = !inQuotes;
                        }
                        continue;
                    }

                    if (!inQuotes && character === delimiter) {
                        result.push(current);
                        current = '';
                        continue;
                    }

                    current += character;
                }

                result.push(current);
                return result.map(value => String(value || '').trim());
            }

            function normalizeHeaderKey(value) {
                return normalizeImportName(value).replace(/[^a-z0-9]/g, '');
            }

            function detectStructuredHeader(columns) {
                const normalized = columns.map(normalizeHeaderKey);
                const nameIndex = normalized.findIndex(value => ['name', 'item', 'itemname', 'weapon', 'weaponname', 'costume', 'costumename'].includes(value));
                const ownershipIndex = normalized.findIndex(value => ['ownership', 'owned', 'status', 'ob', 'overboost'].includes(value));
                const levelIndex = normalized.findIndex(value => ['level', 'lv', 'weaponlevel'].includes(value));
                if (nameIndex < 0 || (ownershipIndex < 0 && levelIndex < 0)) {
                    return null;
                }

                return {
                    nameIndex,
                    ownershipIndex,
                    levelIndex
                };
            }

            function looksLikeOwnershipToken(value) {
                const normalized = normalizeImportName(value).replace(/[^a-z0-9]/g, '');
                return normalized === 'own'
                    || normalized === 'owned'
                    || normalized === 'donotown'
                    || normalized === 'notown'
                    || normalized === 'unowned'
                    || normalized === '3star'
                    || normalized === '4star'
                    || normalized === '5star'
                    || /^ob(?:0|[1-9]|10)$/.test(normalized);
            }

            function looksLikeLevelToken(value) {
                const normalized = normalizeImportName(value).replace(/\s+/g, '');
                if (!normalized) {
                    return false;
                }

                return /^lv\d+$/.test(normalized) || /^level\d+$/.test(normalized) || /^\d+$/.test(normalized);
            }

            function parseLooseImportLine(line, lineNumber) {
                const segments = String(line || '').split(/\s+-\s+/).map(value => value.trim()).filter(Boolean);
                const fallback = {
                    lineNumber,
                    rawLine: line,
                    name: String(line || '').trim(),
                    normalizedName: normalizeImportName(line),
                    ownershipToken: '',
                    levelToken: ''
                };
                if (segments.length <= 1) {
                    return fallback;
                }

                const name = segments.shift() || '';
                let ownershipToken = '';
                let levelToken = '';
                segments.forEach(segment => {
                    if (!ownershipToken && looksLikeOwnershipToken(segment)) {
                        ownershipToken = segment;
                        return;
                    }

                    if (!levelToken && looksLikeLevelToken(segment)) {
                        levelToken = segment;
                        return;
                    }

                    if (!ownershipToken) {
                        ownershipToken = segment;
                        return;
                    }

                    if (!levelToken) {
                        levelToken = segment;
                    }
                });

                return {
                    lineNumber,
                    rawLine: line,
                    name,
                    normalizedName: normalizeImportName(name),
                    ownershipToken,
                    levelToken
                };
            }

            function parseStructuredImportLine(line, lineNumber, headerConfig = null) {
                const delimiter = line.includes('\t') ? '\t' : ',';
                const values = parseDelimitedLine(line, delimiter);
                const config = headerConfig || { nameIndex: 0, ownershipIndex: 1, levelIndex: 2 };
                const name = values[config.nameIndex] || '';
                return {
                    lineNumber,
                    rawLine: line,
                    name,
                    normalizedName: normalizeImportName(name),
                    ownershipToken: config.ownershipIndex >= 0 ? values[config.ownershipIndex] || '' : '',
                    levelToken: config.levelIndex >= 0 ? values[config.levelIndex] || '' : ''
                };
            }

            function parsePasteImportText(text) {
                const sourceLines = String(text || '').split(/\r?\n/);
                const rows = [];
                let headerConfig = null;

                sourceLines.forEach((rawLine, index) => {
                    const trimmed = String(rawLine || '').trim();
                    if (!trimmed) {
                        return;
                    }

                    if (!headerConfig && (trimmed.includes('\t') || trimmed.includes(','))) {
                        const candidateColumns = parseDelimitedLine(trimmed, trimmed.includes('\t') ? '\t' : ',');
                        const detectedHeader = detectStructuredHeader(candidateColumns);
                        if (detectedHeader) {
                            headerConfig = detectedHeader;
                            return;
                        }
                    }

                    rows.push((trimmed.includes('\t') || trimmed.includes(','))
                        ? parseStructuredImportLine(trimmed, index + 1, headerConfig)
                        : parseLooseImportLine(trimmed, index + 1));
                });

                const duplicateNameCounts = new Map();
                rows.forEach(row => {
                    if (!row.normalizedName) {
                        return;
                    }
                    duplicateNameCounts.set(row.normalizedName, (duplicateNameCounts.get(row.normalizedName) || 0) + 1);
                });

                return {
                    rows,
                    duplicateNameCounts
                };
            }

            function resolveImportItem(row) {
                if (!row.normalizedName) {
                    return { item: null, error: 'Missing item name.' };
                }

                const matches = itemNameLookup.get(row.normalizedName) || [];
                if (matches.length === 0) {
                    return { item: null, error: 'No catalog item matched this name.' };
                }

                if (matches.length > 1) {
                    return {
                        item: null,
                        error: `Multiple catalog items matched this name: ${matches.map(match => `${match.name} (${match.character}, ${match.equipmentType})`).join('; ')}`
                    };
                }

                return { item: matches[0], error: '' };
            }

            function parseImportOwnershipForItem(item, token) {
                const trimmed = String(token || '').trim();
                if (!trimmed) {
                    return { supplied: false, value: null, label: 'Not supplied', error: '' };
                }

                const normalized = normalizeImportName(trimmed).replace(/[^a-z0-9]/g, '');
                if (isCostumeItem(item)) {
                    if (['own', 'owned', 'yes', 'true', '1'].includes(normalized)) {
                        return { supplied: true, value: 'own', label: 'Own', error: '' };
                    }

                    if (['donotown', 'notown', 'unowned', 'no', 'false', '0'].includes(normalized)) {
                        return { supplied: true, value: 'do-not-own', label: 'Do Not Own', error: '' };
                    }

                    return { supplied: true, value: null, label: trimmed, error: 'Invalid costume ownership token.' };
                }

                if (['donotown', 'notown', 'unowned', 'no', 'false', '0'].includes(normalized)) {
                    return { supplied: true, value: 'do-not-own', label: 'Do Not Own', error: '' };
                }

                if (['own', 'owned', 'yes', 'true', '1', 'ob0'].includes(normalized)) {
                    return { supplied: true, value: '5-star', label: '5 Star', error: '' };
                }

                if (normalized === '3star') {
                    return { supplied: true, value: '3-star', label: '3 Star', error: '' };
                }

                if (normalized === '4star') {
                    return { supplied: true, value: '4-star', label: '4 Star', error: '' };
                }

                if (normalized === '5star') {
                    return { supplied: true, value: '5-star', label: '5 Star', error: '' };
                }

                const obMatch = /^ob([1-9]|10)$/.exec(normalized);
                if (obMatch) {
                    const value = `ob${obMatch[1]}`;
                    return { supplied: true, value, label: getWeaponOwnershipLabelFromValue(value), error: '' };
                }

                return { supplied: true, value: null, label: trimmed, error: 'Invalid weapon ownership token.' };
            }

            function parseImportLevelToken(token) {
                const trimmed = String(token || '').trim();
                if (!trimmed) {
                    return { supplied: false, value: null, label: 'Not supplied', error: '' };
                }

                const normalized = normalizeImportName(trimmed).replace(/\s+/g, '');
                const numericValue = normalized.startsWith('level')
                    ? Number.parseInt(normalized.substring(5), 10)
                    : normalized.startsWith('lv')
                        ? Number.parseInt(normalized.substring(2), 10)
                        : Number.parseInt(normalized, 10);
                if (!allowedInventoryLevels.includes(numericValue)) {
                    return { supplied: true, value: null, label: trimmed, error: 'Invalid inventory level.' };
                }

                return { supplied: true, value: numericValue, label: `Level ${numericValue}`, error: '' };
            }

            function buildImportRowPreview(row, mode) {
                const duplicateCount = lastParsedPasteImport?.duplicateNameCounts?.get(row.normalizedName) || 0;
                const issues = [];
                if (duplicateCount > 1) {
                    issues.push('Duplicate item name appears multiple times in the pasted rows.');
                }

                const resolved = resolveImportItem(row);
                if (resolved.error) {
                    issues.push(resolved.error);
                }

                const item = resolved.item;
                const ownership = item ? parseImportOwnershipForItem(item, row.ownershipToken) : { supplied: false, value: null, label: 'Unavailable', error: '' };
                const level = parseImportLevelToken(row.levelToken);
                if (ownership.error) {
                    issues.push(ownership.error);
                }
                if (level.error) {
                    issues.push(level.error);
                }

                if (item) {
                    if (isCostumeItem(item)) {
                        if (!ownership.supplied) {
                            issues.push('Costume rows require ownership.');
                        }
                        if (level.supplied) {
                            issues.push('Costume rows do not support levels.');
                        }
                    } else {
                        const currentWeapon = getWeaponRecord(item.id);
                        if (!ownership.supplied && !level.supplied) {
                            issues.push('Weapon rows require ownership, level, or both.');
                        }
                        if (ownership.supplied && ownership.value === 'do-not-own' && level.supplied) {
                            issues.push('Do Not Own rows cannot also set a level.');
                        }
                        if (level.supplied && !ownership.supplied && currentWeapon.ownership === 'do-not-own') {
                            issues.push('Set weapon ownership before importing a level for an unowned weapon.');
                        }
                    }
                }

                if (issues.length > 0) {
                    return {
                        row,
                        item,
                        ownership,
                        level,
                        currentState: null,
                        nextState: null,
                        canApply: false,
                        wouldChange: false,
                        badgeClass: 'text-bg-danger',
                        statusLabel: 'Invalid',
                        details: issues
                    };
                }

                if (isCostumeItem(item)) {
                    const currentState = { owned: getCostumeRecord(item.id).owned };
                    const nextState = { ...currentState };
                    const details = [];
                    if (mode === 'fill-blanks' && currentState.owned) {
                        details.push('Skipped because this costume is already owned.');
                    } else {
                        nextState.owned = ownership.value === 'own';
                    }

                    const wouldChange = currentState.owned !== nextState.owned;
                    return {
                        row,
                        item,
                        ownership,
                        level,
                        currentState,
                        nextState,
                        canApply: wouldChange,
                        wouldChange,
                        badgeClass: wouldChange ? 'text-bg-success' : details.length > 0 ? 'text-bg-warning' : 'text-bg-secondary',
                        statusLabel: wouldChange ? 'Will update' : details.length > 0 ? 'Skipped' : 'No change',
                        details: details.length > 0 ? details : [`${ownership.label} will be applied.`]
                    };
                }

                const currentState = getWeaponRecord(item.id);
                const nextState = { ...currentState };
                const details = [];
                if (ownership.supplied) {
                    if (mode === 'fill-blanks' && currentState.ownership !== 'do-not-own') {
                        details.push('Skipped ownership because this weapon is already owned.');
                    } else {
                        nextState.ownership = ownership.value;
                        if (ownership.value === 'do-not-own') {
                            nextState.level = null;
                        }
                    }
                }

                if (level.supplied) {
                    if (mode === 'fill-blanks' && currentState.level != null) {
                        details.push('Skipped level because a level is already stored.');
                    } else if (nextState.ownership === 'do-not-own') {
                        details.push('Skipped level because the weapon would remain unowned.');
                    } else {
                        nextState.level = level.value;
                    }
                } else if (mode === 'replace' && ownership.supplied && ownership.value !== 'do-not-own' && currentState.level != null) {
                    nextState.level = null;
                    details.push('Replace mode clears the existing stored level when no level is supplied.');
                }

                const wouldChange = currentState.ownership !== nextState.ownership || currentState.level !== nextState.level;
                return {
                    row,
                    item,
                    ownership,
                    level,
                    currentState,
                    nextState,
                    canApply: wouldChange,
                    wouldChange,
                    badgeClass: wouldChange ? 'text-bg-success' : details.length > 0 ? 'text-bg-warning' : 'text-bg-secondary',
                    statusLabel: wouldChange ? 'Will update' : details.length > 0 ? 'Skipped' : 'No change',
                    details: details.length > 0 ? details : ['No changes are needed for this weapon.']
                };
            }

            function renderPasteImportPreview() {
                const mode = pasteImportMode.value || 'merge';
                if (!lastParsedPasteImport || !Array.isArray(lastParsedPasteImport.rows) || lastParsedPasteImport.rows.length === 0) {
                    pasteImportSummary.textContent = 'Parse pasted rows to see matches, skipped lines, and proposed updates.';
                    pasteImportErrors.innerHTML = '';
                    pasteImportPreviewBody.innerHTML = '<tr><td colspan="4" class="inventory-import-preview-empty">Parse rows to preview bulk inventory updates.</td></tr>';
                    applyPasteImportButton.disabled = true;
                    return;
                }

                const previews = lastParsedPasteImport.rows.map(row => buildImportRowPreview(row, mode));
                const invalidCount = previews.filter(entry => entry.statusLabel === 'Invalid').length;
                const updateCount = previews.filter(entry => entry.canApply).length;
                const skippedCount = previews.filter(entry => !entry.canApply && entry.statusLabel === 'Skipped').length;
                const matchedCount = previews.filter(entry => !!entry.item).length;
                pasteImportSummary.textContent = `${previews.length.toLocaleString()} pasted rows · ${matchedCount.toLocaleString()} matched catalog items · ${updateCount.toLocaleString()} rows will update · ${skippedCount.toLocaleString()} skipped · ${invalidCount.toLocaleString()} invalid`;

                const invalidMessages = previews
                    .filter(entry => entry.statusLabel === 'Invalid')
                    .map(entry => `<li>Line ${entry.row.lineNumber}: ${entry.details.map(detail => escapeHtml(detail)).join(' ')}</li>`);
                pasteImportErrors.innerHTML = invalidMessages.length > 0
                    ? `<div class="fw-semibold mb-1">Some rows need attention before they can apply.</div><ul class="mb-0 ps-3">${invalidMessages.join('')}</ul>`
                    : '';

                pasteImportPreviewBody.innerHTML = previews.map(entry => {
                    const itemCell = entry.item
                        ? `<div class="fw-semibold">${escapeHtml(entry.item.name)}</div><small>${escapeHtml(entry.item.character)} · ${escapeHtml(entry.item.equipmentType)}</small>`
                        : `<span class="text-muted">No match</span>`;
                    const parsedBits = [
                        `<div><strong>Name:</strong> ${escapeHtml(entry.row.name || '(blank)')}</div>`,
                        `<div><strong>Ownership:</strong> ${escapeHtml(entry.ownership.label)}</div>`,
                        `<div><strong>Level:</strong> ${escapeHtml(entry.level.label)}</div>`
                    ].join('');
                    const detailHtml = entry.details.map(detail => `<small>${escapeHtml(detail)}</small>`).join('');
                    return `<tr>
                        <td>${entry.row.lineNumber.toLocaleString()}</td>
                        <td>${itemCell}</td>
                        <td>${parsedBits}<small>${escapeHtml(entry.row.rawLine)}</small></td>
                        <td><span class="badge ${entry.badgeClass}">${escapeHtml(entry.statusLabel)}</span>${detailHtml}</td>
                    </tr>`;
                }).join('');

                lastParsedPasteImport.previews = previews;
                applyPasteImportButton.disabled = updateCount === 0;
            }

            function clearPasteImportSession(clearInput = false) {
                lastParsedPasteImport = null;
                if (clearInput) {
                    pasteImportInput.value = '';
                }
                renderPasteImportPreview();
            }

            function parsePasteImportInputText() {
                hideMessages();
                const text = pasteImportInput.value || '';
                if (!text.trim()) {
                    clearPasteImportSession(false);
                    showError('Paste some inventory rows before parsing.');
                    return;
                }

                const parsed = parsePasteImportText(text);
                if (!parsed.rows.length) {
                    clearPasteImportSession(false);
                    showError('No import rows were found in the pasted text.');
                    return;
                }

                lastParsedPasteImport = parsed;
                renderPasteImportPreview();
            }

            function applyParsedPasteImport() {
                hideMessages();
                if (!lastParsedPasteImport || !Array.isArray(lastParsedPasteImport.previews)) {
                    showError('Parse your pasted rows before applying them.');
                    return;
                }

                const applicableRows = lastParsedPasteImport.previews.filter(entry => entry.canApply && entry.item);
                if (applicableRows.length === 0) {
                    showError('No parsed rows are ready to apply.');
                    return;
                }

                const mode = pasteImportMode.value || 'merge';
                const confirmMessage = mode === 'replace'
                    ? `Apply ${applicableRows.length.toLocaleString()} pasted updates in Replace mode? Existing stored levels may be cleared when a replacement row omits a level.`
                    : `Apply ${applicableRows.length.toLocaleString()} pasted updates to your local inventory?`;
                if (!confirmBulkAction(applicableRows.length, confirmMessage, mode === 'replace')) {
                    return;
                }

                const undoSnapshot = {
                    description: `paste import (${mode})`,
                    costumes: cloneInventoryEntries(state.costumes),
                    weapons: cloneInventoryEntries(state.weapons)
                };

                applicableRows.forEach(entry => {
                    if (isCostumeItem(entry.item)) {
                        if (entry.nextState.owned) {
                            state.costumes[entry.item.id] = { owned: true };
                        } else {
                            delete state.costumes[entry.item.id];
                        }
                        return;
                    }

                    if (entry.nextState.ownership === 'do-not-own') {
                        delete state.weapons[entry.item.id];
                        return;
                    }

                    state.weapons[entry.item.id] = {
                        ownership: entry.nextState.ownership,
                        level: entry.nextState.level
                    };
                });

                saveState();
                undoStateSnapshot = undoSnapshot;
                renderInventory();
                clearPasteImportSession(false);
                pasteImportModal?.hide();
                showSuccess(`Applied ${applicableRows.length.toLocaleString()} pasted inventory updates.`);
            }

            function setSnapshotLoading(isLoading) {
                snapshotSpinner.classList.toggle('active', isLoading);
                snapshotOverboost.disabled = isLoading;
                snapshotLevel.disabled = isLoading;
                snapshotLevelRange.disabled = isLoading;
            }

            function showSnapshotError(show) {
                snapshotError.classList.toggle('active', show);
            }

            function formatNumber(value) {
                return Number(value || 0).toLocaleString();
            }

            function updateSnapshotContent(data) {
                showSnapshotError(false);
                const snapshotAbility = document.getElementById('snapshotAbility');
                const snapshotPatk = document.getElementById('snapshotPatk');
                const snapshotMatk = document.getElementById('snapshotMatk');
                const snapshotHeal = document.getElementById('snapshotHeal');
                const snapshotRAbilities = document.getElementById('snapshotRAbilities');
                const snapshotCustomizations = document.getElementById('snapshotCustomizations');
                const snapshotCustomizationsSection = document.getElementById('snapshotCustomizationsSection');

                snapshotAbility.innerHTML = data.abilityText ? String(data.abilityText).replace(/\r?\n/g, '<br />') : '<span class="text-muted">No ability data</span>';
                snapshotPatk.textContent = formatNumber(data.patk);
                snapshotMatk.textContent = formatNumber(data.matk);
                snapshotHeal.textContent = formatNumber(data.heal);

                if (typeof data.level === 'number') {
                    snapshotLevel.value = String(data.level);
                    snapshotLevelRange.value = String(data.level);
                }

                const baseRAbilities = Array.isArray(data.rAbilities) ? data.rAbilities : [];
                const customizationRAbilities = Array.isArray(data.customizations)
                    ? data.customizations.filter(entry => entry && entry.kind === 'R Ability')
                    : [];
                const combinedRAbilities = [
                    ...baseRAbilities.map(entry => ({
                        isCustomization: false,
                        isLocked: !!entry.isLocked,
                        lockedUntilLevel: entry.lockedUntilLevel,
                        basePoints: entry.basePoints,
                        upgradePoints: entry.upgradePoints,
                        totalPoints: entry.totalPoints,
                        skillName: entry.skillName,
                        effects: Array.isArray(entry.effects) ? entry.effects : []
                    })),
                    ...customizationRAbilities.map(entry => ({
                        isCustomization: true,
                        isLocked: false,
                        lockedUntilLevel: null,
                        basePoints: 0,
                        upgradePoints: 0,
                        totalPoints: Number(entry.passiveSkillPoints || 0),
                        skillName: entry.passiveSkillName || entry.description || 'Customization R Ability',
                        effects: Array.isArray(entry.passiveEffects) ? entry.passiveEffects : []
                    }))
                ];

                if (combinedRAbilities.length > 0) {
                    snapshotRAbilities.innerHTML = combinedRAbilities.map(entry => {
                        if (entry.isLocked) {
                            const lockHint = entry.lockedUntilLevel != null ? ` <span class="text-muted">(unlocks at Lv. ${entry.lockedUntilLevel})</span>` : '';
                            return `<li class="text-muted"><i class="fas fa-lock fa-xs me-1"></i>${escapeHtml(entry.skillName)}${lockHint}</li>`;
                        }

                        const breakdown = entry.basePoints > 0 && entry.upgradePoints > 0
                            ? ` <small class="text-muted">(Lv. ${entry.basePoints} + OB ${entry.upgradePoints})</small>`
                            : '';
                        const customizationBadge = entry.isCustomization ? '<span class="badge text-bg-light me-1">Cust.</span>' : '';
                        const effectsHtml = Array.isArray(entry.effects) && entry.effects.length > 0
                            ? `<ul class="snapshot-rability-effects">${entry.effects
                                .filter(effect => effect && effect.description)
                                .map(effect => `<li>${escapeHtml(effect.description)}</li>`)
                                .join('')}</ul>`
                            : '';
                        return `<li class="snapshot-rability-item"><div class="snapshot-rability-main">${customizationBadge}<strong>+${escapeHtml(entry.totalPoints)}</strong> ${escapeHtml(entry.skillName)}${breakdown}</div>${effectsHtml}</li>`;
                    }).join('');
                } else {
                    snapshotRAbilities.innerHTML = '<li class="text-muted">No R Ability data at this level</li>';
                }

                const nonRAbilityCustomizations = Array.isArray(data.customizations)
                    ? data.customizations.filter(entry => entry && entry.kind !== 'R Ability')
                    : [];
                if (nonRAbilityCustomizations.length > 0) {
                    snapshotCustomizations.innerHTML = nonRAbilityCustomizations.map(entry => `<div class="snapshot-customization-entry"><span class="badge text-bg-light">${escapeHtml(entry.slot)}</span><span class="text-muted">${escapeHtml(entry.kind)}</span><span>${escapeHtml(entry.description)}</span></div>`).join('');
                    snapshotCustomizationsSection.style.display = '';
                } else {
                    snapshotCustomizations.innerHTML = '<span class="text-muted">No customizations available</span>';
                    snapshotCustomizationsSection.style.display = 'none';
                }
            }

            function fetchSnapshot() {
                if (!currentSnapshotItem) {
                    return;
                }

                if (snapshotAbortController) {
                    snapshotAbortController.abort();
                }

                snapshotAbortController = new AbortController();
                const overboost = snapshotOverboost.value;
                const level = snapshotLevel.value;
                const url = `/PlayerInventoryManagement?handler=WeaponSnapshot&weaponId=${encodeURIComponent(currentSnapshotItem.id)}&overboost=${encodeURIComponent(overboost)}&level=${encodeURIComponent(level)}`;
                setSnapshotLoading(true);
                showSnapshotError(false);

                fetch(url, { signal: snapshotAbortController.signal })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Request failed');
                        }
                        return response.json();
                    })
                    .then(data => {
                        updateSnapshotContent(data);
                        setSnapshotLoading(false);
                    })
                    .catch(error => {
                        if (error.name === 'AbortError') {
                            return;
                        }
                        showSnapshotError(true);
                        setSnapshotLoading(false);
                    });
            }

            function debouncedFetchSnapshot() {
                clearTimeout(snapshotDebounceTimer);
                snapshotDebounceTimer = setTimeout(fetchSnapshot, 200);
            }

            function openSnapshot(itemId) {
                const item = allItems.find(entry => entry.id === itemId);
                if (!item || !bsModal) {
                    return;
                }

                currentSnapshotItem = item;
                const weaponRecord = getWeaponRecord(item.id);
                snapshotPortrait.src = item.characterPortraitUrl;
                snapshotPortrait.alt = `${item.character} portrait`;
                snapshotItemArt.src = item.previewImageUrl || item.imageUrl;
                snapshotItemArt.alt = item.name;
                snapshotCharacter.textContent = item.character;
                snapshotWeaponName.textContent = item.name;
                snapshotEquipment.textContent = item.equipmentType;
                snapshotElement.textContent = item.element || 'N/A';
                snapshotAbilityType.textContent = item.abilityType || 'N/A';
                snapshotOverboost.value = getSnapshotOverboostValue(weaponRecord.ownership);
                const startingLevel = weaponRecord.level || defaultSnapshotLevel;
                snapshotLevel.value = String(startingLevel);
                snapshotLevelRange.value = String(startingLevel);
                document.getElementById('snapshotAbility').innerHTML = '<span class="text-muted">Loading...</span>';
                document.getElementById('snapshotRAbilities').innerHTML = '<li class="text-muted">Loading...</li>';
                document.getElementById('snapshotCustomizations').innerHTML = '<span class="text-muted">Loading...</span>';
                showSnapshotError(false);
                bsModal.show();
                fetchSnapshot();
            }

            inventorySearchInput.addEventListener('input', event => {
                clearTimeout(inventorySearchDebounceTimer);
                const nextValue = event.target.value || '';
                inventorySearchDebounceTimer = setTimeout(() => {
                    commitSearchFilter(nextValue);
                }, 200);
            });

            inventorySearchInput.addEventListener('change', event => {
                clearTimeout(inventorySearchDebounceTimer);
                commitSearchFilter(event.target.value || '');
            });

            inventoryCharacterFilter.addEventListener('change', event => {
                updateFilters({ character: event.target.value || 'all' });
            });

            inventoryTypeFilter.addEventListener('change', event => {
                updateFilters({ itemType: event.target.value || 'all' });
            });

            inventoryPageSizeSelect.addEventListener('change', event => {
                updateFilters({ pageSize: normalizeInventoryPageSize(event.target.value), page: 1 }, false);
                scrollInventoryResultsToTop();
            });

            inventoryFirstPageButton.addEventListener('click', () => {
                if (state.filters.page <= 1) {
                    return;
                }

                updateFilters({ page: 1 }, false);
                scrollInventoryResultsToTop();
            });

            inventoryPreviousPageButton.addEventListener('click', () => {
                if (state.filters.page <= 1) {
                    return;
                }

                updateFilters({ page: state.filters.page - 1 }, false);
                scrollInventoryResultsToTop();
            });

            inventoryNextPageButton.addEventListener('click', () => {
                updateFilters({ page: state.filters.page + 1 }, false);
                scrollInventoryResultsToTop();
            });

            inventoryLastPageButton.addEventListener('click', () => {
                const filteredItems = getFilteredItems();
                const { totalPages } = getPagedItems(filteredItems);
                if (totalPages <= 0 || state.filters.page >= totalPages) {
                    return;
                }

                updateFilters({ page: totalPages }, false);
                scrollInventoryResultsToTop();
            });

            inventoryClearFiltersButton.addEventListener('click', () => {
                clearTimeout(inventorySearchDebounceTimer);
                updateFilters({ searchText: '', character: 'all', itemType: 'all' });
            });

            inventoryExportButton.addEventListener('click', () => {
                hideMessages();
                exportState();
            });

            inventoryBulkHelpButton.addEventListener('click', () => {
                inventoryBulkHelpModal?.show();
            });

            inventoryPasteImportButton.addEventListener('click', () => {
                clearPasteImportSession(false);
                pasteImportModal?.show();
            });

            inventoryImportButton.addEventListener('click', () => {
                inventoryImportFileInput.click();
            });

            inventoryImportFileInput.addEventListener('change', event => {
                const file = event.target.files && event.target.files[0];
                if (!file) {
                    return;
                }
                hideMessages();
                importState(file);
                inventoryImportFileInput.value = '';
            });

            inventoryResetButton.addEventListener('click', () => {
                if (!window.confirm('Reset all local inventory data stored in this browser?')) {
                    return;
                }
                hideMessages();
                state = createDefaultState();
                clearUndoSnapshot();
                selectedItemIds.clear();
                saveState();
                syncFiltersToUi();
                renderInventory();
                showSuccess('Local inventory data was reset.');
            });

            inventoryBulkScope.addEventListener('change', () => {
                updateBulkActionUi();
            });

            bulkWeaponOwnershipSelect.addEventListener('change', () => {
                updateBulkActionUi();
            });

            bulkWeaponLevelSelect.addEventListener('change', () => {
                updateBulkActionUi();
            });

            bulkCostumeOwnershipSelect.addEventListener('change', () => {
                updateBulkActionUi();
            });

            inventorySelectCurrentPageButton.addEventListener('click', () => {
                hideMessages();
                selectCurrentPageItems();
            });

            inventoryClearSelectionButton.addEventListener('click', () => {
                hideMessages();
                clearSelection();
            });

            inventoryUndoBulkUpdateButton.addEventListener('click', () => {
                hideMessages();
                undoLastBulkUpdate();
            });

            applyBulkWeaponOwnershipButton.addEventListener('click', () => {
                applyBulkWeaponOwnershipUpdate();
            });

            applyBulkWeaponLevelButton.addEventListener('click', () => {
                applyBulkWeaponLevelUpdate();
            });

            clearBulkWeaponLevelButton.addEventListener('click', () => {
                clearBulkWeaponLevels();
            });

            applyBulkCostumeOwnershipButton.addEventListener('click', () => {
                applyBulkCostumeOwnershipUpdate();
            });

            resetBulkScopeButton.addEventListener('click', () => {
                resetBulkScope();
            });

            parsePasteImportButton.addEventListener('click', () => {
                parsePasteImportInputText();
            });

            applyPasteImportButton.addEventListener('click', () => {
                applyParsedPasteImport();
            });

            clearPasteImportButton.addEventListener('click', () => {
                clearPasteImportSession(true);
            });

            pasteImportMode.addEventListener('change', () => {
                renderPasteImportPreview();
            });

            inventoryGrid.addEventListener('change', event => {
                const selectionCheckbox = event.target.closest('.inventory-selection-checkbox');
                const ownershipSelect = event.target.closest('.inventory-ownership-select');
                const levelSelect = event.target.closest('.inventory-level-select');

                if (selectionCheckbox) {
                    const itemId = selectionCheckbox.getAttribute('data-item-id');
                    if (!itemId) {
                        return;
                    }

                    setItemSelection(itemId, selectionCheckbox.checked);
                    const card = selectionCheckbox.closest('.inventory-card');
                    card?.classList.toggle('inventory-card-selected', selectionCheckbox.checked);
                    return;
                }

                if (ownershipSelect) {
                    const itemId = ownershipSelect.getAttribute('data-item-id');
                    const itemType = ownershipSelect.getAttribute('data-item-type');
                    if (!itemId || !itemType) {
                        return;
                    }
                    hideMessages();
                    if (String(itemType).toLowerCase() === 'costume') {
                        setCostumeOwnership(itemId, ownershipSelect.value === 'own');
                    } else {
                        setWeaponOwnership(itemId, ownershipSelect.value);
                    }
                    return;
                }

                if (levelSelect) {
                    const itemId = levelSelect.getAttribute('data-item-id');
                    if (!itemId) {
                        return;
                    }
                    hideMessages();
                    setWeaponLevel(itemId, levelSelect.value);
                }
            });

            inventoryGrid.addEventListener('click', event => {
                const previewTrigger = event.target.closest('.inventory-item-preview-trigger');
                if (previewTrigger) {
                    const previewImageUrl = previewTrigger.getAttribute('data-preview-image-url');
                    const fallbackImageUrl = previewTrigger.getAttribute('data-fallback-image-url');
                    const previewName = previewTrigger.getAttribute('data-preview-name');
                    const previewEquipment = previewTrigger.getAttribute('data-preview-equipment');
                    openItemImagePreview(previewImageUrl, fallbackImageUrl, previewName, previewEquipment);
                    return;
                }

                const viewButton = event.target.closest('.inventory-view-levels-button');
                if (!viewButton) {
                    return;
                }
                const itemId = viewButton.getAttribute('data-item-id');
                if (!itemId) {
                    return;
                }
                openSnapshot(itemId);
            });

            snapshotOverboost.addEventListener('change', () => {
                debouncedFetchSnapshot();
            });

            snapshotLevel.addEventListener('input', () => {
                snapshotLevelRange.value = snapshotLevel.value;
            });

            snapshotLevel.addEventListener('change', () => {
                snapshotLevelRange.value = snapshotLevel.value;
                debouncedFetchSnapshot();
            });

            snapshotLevelRange.addEventListener('input', () => {
                snapshotLevel.value = snapshotLevelRange.value;
                debouncedFetchSnapshot();
            });

            pasteImportModalElement?.addEventListener('hidden.bs.modal', () => {
                clearPasteImportSession(false);
            });

            populateCharacterOptions();
            syncFiltersToUi();
            renderPasteImportPreview();
            renderInventory();
        })();
    </script>
}
