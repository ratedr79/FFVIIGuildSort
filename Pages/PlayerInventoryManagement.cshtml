@page
@model FFVIIEverCrisisAnalyzer.Pages.PlayerInventoryManagementModel
@using System.Text.Json
@{
    ViewData["Title"] = "Player Inventory Management";

    var jsonOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    var itemsJson = JsonSerializer.Serialize(Model.Items, jsonOptions);
    var charactersJson = JsonSerializer.Serialize(Model.AvailableCharacters, jsonOptions);
    var levelsJson = JsonSerializer.Serialize(Model.AllowedInventoryLevels, jsonOptions);
}

<style>
    .inventory-page-shell {
        max-width: 1440px;
    }

    .inventory-hero-card,
    .inventory-toolbar-card,
    .inventory-results-card,
    .inventory-backup-card {
        border: 0;
        box-shadow: 0 0.6rem 1.75rem rgba(15, 23, 42, 0.08);
        border-radius: 1.1rem;
    }

    .inventory-hero-card {
        background: linear-gradient(135deg, rgba(13, 110, 253, 0.12), rgba(111, 66, 193, 0.12));
    }

    .inventory-kicker {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #0d6efd;
        margin-bottom: 0.45rem;
    }

    .inventory-toolbar-card {
        position: sticky;
        top: 1rem;
        z-index: 20;
    }

    .inventory-toolbar-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .inventory-summary-bar {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .inventory-summary-title {
        font-weight: 700;
        font-size: 1rem;
    }

    .inventory-summary-meta {
        color: #6c757d;
        font-size: 0.92rem;
    }

    .inventory-pagination-bar {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 0.85rem;
        margin-bottom: 1rem;
    }

    .inventory-pagination-group {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.65rem;
    }

    .inventory-pagination-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
        gap: 0.5rem;
    }

    .inventory-pagination-status {
        color: #6c757d;
        font-size: 0.9rem;
        font-weight: 600;
        text-align: center;
        min-width: 7.5rem;
    }

    .inventory-page-size-select {
        width: auto;
        min-width: 6rem;
    }

    .inventory-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(305px, 1fr));
        gap: 1rem;
    }

    .inventory-card {
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(148, 163, 184, 0.24);
        border-radius: 1rem;
        background: #fff;
        overflow: hidden;
        min-height: 100%;
        content-visibility: auto;
        contain-intrinsic-size: 440px;
        transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
    }

    .inventory-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.8rem 1.8rem rgba(15, 23, 42, 0.09);
    }

    .inventory-card-owned {
        border-color: rgba(13, 110, 253, 0.4);
        box-shadow: inset 0 0 0 1px rgba(13, 110, 253, 0.08);
    }

    .inventory-card-selected {
        border-color: rgba(111, 66, 193, 0.52);
        box-shadow: inset 0 0 0 2px rgba(111, 66, 193, 0.12), 0 0.7rem 1.65rem rgba(111, 66, 193, 0.12);
    }

    .inventory-card-header {
        display: flex;
        gap: 0.85rem;
        align-items: flex-start;
        padding: 1rem 1rem 0.75rem;
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.95), rgba(255, 255, 255, 0.95));
    }

    .inventory-card-visuals {
        display: flex;
        gap: 0.65rem;
        align-items: center;
        flex-shrink: 0;
    }

    .inventory-card-portrait-shell,
    .inventory-card-item-shell {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.85rem;
        overflow: hidden;
        background: #f8f9fa;
        border: 1px solid rgba(148, 163, 184, 0.25);
    }

    .inventory-card-portrait-shell {
        width: 3.1rem;
        height: 3.1rem;
        padding: 0.18rem;
        background: radial-gradient(circle at top, rgba(13, 110, 253, 0.12), rgba(255, 255, 255, 0.92));
    }

    .inventory-card-item-shell {
        width: 4.15rem;
        height: 4.15rem;
        padding: 0.2rem;
    }

    .inventory-item-preview-trigger {
        padding: 0;
        cursor: zoom-in;
    }

    .inventory-item-preview-trigger:focus-visible {
        outline: 2px solid #0d6efd;
        outline-offset: 2px;
    }

    .inventory-card-portrait,
    .inventory-card-item {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0.7rem;
        display: block;
    }

    .inventory-card-content {
        min-width: 0;
        flex: 1 1 auto;
    }

    .inventory-card-selection {
        margin-left: auto;
        flex-shrink: 0;
    }

    .inventory-card-selection .form-check-input {
        width: 1.15rem;
        height: 1.15rem;
        cursor: pointer;
        margin-top: 0.1rem;
    }

    .inventory-card-character {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: #6c757d;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.35rem;
    }

    .inventory-card-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 0.5rem;
        line-height: 1.3;
    }

    .inventory-pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .inventory-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.25rem 0.65rem;
        background: #f1f5f9;
        color: #334155;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .inventory-pill-type {
        background: rgba(13, 110, 253, 0.1);
        color: #0b5ed7;
    }

    .inventory-pill-owned {
        background: rgba(25, 135, 84, 0.12);
        color: #0f5132;
    }

    .inventory-pill-unowned {
        background: rgba(220, 53, 69, 0.1);
        color: #842029;
    }

    .inventory-card-body {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        padding: 0.95rem 1rem 1rem;
        height: 100%;
    }

    .inventory-ability {
        color: #4b5563;
        font-size: 0.92rem;
        line-height: 1.5;
        min-height: 4.1rem;
    }

    .inventory-control-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
    }

    .inventory-control-block {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .inventory-control-block-full {
        grid-column: 1 / -1;
    }

    .inventory-control-label {
        font-size: 0.78rem;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .inventory-select-disabled {
        opacity: 0.66;
    }

    .inventory-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: auto;
    }

    .inventory-bulk-panel {
        margin-bottom: 1rem;
        border: 1px solid rgba(148, 163, 184, 0.24);
        border-radius: 1rem;
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.96), rgba(255, 255, 255, 0.98));
        padding: 1rem;
    }

    .inventory-bulk-summary {
        color: #64748b;
        font-size: 0.92rem;
    }

    .inventory-bulk-title-row {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
    }

    .inventory-help-trigger {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.7rem;
        height: 1.7rem;
        border-radius: 999px;
        border: 1px solid rgba(13, 110, 253, 0.22);
        background: rgba(13, 110, 253, 0.08);
        color: #0d6efd;
        padding: 0;
    }

    .inventory-help-trigger:hover,
    .inventory-help-trigger:focus-visible {
        background: rgba(13, 110, 253, 0.14);
        color: #0a58ca;
    }

    .inventory-bulk-help-list {
        display: grid;
        gap: 1rem;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .inventory-bulk-help-list li {
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 0.95rem;
        padding: 0.9rem 1rem;
        background: rgba(248, 250, 252, 0.72);
    }

    .inventory-bulk-help-list h6 {
        margin-bottom: 0.45rem;
        font-weight: 700;
    }

    .inventory-bulk-help-list p:last-child {
        margin-bottom: 0;
    }

    .inventory-bulk-selection-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.55rem;
    }

    .inventory-paste-help {
        color: #6c757d;
        font-size: 0.88rem;
        line-height: 1.45;
    }

    .inventory-import-summary {
        border: 1px solid rgba(148, 163, 184, 0.24);
        border-radius: 0.85rem;
        background: rgba(248, 250, 252, 0.92);
        padding: 0.85rem 1rem;
        font-size: 0.92rem;
        color: #475569;
    }

    .inventory-import-errors:empty {
        display: none;
    }

    .inventory-import-preview-empty {
        padding: 1rem;
        text-align: center;
        color: #6c757d;
    }

    .inventory-import-preview-table th,
    .inventory-import-preview-table td {
        vertical-align: top;
        font-size: 0.9rem;
    }

    .inventory-import-preview-table td small {
        display: block;
        color: #64748b;
        margin-top: 0.2rem;
    }

    .inventory-empty-state {
        display: none;
        border: 1px dashed rgba(148, 163, 184, 0.5);
        border-radius: 1rem;
        padding: 2rem 1.25rem;
        text-align: center;
        color: #6c757d;
        background: rgba(248, 250, 252, 0.8);
    }

    .inventory-empty-state.active {
        display: block;
    }

    .inventory-message {
        display: none;
        margin-bottom: 1rem;
    }

    .inventory-message.active {
        display: block;
    }

    .inventory-file-input {
        display: none;
    }

    .inventory-backup-card {
        background: linear-gradient(135deg, rgba(255, 193, 7, 0.15), rgba(255, 255, 255, 0.98));
    }

    #viewLevelsModal .modal-header {
        background: linear-gradient(90deg, rgba(92, 29, 155, 0.08), rgba(92, 29, 155, 0.02));
        border-bottom: 2px solid #b28bff;
    }

    #viewLevelsModal .snapshot-meta {
        margin-top: 0.5rem;
    }

    #viewLevelsModal .weapon-banner-snapshot {
        width: 100%;
        padding-right: 0.85rem;
    }

    #viewLevelsModal .snapshot-section {
        margin-bottom: 1rem;
    }

    #viewLevelsModal .snapshot-section-title {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #8d79b7;
        margin-bottom: 0.35rem;
    }

    #viewLevelsModal .snapshot-ability {
        background-color: #f9f5ff;
        border-left: 3px solid #b28bff;
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 0.7rem 0.9rem;
        font-size: 0.95rem;
        line-height: 1.45;
    }

    #viewLevelsModal .snapshot-stats {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    #viewLevelsModal .snapshot-stat {
        text-align: center;
        min-width: 80px;
    }

    #viewLevelsModal .snapshot-stat-value {
        font-size: 1.25rem;
        font-weight: 700;
        color: #3a2758;
    }

    #viewLevelsModal .snapshot-stat-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #8d79b7;
    }

    #viewLevelsModal .snapshot-rability-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    #viewLevelsModal .snapshot-rability-item {
        padding: 0.3rem 0;
    }

    #viewLevelsModal .snapshot-rability-main {
        display: block;
    }

    #viewLevelsModal .snapshot-rability-effects {
        margin: 0.2rem 0 0.1rem 1.1rem;
        padding-left: 0.4rem;
        color: #585466;
        font-size: 0.86rem;
    }

    #viewLevelsModal .snapshot-customization-entry {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem 0.65rem;
        align-items: baseline;
        padding: 0.2rem 0;
        font-size: 0.9rem;
    }

    #viewLevelsModal .snapshot-spinner {
        display: none;
    }

    #viewLevelsModal .snapshot-spinner.active {
        display: inline-block;
    }

    #viewLevelsModal .snapshot-error {
        display: none;
        color: #dc3545;
        font-size: 0.85rem;
    }

    #viewLevelsModal .snapshot-error.active {
        display: block;
    }

    .inventory-snapshot-banner {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        flex-wrap: wrap;
    }

    .inventory-snapshot-art-shell,
    .inventory-snapshot-portrait-shell {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.9rem;
        overflow: hidden;
        background: #fff;
        border: 1px solid rgba(148, 163, 184, 0.3);
    }

    .inventory-snapshot-portrait-shell {
        width: 3.2rem;
        height: 3.2rem;
    }

    .inventory-snapshot-art-shell {
        width: 4.15rem;
        height: 4.15rem;
        padding: 0.18rem;
    }

    .inventory-snapshot-portrait,
    .inventory-snapshot-art {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0.75rem;
        display: block;
    }

    .inventory-snapshot-meta {
        flex: 1 1 220px;
    }

    .inventory-snapshot-character {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6f42c1;
        margin-bottom: 0.3rem;
    }

    .inventory-snapshot-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: #2f2553;
        margin-bottom: 0.45rem;
    }

    .inventory-snapshot-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .preview-image-frame {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 320px;
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.96), rgba(255, 255, 255, 0.98));
        border: 1px solid rgba(148, 163, 184, 0.24);
        border-radius: 1rem;
        padding: 1rem;
    }

    .preview-image-frame img {
        max-width: 100%;
        max-height: min(75vh, 960px);
        object-fit: contain;
        display: block;
    }

    .inventory-survey-summary {
        border: 1px solid rgba(148, 163, 184, 0.24);
        border-radius: 0.85rem;
        background: rgba(248, 250, 252, 0.92);
        padding: 0.85rem 1rem;
        color: #475569;
        font-size: 0.93rem;
    }

    .inventory-survey-error:empty {
        display: none;
    }

    .inventory-survey-loading {
        display: none;
        align-items: center;
        gap: 0.6rem;
        color: #475569;
        font-weight: 600;
    }

    .inventory-survey-loading.active {
        display: inline-flex;
    }

    .inventory-survey-empty {
        padding: 1rem;
        text-align: center;
        color: #6c757d;
    }

    .inventory-survey-status {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.28rem 0.7rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.01em;
    }

    .inventory-survey-status-owned {
        background: rgba(25, 135, 84, 0.12);
        color: #0f5132;
    }

    .inventory-survey-status-unowned {
        background: rgba(220, 53, 69, 0.1);
        color: #842029;
    }

    .inventory-survey-results-table th,
    .inventory-survey-results-table td {
        vertical-align: middle;
        font-size: 0.92rem;
    }

    @@media (max-width: 991.98px) {
        .inventory-toolbar-card {
            position: static;
        }
    }

    @@media (max-width: 767.98px) {
        .inventory-grid {
            grid-template-columns: 1fr;
        }

        .inventory-control-grid {
            grid-template-columns: 1fr;
        }

        .inventory-card-header {
            padding-bottom: 0.55rem;
        }

        .inventory-card-portrait-shell {
            width: 2.7rem;
            height: 2.7rem;
        }

        .inventory-card-item-shell {
            width: 3.65rem;
            height: 3.65rem;
        }

        .inventory-card-actions .btn {
            flex: 1 1 auto;
        }

        .inventory-pagination-bar,
        .inventory-pagination-group {
            align-items: stretch;
        }

        .inventory-pagination-bar {
            flex-direction: column;
        }

        .inventory-pagination-group {
            width: 100%;
            justify-content: space-between;
        }

        .inventory-pagination-actions {
            width: 100%;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.5rem;
        }

        .inventory-pagination-actions .btn,
        .inventory-page-size-select {
            width: 100%;
        }

        .inventory-pagination-status {
            width: 100%;
            min-width: 0;
            order: -1;
        }
    }
</style>

<div class="container-fluid inventory-page-shell mt-4 mb-5">
    <div class="row g-4 align-items-start">
        <div class="col-12">
            <div class="card inventory-hero-card">
                <div class="card-body p-4 p-lg-5">
                    <div class="inventory-kicker">Local Inventory</div>
                    <div class="d-flex flex-column flex-lg-row justify-content-between gap-4 align-items-lg-center">
                        <div>
                            <h1 class="mb-3"><i class="fas fa-box-open"></i> Player Inventory Management</h1>
                            <p class="text-muted mb-0">Track owned costumes and weapons in your browser, search your armory quickly, and open weapon snapshots using your saved level defaults.</p>
                        </div>
                        <div class="text-lg-end">
                            <div class="fw-semibold text-body-emphasis">Costumes: Own / Do Not Own</div>
                            <div class="fw-semibold text-body-emphasis">Weapons: Do Not Own, 3 Star, 4 Star, 5 Star, OB1-OB10</div>
                            <div class="small text-muted mt-1">Inventory levels use fixed steps: 1, then 10 through 140.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-3">
            <div class="card inventory-toolbar-card">
                <div class="card-body p-4">
                    <div class="inventory-kicker">Find & Manage</div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="inventorySearchInput" class="form-label fw-semibold">Search by item name</label>
                            <input type="search" class="form-control" id="inventorySearchInput" placeholder="Search weapons and costumes" autocomplete="off" />
                        </div>
                        <div class="col-12">
                            <label for="inventoryCharacterFilter" class="form-label fw-semibold">Character</label>
                            <select class="form-select" id="inventoryCharacterFilter">
                                <option value="all">All characters</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="inventoryTypeFilter" class="form-label fw-semibold">Item type</label>
                            <select class="form-select" id="inventoryTypeFilter">
                                <option value="all">All items</option>
                                <option value="Weapon">Weapons</option>
                                <option value="Costume">Costumes</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="inventorySortSelect" class="form-label fw-semibold">Sort by</label>
                            <select class="form-select" id="inventorySortSelect">
                                <option value="defaultAsc">Default Ascending</option>
                                <option value="defaultDesc">Default Descending</option>
                                <option value="nameAsc">Item Name Ascending</option>
                                <option value="nameDesc">Item Name Descending</option>
                                <option value="charNameAsc">Char. &amp; Item Name Ascending</option>
                                <option value="charNameDesc">Char. &amp; Item Name Descending</option>
                            </select>
                        </div>
                        <div class="col-12 d-grid gap-2 d-sm-flex">
                            <button type="button" class="btn btn-outline-secondary flex-fill" id="inventoryClearFiltersButton">Clear filters</button>
                        </div>
                    </div>
                    <hr class="my-4" />
                    <div class="inventory-toolbar-actions">
                        <button type="button" class="btn btn-primary" id="inventoryExportButton"><i class="fas fa-file-export"></i> Export</button>
                        <button type="button" class="btn btn-outline-primary" id="inventoryImportButton"><i class="fas fa-file-import"></i> Import</button>
                        <button type="button" class="btn btn-outline-secondary" id="inventoryPasteImportButton"><i class="fas fa-paste"></i> Paste Import</button>
                        <button type="button" class="btn btn-outline-secondary" id="inventorySheetImportButton"><i class="fas fa-table"></i> Import from Sheet</button>
                        <button type="button" class="btn btn-outline-success" id="inventorySurveyQuickViewButton"><i class="fas fa-clipboard-list"></i> SOLDIER Survey Quick View</button>
                        <button type="button" class="btn btn-outline-danger" id="inventoryResetButton"><i class="fas fa-trash"></i> Reset</button>
                    </div>
                    <input type="file" class="inventory-file-input" id="inventoryImportFileInput" accept="application/json,.json" />
                </div>
            </div>

            <div class="card inventory-backup-card mt-4">
                <div class="card-body p-4">
                    <div class="inventory-kicker text-warning-emphasis">Backup Reminder</div>
                    <p class="mb-2 text-body-emphasis fw-semibold">Your inventory is stored only in this browser.</p>
                    <p class="text-muted small mb-0">Nothing is saved on the server side. Use export backups regularly so you do not lose your data if browser storage is cleared.</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-9">
            <div class="card inventory-results-card mb-3">
