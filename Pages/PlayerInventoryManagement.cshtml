                    hideMessages();
                    const normalizedItemType = String(itemType).toLowerCase();
                    if (normalizedItemType === 'costume') {
                        setCostumeOwnership(itemId, ownershipSelect.value === 'own');
                    } else if (normalizedItemType === 'ultimate') {
                        setUltimateOwnership(itemId, ownershipSelect.value === 'own');
                    } else {
                        setWeaponOwnership(itemId, ownershipSelect.value);
                    }
                    return;
                }

                if (levelSelect) {
                    const itemId = levelSelect.getAttribute('data-item-id');
                    if (!itemId) {
