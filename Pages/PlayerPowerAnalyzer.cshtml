                                                                @if (!string.IsNullOrWhiteSpace(weapon.SelectionReason))
                                                                {
                                                                    <tr>
                                                                        <td colspan="18" class="text-muted"><small><strong>Selected</strong>: @weapon.SelectionReason</small></td>
                                                                    </tr>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(weapon.SynergyReason))
                                                                {
                                                                    <tr>
                                                                        <td colspan="18" class="text-muted"><small><strong>Synergy</strong>: @weapon.SynergyReason</small></td>
                                                                    </tr>
                                                                }
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.SelectedPlayerGear != null)
        {
            var gear = Model.SelectedPlayerGear;
            <div class="modal fade js-gear-modal" id="@gearModalId" tabindex="-1" aria-labelledby="@(gearModalId + "_label")" aria-hidden="true">
                <div class="modal-dialog modal-xl modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <div>
                                <h5 class="modal-title" id="@(gearModalId + "_label")">@gear.InGameName - Submitted Gear</h5>
                                <small class="text-muted">
                                    Score: @gear.Score.ToString("N0")
                                    @if (gear.BestTeamCharacters.Count > 0)
                                    {
                                        <text> | Best Team: @string.Join(", ", gear.BestTeamCharacters)</text>
                                    }
                                </small>
                            </div>
                            <button type="button" class="btn-close js-close-gear-modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="accordion" id="@(gearModalId + "_accordion")">
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="@(gearModalId + "_w_hdr")">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#@(gearModalId + "_w")" aria-expanded="true" aria-controls="@(gearModalId + "_w")">Weapons by Character</button>
                                    </h2>
                                    <div id="@(gearModalId + "_w")" class="accordion-collapse collapse show" aria-labelledby="@(gearModalId + "_w_hdr")" data-bs-parent="#@(gearModalId + "_accordion")">
                                        <div class="accordion-body">
                                            @if (gear.WeaponsByCharacter.Count == 0)
                                            {
                                                <div class="text-muted">No owned weapons found in submission.</div>
                                            }
                                            else
                                            {
                                                @foreach (var weaponGroup in gear.WeaponsByCharacter.OrderBy(k => k.Key, StringComparer.OrdinalIgnoreCase))
                                                {
                                                    <div class="mb-2"><strong>@weaponGroup.Key</strong></div>
                                                    <div class="table-responsive mb-3">
                                                        <table class="table table-sm table-striped mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th>Weapon</th>
                                                                    <th>OB</th>
                                                                    <th>Type</th>
                                                                    <th>Pot%</th>
                                                                    <th>Synergy</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var weapon in weaponGroup.Value)
                                                                {
                                                                    <tr>
                                                                        <td>@weapon.WeaponName</td>
                                                                        <td>@weapon.OverboostLevel</td>
                                                                        <td>@(weapon.IsUltimate ? "Ultimate" : "Weapon")</td>
                                                                        <td>@(weapon.AbilityPotPercent?.ToString("N1") ?? "-")</td>
                                                                        <td><small class="text-muted">@(string.IsNullOrWhiteSpace(weapon.SynergyReason) ? "-" : weapon.SynergyReason)</small></td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="@(gearModalId + "_c_hdr")">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@(gearModalId + "_c")" aria-expanded="false" aria-controls="@(gearModalId + "_c")">Costumes by Character</button>
                                    </h2>
                                    <div id="@(gearModalId + "_c")" class="accordion-collapse collapse" aria-labelledby="@(gearModalId + "_c_hdr")" data-bs-parent="#@(gearModalId + "_accordion")">
                                        <div class="accordion-body">
                                            @if (gear.CostumesByCharacter.Count == 0)
                                            {
                                                <div class="text-muted">No owned costumes found in submission.</div>
                                            }
                                            else
                                            {
                                                @foreach (var costumeGroup in gear.CostumesByCharacter.OrderBy(k => k.Key, StringComparer.OrdinalIgnoreCase))
                                                {
                                                    <div class="mb-1"><strong>@costumeGroup.Key</strong></div>
                                                    <ul class="mb-3">
                                                        @foreach (var costume in costumeGroup.Value)
                                                        {
                                                            <li>@costume.CostumeName</li>
                                                        }
                                                    </ul>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="@(gearModalId + "_u_hdr")">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@(gearModalId + "_u")" aria-expanded="false" aria-controls="@(gearModalId + "_u")">Summons, Enemy Abilities, Memoria, Materia</button>
                                    </h2>
                                    <div id="@(gearModalId + "_u")" class="accordion-collapse collapse" aria-labelledby="@(gearModalId + "_u_hdr")" data-bs-parent="#@(gearModalId + "_accordion")">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <div><strong>Summons</strong></div>
                                                    @if (gear.Summons.Count == 0)
                                                    {
                                                        <div class="text-muted">None</div>
                                                    }
                                                    else
                                                    {
                                                        <ul class="mb-0">
                                                            @foreach (var summon in gear.Summons)
                                                            {
                                                                <li>@summon.Name <span class="text-muted">(Lv @summon.Level/@summon.MaxLevel)</span></li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                                <div class="col-md-4">
                                                    <div><strong>Enemy Abilities</strong></div>
                                                    @if (gear.EnemyAbilities.Count == 0)
                                                    {
                                                        <div class="text-muted">None</div>
                                                    }
                                                    else
                                                    {
                                                        <ul class="mb-0">
                                                            @foreach (var ability in gear.EnemyAbilities)
                                                            {
                                                                <li>@ability.Name <span class="text-muted">(Lv @ability.Level/@ability.MaxLevel)</span></li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                                <div class="col-md-4">
                                                    <div><strong>Memoria</strong></div>
                                                    @if (gear.Memoria.Count == 0)
                                                    {
                                                        <div class="text-muted">None</div>
                                                    }
                                                    else
                                                    {
                                                        <ul class="mb-0">
                                                            @foreach (var memoria in gear.Memoria)
                                                            {
                                                                <li>@memoria.Name <span class="text-muted">(Lv @memoria.Level/@memoria.MaxLevel)</span></li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                            </div>

                                            <div class="mt-3"><strong>Materia</strong></div>
                                            @if (gear.Materia.Count == 0)
                                            {
                                                <div class="text-muted">None</div>
                                            }
                                            else
                                            {
                                                <div class="table-responsive">
                                                    <table class="table table-sm mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th>Materia</th>
                                                                <th>11%+</th>
                                                                <th>8-10%</th>
                                                                <th>0-7%</th>
                                                                <th>Total</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var materia in gear.Materia)
                                                            {
                                                                <tr>
                                                                    <td>@materia.MateriaName</td>
                                                                    <td>@materia.CountPot11Plus</td>
                                                                    <td>@materia.CountPot8To10</td>
                                                                    <td>@materia.CountPot0To7</td>
                                                                    <td>@materia.TotalCount</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                @if (gear.MissingCatalogItems.Count > 0)
                                {
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="@(gearModalId + "_m_hdr")">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@(gearModalId + "_m")" aria-expanded="false" aria-controls="@(gearModalId + "_m")">Missing Catalog Items (@gear.MissingCatalogItems.Count)</button>
                                        </h2>
                                        <div id="@(gearModalId + "_m")" class="accordion-collapse collapse" aria-labelledby="@(gearModalId + "_m_hdr")" data-bs-parent="#@(gearModalId + "_accordion")">
                                            <div class="accordion-body">
                                                <div class="table-responsive">
                                                    <table class="table table-sm mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th>Item</th>
                                                                <th>Raw Value</th>
                                                                <th>Kind</th>
                                                                <th>Notes</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var missing in gear.MissingCatalogItems)
                                                            {
                                                                <tr>
                                                                    <td>@missing.ColumnName</td>
                                                                    <td>@missing.RawValue</td>
                                                                    <td>@missing.InferredKind</td>
                                                                    <td>@missing.Notes</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('playerPowerAnalyzerForm');
            const guildSelect = document.getElementById('GoogleSheetUrl');
            const playerSelect = document.getElementById('PlayerName');
            const playerLoadingIndicator = document.getElementById('playerLoadingIndicator');
            const playerLoadingText = document.getElementById('playerLoadingText');

            function setPlayerLoadingState(isLoading, message) {
                if (playerLoadingIndicator) {
                    playerLoadingIndicator.hidden = !isLoading;
                    playerLoadingIndicator.setAttribute('aria-hidden', isLoading ? 'false' : 'true');
                }

                if (playerLoadingText && message) {
                    playerLoadingText.textContent = message;
                }

                if (playerSelect) {
                    playerSelect.setAttribute('aria-busy', isLoading ? 'true' : 'false');
                }
            }

            async function loadPlayers() {
                if (!form || !guildSelect || !playerSelect) {
                    return;
                }

                const guildUrl = guildSelect.value;
                const previousValue = playerSelect.value;
                playerSelect.innerHTML = '<option value="">-- Select player --</option>';
                playerSelect.disabled = true;

                if (!guildUrl) {
                    setPlayerLoadingState(false, 'Loading players from survey sheet...');
                    return;
                }

                playerSelect.innerHTML = '<option value="">Loading players...</option>';
                setPlayerLoadingState(true, 'Loading players from survey sheet...');

                try {
                    const formData = new FormData(form);
                    const token = form.querySelector('input[name="__RequestVerificationToken"]');
                    const response = await fetch('@Url.Page("/PlayerPowerAnalyzer", "LoadPlayers")', {
                        method: 'POST',
                        headers: token ? { 'RequestVerificationToken': token.value } : {},
                        body: formData
                    });

                    if (!response.ok) {
                        playerSelect.innerHTML = '<option value="">Unable to load players</option>';
                        return;
                    }

                    const payload = await response.json();
                    const players = Array.isArray(payload) ? payload : (payload.players || []);
                    playerSelect.innerHTML = '<option value="">-- Select player --</option>';
                    players.forEach((name) => {
                        const option = document.createElement('option');
                        option.value = name;
                        option.textContent = name;
                        if (name === previousValue) {
                            option.selected = true;
                        }
                        playerSelect.appendChild(option);
                    });

                    if (players.length === 0) {
                        playerSelect.innerHTML = '<option value="">No players found</option>';
                    }

                    playerSelect.disabled = players.length === 0;
                } finally {
                    setPlayerLoadingState(false, 'Loading players from survey sheet...');
                }
            }

            function wireCollapseToggleText() {
                const toggles = document.querySelectorAll('button.js-view-toggle[data-bs-toggle="collapse"][data-bs-target]');
                toggles.forEach((btn) => {
                    const targetSel = btn.getAttribute('data-bs-target');
                    if (!targetSel) {
                        return;
                    }

                    const target = document.querySelector(targetSel);
                    if (!target) {
                        return;
                    }

                    const viewText = btn.getAttribute('data-view-text') || 'View';
                    const hideText = btn.getAttribute('data-hide-text') || 'Hide';
                    target.addEventListener('shown.bs.collapse', function () { btn.textContent = hideText; });
                    target.addEventListener('hidden.bs.collapse', function () { btn.textContent = viewText; });
                });
            }

            function mountGearModalsToBody() {
                const modalEls = document.querySelectorAll('.js-gear-modal');
                modalEls.forEach((modalEl) => {
                    if (modalEl.dataset.appendedToBody === 'true') {
                        return;
                    }

                    document.body.appendChild(modalEl);
                    modalEl.dataset.appendedToBody = 'true';
                });
            }

            function wireGearModalOpenButtons() {
                const openButtons = document.querySelectorAll('button.js-open-gear-modal[data-gear-modal-id]');
                openButtons.forEach((btn) => {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();

                        const modalId = btn.getAttribute('data-gear-modal-id');
                        if (!modalId || typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                            return;
                        }

                        const modalEl = document.getElementById(modalId);
                        if (!modalEl) {
                            return;
                        }

                        if (modalEl.dataset.guardWired !== 'true') {
                            modalEl.addEventListener('hide.bs.modal', function (evt) {
                                if (modalEl.dataset.allowHide === 'true') {
                                    modalEl.dataset.allowHide = 'false';
                                    return;
                                }

                                evt.preventDefault();
                            });

                            modalEl.dataset.allowHide = 'false';
                            modalEl.dataset.guardWired = 'true';
                        }

                        const modal = bootstrap.Modal.getOrCreateInstance(modalEl, {
                            backdrop: 'static',
                            keyboard: false,
                            focus: true
                        });
                        modalEl.dataset.allowHide = 'false';
                        modal.show();
                    });
                });

                const closeButtons = document.querySelectorAll('button.js-close-gear-modal');
                closeButtons.forEach((btn) => {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();

                        const modalEl = btn.closest('.js-gear-modal');
                        if (!modalEl || typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                            return;
                        }

                        modalEl.dataset.allowHide = 'true';
                        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                        modal.hide();
                    });
                });
            }

            if (guildSelect) {
                guildSelect.addEventListener('change', loadPlayers);
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function () {
                    mountGearModalsToBody();
                    wireCollapseToggleText();
                    wireGearModalOpenButtons();
                });
            } else {
                mountGearModalsToBody();
                wireCollapseToggleText();
                wireGearModalOpenButtons();
            }
        })();
    </script>
}
