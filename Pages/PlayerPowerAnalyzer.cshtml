@page
@model PlayerPowerAnalyzerModel
@{
    ViewData["Title"] = "Player Power Analyzer";
}

<style>
    .modal-open .card,
    .modal-open .card:hover {
        transform: none !important;
        transition: none !important;
    }

    .player-analyzer-result-card {
        border: 1px solid rgba(13, 110, 253, 0.16);
        box-shadow: 0 0.5rem 1.25rem rgba(15, 23, 42, 0.08);
    }

    .player-analyzer-result-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 55%, #084298 100%);
        border-bottom: 0;
        color: #fff;
        padding: 1rem 1.25rem;
    }

    .player-analyzer-result-header .player-analyzer-header-kicker,
    .player-analyzer-result-header .player-analyzer-header-subtle {
        color: rgba(255, 255, 255, 0.84);
    }

    .player-analyzer-name-link {
        color: #fff;
        font-size: 1.2rem;
        font-weight: 700;
        line-height: 1.2;
        text-decoration: underline;
        text-decoration-color: rgba(255, 255, 255, 0.55);
        text-decoration-thickness: 2px;
        text-underline-offset: 0.18em;
    }

    .player-analyzer-name-link:hover,
    .player-analyzer-name-link:focus {
        color: #fff;
        text-decoration-color: #fff;
    }

    .player-analyzer-name-link:focus-visible {
        outline: 2px solid rgba(255, 255, 255, 0.9);
        outline-offset: 3px;
        border-radius: 0.25rem;
    }

    .player-analyzer-header-name-row {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .player-analyzer-info-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.9rem;
        height: 1.9rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.38);
        background-color: rgba(255, 255, 255, 0.16);
        color: #fff;
        padding: 0;
    }

    .player-analyzer-info-button:hover,
    .player-analyzer-info-button:focus {
        color: #fff;
        background-color: rgba(255, 255, 255, 0.26);
        border-color: rgba(255, 255, 255, 0.55);
    }

    .player-analyzer-info-button:focus-visible {
        outline: 2px solid rgba(255, 255, 255, 0.92);
        outline-offset: 2px;
    }

    .player-analyzer-header-chip {
        display: inline-flex;
        align-items: center;
        padding: 0.32rem 0.7rem;
        border-radius: 999px;
        background-color: rgba(255, 255, 255, 0.14);
        border: 1px solid rgba(255, 255, 255, 0.24);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 500;
        backdrop-filter: blur(2px);
    }

    .player-analyzer-team-summary {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.2rem;
    }

    .player-analyzer-team-value {
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
    }

    .player-analyzer-score {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 7rem;
        padding: 0.6rem 0.9rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.16);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: #fff;
        font-weight: 700;
        font-size: 1.25rem;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    }

    .player-analyzer-chip {
        display: inline-flex;
        align-items: center;
        padding: 0.3rem 0.65rem;
        border-radius: 999px;
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        font-size: 0.85rem;
    }

    .player-analyzer-metric {
        border: 1px solid #edf0f2;
        border-radius: 0.75rem;
        background-color: #fbfcfd;
        padding: 0.85rem 1rem;
        height: 100%;
    }

    @@media (max-width: 767.98px) {
        .player-analyzer-result-header,
        .player-analyzer-team-summary {
            text-align: left;
        }

        .player-analyzer-team-summary {
            align-items: flex-start;
        }
    }

    .player-analyzer-metric-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6c757d;
        margin-bottom: 0.25rem;
    }

    .player-analyzer-metric-value {
        font-weight: 600;
        color: #212529;
    }

    .player-analyzer-character-card {
        border: 1px solid #e9ecef;
        border-radius: 0.9rem;
        padding: 1rem;
        background-color: #fff;
    }

    .player-analyzer-loading-indicator {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding: 0.4rem 0.65rem;
        border-radius: 0.5rem;
        background-color: #eef5ff;
        color: #0b5ed7;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .player-analyzer-loading-indicator[hidden] {
        display: none;
    }
</style>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-3">
                <i class="fas fa-user-gear"></i> Player Power Analyzer
            </h1>
            <p class="text-muted mb-3">Analyze a single player from a survey sheet using the same team recommendation logic as Power Levels, without guild ranking or submission summaries.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-sliders"></i> Analysis Inputs</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Analyze" id="playerPowerAnalyzerForm">
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="GoogleSheetUrl" class="form-label">Survey Sheet</label>
                                <select class="form-select" id="GoogleSheetUrl" name="GoogleSheetUrl">
                                    <option value="">-- Select a survey sheet --</option>
                                    @foreach (var sheet in Model.AvailableSheets)
                                    {
                                        if (string.Equals(Model.GoogleSheetUrl, sheet.Url, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <option value="@sheet.Url" selected>@sheet.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@sheet.Url">@sheet.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="PlayerName" class="form-label">Player</label>
                                <select class="form-select" id="PlayerName" name="PlayerName" @(Model.AvailablePlayers.Count == 0 ? "disabled" : null)>
                                    <option value="">-- Select player --</option>
                                    @foreach (var player in Model.AvailablePlayers)
                                    {
                                        if (string.Equals(Model.PlayerName, player, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <option value="@player" selected>@player</option>
                                        }
                                        else
                                        {
                                            <option value="@player">@player</option>
                                        }
                                    }
                                </select>
                                <div class="player-analyzer-loading-indicator" id="playerLoadingIndicator" hidden aria-live="polite" aria-hidden="true">
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    <span id="playerLoadingText">Loading players from survey sheet...</span>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label" for="EnemyWeakness">Enemy Weakness</label>
                                <select class="form-select" id="EnemyWeakness" name="EnemyWeakness">
                                    @foreach (var option in new[] { "None", "Earth", "Fire", "Water", "Ice", "Lightning", "Wind" })
                                    {
                                        if (string.Equals(Model.EnemyWeakness.ToString(), option, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <option value="@option" selected>@option</option>
                                        }
                                        else
                                        {
                                            <option value="@option">@option</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="PreferredDamageType">Preferred Damage Type</label>
                                <select class="form-select" id="PreferredDamageType" name="PreferredDamageType">
                                    @foreach (var option in new[] { "Any", "Physical", "Magical" })
                                    {
                                        if (string.Equals(Model.PreferredDamageType.ToString(), option, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <option value="@option" selected>@option</option>
                                        }
                                        else
                                        {
                                            <option value="@option">@option</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="TargetScenario">Enemy Count Weighting</label>
                                <select class="form-select" id="TargetScenario" name="TargetScenario">
                                    @if (string.Equals(Model.TargetScenario.ToString(), "Unknown", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="Unknown" selected>Unknown (assume single enemy)</option>
                                    }
                                    else
                                    {
                                        <option value="Unknown">Unknown (assume single enemy)</option>
                                    }
                                    @if (string.Equals(Model.TargetScenario.ToString(), "SingleEnemy", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="SingleEnemy" selected>Single Enemy</option>
                                    }
                                    else
                                    {
                                        <option value="SingleEnemy">Single Enemy</option>
                                    }
                                    @if (string.Equals(Model.TargetScenario.ToString(), "MultipleEnemies", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="MultipleEnemies" selected>Multiple Enemies</option>
                                    }
                                    else
                                    {
                                        <option value="MultipleEnemies">Multiple Enemies</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <details class="mb-3">
                            <summary class="form-label">Advanced options</summary>

                            <div class="mb-4 mt-3">
                                <h6 class="mb-2"><i class="fas fa-users"></i> Valid Team Compositions</h6>
                                <p class="text-muted small">Teams not matching selected templates will have their score reduced by 50%.</p>
                                <div class="row">
                                    @foreach (var template in Model.AvailableTeamTemplates.OrderBy(t => t.Priority))
                                    {
                                        var isChecked = Model.EnabledTeamTemplates.TryGetValue(template.Name, out var enabled) ? enabled : template.Enabled;
                                        <div class="col-md-6 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="EnabledTeamTemplates[@template.Name]"
                                                       value="true"
                                                       id="template_@template.Name.Replace("/", "_")"
                                                       @(isChecked ? "checked" : null)>
                                                <label class="form-check-label" for="template_@template.Name.Replace("/", "_")">@template.Name</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <hr />

                            <div>
                                <h6 class="mb-2"><i class="fas fa-bolt"></i> Synergy Effect Bonuses</h6>
                                <div class="row mt-2">
                                    @{
                                        var effects = new (string Key, string Label)[]
                                        {
                                            ("ElementalResistanceDown", "Elemental resistance down"),
                                            ("AtbPlus", "ATB +N"),
                                            ("ElementalDamageBonus", "Elemental damage bonus"),
                                            ("ElementalDamageUp", "Elemental damage up"),
                                            ("WeaponBoost", "Phys/Mag weapon boost"),
                                            ("ElementalWeaponBoost", "Elemental weapon boost"),
                                            ("SingleTargetDamageReceivedUp", "Single-target damage received up"),
                                            ("DamageReceivedUp", "Damage received up"),
                                            ("DamageTypeDamageBonus", "Phys/Mag damage bonus"),
                                            ("DamageTypeAtkUp", "PATK/MATK up"),
                                            ("ExploitWeakness", "Exploit weakness"),
                                            ("Haste", "Haste"),
                                            ("AtbConservationEffect", "ATB conservation effect"),
                                            ("Enfeeble", "Enfeeble"),
                                            ("Enliven", "Enliven (raises damage buffs)"),
                                            ("Torpor", "Torpor (short burst damage vulnerability)"),
                                            ("AppliedStatsDebuffTierIncreased", "Applied debuff tier increased"),
                                            ("AppliedStatsBuffTierIncreased", "Applied buff tier increased"),
                                            ("AmpAbilities", "Amp abilities"),
                                            ("DefenseDown", "Defense down (PDEF/MDEF)")
                                        };

                                        var weightOptions = new (int Value, string Text)[]
                                        {
                                            (0, "None"),
                                            (100, "+100%"),
                                            (200, "+200%"),
                                            (300, "+300%"),
                                            (400, "+400%"),
                                            (500, "+500%")
                                        };
                                    }
                                    @foreach (var effect in effects)
                                    {
                                        var selected = Model.SynergyEffectBonusPercents.TryGetValue(effect.Key, out var value) ? value : 0;
                                        <div class="col-md-6 mb-2">
                                            <label class="form-label">@effect.Label</label>
                                            <select class="form-select form-select-sm" name="SynergyEffectBonusPercents[@effect.Key]">
                                                @foreach (var option in weightOptions)
                                                {
                                                    if (option.Value == selected)
                                                    {
                                                        <option value="@option.Value" selected>@option.Text</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@option.Value">@option.Text</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    }
                                </div>
                            </div>
                        </details>

                        <button type="submit" class="btn btn-primary" id="showBestTeamsButton">
                            <i class="fas fa-calculator"></i> Show Best Teams
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Notes</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2"><strong>Player list</strong> comes from the selected survey sheet, similar to Should I Attack.</div>
                    <div class="mb-2"><strong>Analysis</strong> reuses the Power Levels optimizer and team synergy detection.</div>
                    <div class="mb-2"><strong>Output</strong> focuses on one player only, so there is no guild ranking, submission summary, or CSV export.</div>
                    <div><strong>Submitted gear</strong> remains available by clicking the player name after analysis.</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.SelectedTeam != null)
    {
        var team = Model.SelectedTeam;
        var breakdown = team.Breakdown;
        var hasGearSummary = Model.SelectedPlayerGear != null;
        var detailsId = "selectedPlayerTeamDetails";
        var altTeamsId = "selectedPlayerAltTeams";
        var missingId = "selectedPlayerMissingItems";
        var gearModalId = "selectedPlayerGearModal";

        <div class="row">
            <div class="col-12">
                <div class="card mb-4 player-analyzer-result-card">
                    <div class="card-header player-analyzer-result-header d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div>
                            <h5 class="mb-0">
                                <span class="player-analyzer-header-name-row">
                                    @if (hasGearSummary)
                                    {
                                        <button class="btn btn-link p-0 align-baseline js-open-gear-modal player-analyzer-name-link" type="button" data-gear-modal-id="@gearModalId">@team.InGameName</button>
                                        <button class="btn player-analyzer-info-button js-open-gear-modal" type="button" data-gear-modal-id="@gearModalId" title="View submitted gear and player details" aria-label="View submitted gear and player details">
                                            <i class="fas fa-circle-info"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="player-analyzer-name-link text-decoration-none">@team.InGameName</span>
                                    }
                                </span>
                            </h5>
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                @if (!string.IsNullOrWhiteSpace(team.DiscordName))
                                {
                                    <span class="player-analyzer-header-chip">@team.DiscordName</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(team.SubmittedGuild))
                                {
                                    <span class="player-analyzer-header-chip">Submitted: @team.SubmittedGuild</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(team.BannerResponse))
                                {
                                    <span class="player-analyzer-header-chip">Banner: @team.BannerResponse</span>
                                }
                            </div>
                        </div>
                        <div class="player-analyzer-team-summary text-end">
                            <div class="small player-analyzer-header-kicker">Recommended Team</div>
                            <div class="player-analyzer-team-value">@string.Join(", ", team.Characters)</div>
                            <div class="mt-2"><span class="player-analyzer-score">@team.Score.ToString("N0")</span></div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 mb-4">
                            <div class="col-md-3 col-sm-6">
                                <div class="player-analyzer-metric">
                                    <div class="player-analyzer-metric-label">Weakness</div>
                                    <div class="player-analyzer-metric-value">@Model.EnemyWeakness</div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <div class="player-analyzer-metric">
                                    <div class="player-analyzer-metric-label">Damage Type</div>
                                    <div class="player-analyzer-metric-value">@Model.PreferredDamageType</div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <div class="player-analyzer-metric">
                                    <div class="player-analyzer-metric-label">Target Scenario</div>
                                    <div class="player-analyzer-metric-value">@Model.TargetScenario</div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <div class="player-analyzer-metric">
                                    <div class="player-analyzer-metric-label">Alternate Teams</div>
                                    <div class="player-analyzer-metric-value">@(team.AlternateTeams?.Count ?? 0)</div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @if (breakdown != null)
                            {
                                <button class="btn btn-sm btn-outline-primary js-view-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#@detailsId" aria-expanded="true" aria-controls="@detailsId" data-view-text="View details" data-hide-text="Hide details">Hide details</button>
                            }
                            @if (team.AlternateTeams != null && team.AlternateTeams.Count > 0)
                            {
                                <button class="btn btn-sm btn-outline-secondary js-view-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#@altTeamsId" aria-expanded="false" aria-controls="@altTeamsId" data-view-text="Other teams" data-hide-text="Hide other teams">Other teams</button>
                            }
                        </div>

                        @if (team.AlternateTeams != null && team.AlternateTeams.Count > 0)
                        {
                            <div class="collapse mb-3" id="@altTeamsId">
                                <div class="card card-body bg-light border-0">
                                    <div class="mb-1"><strong>Other Teams (Top 5)</strong></div>
                                    <div class="table-responsive">
                                        <table class="table table-sm mb-0">
                                            <thead>
                                                <tr>
                                                    <th>#</th>
                                                    <th>Team</th>
                                                    <th>Total</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @for (int i = 0; i < team.AlternateTeams.Count; i++)
                                                {
                                                    var alternate = team.AlternateTeams[i];
                                                    <tr>
                                                        <td>@(i + 1)</td>
                                                        <td>@string.Join(", ", alternate.Characters)</td>
                                                        <td>@alternate.Score.ToString("N0")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="collapse show" id="@detailsId">
                            @if (breakdown == null)
                            {
                                <div class="text-muted">No breakdown available.</div>
                            }
                            else
                            {
                                <div class="row">
                                    <div class="col-12 mb-2">
                                        <div><strong>Applied Rules</strong></div>
                                        <div class="text-muted">@string.Join(" | ", breakdown.AppliedRules)</div>
                                    </div>

                                    <div class="col-12 mb-3">
                                        <div><strong>Battle Context</strong></div>
                                        <div class="text-muted">Weakness: @breakdown.EnemyWeakness | Preferred Damage: @breakdown.PreferredDamageType | Max DPS: @breakdown.MaxDpsAllowed</div>
                                    </div>

                                    <div class="col-12 mb-2">
                                        <strong>Team Score</strong>: @breakdown.TeamScore.ToString("N0")
                                    </div>

                                    @if (breakdown.SynergyBonus > 0)
                                    {
                                        <div class="col-12 mb-2">
                                            <strong>Team Synergy Bonus</strong>: @breakdown.SynergyBonus.ToString("N0")
                                            <span class="text-muted">(weighted weapon synergy categories with diminishing returns)</span>
                                            @if (breakdown.SynergyNotes != null && breakdown.SynergyNotes.Count > 0)
                                            {
                                                <div class="small text-muted mt-1">
                                                    @foreach (var note in breakdown.SynergyNotes)
                                                    {
                                                        <div>@note</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (breakdown.SelectedMemoria != null && breakdown.MemoriaScore > 0)
                                    {
                                        <div class="col-12 mb-2">
                                            <strong>Memoria Bonus</strong>: @breakdown.MemoriaScore.ToString("N0")
                                            <span class="text-muted">(@breakdown.SelectedMemoria.MemoriaName - Level @breakdown.SelectedMemoria.Level/@breakdown.SelectedMemoria.MaxLevel)</span>
                                        </div>
                                    }

                                    @if (breakdown.Materia != null && breakdown.Materia.Count > 0 && breakdown.MateriaScore > 0)
                                    {
                                        <div class="col-12 mb-2">
                                            <strong>Materia Bonus</strong>: @breakdown.MateriaScore.ToString("N0")
                                        </div>
                                        <div class="col-12 mb-3">
                                            <div class="table-responsive">
                                                <table class="table table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th>Materia</th>
                                                            <th>11%+</th>
                                                            <th>8-10%</th>
                                                            <th>0-7%</th>
                                                            <th class="text-end">Score</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var materia in breakdown.Materia.Where(m => m.Score > 0))
                                                        {
                                                            <tr>
                                                                <td>@materia.MateriaName</td>
                                                                <td>@materia.CountPot11Plus</td>
                                                                <td>@materia.CountPot8To10</td>
                                                                <td>@materia.CountPot0To7</td>
                                                                <td class="text-end">@materia.Score.ToString("N0")</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    }

                                    @if (breakdown.SelectedUtilityItems != null && breakdown.SelectedUtilityItems.Count > 0)
                                    {
                                        <div class="col-12 mb-2">
                                            <strong>Utility Items Bonus</strong>: @breakdown.UtilityScore.ToString("N0")
                                        </div>
                                        <div class="col-12 mb-3">
                                            <div class="table-responsive">
                                                <table class="table table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th>Kind</th>
                                                            <th>Name</th>
                                                            <th>Level</th>
                                                            <th>Score</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var utility in breakdown.SelectedUtilityItems)
                                                        {
                                                            <tr>
                                                                <td>@utility.Kind</td>
                                                                <td>@utility.Name</td>
