@page "/PlayerPowerAnalyzerV2"
@using FFVIIEverCrisisAnalyzer.Models
@model FFVIIEverCrisisAnalyzer.Pages.PlayerPowerAnalyzerV2Model
@{
    ViewData["Title"] = "Player Power Analyzer V2";
}

@functions {
    // The recommended team plus each alternate, flattened into a uniform list so the page can render a chooser
    // and one toggle-able build-out panel per team (the recommended team is first / default-selected).
    private sealed class ChooserTeam
    {
        public string Label { get; init; } = string.Empty;
        public double Score { get; init; }
        public List<PlayerPowerAnalyzerV2CharacterBuild> Builds { get; init; } = new();
        public bool IsRecommended { get; init; }
        public List<string> Adds { get; init; } = new();
        public List<string> Drops { get; init; } = new();
        public string QuickCopyText { get; init; } = string.Empty;
        public List<string> DebugNotes { get; init; } = new();
    }

    private static List<ChooserTeam> BuildChooserTeams(PlayerPowerAnalyzerV2Result result)
    {
        var teams = new List<ChooserTeam>
        {
            new ChooserTeam
            {
                Label = string.Join(" / ", result.TeamCharacters),
                Score = result.Score,
                Builds = result.Characters,
                IsRecommended = true,
                QuickCopyText = BuildQuickCopyText(result.Characters),
                DebugNotes = result.DebugNotes
            }
        };

        foreach (var alt in result.AlternateTeams)
        {
            teams.Add(new ChooserTeam
            {
                Label = string.Join(" / ", alt.Characters),
                Score = alt.Score,
                Builds = alt.CharacterBuilds,
                IsRecommended = false,
                Adds = alt.AddsVsBest,
                Drops = alt.DropsVsBest,
                QuickCopyText = BuildQuickCopyText(alt.CharacterBuilds),
                DebugNotes = alt.DebugNotes
            });
        }

        return teams;
    }

    private static string BuildQuickCopyText(List<PlayerPowerAnalyzerV2CharacterBuild> builds)
    {
        return string.Join(Environment.NewLine + Environment.NewLine, builds.Select(BuildQuickCopyCharacterLine));
    }

    private static string BuildQuickCopyCharacterLine(PlayerPowerAnalyzerV2CharacterBuild character)
    {
        var parts = new List<string>();

        var pairedWeapons = new[] { character.MainWeapon?.Name, character.OffHandWeapon?.Name }
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Cast<string>()
            .ToList();
        if (pairedWeapons.Count > 0)
        {
            parts.Add($"{character.CharacterName} w/ {JoinWithAnd(pairedWeapons)}.");
        }
        else
        {
            parts.Add(character.CharacterName + ".");
        }

        if (!string.IsNullOrWhiteSpace(character.MainOutfit?.Name))
        {
            parts.Add($"{character.MainOutfit.Name} costume.");
        }

        if (!string.IsNullOrWhiteSpace(character.UltimateWeapon?.Name))
        {
            parts.Add($"{character.UltimateWeapon.Name} UW.");
        }

        var subWeaponNames = character.SubWeapons
            .Select(slot => slot.Name)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .ToList();
        if (subWeaponNames.Count > 0)
        {
            parts.Add($"{JoinWithAnd(subWeaponNames)} for sub {(subWeaponNames.Count == 1 ? "weapon" : "weapons")}.");
        }

        var subOutfitNames = character.SubOutfits
            .Select(slot => slot.Name)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .ToList();
        if (subOutfitNames.Count > 0)
        {
            parts.Add($"{JoinWithAnd(subOutfitNames)} for sub {(subOutfitNames.Count == 1 ? "costume" : "costumes")}.");
        }

        return string.Join(" ", parts);
    }

    private static string JoinWithAnd(IReadOnlyList<string> values)
    {
        return values.Count switch
        {
            0 => string.Empty,
            1 => values[0],
            2 => values[0] + " and " + values[1],
            _ => string.Join(", ", values.Take(values.Count - 1)) + ", and " + values[^1]
        };
    }

    // Maps a slot's full SlotName (e.g. "Main Weapon", "Off-hand", "Ultimate", "Main Outfit") to a short,
    // scannable chip label + a power-v2-slot-chip-* color variant. Used to replace "SlotName:" text prefixes.
    private static (string Label, string CssClass) SlotChip(string? slotName)
    {
        return (slotName ?? string.Empty) switch
        {
            "Main Weapon" => ("Main", "power-v2-slot-chip-main"),
            "Off-hand" => ("Off", "power-v2-slot-chip-off"),
            "Ultimate" => ("UW", "power-v2-slot-chip-uw"),
            "Main Outfit" => ("Costume", "power-v2-slot-chip-costume"),
            "Sub Weapon" => ("Sub", "power-v2-slot-chip-sub"),
            "Sub Outfit" => ("Sub", "power-v2-slot-chip-sub"),
            _ => (string.IsNullOrWhiteSpace(slotName) ? "Slot" : slotName!, "power-v2-slot-chip-sub")
        };
    }
}

<div class="container-xxl py-4 power-v2-page">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <div class="text-uppercase small text-primary fw-semibold mb-2">Local Inventory Engine</div>
            <h1 class="display-6 fw-bold mb-2">Player Power Analyzer V2</h1>
            <p class="text-muted mb-0">Uses your saved inventory OB and level state to build a recommended 3-character team with explicit off-hand, sub-weapon, outfit, required-effect, and boss-immunity handling.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-outline-dark" id="playerPowerAnalyzerV2ImportButton">Load Repro File</button>
            <a class="btn btn-outline-secondary" href="/PlayerInventoryManagement">Open Inventory</a>
            <a class="btn btn-outline-primary" href="/PlayerPowerAnalyzer">Legacy Analyzer</a>
        </div>
    </div>

    <div class="alert alert-info d-flex align-items-start gap-2 mb-4" role="note">
        <span class="badge flex-shrink-0 mt-1" style="background-color: var(--brand-primary-strong); color: #fff;">BETA</span>
        <div>
            <strong>Beta &mdash; work in progress.</strong> This analyzer is under active development, and not every option has been fully tested yet. If a recommendation looks off &mdash; or you have team-build suggestions &mdash; <a href="#playerPowerAnalyzerV2ReproSection">instructions for submitting feedback</a> (with a debug snapshot) are at the bottom of the page.
        </div>
    </div>

    <div class="alert alert-info mb-4">
        This V2 page reads inventory from the shared browser storage key <code>player-inventory-state-v1</code>. It does not use survey-sheet ownership.
    </div>

    <input type="file" id="playerPowerAnalyzerV2ImportFile" class="d-none" accept=".json,application/json" />
    <div id="playerPowerAnalyzerV2ImportStatus" class="alert alert-secondary mb-4 d-none"></div>

    <form method="post" asp-page-handler="Analyze" id="playerPowerAnalyzerV2Form" class="d-grid gap-4">
        <input asp-for="LocalInventoryStateJson" type="hidden" id="LocalInventoryStateJson" />

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <span class="form-label fw-semibold d-block">Battle context</span>
                <div class="btn-group" role="group" aria-label="Battle context mode">
                    <input type="radio" class="btn-check" name="battleContextModeRadio" id="battleModeManual" value="manual" autocomplete="off" checked />
                    <label class="btn btn-outline-primary" for="battleModeManual">Manual</label>
                    <input type="radio" class="btn-check" name="battleContextModeRadio" id="battleModeBoss" value="boss" autocomplete="off" />
                    <label class="btn btn-outline-primary" for="battleModeBoss">By Boss</label>
                </div>
                <div class="dc-section-hint mt-2">Set Enemy Weakness / Damage Type / Target Scenario yourself, or pick a boss to infer them (and its required/damage sigils). Inferred values are shown below and stay editable.</div>

                <div id="bossPickerSection" class="mt-3 d-none">
                    <label class="form-label fw-semibold" for="bossSearchInput">Select an enemy</label>
                    <input type="text" class="form-control" id="bossSearchInput" placeholder="Search a boss or stage (e.g. Titan)" autocomplete="off" aria-autocomplete="list" />
                    <div id="bossSearchResults" class="list-group mt-1" style="max-height: 18rem; overflow-y: auto;"></div>
                    <div id="bossContextSummary" class="alert alert-info mt-2 small mb-0 d-none"></div>
                </div>
                <div id="bonusSigilsContainer"></div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="EnemyWeakness" class="form-label fw-semibold">Enemy Weakness</label>
                        <select asp-for="EnemyWeakness" class="form-select" asp-items="Html.GetEnumSelectList<Element>()"></select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="PreferredDamageType" class="form-label fw-semibold">Preferred Damage Type</label>
                        <select asp-for="PreferredDamageType" class="form-select" asp-items="Html.GetEnumSelectList<DamageType>()"></select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="TargetScenario" class="form-label fw-semibold">Target Scenario</label>
                        <select asp-for="TargetScenario" class="form-select" asp-items="Html.GetEnumSelectList<EnemyTargetScenario>()"></select>
                    </div>
                    <div class="col-md-3">
                        <span class="form-label fw-semibold d-block">Search Mode</span>
                        @* Segmented control: label-wrapped radios styled as DamageCalc mode chips. Binds to SearchMode
                           (posts enum value Fast/Full); Fast is checked by default to match the model default. *@
                        <div class="btn-group w-100" role="radiogroup" aria-label="Search Mode" id="SearchModeGroup">
                            <input asp-for="SearchMode" type="radio" class="btn-check" id="SearchMode_Fast" value="Fast" autocomplete="off" />
                            <label class="btn btn-outline-primary dc-chip-mode dc-mode-label" for="SearchMode_Fast">Fast · ~15s</label>
                            <input asp-for="SearchMode" type="radio" class="btn-check" id="SearchMode_Full" value="Full" autocomplete="off" />
                            <label class="btn btn-outline-primary dc-chip-mode dc-mode-label" for="SearchMode_Full">Full · ~60s</label>
                        </div>
                        <div class="form-check mt-2 d-flex align-items-center flex-wrap gap-2">
                            <span class="d-inline-flex align-items-center">
                                <input asp-for="ProSubWeaponOptimization" class="form-check-input mt-0 me-2" type="checkbox" id="ProSubWeaponOptimization" aria-describedby="ProSubWeaponOptimizationHint" />
                                <label class="form-check-label" for="ProSubWeaponOptimization">Pro: deeper sub-weapon optimization</label>
                            </span>
                            <span id="ProSubWeaponOptimizationHint" class="badge dc-chip dc-chip-mode">Available in Full mode</span>
                        </div>
                        <div class="dc-section-hint mt-2">
                            <div><span class="fw-semibold">Full (recommended):</span> Searches your full armory for the most accurate recommendation. Slower.</div>
                            <div><span class="fw-semibold">Fast:</span> Quick results for rough ideas — searches a reduced set of your strongest options and skips clearly-behind candidates. May differ from Full.</div>
                            <div><span class="fw-semibold">Pro (Full only):</span> picks sub-weapons by their exact damage contribution for the most refined build. Most accurate, slowest.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-1">Required Characters <span class="text-muted fw-normal fs-6">(optional, up to 3)</span></h2>
                <p class="text-muted small mb-3">Force specific characters into the recommended team &mdash; every built team will include all of them. You must own a main-hand weapon for each. Mutually-exclusive characters (e.g. a character and its alternate version) can't both be required.</p>
                <div class="row g-2" id="requiredCharactersGroup" data-max-required="3">
                    @foreach (var character in Model.AvailableCharacters)
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            <label class="form-check border rounded-3 px-3 py-2 mb-0">
                                <input class="form-check-input me-2 required-character-input" type="checkbox" name="RequiredCharacters" value="@character" @(Model.RequiredCharacters.Contains(character, StringComparer.OrdinalIgnoreCase) ? "checked" : null) />
                                <span class="form-check-label">@character</span>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Team Templates</h2>
                <div class="row g-2">
                    @foreach (var template in Model.AvailableTeamTemplates)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <label class="form-check border rounded-3 px-3 py-2 mb-0">
                                <input class="form-check-input me-2" type="checkbox" name="EnabledTeamTemplates[@template.Name]" value="true" @(Model.EnabledTeamTemplates.TryGetValue(template.Name, out var isEnabled) && isEnabled ? "checked" : null) />
                                <input type="hidden" name="EnabledTeamTemplates[@template.Name]" value="false" />
                                <span class="form-check-label">@template.Name</span>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Advanced filters: collapsed-by-default accordion reusing DamageCalc's dc-accordion pattern.
           All effect/immunity inputs stay inside the <form> with unchanged asp-for/name attributes — the
           accordion only hides them visually so they still bind/post. *@
        <div class="accordion dc-accordion" id="playerPowerAnalyzerV2AdvancedAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header" id="advancedFiltersHeading">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#advancedFiltersCollapse" aria-expanded="false" aria-controls="advancedFiltersCollapse">
                        Advanced filters
                    </button>
                </h2>
                <div id="advancedFiltersCollapse" class="accordion-collapse collapse" aria-labelledby="advancedFiltersHeading" data-bs-parent="#playerPowerAnalyzerV2AdvancedAccordion">
                    <div class="accordion-body">
                        <p class="dc-section-hint">Optional constraints. Boss immunities and required/preferred effects narrow which builds are valid or boosted; leave collapsed for a quick analysis.</p>
                        <div class="row g-4">
                            <div class="col-lg-12">
                                <h3 class="h6 fw-bold mb-2">Boss Immunities</h3>
                                <div class="row g-3">
                                    @foreach (var group in Model.BossImmunityOptionsByGroup)
                                    {
                                        <div class="col-md-6 col-lg-4">
                                            <div class="small text-uppercase text-muted fw-semibold mb-2">@group.Key</div>
                                            <div class="d-grid gap-2">
                                                @foreach (var option in group.Value)
                                                {
                                                    <label class="form-check border rounded-3 px-3 py-2 mb-0">
                                                        <input class="form-check-input me-2" type="checkbox" name="BossImmunityKeys" value="@option.Key" @(Model.BossImmunityKeys.Contains(option.Key, StringComparer.OrdinalIgnoreCase) ? "checked" : null) />
                                                        <span class="form-check-label">@option.Label</span>
                                                    </label>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-lg-12">
                                <h3 class="h6 fw-bold mb-2">Required Sigils</h3>
                                <p class="dc-section-hint mb-2">Only keep teams where a character can cover each selected sigil: a <strong>main-hand</strong> sigil-boost materia slot for ◯ Circle / △ Triangle / ✕ Cross, or a <strong>main- or off-hand</strong> ◊ Diamond ability sigil. (Match this to a boss's break sigils on the <a asp-page="/EnemyStats">Enemy Stats</a> page.)</p>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var (value, symbol) in Model.AvailableSigils)
                                    {
                                        <label class="form-check border rounded-3 px-3 py-2 mb-0">
                                            <input class="form-check-input me-2" type="checkbox" name="RequiredSigils" value="@value" @(Model.RequiredSigils.Contains(value, StringComparer.OrdinalIgnoreCase) ? "checked" : null) />
                                            <span class="form-check-label">@symbol @value</span>
                                        </label>
                                    }
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        @* Tri-state effect filter: ONE row per effect, each with an Off / Preferred / Required
                           segmented radio group. The visible radios drive two visually-hidden checkboxes per effect
                           (name="HardRequiredEffectKeys" and name="SoftPreferredEffectKeys") so the form posts the
                           exact same field names/values as the old two-list UI — zero server change. Mutually
                           exclusive by construction, so the old silent-dedupe (.Except) trap is gone. JS in
                           initEffectTriState() initializes each pill from the hidden checkbox checked-state on load
                           (and is re-called after a repro import). *@
                        <h3 class="h6 fw-bold mb-2">Required &amp; Preferred Effects</h3>
                        <p class="dc-section-hint">Set each effect to <span class="fw-semibold">Off</span>, <span class="fw-semibold">⭐ Preferred</span> (boosts score), or <span class="fw-semibold">🔒 Required</span> (invalidates builds that lack it). An effect can be one or the other, not both.</p>
                        <div id="playerPowerAnalyzerV2EffectTriState">
                            @foreach (var group in Model.EffectOptionsByGroup)
                            {
                                <div class="mb-3">
                                    <div class="small text-uppercase text-muted fw-semibold mb-2">@group.Key</div>
                                    <div class="d-grid gap-2">
                                        @foreach (var option in group.Value)
                                        {
                                            var triName = "effectTriState_" + option.Key;
                                            var isRequired = Model.HardRequiredEffectKeys.Contains(option.Key, StringComparer.OrdinalIgnoreCase);
                                            var isPreferred = !isRequired && Model.SoftPreferredEffectKeys.Contains(option.Key, StringComparer.OrdinalIgnoreCase);
                                            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 border rounded-3 px-3 py-2 power-v2-effect-row" data-effect-key="@option.Key">
                                                @* Visually-hidden checkboxes carry the binding. JS keeps them in sync with the visible radios. *@
                                                <input class="visually-hidden power-v2-effect-hidden-required" type="checkbox" name="HardRequiredEffectKeys" value="@option.Key" tabindex="-1" aria-hidden="true" @(isRequired ? "checked" : null) />
                                                <input class="visually-hidden power-v2-effect-hidden-preferred" type="checkbox" name="SoftPreferredEffectKeys" value="@option.Key" tabindex="-1" aria-hidden="true" @(isPreferred ? "checked" : null) />
                                                <span class="form-check-label fw-semibold power-v2-effect-label" id="@(triName)_label">@option.Label</span>
                                                <div class="btn-group btn-group-sm flex-shrink-0 power-v2-effect-tri" role="radiogroup" aria-labelledby="@(triName)_label">
                                                    <input type="radio" class="btn-check" name="@triName" id="@(triName)_off" value="off" autocomplete="off" @(!isRequired && !isPreferred ? "checked" : null) />
                                                    <label class="btn btn-outline-secondary" for="@(triName)_off">Off</label>
                                                    <input type="radio" class="btn-check" name="@triName" id="@(triName)_preferred" value="preferred" autocomplete="off" @(isPreferred ? "checked" : null) />
                                                    <label class="btn btn-outline-primary" for="@(triName)_preferred" title="Preferred (boosts score)">⭐ <span class="d-none d-sm-inline">Preferred</span><span class="d-sm-none">Pref</span></label>
                                                    <input type="radio" class="btn-check" name="@triName" id="@(triName)_required" value="required" autocomplete="off" @(isRequired ? "checked" : null) />
                                                    <label class="btn btn-outline-danger" for="@(triName)_required" title="Required (invalidates builds without it)">🔒 <span class="d-none d-sm-inline">Required</span><span class="d-sm-none">Req</span></label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <hr class="my-4" />

                        <h3 class="h6 fw-bold mb-2">Analysis Notes</h3>
                        <div class="dc-section-hint">
                            <div>Main weapon, off-hand, ultimate, and main outfit effects are scored as active team utility.</div>
                            <div>Off-hand contributes half-value stats and passive points, rounded down immediately, but still uses its ability for utility scoring.</div>
                            <div>Sub-weapons and sub-outfits only contribute half-value stats and passive points, rounded down immediately.</div>
                            <div>Sub weapons are shared across the full team and cannot be duplicated once equipped.</div>
                            <div>Hard-required effects invalidate a build. Preferred effects boost score without invalidating.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary btn-lg">Analyze V2 Team</button>
            <a class="btn btn-outline-secondary btn-lg" href="/PlayerPowerAnalyzerV2">Reset</a>
        </div>
    </form>

    @if (Model.AnalysisResult != null && !Model.AnalysisResult.HasResult)
    {
        <div class="alert alert-warning mt-4">@Model.AnalysisResult.FailureReason</div>
    }

    @if (Model.AnalysisResult?.HasResult == true)
    {
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
                    <div>
                        <div class="text-uppercase small text-primary fw-semibold mb-2">Recommended Team</div>
                        <h2 class="h3 fw-bold mb-2">@string.Join(" / ", Model.AnalysisResult.TeamCharacters)</h2>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge power-v2-score-badge px-3 py-2" title="Relative model score — a unitless ranking number, not in-game power.">Score @Model.AnalysisResult.Score.ToString("N2")</span>
                            <span class="small text-muted">relative model number — no unit</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.AnalysisResult.OffensiveAbilitySummary))
                        {
                            <div class="small text-muted"><span class="fw-semibold">Why:</span> @Model.AnalysisResult.OffensiveAbilitySummary</div>
                        }
                    </div>
                    <div class="d-flex flex-wrap gap-2 align-content-start">
                        @if (!string.IsNullOrWhiteSpace(Model.AnalysisResult.MatchedTemplateName))
                        {
                            <span class="badge power-v2-pill-primary px-3 py-2">@Model.AnalysisResult.MatchedTemplateName</span>
                        }
                        @foreach (var label in Model.AnalysisResult.ProvidedEffectLabels)
                        {
                            <span class="badge power-v2-pill px-3 py-2">@label</span>
                        }
                    </div>
                </div>

                <div class="border rounded-3 p-3 mb-3 bg-light-subtle">
                    <div class="dc-section-hint mb-0">
                        <strong>About these suggestions:</strong> These are model-driven recommendations and a strong starting point — an experienced player might build differently. If a pick looks off, or you've found a better build, <a href="#playerPowerAnalyzerV2ReproSection"><strong>export the debug snapshot</strong></a> (it captures your inventory, settings, and this result) and send it to us with a note on what looks wrong. Submit/contact details are at the bottom of the page.
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.AnalysisResult.OffensiveAbilitySummary))
                {
                    <div class="border rounded-3 p-3 mb-3 bg-light-subtle">
                        <div class="small text-uppercase text-muted fw-semibold mb-2">Offensive Ability Summary</div>
                        <div>@Model.AnalysisResult.OffensiveAbilitySummary</div>
                    </div>
                }

                @if (Model.AnalysisResult.Warnings.Count > 0)
                {
                    <div class="alert alert-warning">
                        @foreach (var warning in Model.AnalysisResult.Warnings)
                        {
                            <div>@warning</div>
                        }
                    </div>
                }

                <div class="row g-3 mb-3">
                    <div class="col-lg-4">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="small text-uppercase text-muted fw-semibold mb-2">Hard Requirements</div>
                            <div class="small mb-2"><strong>Matched:</strong> @(Model.AnalysisResult.MatchedRequiredEffects.Count > 0 ? string.Join(", ", Model.AnalysisResult.MatchedRequiredEffects) : "None")</div>
                            <div class="small"><strong>Missing:</strong> @(Model.AnalysisResult.MissingRequiredEffects.Count > 0 ? string.Join(", ", Model.AnalysisResult.MissingRequiredEffects) : "None")</div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="small text-uppercase text-muted fw-semibold mb-2">Preferred Effects</div>
                            <div class="small mb-2"><strong>Matched:</strong> @(Model.AnalysisResult.MatchedPreferredEffects.Count > 0 ? string.Join(", ", Model.AnalysisResult.MatchedPreferredEffects) : "None")</div>
                            <div class="small"><strong>Missing:</strong> @(Model.AnalysisResult.MissingPreferredEffects.Count > 0 ? string.Join(", ", Model.AnalysisResult.MissingPreferredEffects) : "None")</div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="small text-uppercase text-muted fw-semibold mb-2">Inventory Coverage</div>
                            <div class="small mb-2"><strong>Characters:</strong> @Model.AnalysisResult.AvailableCharacterCount</div>
                            <div class="small"><strong>Unset Levels:</strong> @Model.AnalysisResult.UnsetLevelWeaponCount</div>
                        </div>
                    </div>
                </div>

                @if (Model.AnalysisResult.SuppressedEffectNotes.Count > 0)
                {
                    <div class="alert alert-secondary">
                        @foreach (var note in Model.AnalysisResult.SuppressedEffectNotes)
                        {
                            <div>@note</div>
                        }
                    </div>
                }
            </div>
        </div>

        var chooserTeams = BuildChooserTeams(Model.AnalysisResult);

        if (chooserTeams.Count > 1)
        {
            <div class="card shadow-sm border-0 mt-3">
                <div class="card-body p-3">
                    <div class="small text-uppercase text-muted fw-semibold mb-2">Choose a team to view its full build-out</div>
                    <div class="d-flex flex-wrap gap-2" id="playerPowerAnalyzerV2TeamChooser">
                        @for (var ti = 0; ti < chooserTeams.Count; ti++)
                        {
                            var ct = chooserTeams[ti];
                            <button type="button" class="btn @(ti == 0 ? "btn-primary" : "btn-outline-secondary") btn-sm team-chooser-btn" data-team-index="@ti">
                                <span class="fw-semibold">@(ct.IsRecommended ? "★ Recommended" : "Alternate")</span>
                                <span class="ms-1">@ct.Label</span>
                                <span class="badge bg-light text-dark ms-1">@ct.Score.ToString("N0")</span>
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        for (var teamIndex = 0; teamIndex < chooserTeams.Count; teamIndex++)
        {
            var chosenTeam = chooserTeams[teamIndex];
            <div class="row g-4 mt-1 team-buildout" data-team-index="@teamIndex" style="@(teamIndex == 0 ? string.Empty : "display:none;")">
                @if (!chosenTeam.IsRecommended && (chosenTeam.Adds.Count > 0 || chosenTeam.Drops.Count > 0))
                {
                    <div class="col-12">
                        <div class="alert alert-secondary mb-0">
                            <div class="fw-semibold mb-1">Tradeoff vs recommended team</div>
                            @if (chosenTeam.Adds.Count > 0)
                            {
                                <div class="small"><strong>Adds:</strong> @string.Join(", ", chosenTeam.Adds)</div>
                            }
                            @if (chosenTeam.Drops.Count > 0)
                            {
                                <div class="small"><strong>Drops:</strong> @string.Join(", ", chosenTeam.Drops)</div>
                            }
                        </div>
                    </div>
                }
                @foreach (var character in chosenTeam.Builds)
                {
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@character.CharacterPortraitUrl" alt="@character.CharacterName" class="rounded-3 character-portrait" />
                                    <div>
                                        <h3 class="h4 fw-bold mb-1">@character.CharacterName</h3>
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <span class="text-muted">@character.Role</span>
                                            <span class="badge power-v2-score-badge px-2 py-1" title="Relative model score — a unitless ranking number.">Score @character.Score.ToString("N2")</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap gap-2 align-content-start">
                                    <span class="badge power-v2-pill px-3 py-2">PATK @character.TotalPatk</span>
                                    <span class="badge power-v2-pill px-3 py-2">MATK @character.TotalMatk</span>
                                    <span class="badge power-v2-pill px-3 py-2">HEAL @character.TotalHeal</span>
                                </div>
                            </div>

                            @if (character.ProvidedEffectLabels.Count > 0)
                            {
                                <div class="mb-3 d-flex flex-wrap gap-2">
                                    @foreach (var label in character.ProvidedEffectLabels)
                                    {
                                        <span class="badge power-v2-pill-accent px-3 py-2">@label</span>
                                    }
                                </div>
                            }

                            @if (character.RecommendedMateria.Count > 0)
                            {
                                <div class="border rounded-3 p-3 mb-3 bg-light-subtle">
                                    <div class="small text-uppercase text-muted fw-semibold mb-2">Assumed Materia Setup</div>
                                    <div class="row g-2">
                                        @foreach (var slotNumber in Enumerable.Range(1, 3))
                                        {
                                            var materia = character.RecommendedMateria.FirstOrDefault(item => item.SlotNumber == slotNumber);
                                            <div class="col-md-4">
                                                <div class="border rounded-3 p-3 h-100 bg-white">
                                                    <div class="small text-uppercase text-muted fw-semibold mb-1">Materia Slot @slotNumber</div>
                                                    @if (materia == null)
                                                    {
                                                        <div class="small text-muted">Open / no current engine assumption.</div>
                                                    }
                                                    else
                                                    {
                                                        <div class="fw-semibold">@materia.Name</div>
                                                        <div class="small text-muted">Provides @materia.ProvidedEffectLabel</div>
                                                        <div class="small text-muted mt-1">@materia.Reason</div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="row g-3">
                                <div class="col-lg-6">
                                    <div class="border rounded-3 p-3 h-100">
                                        <div class="small text-uppercase text-muted fw-semibold mb-2">Weapons</div>
                                        @foreach (var slot in new[] { character.MainWeapon, character.OffHandWeapon, character.UltimateWeapon }.Where(slot => slot != null))
                                        {
                                            var weaponChip = SlotChip(slot!.SlotName);
                                            <div class="slot-entry mb-3">
                                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                                    <span class="badge power-v2-slot-chip @weaponChip.CssClass" title="@slot.SlotName">@weaponChip.Label</span>
                                                    <span class="fw-semibold">@slot.Name</span>
                                                    <span class="badge power-v2-score-badge" title="Relative model score — a unitless ranking number.">Score @slot.Score.ToString("N2")</span>
                                                </div>
                                                <div class="small text-muted">Lv @slot.Level • OB @slot.OverboostLevel</div>
                                                @if ((string.Equals(slot.SlotName, "Main Weapon", StringComparison.OrdinalIgnoreCase)
                                                    || string.Equals(slot.SlotName, "Off-hand", StringComparison.OrdinalIgnoreCase))
                                                    && !string.IsNullOrWhiteSpace(slot.AbilityText))
                                                {
                                                    <div class="small mt-1">Ability: @slot.AbilityText</div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(slot.SelectedCustomization))
                                                {
                                                    <div class="small">Customization: @slot.SelectedCustomization</div>
                                                }
                                                @if (slot.PassiveSummaries.Count > 0)
                                                {
                                                    <div class="small text-muted">@string.Join(" • ", slot.PassiveSummaries)</div>
                                                }
                                            </div>
                                        }
                                        @if (character.SubWeapons.Count > 0)
                                        {
                                            <div class="small text-uppercase text-muted fw-semibold mb-2 mt-3">Sub Weapons</div>
                                            @foreach (var sub in character.SubWeapons)
                                            {
                                                <div class="slot-entry mb-2">
                                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                                        <span class="badge power-v2-slot-chip power-v2-slot-chip-sub" title="Sub Weapon">Sub</span>
                                                        <span class="fw-semibold">@sub.Name</span>
                                                    </div>
                                                    <div class="small text-muted">Lv @sub.Level • OB @sub.OverboostLevel • @string.Join(" • ", sub.PassiveSummaries)</div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="border rounded-3 p-3 h-100">
                                        <div class="small text-uppercase text-muted fw-semibold mb-2">Outfits & Passive Stack</div>
                                        @foreach (var slot in new[] { character.MainOutfit }.Where(slot => slot != null))
                                        {
                                            var outfitChip = SlotChip(slot!.SlotName);
                                            <div class="slot-entry mb-3">
                                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                                    <span class="badge power-v2-slot-chip @outfitChip.CssClass" title="@slot.SlotName">@outfitChip.Label</span>
                                                    <span class="fw-semibold">@slot.Name</span>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(slot.AbilityText))
                                                {
                                                    <div class="small mt-1">Ability: @slot.AbilityText</div>
                                                }
                                                <div class="small text-muted">@string.Join(" • ", slot.PassiveSummaries)</div>
                                            </div>
                                        }
                                        @if (character.SubOutfits.Count > 0)
                                        {
                                            <div class="small text-uppercase text-muted fw-semibold mb-2 mt-3">Sub Outfits</div>
                                            @foreach (var sub in character.SubOutfits)
                                            {
                                                <div class="slot-entry mb-2">
                                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                                        <span class="badge power-v2-slot-chip power-v2-slot-chip-sub" title="Sub Outfit">Sub</span>
                                                        <span class="fw-semibold">@sub.Name</span>
                                                    </div>
                                                    <div class="small text-muted">@string.Join(" • ", sub.PassiveSummaries)</div>
                                                </div>
                                            }
                                        }

                                        @if (character.KeyRAbilities.Count > 0)
                                        {
                                            <div class="small text-uppercase text-muted fw-semibold mb-2 mt-3">Top Passive Totals</div>
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (var passive in character.KeyRAbilities)
                                                {
                                                    <span class="badge power-v2-pill px-3 py-2">@passive</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                }
            </div>
        }

        <div class="row g-4 mt-1">
            <div class="col-xl-4 col-lg-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
                            <h3 class="h5 fw-bold mb-0">Quick Copy</h3>
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="playerPowerAnalyzerV2QuickCopyButton">Copy</button>
                        </div>
                        <div class="small text-muted mb-2">Simple text version of the selected team for quick paste and follow-up analysis.</div>
                        <textarea class="form-control power-v2-quick-copy-text" id="playerPowerAnalyzerV2QuickCopyText" readonly>@chooserTeams[0].QuickCopyText</textarea>
                        <div class="small text-muted mt-2" id="playerPowerAnalyzerV2QuickCopyStatus"></div>
                        @* Hidden per-team copies of the quick-copy text; the chooser JS swaps the visible textarea above. *@
                        @for (var qi = 0; qi < chooserTeams.Count; qi++)
                        {
                            <textarea class="d-none team-quickcopy-source" data-team-index="@qi">@chooserTeams[qi].QuickCopyText</textarea>
                        }
                    </div>
                </div>
            </div>
            @* "Other Teams" summary card removed — the team chooser above now lists every team (name + score)
               and lets the user view each one's full build-out, with the Adds/Drops tradeoff shown inline. *@
            @if (chooserTeams.Any(t => t.DebugNotes.Count > 0))
            {
                <div class="col-xl-4 col-lg-6">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4">
                                <h3 class="h5 fw-bold mb-3">Debug Notes</h3>
                                @for (var di = 0; di < chooserTeams.Count; di++)
                                {
                                    <div class="small text-muted d-grid gap-2 team-debugnotes" data-team-index="@di" style="@(di == 0 ? string.Empty : "display:none;")">
                                        @if (chooserTeams[di].DebugNotes.Count == 0)
                                        {
                                            <div class="fst-italic">No debug notes for this team.</div>
                                        }
                                        @foreach (var note in chooserTeams[di].DebugNotes)
                                        {
                                            <div>@note</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                </div>
            }
            </div>

        <div class="card shadow-sm border-0 mt-4" id="playerPowerAnalyzerV2ReproSection">
            <div class="card-body p-4">
                <h3 class="h5 fw-bold mb-3">Issues or Suggestions?</h3>
                <p class="text-muted mb-3">Do you believe this team build is incorrect or misleading? Export a repro file, then send that file along with a detailed description of what you believe is wrong to <strong>ddelaneyca</strong> on Discord or <a href="mailto:ddelaneyca@gmail.com">ddelaneyca@gmail.com</a>.</p>
                <p class="text-muted mb-3">When reporting, please include <strong>what looks wrong with the recommended team</strong> — which character/weapon/costume pick, and why you'd expect different — along with the exported snapshot, so we can reproduce and investigate.</p>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <button type="button" class="btn btn-primary" id="playerPowerAnalyzerV2ExportButton">Export V2 Repro File</button>
                    <button type="button" class="btn btn-outline-secondary" id="playerPowerAnalyzerV2ImportResultButton">Load Repro File and Re-run</button>
                </div>
                <div class="small text-muted d-grid gap-2">
                    <div>The exported file includes your local inventory snapshot and the current V2 analyzer settings from this page.</div>
                    <div>Anyone with the file can load it back into this page to reproduce the same analyzer request and compare the resulting team.</div>
                </div>
            </div>
        </div>

        <script>
            (function () {
                var buttons = Array.prototype.slice.call(document.querySelectorAll('.team-chooser-btn'));
                var panels = Array.prototype.slice.call(document.querySelectorAll('.team-buildout'));
                var debugBlocks = Array.prototype.slice.call(document.querySelectorAll('.team-debugnotes'));
                var quickCopyText = document.getElementById('playerPowerAnalyzerV2QuickCopyText');
                buttons.forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var idx = btn.getAttribute('data-team-index');
                        panels.forEach(function (panel) {
                            panel.style.display = panel.getAttribute('data-team-index') === idx ? '' : 'none';
                        });
                        debugBlocks.forEach(function (block) {
                            block.style.display = block.getAttribute('data-team-index') === idx ? '' : 'none';
                        });
                        // Swap the Quick Copy text to the selected team's loadout (the Copy button keeps working on it).
                        var source = document.querySelector('.team-quickcopy-source[data-team-index="' + idx + '"]');
                        if (quickCopyText && source) {
                            quickCopyText.value = source.value;
                        }
                        buttons.forEach(function (other) {
                            var isActive = other === btn;
                            other.classList.toggle('btn-primary', isActive);
                            other.classList.toggle('btn-outline-secondary', !isActive);
                        });
                    });
                });
            })();
        </script>
    }
</div>

<div id="playerPowerAnalyzerV2ProcessingOverlay" class="power-v2-processing-overlay" aria-hidden="true">
    <div class="power-v2-processing-dialog shadow-lg">
        <div class="spinner-border text-primary mb-3" role="status" aria-hidden="true"></div>
        <h2 class="h4 fw-bold mb-2">Analyzing V2 Team</h2>
        <p class="text-muted mb-3">Team generation can take a while for large inventories. Please keep this tab open while I process your builds.</p>
        <div id="playerPowerAnalyzerV2ProcessingStatus" class="fw-semibold">Loading inventory snapshot...</div>
        <div class="small text-muted mt-2">This page will update automatically when analysis finishes.</div>
    </div>
</div>

@section Styles {
    <style>
        .power-v2-page .power-v2-pill {
            background: #f8fafc;
            color: #0f172a;
            border: 1px solid rgba(15, 23, 42, 0.14);
        }

        .power-v2-page .power-v2-pill-primary {
            background: var(--brand-primary-strong);
            color: #ffffff;
            border: 1px solid var(--brand-primary-strong);
        }

        .power-v2-page .power-v2-pill-accent {
            background: var(--brand-primary-soft);
            color: var(--brand-primary-strong);
            border: 1px solid var(--brand-primary);
        }

        .power-v2-page .power-v2-score-badge {
            background: #eef2ff;
            color: #3730a3;
            border: 1px solid #c7d2fe;
            font-variant-numeric: tabular-nums;
            font-weight: 600;
        }

        /* Slot-type chips: small, uppercase, colored by slot family so the eye can scan Main / Off / UW / Sub / Costume. */
        .power-v2-page .power-v2-slot-chip {
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            padding: 0.1rem 0.5rem;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            text-transform: uppercase;
        }

        .power-v2-page .power-v2-slot-chip-main {
            background: var(--brand-primary-strong);
            color: #ffffff;
            border: 1px solid var(--brand-primary-strong);
        }

        .power-v2-page .power-v2-slot-chip-off {
            background: var(--brand-primary-soft);
            color: var(--brand-primary-strong);
            border: 1px solid var(--brand-primary);
        }

        .power-v2-page .power-v2-slot-chip-uw {
            background: #fef3c7;
            color: #92400e;
            border: 1px solid #fcd34d;
        }

        .power-v2-page .power-v2-slot-chip-costume {
            background: #ede9fe;
            color: #5b21b6;
            border: 1px solid #ddd6fe;
        }

        .power-v2-page .power-v2-slot-chip-sub {
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #cbd5e1;
        }

        .power-v2-page .power-v2-effect-row {
            background: #ffffff;
        }

        .power-v2-page .character-portrait {
            width: 72px;
            height: 72px;
            object-fit: cover;
            border: 1px solid rgba(15, 23, 42, 0.1);
        }

        .power-v2-page .slot-entry:last-child {
            margin-bottom: 0;
        }

        .power-v2-page .power-v2-quick-copy-text {
            min-height: 14rem;
            font-family: Consolas, "Courier New", monospace;
            font-size: 0.94rem;
            white-space: pre-wrap;
        }

        .power-v2-processing-overlay {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            background: rgba(15, 23, 42, 0.52);
            backdrop-filter: blur(4px);
            z-index: 1080;
        }

        .power-v2-processing-overlay.is-visible {
            display: flex;
        }

        .power-v2-processing-dialog {
            width: min(100%, 32rem);
            border-radius: 1rem;
            background: #ffffff;
            padding: 2rem;
            text-align: center;
        }

        body.power-v2-processing-active {
            overflow: hidden;
        }
    </style>
}
@section Scripts {
    <script>
        (function () {
            const storageKey = 'player-inventory-state-v1';
            const exportSchema = 'player-power-analyzer-v2-repro';
            const exportSchemaVersion = 1;
            const input = document.getElementById('LocalInventoryStateJson');
            const form = document.getElementById('playerPowerAnalyzerV2Form');
            const overlay = document.getElementById('playerPowerAnalyzerV2ProcessingOverlay');
            const status = document.getElementById('playerPowerAnalyzerV2ProcessingStatus');
            const analyzeButton = form ? form.querySelector('button[type="submit"]') : null;
            const exportButton = document.getElementById('playerPowerAnalyzerV2ExportButton');
            const importButton = document.getElementById('playerPowerAnalyzerV2ImportButton');
            const importResultButton = document.getElementById('playerPowerAnalyzerV2ImportResultButton');
            const importFileInput = document.getElementById('playerPowerAnalyzerV2ImportFile');
            const importStatus = document.getElementById('playerPowerAnalyzerV2ImportStatus');
            const quickCopyButton = document.getElementById('playerPowerAnalyzerV2QuickCopyButton');
            const quickCopyText = document.getElementById('playerPowerAnalyzerV2QuickCopyText');
            const quickCopyStatus = document.getElementById('playerPowerAnalyzerV2QuickCopyStatus');
            const processingMessages = [
                'Loading inventory snapshot...',
                'Scoring main-hand, off-hand, and ultimate weapon options...',
                'Assembling character variants and passive totals...',
                'Assigning shared sub-weapons across the full team...',
                'Checking required effects, boss immunities, and team templates...',
                'Finalizing the highest-scoring teams...'
            ];
            let processingTimer = null;

            function hydrateInventoryState() {
                if (!input) {
                    return;
                }

                input.value = window.localStorage.getItem(storageKey) || '';
            }

            function setImportStatus(message, isError) {
                if (!importStatus) {
                    return;
                }

                if (!message) {
                    importStatus.textContent = '';
                    importStatus.classList.add('d-none');
                    importStatus.classList.remove('alert-danger');
                    importStatus.classList.add('alert-secondary');
                    return;
                }

                importStatus.textContent = message;
                importStatus.classList.remove('d-none');
                importStatus.classList.toggle('alert-danger', !!isError);
                importStatus.classList.toggle('alert-secondary', !isError);
            }

            function getCheckedValues(name) {
                return Array.from(document.querySelectorAll(`input[name="${name}"]:checked`)).map(function (element) {
                    return element.value;
                });
            }

            function getEnabledTeamTemplates() {
                const enabled = [];
                document.querySelectorAll('input[name^="EnabledTeamTemplates["][type="checkbox"]').forEach(function (checkbox) {
                    if (checkbox.checked) {
                        const match = checkbox.name.match(/^EnabledTeamTemplates\[(.*)\]$/);
                        if (match && match[1]) {
                            enabled.push(match[1]);
                        }
                    }
                });
                return enabled;
            }

            function buildAnalyzerRequestSnapshot() {
                const enemyWeakness = document.getElementById('EnemyWeakness');
                const preferredDamageType = document.getElementById('PreferredDamageType');
                const targetScenario = document.getElementById('TargetScenario');
                const checkedSearchMode = document.querySelector('input[name="SearchMode"][type="radio"]:checked');
                const proSubWeapon = document.getElementById('ProSubWeaponOptimization');
                return {
                    enemyWeakness: enemyWeakness ? enemyWeakness.value : 'None',
                    preferredDamageType: preferredDamageType ? preferredDamageType.value : 'Any',
                    targetScenario: targetScenario ? targetScenario.value : 'Unknown',
                    searchMode: checkedSearchMode ? checkedSearchMode.value : 'Fast', // default Fast (matches UI default)
                    proSubWeaponOptimization: proSubWeapon ? proSubWeapon.checked : false,
                    enabledTeamTemplates: getEnabledTeamTemplates(),
                    bossImmunityKeys: getCheckedValues('BossImmunityKeys'),
                    hardRequiredEffectKeys: getCheckedValues('HardRequiredEffectKeys'),
                    softPreferredEffectKeys: getCheckedValues('SoftPreferredEffectKeys')
                };
            }

            function createExportPayload() {
                hydrateInventoryState();
                return {
                    schema: exportSchema,
                    schemaVersion: exportSchemaVersion,
                    exportedAtUtc: new Date().toISOString(),
                    sourcePage: 'PlayerPowerAnalyzerV2',
                    inventoryStorageKey: storageKey,
                    localInventoryStateJson: input ? (input.value || '') : '',
                    analyzerRequest: buildAnalyzerRequestSnapshot()
                };
            }

            function exportStateToFile() {
                const payload = createExportPayload();
                if (!payload.localInventoryStateJson) {
                    setImportStatus('No local inventory snapshot is currently loaded. Update inventory first, then analyze or export again.', true);
                    return;
                }

                const json = JSON.stringify(payload, null, 2);
                const blob = new Blob([json], { type: 'application/json;charset=utf-8' });
                const url = URL.createObjectURL(blob);
                const anchor = document.createElement('a');
                const stamp = new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-');
                anchor.href = url;
                anchor.download = `player-power-analyzer-v2-repro-${stamp}.json`;
                document.body.appendChild(anchor);
                anchor.click();
                document.body.removeChild(anchor);
                URL.revokeObjectURL(url);
                setImportStatus('Repro file exported. Send it with a description of the issue so the build can be replicated.', false);
            }

            function setSelectValue(id, value) {
                const select = document.getElementById(id);
                if (select && typeof value === 'string' && value.length > 0) {
                    select.value = value;
                }
            }

            function setRadioGroupValue(name, value, fallback) {
                const target = (typeof value === 'string' && value.length > 0) ? value : fallback;
                const radios = Array.prototype.slice.call(document.querySelectorAll(`input[name="${name}"][type="radio"]`));
                let matched = false;
                radios.forEach(function (radio) {
                    const isMatch = radio.value === target;
                    radio.checked = isMatch;
                    matched = matched || isMatch;
                });
                // Older snapshots may carry an unexpected value; fall back to the default radio so the control is never empty.
                if (!matched && fallback) {
                    radios.forEach(function (radio) { radio.checked = radio.value === fallback; });
                }
            }

            function setCheckboxGroup(name, selectedValues) {
                const selected = new Set(Array.isArray(selectedValues) ? selectedValues : []);
                document.querySelectorAll(`input[name="${name}"][type="checkbox"]`).forEach(function (checkbox) {
                    checkbox.checked = selected.has(checkbox.value);
                });
            }

            function setEnabledTeamTemplates(selectedTemplates) {
                const selected = new Set(Array.isArray(selectedTemplates) ? selectedTemplates : []);
                document.querySelectorAll('input[name^="EnabledTeamTemplates["][type="checkbox"]').forEach(function (checkbox) {
                    const match = checkbox.name.match(/^EnabledTeamTemplates\[(.*)\]$/);
                    checkbox.checked = !!(match && selected.has(match[1]));
                });
            }

            function applyImportedPayload(payload) {
                const request = payload && typeof payload === 'object' && payload.analyzerRequest && typeof payload.analyzerRequest === 'object'
                    ? payload.analyzerRequest
                    : payload;
                const importedInventoryJson = payload && typeof payload.localInventoryStateJson === 'string'
                    ? payload.localInventoryStateJson
                    : '';

                if (!importedInventoryJson) {
                    throw new Error('The selected repro file does not contain a local inventory snapshot.');
                }

                window.localStorage.setItem(storageKey, importedInventoryJson);
                if (input) {
                    input.value = importedInventoryJson;
                }

                setSelectValue('EnemyWeakness', request.enemyWeakness);
                setSelectValue('PreferredDamageType', request.preferredDamageType);
                setSelectValue('TargetScenario', request.targetScenario);
                // Older snapshots without searchMode default to Fast (matches the model default).
                setRadioGroupValue('SearchMode', request.searchMode, 'Fast');
                const proSubWeaponImport = document.getElementById('ProSubWeaponOptimization');
                if (proSubWeaponImport) {
                    proSubWeaponImport.checked = !!request.proSubWeaponOptimization;
                }
                syncProSubWeaponGating();
                setEnabledTeamTemplates(request.enabledTeamTemplates);
                setCheckboxGroup('BossImmunityKeys', request.bossImmunityKeys);
                setCheckboxGroup('HardRequiredEffectKeys', request.hardRequiredEffectKeys);
                setCheckboxGroup('SoftPreferredEffectKeys', request.softPreferredEffectKeys);
                // Re-sync the visible tri-state pills from the checkboxes we just set (function is hoisted).
                initEffectTriState();
            }

            function triggerImportState() {
                if (!importFileInput) {
                    return;
                }

                importFileInput.value = '';
                importFileInput.click();
            }

            function setQuickCopyStatus(message) {
                if (!quickCopyStatus) {
                    return;
                }

                quickCopyStatus.textContent = message || '';
            }

            function copyQuickCopyText() {
                if (!quickCopyText) {
                    return;
                }

                const text = quickCopyText.value || '';
                if (!text.trim()) {
                    setQuickCopyStatus('Nothing to copy.');
                    return;
                }

                if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
                    navigator.clipboard.writeText(text).then(function () {
                        setQuickCopyStatus('Copied to clipboard.');
                    }).catch(function () {
                        quickCopyText.focus();
                        quickCopyText.select();
                        document.execCommand('copy');
                        setQuickCopyStatus('Copied to clipboard.');
                    });
                    return;
                }

                quickCopyText.focus();
                quickCopyText.select();
                document.execCommand('copy');
                setQuickCopyStatus('Copied to clipboard.');
            }

            function startProcessingOverlay() {
                if (!overlay || !status) {
                    return;
                }

                if (processingTimer) {
                    window.clearInterval(processingTimer);
                }

                let index = 0;
                status.textContent = processingMessages[index];
                overlay.classList.add('is-visible');
                overlay.setAttribute('aria-hidden', 'false');
                document.body.classList.add('power-v2-processing-active');
                if (analyzeButton) {
                    analyzeButton.setAttribute('disabled', 'disabled');
                }

                processingTimer = window.setInterval(function () {
                    index = (index + 1) % processingMessages.length;
                    status.textContent = processingMessages[index];
                }, 2400);
            }

            // --- Tri-state effect filter (Off / Preferred / Required) ---------------------------------------
            // Each effect row has two visually-hidden checkboxes (HardRequiredEffectKeys / SoftPreferredEffectKeys)
            // that carry the form binding, plus a visible radio group. The radios drive the checkboxes so the form
            // posts identical field names/values to the old two-list UI, with mutual exclusivity by construction.
            function syncEffectRowFromRadios(row) {
                if (!row) {
                    return;
                }
                const requiredBox = row.querySelector('.power-v2-effect-hidden-required');
                const preferredBox = row.querySelector('.power-v2-effect-hidden-preferred');
                const checkedRadio = row.querySelector('.power-v2-effect-tri input[type="radio"]:checked');
                const state = checkedRadio ? checkedRadio.value : 'off';
                if (requiredBox) {
                    requiredBox.checked = state === 'required';
                }
                if (preferredBox) {
                    preferredBox.checked = state === 'preferred';
                }
            }

            // Initialize each visible radio group FROM the hidden checkbox checked-state. Used on page load (so a
            // server re-rendered form reflects correctly) and after a repro import (which sets the checkboxes).
            function initEffectTriState() {
                const rows = document.querySelectorAll('#playerPowerAnalyzerV2EffectTriState .power-v2-effect-row');
                rows.forEach(function (row) {
                    const requiredBox = row.querySelector('.power-v2-effect-hidden-required');
                    const preferredBox = row.querySelector('.power-v2-effect-hidden-preferred');
                    const isRequired = !!(requiredBox && requiredBox.checked);
                    const isPreferred = !isRequired && !!(preferredBox && preferredBox.checked);
                    const offRadio = row.querySelector('.power-v2-effect-tri input[value="off"]');
                    const preferredRadio = row.querySelector('.power-v2-effect-tri input[value="preferred"]');
                    const requiredRadio = row.querySelector('.power-v2-effect-tri input[value="required"]');
                    if (offRadio) {
                        offRadio.checked = !isRequired && !isPreferred;
                    }
                    if (preferredRadio) {
                        preferredRadio.checked = isPreferred;
                    }
                    if (requiredRadio) {
                        requiredRadio.checked = isRequired;
                    }
                    // Re-sync the hidden checkboxes so Preferred/Required are mutually exclusive even if the imported
                    // payload set both (Required wins, matching the server's old .Except dedupe semantics).
                    syncEffectRowFromRadios(row);
                });
            }

            document.querySelectorAll('#playerPowerAnalyzerV2EffectTriState .power-v2-effect-tri input[type="radio"]').forEach(function (radio) {
                radio.addEventListener('change', function () {
                    syncEffectRowFromRadios(radio.closest('.power-v2-effect-row'));
                });
            });
            initEffectTriState();

            hydrateInventoryState();

            // Pro (deeper sub-weapon optimization) is FULL-only. When Search Mode = Fast, disable AND uncheck the
            // Pro checkbox so it can never apply in Fast (keeping Fast as fast as possible). Re-enabled in Full.
            // Search Mode is now a radio-based segmented control: read the checked radio's value.
            const searchModeRadios = Array.prototype.slice.call(document.querySelectorAll('input[name="SearchMode"][type="radio"]'));
            const proSubWeaponCheckbox = document.getElementById('ProSubWeaponOptimization');
            const proSubWeaponHint = document.getElementById('ProSubWeaponOptimizationHint');
            function getSelectedSearchMode() {
                const checked = searchModeRadios.find(function (radio) { return radio.checked; });
                return checked ? checked.value : 'Fast';
            }
            function syncProSubWeaponGating() {
                if (!proSubWeaponCheckbox) {
                    return;
                }
                const isFast = getSelectedSearchMode() === 'Fast';
                if (isFast) {
                    proSubWeaponCheckbox.checked = false;
                    proSubWeaponCheckbox.disabled = true;
                    // WCAG: expose the disabled reason to assistive tech and show the inline hint.
                    proSubWeaponCheckbox.setAttribute('aria-disabled', 'true');
                    if (proSubWeaponHint) {
                        proSubWeaponHint.classList.remove('d-none');
                    }
                }
                else {
                    proSubWeaponCheckbox.disabled = false;
                    proSubWeaponCheckbox.setAttribute('aria-disabled', 'false');
                    if (proSubWeaponHint) {
                        proSubWeaponHint.classList.add('d-none');
                    }
                }
            }
            searchModeRadios.forEach(function (radio) {
                radio.addEventListener('change', syncProSubWeaponGating);
            });
            syncProSubWeaponGating();

            // Required Characters: cap selection at 3 — once 3 are checked, disable the rest until one is freed.
            const requiredCharacterGroup = document.getElementById('requiredCharactersGroup');
            if (requiredCharacterGroup) {
                const maxRequired = parseInt(requiredCharacterGroup.getAttribute('data-max-required'), 10) || 3;
                const requiredInputs = Array.prototype.slice.call(requiredCharacterGroup.querySelectorAll('.required-character-input'));
                const syncRequiredCharacterLimit = function () {
                    const atLimit = requiredInputs.filter(function (i) { return i.checked; }).length >= maxRequired;
                    requiredInputs.forEach(function (input) {
                        input.disabled = atLimit && !input.checked;
                        input.closest('.form-check').classList.toggle('opacity-50', input.disabled);
                    });
                };
                requiredInputs.forEach(function (input) {
                    input.addEventListener('change', syncRequiredCharacterLimit);
                });
                syncRequiredCharacterLimit();
            }

            // ----- By-Boss battle context: pick an enemy → infer weakness / damage type / scenario / sigils -----
            (function setupBossPicker() {
                const manualRadio = document.getElementById('battleModeManual');
                const bossRadio = document.getElementById('battleModeBoss');
                const pickerSection = document.getElementById('bossPickerSection');
                const searchInput = document.getElementById('bossSearchInput');
                const resultsList = document.getElementById('bossSearchResults');
                const summary = document.getElementById('bossContextSummary');
                const bonusContainer = document.getElementById('bonusSigilsContainer');
                const weaknessSelect = document.getElementById('EnemyWeakness');
                const damageTypeSelect = document.getElementById('PreferredDamageType');
                const scenarioSelect = document.getElementById('TargetScenario');
                if (!manualRadio || !bossRadio || !pickerSection) { return; }

                function setMode(isBoss) {
                    pickerSection.classList.toggle('d-none', !isBoss);
                    if (!isBoss) {
                        bonusContainer.innerHTML = '';
                        summary.classList.add('d-none');
                        resultsList.innerHTML = '';
                    }
                }
                manualRadio.addEventListener('change', function () { setMode(false); });
                bossRadio.addEventListener('change', function () { setMode(true); });

                let debounceTimer = null;
                searchInput.addEventListener('input', function () {
                    clearTimeout(debounceTimer);
                    const q = searchInput.value.trim();
                    if (q.length < 2) { resultsList.innerHTML = ''; return; }
                    debounceTimer = setTimeout(function () { doSearch(q); }, 250);
                });

                async function doSearch(q) {
                    try {
                        const resp = await fetch('?handler=BossSearch&q=' + encodeURIComponent(q), { headers: { 'Accept': 'application/json' } });
                        if (!resp.ok) { return; }
                        renderResults(await resp.json());
                    } catch (e) { /* ignore */ }
                }

                function renderResults(items) {
                    resultsList.innerHTML = '';
                    if (!items || !items.length) {
                        resultsList.innerHTML = '<div class="list-group-item text-muted small">No matches.</div>';
                        return;
                    }
                    items.forEach(function (item) {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action';
                        btn.textContent = item.label;
                        btn.addEventListener('click', function () { selectEnemy(item.enemyId, item.level, item.label); });
                        resultsList.appendChild(btn);
                    });
                }

                async function selectEnemy(enemyId, level, label) {
                    try {
                        const resp = await fetch('?handler=BossContext&enemyId=' + enemyId + '&level=' + level, { headers: { 'Accept': 'application/json' } });
                        if (!resp.ok) { return; }
                        const ctx = await resp.json();
                        if (!ctx.found) { return; }
                        applyContext(ctx);
                        resultsList.innerHTML = '';
                        searchInput.value = label;
                    } catch (e) { /* ignore */ }
                }

                function setSelectValue(select, value) {
                    if (!select || !value) { return; }
                    // Enum selects (GetEnumSelectList) use the integer value + the enum NAME as the option text, so
                    // match on either the value or the displayed text.
                    const wanted = String(value).toLowerCase();
                    const match = Array.prototype.find.call(select.options, function (o) {
                        return o.value.toLowerCase() === wanted || o.text.trim().toLowerCase() === wanted;
                    });
                    if (match) { select.value = match.value; }
                }

                function applyContext(ctx) {
                    setSelectValue(weaknessSelect, ctx.weakness);
                    setSelectValue(damageTypeSelect, ctx.damageType);
                    setSelectValue(scenarioSelect, ctx.scenario);

                    const required = (ctx.requiredSigils || []).map(function (s) { return s.toLowerCase(); });
                    document.querySelectorAll('input[name="RequiredSigils"]').forEach(function (cb) {
                        cb.checked = required.indexOf(cb.value.toLowerCase()) >= 0;
                    });

                    bonusContainer.innerHTML = '';
                    (ctx.bonusSigils || []).forEach(function (s) {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'BonusSigils';
                        input.value = s;
                        bonusContainer.appendChild(input);
                    });

                    const reqText = (ctx.requiredSigils && ctx.requiredSigils.length) ? ctx.requiredSigils.join(', ') : 'none';
                    const bonusText = (ctx.bonusSigils && ctx.bonusSigils.length) ? ctx.bonusSigils.join(', ') : 'none';
                    summary.innerHTML = '<strong>' + ctx.enemyName + ' (Lv ' + ctx.level + ')</strong> — Weakness: <strong>' + ctx.weakness +
                        '</strong> · Damage type: <strong>' + ctx.damageType + '</strong> <span class="text-muted">(' + ctx.damageTypeReason + ')</span>' +
                        ' · PDEF ' + ctx.pdef + ' / MDEF ' + ctx.mdef + '<br>Required sigils: <strong>' + reqText +
                        '</strong> · Damage sigils (bonus): <strong>' + bonusText + '</strong>. <span class="text-muted">All values stay editable above / in Advanced filters.</span>';
                    summary.classList.remove('d-none');
                }
            })();

            if (exportButton) {
                exportButton.addEventListener('click', exportStateToFile);
            }

            if (quickCopyButton) {
                quickCopyButton.addEventListener('click', copyQuickCopyText);
            }

            if (importButton) {
                importButton.addEventListener('click', triggerImportState);
            }

            if (importResultButton) {
                importResultButton.addEventListener('click', triggerImportState);
            }

            if (importFileInput) {
                importFileInput.addEventListener('change', function (event) {
                    const file = event.target && event.target.files ? event.target.files[0] : null;
                    if (!file) {
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function () {
                        try {
                            const raw = typeof reader.result === 'string' ? reader.result : '';
                            const payload = JSON.parse(raw);
                            if (!payload || typeof payload !== 'object') {
                                throw new Error('The selected file is not a valid JSON object.');
                            }

                            if (payload.schema && payload.schema !== exportSchema) {
                                throw new Error(`Unexpected repro schema '${payload.schema}'.`);
                            }

                            applyImportedPayload(payload);
                            setImportStatus('Repro file loaded. Re-running V2 analysis with the imported inventory and settings...', false);
                            if (form) {
                                if (typeof form.requestSubmit === 'function') {
                                    form.requestSubmit();
                                }
                                else {
                                    form.submit();
                                }
                            }
                        }
                        catch (error) {
                            setImportStatus(error instanceof Error ? error.message : 'The selected repro file could not be loaded.', true);
                        }
                    };
                    reader.onerror = function () {
                        setImportStatus('The selected repro file could not be read.', true);
                    };
                    reader.readAsText(file);
                });
            }

            function stopProcessingOverlay() {
                if (processingTimer) {
                    window.clearInterval(processingTimer);
                    processingTimer = null;
                }
                if (overlay) {
                    overlay.classList.remove('is-visible');
                    overlay.setAttribute('aria-hidden', 'true');
                }
                document.body.classList.remove('power-v2-processing-active');
                if (analyzeButton) {
                    analyzeButton.removeAttribute('disabled');
                }
            }

            // Parse a JSON response defensively: if the server ever returns HTML (an error page, a wrong handler),
            // surface a clear message instead of a raw "Unexpected token '<'" JSON parse error.
            function readJson(response) {
                return response.text().then(function (text) {
                    let data = null;
                    try { data = JSON.parse(text); } catch (e) { data = null; }
                    if (!response.ok || !data) {
                        throw new Error(data && data.error ? data.error : ('Server returned an unexpected response (HTTP ' + response.status + ').'));
                    }
                    return data;
                });
            }

            // Async analysis: start a background job, poll until done, then reload the page with the precomputed
            // result. Every request here is sub-second, so Cloudflare's 100s origin-response timeout never fires
            // even when the analysis itself takes minutes.
            function runAnalysisAsync() {
                if (!form) {
                    return;
                }

                const data = new FormData(form); // carries the antiforgery token, all bound fields, and the hydrated inventory
                fetch('?handler=StartAnalyze', { method: 'POST', body: data })
                    .then(readJson)
                    .then(function (payload) {
                        if (!payload || !payload.jobId) {
                            throw new Error('Analysis did not start (no job id returned).');
                        }
                        pollAnalysisJob(payload.jobId);
                    })
                    .catch(function (error) {
                        stopProcessingOverlay();
                        setImportStatus(error && error.message ? error.message : 'Failed to start analysis.', true);
                    });
            }

            function pollAnalysisJob(jobId) {
                fetch('?handler=AnalyzeStatus&id=' + encodeURIComponent(jobId), { headers: { 'Accept': 'application/json' } })
                    .then(readJson)
                    .then(function (state) {
                        if (state.status === 'completed') {
                            if (status) { status.textContent = 'Done — loading results...'; }
                            window.location = window.location.pathname + '?resultJobId=' + encodeURIComponent(jobId);
                            return;
                        }
                        if (state.status === 'failed') {
                            stopProcessingOverlay();
                            setImportStatus(state.error ? ('Analysis failed: ' + state.error) : 'Analysis failed.', true);
                            return;
                        }
                        if (state.status === 'notfound') {
                            stopProcessingOverlay();
                            setImportStatus('Analysis job was not found (it may have expired). Please try again.', true);
                            return;
                        }
                        // queued / running — keep waiting (the overlay cycles its own status messages)
                        window.setTimeout(function () { pollAnalysisJob(jobId); }, 1500);
                    })
                    .catch(function () {
                        // Transient network blip; keep polling a little slower.
                        window.setTimeout(function () { pollAnalysisJob(jobId); }, 2500);
                    });
            }

            if (form) {
                form.addEventListener('submit', function (event) {
                    event.preventDefault();
                    setImportStatus('', false);
                    hydrateInventoryState();
                    startProcessingOverlay();
                    runAnalysisAsync();
                });
            }
        })();
    </script>
}
