@model FFVIIEverCrisisAnalyzer.Models.GuildBattleSheetSection

@{
    var showRAbilitiesInsteadOfAbilityText = Model.Title.Contains("Potency", StringComparison.OrdinalIgnoreCase)
        || Model.Title.Contains("Sub Weapons", StringComparison.OrdinalIgnoreCase);
    var showAbilityText = false;
    var usesFullWeaponPool = Model.Title.Contains("Resistance Down", StringComparison.OrdinalIgnoreCase)
        || Model.Title.Contains("Damage Up", StringComparison.OrdinalIgnoreCase)
        || Model.Title.Contains("Damage Bonus", StringComparison.OrdinalIgnoreCase);
    var sectionKicker = usesFullWeaponPool ? "Shared Dataset Matches" : "Featured Pool Matches";
}

<div class="card shadow-sm border-0 h-100 guild-sheet-section-card guild-sheet-surface-card">
    <div class="card-header bg-white border-0 px-3 px-lg-4 pt-3 pb-0 guild-sheet-card-header guild-sheet-section-header">
        <div class="guild-sheet-card-kicker">@sectionKicker</div>
        <h3 class="mb-1 guild-sheet-card-title guild-sheet-section-title">@Model.Title</h3>
        <p class="text-muted mb-0 guild-sheet-card-subtitle">@(usesFullWeaponPool ? "Matches from the shared weapon dataset." : "Featured-only matches from the shared weapon dataset.")</p>
    </div>
    <div class="card-body p-3 p-lg-4">
        @if (Model.Entries.Count == 0)
        {
            <p class="text-muted mb-0">@Model.EmptyMessage</p>
        }
        else
        {
            <div class="d-flex flex-column gap-2 guild-sheet-section-list">
                @foreach (var entry in Model.Entries)
                {
                    <div class="utility-entry">
                        <div class="d-flex gap-2 align-items-start">
                            <button type="button" class="gear-thumb-button utility-thumb-button" data-bs-toggle="modal" data-bs-target="#previewModal" data-image-url="@entry.PreviewImageUrl" data-image-title="@entry.Name">
                                <img src="@entry.ImageUrl" alt="@entry.Name" class="utility-thumb" />
                            </button>
                            <div class="flex-grow-1">
                                <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                                    <strong>@entry.Name</strong>
                                    <span class="sheet-pill sheet-pill-light">@entry.Character</span>
                                    @if (!entry.EquipmentType.Equals("Featured", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="sheet-pill sheet-pill-highlight">@entry.EquipmentType</span>
                                    }
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary guild-sheet-view-levels-button btn-view-levels"
                                            data-weapon-id="@entry.WeaponId"
                                            data-character="@entry.Character"
                                            data-weapon="@entry.Name"
                                            data-equipment="@entry.EquipmentType"
                                            data-element="@entry.Element"
                                            data-ability-type="@entry.AbilityType"
                                            data-image-url="@entry.ImageUrl"
                                            data-preview-image-url="@entry.PreviewImageUrl"
                                            data-has-customizations="@(entry.HasCustomizations ? "true" : "false")">
                                        View Levels
                                    </button>
                                </div>
                                @if (entry.Highlights.Count > 0)
                                {
                                    <div class="d-flex flex-wrap gap-2 mb-1">
                                        @foreach (var highlight in entry.Highlights)
                                        {
                                            <span class="sheet-pill sheet-pill-light">@highlight</span>
                                        }
                                    </div>
                                }
                                @if (showRAbilitiesInsteadOfAbilityText)
                                {
                                    var rAbilityDetails = entry.RAbilityDetails.Where(detail => !string.IsNullOrWhiteSpace(detail)).Take(4).ToList();
                                    if (rAbilityDetails.Count > 0)
                                    {
                                        <div class="small text-body-secondary mb-1">Lv.140 / OB10 R Abilities</div>
                                        <div class="d-flex flex-column gap-1 mb-1">
                                            @foreach (var rAbilityDetail in rAbilityDetails)
                                            {
                                                <div class="small text-body-secondary">@rAbilityDetail</div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        var rAbilities = entry.RAbilityNames.Where(name => !string.IsNullOrWhiteSpace(name)).Take(4).ToList();
                                        if (rAbilities.Count > 0)
                                        {
                                            <div class="small text-body-secondary mb-1">Lv.140 / OB10 R Abilities</div>
                                            <div class="d-flex flex-wrap gap-2 mb-1">
                                                @foreach (var rAbility in rAbilities)
                                                {
                                                    <span class="sheet-pill sheet-pill-highlight">@rAbility</span>
                                                }
                                            </div>
                                        }
                                    }
                                }
                                else if (showAbilityText)
                                {
                                    <div class="small text-body-secondary line-clamp-3">@entry.AbilityText</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
