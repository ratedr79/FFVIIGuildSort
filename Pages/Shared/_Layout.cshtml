<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blitzball Fantasy League Manager</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.8/css/dataTables.dataTables.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FFVIIEverCrisisAnalyzer.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <i class="fas fa-tools text-primary"></i> SOLDIER Tools
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">
                                <i class="fas fa-home"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/PowerLevelAnalyzer">
                                <i class="fas fa-futbol"></i> Power Levels <i class="fas fa-lock small text-warning" title="Leadership only"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/DataDiagnostics">
                                <i class="fas fa-list-check"></i> Data Diagnostics <i class="fas fa-lock small text-warning" title="Leadership only"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/GearSearch">
                                <i class="fas fa-search"></i> Gear Search
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/EnemyStats">
                                <i class="fas fa-dragon"></i> Enemy Stats
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/GuildBattle">
                                <i class="fas fa-chess"></i> Guild Battle <i class="fas fa-lock small text-warning" title="Leadership only"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/GuildBattleTest">
                                <i class="fas fa-flask"></i> GB Test <i class="fas fa-lock small text-warning" title="Leadership only"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/ZelarithAssignment">
                                <i class="fas fa-terminal"></i> Zelarith <i class="fas fa-lock small text-warning" title="Leadership only"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Unlock">
                                <i class="fas fa-key"></i> Unlock
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="border-top py-2 mt-2" style="border-top: 0 !important;">
        <div class="container small text-muted text-center mt-0">
            <i class="fas fa-comment-dots me-1"></i>Issues or suggestions? Message <strong>@@ddelaneyca</strong> on Discord
            <span class="mx-2">|</span>
            <i class="fab fa-github me-1"></i>
            <a class="link-secondary" href="https://github.com/ratedr79/FFVIIGuildSort" target="_blank" rel="noopener noreferrer">github.com/ratedr79/FFVIIGuildSort</a>
        </div>
    </div>

    @* Footer hidden - was floating over collapsible panels *@
    @* <footer class="footer text-muted">
        <div class="container">
            &copy; 2026 - Blitzball Fantasy League Manager - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer> *@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
