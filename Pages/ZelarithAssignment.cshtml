@page
@model FFVIIEverCrisisAnalyzer.Pages.ZelarithAssignmentModel
@using FFVIIEverCrisisAnalyzer.Models
@{
    ViewData["Title"] = "Zelarith's Assignment Application";
}

<div class="container mt-4">
    <h1 class="mb-3"><i class="fas fa-terminal"></i> Zelarith's Assignment Application</h1>
    <p class="text-muted mb-3">Run the Dispatcher workflow on guild battle CSV data to generate and simulate stage assignments.</p>

    <div class="alert alert-warning" role="alert">
        <i class="fas fa-exclamation-triangle"></i>
        This page runs an external application and writes to a temporary shared text file (`input.txt`) in the Dispatcher directory.
        If multiple users run this page at the same time, results may overlap and become inconsistent.
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @Model.ErrorMessage
        </div>
    }

    <div class="card mb-3">
        <div class="card-header">
            <strong>Data Source</strong>
        </div>
        <div class="card-body">
            <form method="post" enctype="multipart/form-data" asp-page-handler="Run">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="GoogleSheetUrl" class="form-label">Google Sheets (Published CSV)</label>
                        <select class="form-select" id="GoogleSheetUrl" name="GoogleSheetUrl">
                            <option value="">-- Select a Google Sheet --</option>
                            @foreach (var sheet in Model.AvailableSheets)
                            {
                                <option value="@sheet.Url">@sheet.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="UploadedFile" class="form-label">Or Upload CSV File</label>
                        <input type="file" class="form-control" id="UploadedFile" name="UploadedFile" accept=".csv" />
                    </div>
                    <div class="col-md-2">
                        <label for="CurrentDay" class="form-label">Day</label>
                        <select class="form-select" id="CurrentDay" name="CurrentDay">
                            <option value="1" selected="@(Model.CurrentDay == 1)">Day 1</option>
                            <option value="2" selected="@(Model.CurrentDay == 2)">Day 2</option>
                            <option value="3" selected="@(Model.CurrentDay == 3)">Day 3</option>
                        </select>
                    </div>
                    <div class="col-md-1">
                        <label for="MarginOfErrorPercent" class="form-label">Margin %</label>
                        <input type="number" class="form-control" id="MarginOfErrorPercent" name="MarginOfErrorPercent" value="@Model.MarginOfErrorPercent" step="0.5" min="0" max="20" />
                    </div>
                    <div class="col-md-1">
                        <label for="NumberOfRuns" class="form-label">Runs</label>
                        <input type="number" class="form-control" id="NumberOfRuns" name="NumberOfRuns" value="@Model.NumberOfRuns" min="1" max="50" />
                    </div>
                    <div class="col-md-2">
                        <label for="OvershootTriggerPercent" class="form-label">Overshoot Trigger %</label>
                        <input type="number" class="form-control" id="OvershootTriggerPercent" name="OvershootTriggerPercent" value="@Model.OvershootTriggerPercent" step="1" min="0" max="100" title="If the smallest projected overshoot on a target stage exceeds this value, the simulation tries to promote a lower-stage cleanup attacker." />
                    </div>
                    <div class="col-md-3">
                        <label for="CleanupConfidenceBufferPercent" class="form-label text-nowrap">Cleanup Confidence Buffer %</label>
                        <input type="number" class="form-control" id="CleanupConfidenceBufferPercent" name="CleanupConfidenceBufferPercent" value="@Model.CleanupConfidenceBufferPercent" step="1" min="0" max="100" title="A promoted cleanup candidate is considered safe when their target-stage mock/average is at least remaining HP plus this buffer." />
                    </div>
                </div>
                <div class="form-text mt-2">
                    <i class="fas fa-info-circle"></i>
                    Overshoot Trigger % decides when to try cleanup reassignment (to reduce wasted damage). Cleanup Confidence Buffer % sets required headroom above remaining HP for a promoted cleanup candidate.
                </div>
                <!-- Advanced: HP Override -->
                <div class="mt-3">
                    <a class="text-decoration-none text-muted small" data-bs-toggle="collapse" href="#hpOverrideCollapse" role="button" aria-expanded="false" aria-controls="hpOverrideCollapse">
                        <i class="fas fa-cog"></i> Advanced <i class="fas fa-chevron-down fa-xs"></i>
                    </a>
                    <div class="collapse" id="hpOverrideCollapse">
                        <div class="card card-body mt-2 p-2">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="HpOverrideEnabled" name="HpOverrideEnabled" value="true" @(Model.HpOverrideEnabled ? "checked" : "") onchange="document.getElementById('hpOverrideFields').style.display = this.checked ? '' : 'none';" />
                                <label class="form-check-label" for="HpOverrideEnabled">Enable HP Override</label>
                            </div>
                            <div id="hpOverrideFields" style="display: @(Model.HpOverrideEnabled ? "" : "none");">
                                <p class="text-muted small mb-2"><i class="fas fa-info-circle"></i> If you leave a stage blank, its HP will be computed from the CSV data.</p>
                                <div class="row g-2 align-items-end">
                                    <div class="col"><label class="form-label small mb-0">S1</label><input type="number" step="0.1" min="0" max="100" class="form-control form-control-sm" name="HpS1" value="@Model.HpS1" placeholder="CSV" /></div>
                                    <div class="col"><label class="form-label small mb-0">S2</label><input type="number" step="0.1" min="0" max="100" class="form-control form-control-sm" name="HpS2" value="@Model.HpS2" placeholder="CSV" /></div>
                                    <div class="col"><label class="form-label small mb-0">S3</label><input type="number" step="0.1" min="0" max="100" class="form-control form-control-sm" name="HpS3" value="@Model.HpS3" placeholder="CSV" /></div>
                                    <div class="col"><label class="form-label small mb-0">S4</label><input type="number" step="0.1" min="0" max="100" class="form-control form-control-sm" name="HpS4" value="@Model.HpS4" placeholder="CSV" /></div>
                                    <div class="col"><label class="form-label small mb-0">S5</label><input type="number" step="0.1" min="0" max="100" class="form-control form-control-sm" name="HpS5" value="@Model.HpS5" placeholder="CSV" /></div>
                                    <div class="col"><label class="form-label small mb-0">S6</label><input type="number" step="0.1" min="0" max="100" class="form-control form-control-sm" name="HpS6" value="@Model.HpS6" placeholder="CSV" /></div>
                                    <div class="col-auto d-flex align-items-end">
                                        <div class="form-check mb-1">
                                            <input class="form-check-input" type="checkbox" id="HpS6Unlocked" name="HpS6Unlocked" value="true" @(Model.HpS6Unlocked ? "checked" : "") />
                                            <label class="form-check-label small" for="HpS6Unlocked">S6 Unlocked</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-play"></i> Run Dispatcher
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.HasRun && !string.IsNullOrEmpty(Model.Output))
    {
        @if (Model.HpComputationDebug != null)
        {
            var hpDebug = Model.HpComputationDebug;
            <div class="card mb-3">
                <div class="card-header">
                    <a class="text-decoration-none text-dark d-flex justify-content-between align-items-center" data-bs-toggle="collapse" href="#hpComputationCollapse" role="button" aria-expanded="false" aria-controls="hpComputationCollapse">
                        <strong><i class="fas fa-heartbeat"></i> Stage HP Computation (Simulation Start State)</strong>
                        <i class="fas fa-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse" id="hpComputationCollapse">
                    <div class="card-body p-2">
                        <div class="row g-2 mb-2">
                            <div class="col-md-2">
                                <div class="small text-muted">Day</div>
                                <div><strong>@hpDebug.CurrentDay</strong></div>
                            </div>
                            <div class="col-md-2">
                                <div class="small text-muted">Attempts Replayed</div>
                                <div><strong>@hpDebug.TotalAttemptsProcessed</strong></div>
                            </div>
                            <div class="col-md-2">
                                <div class="small text-muted">Attempts On Day</div>
                                <div><strong>@hpDebug.AttemptsOnCurrentDay</strong></div>
                            </div>
                            <div class="col-md-2">
                                <div class="small text-muted">Remaining Hits</div>
                                <div><strong>@hpDebug.RemainingHits</strong></div>
                            </div>
                            <div class="col-md-2">
                                <div class="small text-muted">Resets Replayed</div>
                                <div><strong>@hpDebug.ResetsDetectedWhileReplaying</strong></div>
                            </div>
                            <div class="col-md-2">
                                <div class="small text-muted">S6 Unlocked</div>
                                <div><strong>@(hpDebug.Stage6UnlockedByS5Kills ? "Yes" : "No")</strong></div>
                            </div>
                        </div>

                        <div class="small text-muted mb-2">
                            <i class="fas fa-info-circle"></i>
                            @hpDebug.ComputationMethod
                        </div>

                        @if (hpDebug.DayTransitionNotes.Any())
                        {
                            <div class="alert alert-info py-2 mb-2" role="alert">
                                <div class="fw-semibold mb-1"><i class="fas fa-exchange-alt"></i> Day Transitions</div>
                                <ul class="mb-0 small">
                                    @foreach (var note in hpDebug.DayTransitionNotes)
                                    {
                                        <li>@note</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (hpDebug.MissingKillWarnings.Any())
                        {
                            <div class="alert alert-warning py-2 mb-2" role="alert">
                                <div class="fw-semibold mb-1"><i class="fas fa-exclamation-triangle"></i> Potential missing kill checkbox detected</div>
                                <ul class="mb-0 small">
                                    @foreach (var warning in hpDebug.MissingKillWarnings)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="table-responsive mb-2">
                            <table class="table table-sm table-bordered mb-0" style="font-size: 0.85rem;">
                                <thead class="table-light">
                                    <tr>
                                        <th>Stage</th>
                                        <th class="text-end">Start HP (Day @hpDebug.CurrentDay)</th>
                                        <th class="text-end">Day Damage</th>
                                        <th class="text-end">Day Kills</th>
                                        <th class="text-end">Resets</th>
                                        <th class="text-end">Final HP</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var stage in Enum.GetValues<StageId>())
                                    {
                                        var totalDamage = hpDebug.TotalDamageByStage.GetValueOrDefault(stage, 0);
                                        var killRows = hpDebug.KillRowsByStage.GetValueOrDefault(stage, 0);
                                        var resets = hpDebug.EffectiveResetsByStage.GetValueOrDefault(stage, 0);
                                        var startHp = hpDebug.InitialHpByStage.GetValueOrDefault(stage, 0);
                                        var finalHp = hpDebug.FinalHpByStage.GetValueOrDefault(stage, 0);
                                        <tr>
                                            <td>S@((int)stage)</td>
                                            <td class="text-end">@startHp.ToString("F3")%</td>
                                            <td class="text-end">@totalDamage.ToString("F3")%</td>
                                            <td class="text-end">@killRows</td>
                                            <td class="text-end">@resets</td>
                                            <td class="text-end">@finalHp.ToString("F3")%</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0" style="font-size: 0.8rem;">
                                <thead>
                                    <tr>
                                        <th>Day</th>
                                        <th>Row</th>
                                        <th>Player</th>
                                        <th>Stage</th>
                                        <th>Damage</th>
                                        <th>Killed</th>
                                        <th>Contribution</th>
                                        <th>Note</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in hpDebug.ReplayEntries)
                                    {
                                        <tr>
                                            <td>@entry.Day</td>
                                            <td>@entry.RowIndex</td>
                                            <td>@entry.PlayerName</td>
                                            <td>S@((int)entry.Stage)</td>
                                            <td>@entry.DamagePercent.ToString("F3")%</td>
                                            <td>@(entry.Killed ? "Yes" : "No")</td>
                                            <td>@(entry.Killed ? "+damage, +kill row" : "+damage")</td>
                                            <td>@entry.Note</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Dispatcher Raw Output (collapsible) -->
        <div class="card mb-3">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center gap-2">
                    <a class="text-decoration-none text-dark d-flex justify-content-between align-items-center flex-grow-1" data-bs-toggle="collapse" href="#dispatcherOutputCollapse" role="button" aria-expanded="false" aria-controls="dispatcherOutputCollapse">
                        <strong><i class="fas fa-terminal"></i> Dispatcher Output</strong>
                        <i class="fas fa-chevron-down"></i>
                    </a>
                    <div class="d-flex align-items-center gap-2">
                        <span id="dispatcherCopyStatus" class="small d-none px-2 py-1 rounded bg-light text-dark" aria-live="polite"></span>
                        <button type="button" id="copyDispatcherOutputButton" class="btn btn-sm btn-light text-dark border-0" data-copy-target="dispatcherOutputText">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                </div>
            </div>
            <div class="collapse" id="dispatcherOutputCollapse">
                <div class="card-body p-0">
                    <pre id="dispatcherOutputText" class="mb-0 p-3" style="background: #1e1e1e; color: #d4d4d4; font-size: 0.85rem; max-height: 600px; overflow-y: auto; white-space: pre-wrap; word-wrap: break-word;">@Model.Output</pre>
                </div>
            </div>
        </div>

        @if (Model.Players != null && Model.Players.Count > 0)
        {
            <!-- Player Percentages (collapsed by default) -->
            <div class="card mb-3">
                <div class="card-header">
                    <a class="text-decoration-none text-dark d-flex justify-content-between align-items-center" data-bs-toggle="collapse" href="#playerMocksCollapse" role="button" aria-expanded="false" aria-controls="playerMocksCollapse">
                        <strong>Player Percentages</strong>
                        <i class="fas fa-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse" id="playerMocksCollapse">
                    <div class="card-body p-2">
                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0" style="font-size: 0.85rem;">
                                <thead>
                                    <tr>
                                        <th style="width: 30%;">Player</th>
                                        <th class="text-center" style="width: 10%;">S1</th>
                                        <th class="text-center" style="width: 10%;">S2</th>
                                        <th class="text-center" style="width: 10%;">S3</th>
                                        <th class="text-center" style="width: 10%;">S4</th>
                                        <th class="text-center" style="width: 10%;">S5</th>
                                        <th class="text-center" style="width: 10%;">S6</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var player in Model.Players.OrderBy(p => p.Name))
                                    {
                                        <tr>
                                            <td class="text-truncate" style="max-width: 100px;" title="@player.Name">@player.Name</td>
                                            @foreach (var stage in Enum.GetValues<StageId>())
                                            {
                                                var pct = player.AveragedPercents.GetValueOrDefault(stage, 0);
                                                <td class="text-center">@pct.ToString("F1")</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="small text-muted mt-2">
                            <i class="fas fa-info-circle"></i> Percentages include live attack data averaged with mocks
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.ParsedPlan != null)
        {
            <!-- Parsed Assignments -->
            <div class="card mb-3">
                <div class="card-header">
                    <a class="text-decoration-none text-dark d-flex justify-content-between align-items-center" data-bs-toggle="collapse" href="#parsedAssignmentsCollapse" role="button" aria-expanded="true" aria-controls="parsedAssignmentsCollapse">
                        <strong><i class="fas fa-users"></i> Parsed Assignments</strong>
                        <i class="fas fa-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse show" id="parsedAssignmentsCollapse">
                    <div class="card-body p-2">
                        <p class="text-muted small mb-2">
                            <i class="fas fa-info-circle"></i>
                            Dispatcher expects <strong>@Model.ParsedPlan.ExpectedResets reset(s)</strong>.
                            Players with a number in parentheses use that many attacks on the stage; others use all remaining.
                        </p>
                        <div class="row">
                            @foreach (var stage in Enum.GetValues<StageId>())
                            {
                                var assignments = Model.ParsedPlan.StageAssignments.GetValueOrDefault(stage);
                                if (assignments != null && assignments.Count > 0)
                                {
                                    <div class="col-md-4 col-lg-2 mb-2">
                                        <div class="card h-100">
                                            <div class="card-header py-1 text-center">
                                                <strong>Stage @((int)stage)</strong>
                                            </div>
                                            <div class="card-body p-2">
                                                <ul class="list-unstyled mb-0 small">
                                                    @foreach (var a in assignments)
                                                    {
                                                        <li>
                                                            @a.PlayerName
                                                            @if (a.Attacks > 0)
                                                            {
                                                                <span class="badge bg-secondary">@a.Attacks</span>
                                                            }
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.Players != null && Model.Players.Count > 0 && Model.CurrentDay >= 2)
        {
            // Build missing attacks data for all previous days
            var missingAttacks = new List<(string Name, int Day, int Missing)>();
            for (int day = 1; day < Model.CurrentDay; day++)
            {
                foreach (var player in Model.Players.OrderBy(p => p.Name))
                {
                    int attacksOnDay = player.Attempts.Count(a => a.Day == day);
                    if (attacksOnDay < 3)
                    {
                        missingAttacks.Add((player.Name, day, 3 - attacksOnDay));
                    }
                }
            }

            if (missingAttacks.Any())
            {
                <!-- Missing Attacks -->
                <div class="card mb-3">
                    <div class="card-header">
                        <a class="text-decoration-none text-dark d-flex justify-content-between align-items-center" data-bs-toggle="collapse" href="#missingAttacksCollapse" role="button" aria-expanded="true" aria-controls="missingAttacksCollapse">
                            <strong><i class="fas fa-exclamation-triangle text-warning"></i> Missing Attacks (@missingAttacks.Sum(m => m.Missing) total)</strong>
                            <i class="fas fa-chevron-down"></i>
                        </a>
                    </div>
                    <div class="collapse show" id="missingAttacksCollapse">
                        <div class="card-body p-2">
                            <p class="text-muted small mb-2">
                                <i class="fas fa-info-circle"></i>
                                Players who did not use all 3 attacks on previous day(s).
                            </p>
                            <div class="table-responsive">
                                <table class="table table-sm table-striped mb-0" style="font-size: 0.85rem;">
                                    <thead>
                                        <tr>
                                            <th>Player</th>
                                            <th class="text-center">Day</th>
                                            <th class="text-center">Attacks Used</th>
                                            <th class="text-center">Missing</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var entry in missingAttacks)
                                        {
                                            <tr>
                                                <td>@entry.Name</td>
                                                <td class="text-center">@entry.Day</td>
                                                <td class="text-center">@(3 - entry.Missing)</td>
                                                <td class="text-center"><span class="badge bg-danger">@entry.Missing</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        @if (Model.AggregatedResults != null)
        {
            var agg = Model.AggregatedResults;
            var isMulti = agg.TotalRuns > 1;

            <!-- Aggregated Summary -->
            <div class="card mb-3">
                <div class="card-header">
                    <strong><i class="fas fa-chart-bar"></i> Simulation Results (@agg.TotalRuns run@(agg.TotalRuns > 1 ? "s" : ""))</strong>
                </div>
                <div class="card-body p-2">
                    <div class="row text-center mb-3">
                        <div class="col">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <div class="small text-muted">@(isMulti ? "Avg Resets" : "Resets")</div>
                                    <div class="h5 mb-0">@(isMulti ? agg.AvgResets.ToString("F1") : agg.Runs.First().Resets.ToString())</div>
                                    @if (isMulti)
                                    {
                                        <div class="small text-muted">@agg.MinResets – @agg.MaxResets</div>
                                    }
                                </div>
                            </div>
                        </div>
                        @foreach (var stage in Enum.GetValues<StageId>())
                        {
                            var avgHp = agg.AvgFinalHP.GetValueOrDefault(stage, 0);
                            var avgClears = agg.AvgClears.GetValueOrDefault(stage, 0);
                            var clearRate = agg.ClearRatePercent.GetValueOrDefault(stage, 0);
                            var bg = avgHp <= 0.005 ? "bg-success text-white" : avgHp < 50 ? "bg-warning" : "bg-light";
                            <div class="col">
                                <div class="card @bg">
                                    <div class="card-body py-2">
                                        <div class="small">S@((int)stage)</div>
                                        <div class="h6 mb-0">@avgClears.ToString("F1") clears</div>
                                        <div class="small">@avgHp.ToString("F1")% HP left</div>
                                        <div class="small text-muted">@clearRate.ToString("F0")% clear rate</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Per-Run Breakdown -->
            <div class="card mb-3">
                    <div class="card-header">
                        <a class="text-decoration-none text-dark d-flex justify-content-between align-items-center" data-bs-toggle="collapse" href="#perRunCollapse" role="button" aria-expanded="true" aria-controls="perRunCollapse">
                            <strong><i class="fas fa-table"></i> Per-Run Breakdown</strong>
                            <i class="fas fa-chevron-down"></i>
                        </a>
                    </div>
                    <div class="collapse show" id="perRunCollapse">
                        <div class="card-body p-2">
                            <div class="table-responsive">
                                <table class="table table-sm table-striped mb-0" style="font-size: 0.85rem;">
                                    <thead>
                                        <tr>
                                            <th></th>
                                            <th>Run</th>
                                            <th class="text-center">Resets</th>
                                            <th class="text-center">Attacks</th>
                                            @foreach (var stage in Enum.GetValues<StageId>())
                                            {
                                                <th class="text-center">S@((int)stage) HP</th>
                                            }
                                            <th class="text-end">Total Points</th>
                                            <th class="text-center">Rank</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ var colSpan = 11 + Enum.GetValues<StageId>().Length; }
                                        @foreach (var run in agg.Runs)
                                        {
                                            var isBest = run.RunIndex == agg.BestRunIndex;
                                            var isWorst = run.RunIndex == agg.WorstRunIndex;
                                            var rowClass = isBest ? "table-success" : isWorst ? "table-danger" : "";
                                            var detailId = $"dispRunDetail-{run.RunIndex}";
                                            <tr class="@rowClass">
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-link p-0 text-decoration-none" data-bs-toggle="collapse" data-bs-target="#@detailId" aria-expanded="false" aria-controls="@detailId" title="Toggle details">
                                                        <i class="fas fa-chevron-right fa-xs toggle-icon"></i>
                                                    </button>
                                                </td>
                                                <td>@run.RunIndex</td>
                                                <td class="text-center">@run.Resets</td>
                                                <td class="text-center">@run.TotalAttacks</td>
                                                @foreach (var stage in Enum.GetValues<StageId>())
                                                {
                                                    var hp = run.FinalHP.GetValueOrDefault(stage);
                                                    var color = hp <= 0.01 ? "text-success" : hp < 50 ? "text-warning" : "text-danger";
                                                    <td class="text-center @color">@hp.ToString("F1")%</td>
                                                }
                                                @{
                                                    var zRunPts = run.AttackLog.Where(e => !e.IsReset).Sum(e => e.EstimatedPoints + e.BonusPoints);
                                                }
                                                <td class="text-end">@(zRunPts > 0 ? zRunPts.ToString("N0") : "")</td>
                                                <td class="text-center">
                                                    @if (isBest) { <span class="badge bg-success">Best</span> }
                                                    else if (isWorst) { <span class="badge bg-danger">Worst</span> }
                                                </td>
                                            </tr>
                                            <tr class="collapse" id="@detailId">
                                                <td colspan="@colSpan" class="p-0">
                                                    <div class="p-2 bg-light border-top">
                                                        <strong>Attack Log — Run @run.RunIndex (@run.AttackLog.Count(a => !a.IsReset) attacks)</strong>
                                                        <div class="table-responsive mt-1" style="max-height: 400px; overflow-y: auto;">
                                                            <table class="table table-sm mb-0" style="font-size: 0.8rem;">
                                                                <thead class="sticky-top bg-light">
                                                                    <tr>
                                                                        <th>Player</th>
                                                                        <th class="text-center">Stage</th>
                                                                        <th class="text-center">Damage</th>
                                                                        <th class="text-center">Remaining HP</th>
                                                                        <th class="text-end">Est. Points</th>
                                                                        <th class="text-center">Status</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @foreach (var entry in run.AttackLog)
                                                                    {
                                                                        if (entry.IsReset)
                                                                        {
                                                                            <tr class="table-secondary">
                                                                                <td colspan="6"><strong>@entry.PlayerName</strong>
                                                                                    @if (entry.PlayerName.Contains("Starting HP"))
                                                                                    {
                                                                                        <span class="float-end">@entry.RemainingHP.ToString("F1")%</span>
                                                                                    }
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                        else
                                                                        {
                                                                            <tr class="@(entry.Cleared ? "table-success" : "")">
                                                                                <td>@entry.PlayerName</td>
                                                                                <td class="text-center">S@((int)entry.Stage)</td>
                                                                                <td class="text-center">@entry.Damage.ToString("F1")%</td>
                                                                                <td class="text-center">@entry.RemainingHP.ToString("F1")%</td>
                                                                                <td class="text-end">@if (entry.EstimatedPoints > 0 || entry.BonusPoints > 0) { @((entry.EstimatedPoints + entry.BonusPoints).ToString("N0")) if (entry.BonusPoints > 0) { <small class="text-success"> (+@entry.BonusPoints.ToString("N0"))</small> } }</td>
                                                                                <td class="text-center">@(entry.Cleared ? "CLEARED" : "")</td>
                                                                            </tr>
                                                                        }
                                                                    }
                                                                </tbody>
                                                                <tfoot>
                                                                    @{
                                                                        var zRunTotalBase = run.AttackLog.Where(e => !e.IsReset).Sum(e => e.EstimatedPoints);
                                                                        var zRunTotalBonus = run.AttackLog.Where(e => !e.IsReset).Sum(e => e.BonusPoints);
                                                                    }
                                                                    <tr class="table-dark fw-bold">
                                                                        <td colspan="4" class="text-end">Total</td>
                                                                        <td class="text-end">@((zRunTotalBase + zRunTotalBonus).ToString("N0")) @if (zRunTotalBonus > 0) { <small class="text-success">(+@zRunTotalBonus.ToString("N0") bonus)</small> }</td>
                                                                        <td></td>
                                                                    </tr>
                                                                </tfoot>
                                                            </table>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
            </div>

            <!-- Best Run Attack Log (or single run) -->
            @if (Model.SimulationResult != null && Model.SimulationResult.AttackLog.Any())
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <a class="text-decoration-none text-dark d-flex justify-content-between align-items-center" data-bs-toggle="collapse" href="#attackLogCollapse" role="button" aria-expanded="true" aria-controls="attackLogCollapse">
                            <strong><i class="fas fa-list"></i> @(isMulti ? $"Best Run (#{agg.BestRunIndex}) " : "")Attack Log (@Model.SimulationResult.AttackLog.Count(e => !e.IsReset) attacks)</strong>
                            <i class="fas fa-chevron-down"></i>
                        </a>
                    </div>
                    <div class="collapse show" id="attackLogCollapse">
                        <div class="card-body p-2">
                            <div class="table-responsive">
                                <table class="table table-sm table-striped mb-0" style="font-size: 0.85rem;">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Player</th>
                                            <th class="text-center">Stage</th>
                                            <th class="text-center">Damage</th>
                                            <th class="text-center">Remaining HP</th>
                                            <th class="text-end">Est. Points</th>
                                            <th class="text-center">Cleared</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ int attackNum = 0; }
                                        @foreach (var entry in Model.SimulationResult.AttackLog)
                                        {
                                            if (entry.IsReset)
                                            {
                                                <tr class="table-info">
                                                    @if (entry.PlayerName.Contains("Starting HP"))
                                                    {
                                                        <td colspan="4" class="text-center fw-bold">@entry.PlayerName</td>
                                                        <td class="text-center fw-bold">@entry.RemainingHP.ToString("F1")%</td>
                                                        <td colspan="2"></td>
                                                    }
                                                    else
                                                    {
                                                        <td colspan="7" class="text-center fw-bold">@entry.PlayerName</td>
                                                    }
                                                </tr>
                                            }
                                            else
                                            {
                                                attackNum++;
                                                <tr class="@(entry.Cleared ? "table-success" : "")">
                                                    <td>@attackNum</td>
                                                    <td>@entry.PlayerName</td>
                                                    <td class="text-center">S@((int)entry.Stage)</td>
                                                    <td class="text-center">@entry.Damage.ToString("F1")%</td>
                                                    <td class="text-center">@entry.RemainingHP.ToString("F1")%</td>
                                                    <td class="text-end">@if (entry.EstimatedPoints > 0 || entry.BonusPoints > 0) { @((entry.EstimatedPoints + entry.BonusPoints).ToString("N0")) if (entry.BonusPoints > 0) { <small class="text-success"> (+@entry.BonusPoints.ToString("N0"))</small> } }</td>
                                                    <td class="text-center">
                                                        @if (entry.Cleared)
                                                        {
                                                            <span class="badge bg-success">Clear</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                    <tfoot>
                                        @{
                                            var bestTotalBase = Model.SimulationResult.AttackLog.Where(e => !e.IsReset).Sum(e => e.EstimatedPoints);
                                            var bestTotalBonus = Model.SimulationResult.AttackLog.Where(e => !e.IsReset).Sum(e => e.BonusPoints);
                                        }
                                        <tr class="table-dark fw-bold">
                                            <td colspan="5" class="text-end">Total</td>
                                            <td class="text-end">@((bestTotalBase + bestTotalBonus).ToString("N0")) @if (bestTotalBonus > 0) { <small class="text-success">(+@bestTotalBonus.ToString("N0") bonus)</small> }</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const copyButton = document.getElementById('copyDispatcherOutputButton');
            const copyStatus = document.getElementById('dispatcherCopyStatus');

            if (!copyButton) {
                return;
            }

            const setStatus = function (message, isError) {
                if (!copyStatus) {
                    return;
                }

                copyStatus.textContent = message;
                copyStatus.classList.remove('d-none', 'bg-light', 'text-dark', 'bg-danger', 'text-white');
                copyStatus.classList.add(isError ? 'bg-danger' : 'bg-light');
                copyStatus.classList.add(isError ? 'text-white' : 'text-dark');

                window.setTimeout(function () {
                    copyStatus.classList.add('d-none');
                }, 2000);
            };

            const copyText = async function (text) {
                if (navigator.clipboard && window.isSecureContext) {
                    await navigator.clipboard.writeText(text);
                    return;
                }

                const textArea = document.createElement('textarea');
                textArea.value = text;
                textArea.setAttribute('readonly', 'readonly');
                textArea.style.position = 'absolute';
                textArea.style.left = '-9999px';
                document.body.appendChild(textArea);
                textArea.select();
                textArea.setSelectionRange(0, textArea.value.length);

                const copied = document.execCommand('copy');
                document.body.removeChild(textArea);

                if (!copied) {
                    throw new Error('Copy command failed.');
                }
            };

            copyButton.addEventListener('click', async function () {
                const targetId = copyButton.getAttribute('data-copy-target');
                const target = targetId ? document.getElementById(targetId) : null;
                const text = target ? target.textContent || '' : '';

                if (!text.trim()) {
                    setStatus('Nothing to copy.', true);
                    return;
                }

                try {
                    await copyText(text);
                    setStatus('Copied!', false);
                }
                catch {
                    setStatus('Copy failed.', true);
                }
            });
        });
    </script>
}
