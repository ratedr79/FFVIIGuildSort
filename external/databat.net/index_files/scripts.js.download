        /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
        ///////// EVENTS ///////// EVENTS ///////// EVENTS ///////// EVENTS ///////// EVENTS ///////// EVENTS ///////// EVENTS ///////// EVENTS /////////
        /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
            /////////////////////////////////
            ///////////// MODAL /////////////
            /////////////////////////////////
        /////////////////////////////////////
        //// EVENT TO POPUP WEAPON MODAL ////
        /////////////////////////////////////
        $('#weaponList').dataTable().on('click.dt', 'tr', function () {
            let data = table.row(this).data();
            showWeapon(data);
        });

        /////////////////////////////////////
        //// EVENT FOR CUSTOM SEARCHPANE ////
        /////////////////////////////////////
        $(document).on('click', '.dtsp-panesContainer table tr:not(.unselectable)', function() {
            let paneSelection = new Array();
            let rowSelection = new Array();

            // SELECT <> DESELECT //
            if ($(this).hasClass('selected')) { $(this).removeClass('selected'); }
            else { 
                // SELECT ITEM AUTHORIZATION //
                if (manageSelection($(this).offsetParent())) { $(this).addClass('selected'); }
                else { return false; }
            }

            // GET ENTIRE SEARCHPANE SELECTION //
            getSelection(paneSelection);

            // GENERATE CARTESIAN COMBINATION
            let cartesian = getCombination(paneSelection);
            console.log(cartesian)

            // CHECK ROWS //
            table.rows().every( function () {
                rowSelection.push(checkRow(this.data(), cartesian));
            })
            rowSelection = rowSelection.filter(function(entry) { return /\S/.test(entry); });
            rowSelection = rowSelection.map(i => '^' + i + '$');
 
            // SEARCH ROWS //
            if (rowSelection.length > 0) {
                table.column(0).search(rowSelection.join('|'), true, false, true).draw();
            } else { table.column(0).search('^@@@@$', true, false, true).draw(); }
        });

        /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
        ///////// FUNCTIONS ///////// FUNCTIONS ///////// FUNCTIONS ///////// FUNCTIONS ///////// FUNCTIONS ///////// FUNCTIONS ///////// FUNCTIONS ///////// 
        /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
            /////////////////////////////////
            ///////////// MODAL /////////////
            /////////////////////////////////
        ////////////////////////////////////////
        //// FUNCTION TO POPUP WEAPON MODAL ////
        ////////////////////////////////////////
        function showWeapon(data) {
            let myModal = document.getElementById('weaponModal-Skull');
            let bsModal = new bootstrap.Modal(myModal);
            let xmlhttp = new XMLHttpRequest();
    
            xmlhttp.onreadystatechange = function() {
                if (this.readyState == 4 && this.status == 200) {
                    document.getElementById("weaponModal").innerHTML = xmlhttp.responseText;
                }
            };
            xmlhttp.open("POST","lib/printWeapon.php",true);
            xmlhttp.setRequestHeader("Content-Type", "application/json");
            xmlhttp.send(JSON.stringify(data));
    
            bsModal.show();
        }

            ///////////////////////////////////////
            ///////////// SEARCHPANES /////////////
            ///////////////////////////////////////
        /////////////////////////////////////////////////////
        //// FUNCTION FOR BUFF/DEBUFF CUSTOM SEARCHPANES ////
        /////////////////////////////////////////////////////
        function checkRow(row, selection) {
            let result = 0;
            let check = true;
            const CSP1 = [label_convert(row['CSP1_ED']), label_convert(row['CSP1_EG']), label_convert(row['CSP1_EH']), label_convert(row['CSP1_EP']), label_convert(row['CSP1_ER']), label_convert(row['CSP1_ES'])];
            const CSP2 = [label_convert(row['CSP2_ED']), label_convert(row['CSP2_EG']), label_convert(row['CSP2_EH']), label_convert(row['CSP2_EP']), label_convert(row['CSP2_ER']), label_convert(row['CSP2_ES'])];
            const CSP3 = [label_convert(row['CSP3_ED']), label_convert(row['CSP3_EG']), label_convert(row['CSP3_EH']), label_convert(row['CSP3_EP']), label_convert(row['CSP3_ER']), label_convert(row['CSP3_ES'])];
            const CSP4 = [label_convert(row['CSP4_ED']), label_convert(row['CSP4_EG']), label_convert(row['CSP4_EH']), label_convert(row['CSP4_EP']), label_convert(row['CSP4_ER']), label_convert(row['CSP4_ES'])];
            const CSP5 = [label_convert(row['CSP5_ED']), label_convert(row['CSP5_EG']), label_convert(row['CSP5_EH']), label_convert(row['CSP5_EP']), label_convert(row['CSP5_ER']), label_convert(row['CSP5_ES'])];
            
            $.each(selection, function(index, obj) {
                // Check Units
                if (obj.units != "" && obj.units != row['U_NAME']) { return; }

                // Check Buffs/Debuffs
                // Attention Buff Physical/Magical se gèrent avec C_EL
                // On verifie par groupement CSPX
                if (obj.buffs != "") {
                    check = false;
                    // CSP1_AF
                    csp1: if (CSP1.includes(obj.buffs)) {
                        if (row['CSP1_AF'] != 'Buff') { break csp1; }
                        // CSP1_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP1_AOE'])) { break csp1; }
                        // CSP1_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.buffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp1; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp1; }
                                default :
                                    if (obj.elements != label_convert(row['CSP1_EL'])) { break csp1; }
                            }
                        }
                        check = true;
                    }
                    // CSP2_AF
                    csp2: if (CSP2.includes(obj.buffs)) {
                        if (row['CSP2_AF'] != 'Buff') { break csp2; }
                        // CSP2_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP2_AOE'])) { break csp2; }
                        // CSP2_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.buffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp2; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp2; }
                                default :
                                    if (obj.elements != label_convert(row['CSP2_EL'])) { break csp2; }
                            }
                        }
                        check = true;
                    }
                    // CSP3_AF
                    csp3: if (CSP3.includes(obj.buffs)) {
                        if (row['CSP3_AF'] != 'Buff') { break csp3; }
                        // CSP3_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP3_AOE'])) { break csp3; }
                        // CSP3_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.buffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp3; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp3; }
                                default :
                                    if (obj.elements != label_convert(row['CSP3_EL'])) { break csp3; }
                            }
                        }
                        check = true;
                    }
                    // CSP4_AF
                    csp4: if (CSP4.includes(obj.buffs)) {
                        if (row['CSP4_AF'] != 'Buff') { break csp4; }
                        // CSP4_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP4_AOE'])) { break csp4; }
                        // CSP4_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.buffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp4; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp4; }
                                default :
                                    if (obj.elements != label_convert(row['CSP4_EL'])) { break csp4; }
                            }
                        }
                        check = true;
                    }
                    // CSP5_AF
                    csp5: if (CSP5.includes(obj.buffs)) {
                        if (row['CSP5_AF'] != 'Buff') { break csp5; }
                        // CSP5_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP5_AOE'])) { break csp5; }
                        // CSP5_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.buffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp5; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp5; }
                                default :
                                    if (obj.elements != label_convert(row['CSP5_EL'])) { break csp5; }
                            }
                        }
                        check = true;
                    }
                }
                else if (obj.debuffs != "") {
                    check = false;
                     // CSP1_AF
                    csp1: if (CSP1.includes(obj.debuffs)) {
                        if (row['CSP1_AF'] != 'Debuff') { break csp1; }
                        // CSP1_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP1_AOE'])) { break csp1; }
                        // CSP1_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.debuffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp1; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp1; }
                                default :
                                    if (obj.elements != label_convert(row['CSP1_EL'])) { break csp1; }
                            }
                        }
                        check = true;
                    }
                    // CSP2_AF
                    csp2: if (CSP2.includes(obj.debuffs)) {
                        if (row['CSP2_AF'] != 'Debuff') { break csp2; }
                        // CSP2_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP2_AOE'])) { break csp2; }
                        // CSP2_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.debuffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp2; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp2; }
                                default :
                                    if (obj.elements != label_convert(row['CSP2_EL'])) { break csp2; }
                            }
                        }
                        check = true;
                    }
                    // CSP3_AF
                    csp3: if (CSP3.includes(obj.debuffs)) {
                        if (row['CSP3_AF'] != 'Debuff') { break csp3; }
                        // CSP3_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP3_AOE'])) { break csp3; }
                        // CSP3_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.debuffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp3; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp3; }
                                default :
                                    if (obj.elements != label_convert(row['CSP3_EL'])) { break csp3; }
                            }
                        }
                        check = true;
                    }
                    // CSP4_AF
                    csp4: if (CSP4.includes(obj.debuffs)) {
                        if (row['CSP4_AF'] != 'Debuff') { break csp4; }
                        // CSP4_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP4_AOE'])) { break csp4; }
                        // CSP4_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.debuffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp4; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp4; }
                                default :
                                    if (obj.elements != label_convert(row['CSP4_EL'])) { break csp4; }
                            }
                        }
                        check = true;
                    }
                    // CSP5_AF
                    csp5: if (CSP5.includes(obj.debuffs)) {
                        if (row['CSP5_AF'] != 'Debuff') { break csp5; }
                        // CSP5_AF >> AOE
                        if (obj.aoe != "" && obj.aoe != label_convert(row['CSP5_AOE'])) { break csp5; }
                        // CSP5_AF >> ELEMENTS
                        if (obj.elements != "") {
                            switch (obj.debuffs) {
                                case 'Physical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp5; }
                                case 'Magical':
                                    if (obj.elements != label_convert(row['C_EL'])) { break csp5; }
                                default :
                                    if (obj.elements != label_convert(row['CSP5_EL'])) { break csp5; }
                            }
                        }
                        check = true;
                    }
                } 
                else {

                    // Check AOE
                    if (obj.aoe != "" && obj.aoe != label_convert(row['CSP1_AOE'])) { return; }

                    // Check Elements
                    if (obj.elements === "Non-Elemental" && obj.elements != label_convert(row['C_EL'])) { return; }
                    else if (obj.elements != "" && (obj.elements != label_convert(row['C_EL']) && obj.elements != label_convert(row['CSP1_EL']) && obj.elements != label_convert(row['CSP2_EL']) && obj.elements != label_convert(row['CSP3_EL']) && obj.elements != label_convert(row['CSP4_EL']) && obj.elements != label_convert(row['CSP5_EL']))) { return; }
                }

                // Check Reinforcement
                if (obj.ras != "" && (obj.ras != label_convert(row['RAF1_NAME']) && obj.ras != label_convert(row['RAF2_NAME']))) { return; }

                // Check Sigils
                if (obj.sigs != "" && (obj.sigs != label_convert(row['C_SIG']) && obj.sigs != label_convert(row['SPM1_SIG']) && obj.sigs != label_convert(row['SPM2_SIG']) && obj.sigs != label_convert(row['SPM3_SIG']))) { return; }
            
                // Check Support M
                if (obj.sms != "" && (obj.sms != label_convert(row['SPM1_NAME']) && obj.sms != label_convert(row['SPM2_NAME']) && obj.sms != label_convert(row['SPM3_NAME']))) { return; }

                if ( check ) { result += 1; }
            })

            if (result == selection.length) { return row['W_NAME']; }
        }

        ////////////////////////////////////////////////
        //// FUNCTION TO GET CARTESIAN COMBINATIONS ////
        ////////////////////////////////////////////////
        function getCombination(paneSelection) {
            let selection = new Object();
            selection.units = "";
            selection.aoe = "";
            selection.buffs = new Array();
            selection.debuffs = new Array();
            selection.elements = new Array();
            selection.ras = new Array();
            selection.sigs = new Array();
            selection.sms = "";

            $.each(paneSelection, function(index, value) {
                switch(value[0]) {
    
                    case "DataTables_Table_0":
                        selection.units = value[1];
                        break;
                    case "DataTables_Table_1":
                        selection.aoe = value[1];
                        break;
                    case "DataTables_Table_2":
                        selection.buffs.push(value[1]);
                        break;
                    case "DataTables_Table_3":
                        selection.debuffs.push(value[1]);
                        break;
                    case "DataTables_Table_4":
                        selection.elements.push(value[1]);
                        break; 
                    case "DataTables_Table_5":
                        selection.ras.push(value[1]);
                        break;
                    case "DataTables_Table_6":
                        selection.sigs.push(value[1]);
                        break;
                    case "DataTables_Table_7":
                        selection.sms = value[1];
                        break;
                }
            })
            const comb = cartesianProduct(selection);
            const result = manageElementSelection(comb);

            return result;
        }

        ////////////////////////////////////////////////////
        //// FUNCTION TO GET SEARCHPANES SELECTED ITEMS ////
        ////////////////////////////////////////////////////
        function getSelection(paneSelection) {

            let panes = table.searchPanes.container().find('.dt-scroll-body table');

            $.each(panes, function (index, pane) {
                rows = $(pane).find('tbody tr');
                $.each(rows, function(index, row) {
                    if ( $(row).hasClass('selected') ) {
                        let tableId = $(pane).attr('id');
                        let selectedItem = $(row).text();
                        
                        paneSelection.push([tableId, selectedItem]);
                    }
                })
                highlightSelection(pane);
            })

            sessionStorage.setItem('paneSelection', JSON.stringify(paneSelection));
        }

        ////////////////////////////////////////////////////
        //// FUNCTION TO SET SEARCHPANES SELECTED ITEMS ////
        ////////////////////////////////////////////////////
        function setSelection(pane, paneSelection) {

            let rows = pane.find('tbody tr');

            $.each(paneSelection, function(index, item ) {
                if (item[0] === pane.attr('id')) { 
                    $.each(rows, function(rowId, row) {
                        if( $(row).text() === item[1]) {
                            $(row).addClass('selected');
                        }
                    })
                }
            })
            highlightSelection(pane);
        }

        //////////////////////////////////////////////
        //// FUNCTION TO HIGHLIGHT SELECTED PANES ////
        //////////////////////////////////////////////
        function highlightSelection(pane) {
            
            let button = $(pane).parents('.dtsp-searchPane').find('.dtsp-subRow2 button');
            let rows = $(pane).find('tbody tr');
            let apply = false;

            $.each(rows, function(index, value) {
                if ( $(value).hasClass('selected') ) { apply = true; }
            })

            if (apply) { 
                $(button).css({"color": "rgb(23, 23, 23)"});
                $(button).css({"background-color": "rgba(3, 40, 70, 0.5)"});
            }
            else { 
                $(button).css({"color": "rgb(3, 40, 70)"});
                $(button).css({"background-color": "rgba(23, 23, 23, 0.25)"});
            }
        }

        /////////////////////////////////////////////////
        //// FUNCTION TO LIMIT SELECTED ITEMS NUMBER ////
        /////////////////////////////////////////////////
        function manageSelection(pane) {

            let selected = $(pane).find('tbody tr.selected');

            switch($(pane).attr('id')) {
                case 'DataTables_Table_0':
                    if (selected.length >= 1) { return false; }
                    else { return true; }

                case 'DataTables_Table_1':
                    if (selected.length >= 1) { return false; }
                    else { return true; }

                case 'DataTables_Table_2':
                    if (selected.length >= 5) { return false; }
                    else { return true; }

                case 'DataTables_Table_3':
                    if (selected.length >= 5) { return false; }
                    else { return true; }

                case 'DataTables_Table_4':
                    if (selected.length >= 5) { return false; }
                    else { return true; }

                case 'DataTables_Table_5':
                    if (selected.length >= 2) { return false; }
                    else { return true; }

                case 'DataTables_Table_6':
                    if (selected.length >= 4) { return false; }
                    else { return true; }

                case 'DataTables_Table_7':
                    if (selected.length >= 1) { return false; }
                    else { return true; }
            }
        }

        //////////////////////////////////////////////////////////////////////////////////
        //// FUNCTION TO CONVERT DATABASE LABEL ITEMS TO SEARCHPANE LABEL IF NOT SAME ////
        //////////////////////////////////////////////////////////////////////////////////
        function label_convert(dbLabel) {
            // DAMAGE CASE //
            if (dbLabel === 'PHY') { dbLabel = 'Physical' }
            else if (dbLabel === 'MAG') { dbLabel = 'Magical' }
            else if (dbLabel === 'PHY/MAG') { dbLabel = 'Physical/Magical' }
            // STATUS CASE //
            else if (dbLabel === 'Amp(PHY)' || dbLabel === 'Amp(MAG)' || dbLabel === 'Amp(HEAL)') { dbLabel = 'Amp' }
            // RESISTANCE CASE //
            else if (dbLabel === 'PHY Resist.') { dbLabel = 'Physical Resist.' }
            else if (dbLabel === 'MAG Resist.') { dbLabel = 'Magical Resist.' }
            // ELEMENT CASE //
            else if (dbLabel === '-') { dbLabel = 'Non-Elemental' }
            // SUPPORT MATERIA CASE //
            else if (dbLabel === 'All (Cure Spells) I') { dbLabel = 'All (Cure Spells)' }
            else if (dbLabel === 'All (Esuna) I') { dbLabel = 'All (Esuna)' }
            else if (dbLabel === 'HEAL Boost I') { dbLabel = 'Heal Boost' }
            else if (dbLabel === 'Circle Sigil Boost II') { dbLabel = 'Sigil Boost II' }
            else if (dbLabel === 'Cross Sigil Boost II') { dbLabel = 'Sigil Boost II' }
            else if (dbLabel === 'Diamond Sigil Boost II') { dbLabel = 'Sigil Boost II' }
            else if (dbLabel === 'Triangle Sigil Boost II') { dbLabel = 'Sigil Boost II' }

            return dbLabel;
        }

        ///////////////////////////////////////////
        //// FUNCTION TO GET CARTESIAN PRODUCT ////
        ///////////////////////////////////////////
        function cartesianProduct(selection) {
            const splitFields = ['buffs', 'debuffs'];
            const allKeys = Object.keys(selection);

            const otherKeys = allKeys.filter(k => !splitFields.includes(k));
            const arrayKeys = otherKeys.filter(k => Array.isArray(selection[k]));
            const scalarKeys = otherKeys.filter(k => !Array.isArray(selection[k]));

            const arrays = arrayKeys.map(k => selection[k].length === 0 ? [""] : selection[k]);

            const baseCartesian = arrays.reduce((acc, curr) => {
                return acc.flatMap(d => curr.map(e => [...d, e]));
            }, [[]]);

            const results = [];
            const buffs = selection.buffs || [];
            const debuffs = selection.debuffs || [];

            const hasBuffs = buffs.length > 0;
            const hasDebuffs = debuffs.length > 0;

            function generate(extraKey, values) {
                const safeValues = values.length === 0 ? [""] : values;

                for (const base of baseCartesian) {
                    for (const val of safeValues) {
                        const result = {};
                        let arrayIndex = 0;

                        for (const key of allKeys) {
                            if (scalarKeys.includes(key)) {
                                result[key] = selection[key] ?? "";
                            } else if (arrayKeys.includes(key)) {
                                result[key] = base[arrayIndex] ?? "";
                                arrayIndex++;
                            } else if (key === 'buffs') {
                                result[key] = extraKey === 'buffs' ? val : "";
                            } else if (key === 'debuffs') {
                                result[key] = extraKey === 'debuffs' ? val : "";
                            }
                        }
                        results.push(result);
                    }
                }
            }

            if (hasBuffs) generate('buffs', buffs);
            if (hasDebuffs) generate('debuffs', debuffs);

            if (!hasBuffs && !hasDebuffs) {
                for (const base of baseCartesian) {
                    const result = {};
                    let arrayIndex = 0;

                    for (const key of allKeys) {
                        if (scalarKeys.includes(key)) {
                            result[key] = selection[key] ?? "";
                        } else if (arrayKeys.includes(key)) {
                            result[key] = base[arrayIndex] ?? "";
                            arrayIndex++;
                        } else if (key === 'buffs' || key === 'debuffs') {
                            result[key] = "";
                        }
                    }
                    results.push(result); 
                }
            }
            return results;
        }

        //////////////////////////////////////////////
        //// FUNCTION TO MANAGE ELEMENT SELECTION ////
        //////////////////////////////////////////////
        function manageElementSelection(comb){

            const elementAffect = ['Physical', 'Magical', 'Element Pot.', 'Element Resist.', 'Element Weakness', 'Damage(Element)', 'Weapon(Element)', 'Single-Tgt Element', 'All-Tgt Element'];
            let result = [];

            comb.forEach(obj => {
                if ( obj.buffs != "" || obj.debuffs != "" ) {
                    if ( obj.elements != "" && (!elementAffect.includes(obj.buffs) && !elementAffect.includes(obj.debuffs)) ) { 
                        obj.elements = "";
                        result.push(obj);
                    } else { result.push(obj); }
                } else { result.push(obj); }
            })
            // Suppression des doublons
            result = suppressionDoublon(result);

            return result;
        }

        ////////////////////////////////////////////////////////////
        //// FUNCTION TO SUPRESS DOUBLON FROM ELEMENT SELECTION ////
        ////////////////////////////////////////////////////////////
        function suppressionDoublon(comb) {
            const seen = new Set();

            return comb.filter(obj => {
                const sorted = Object.keys(obj).sort().reduce((acc, key) => {
                acc[key] = obj[key];
                return acc;
                }, {});

                const serialized = JSON.stringify(sorted);
                if (seen.has(serialized)) {
                return false;
                }
                seen.add(serialized);
                return true;
            });
        }

            ////////////////////////////////
            ///////////// SORT /////////////
            ////////////////////////////////
        ///////////////////////////////////////////////////////////////////////////////////////////////////
        //// FUNCTION TO SORT AND RESTORE DEFAULT SORT (DISABLE BUTTONS CAUSE ONLY ONE SORT AT A TIME) ////
        ///////////////////////////////////////////////////////////////////////////////////////////////////
        function toggleSort(dt, currentColumnName, defaultColumnName) {
            let currentColumnIndex = dt.column(currentColumnName + ':name').index();
            let defaultColumnIndex = dt.column(defaultColumnName + ':name').index();
            let currentOrder = dt.order();
            
            if (currentColumnName === 'W_NAME') {
                dt.order([defaultColumnIndex, 'asc']).draw();
                dt.buttons('.sort').enable();
            } else if (currentOrder[0][0] === defaultColumnIndex && currentColumnName !== 'W_CAST') {
                dt.order([currentColumnIndex, 'desc']).draw();
                dt.buttons('.sort').disable();
                dt.button(currentColumnName + ':name').enable();
            } else if (currentOrder[0][0] === defaultColumnIndex && currentColumnName === 'W_CAST') {
                dt.order([currentColumnIndex, 'asc']).draw();
                dt.buttons('.sort').disable();
                dt.button(currentColumnName + ':name').enable();
            } else {
                dt.order([defaultColumnIndex, 'asc']).draw();
                dt.buttons('.sort').enable();
            }
        }
    })
})
